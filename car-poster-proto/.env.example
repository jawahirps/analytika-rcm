# Copy this file to .env and fill in your local values.

OPENAI_API_KEY=

# The model is configurable. Use gpt-3.5-turbo if it is available on your account,
# or leave the default in engine.py for a current lightweight OpenAI model.
OPENAI_MODEL=gpt-4o-mini

# Put google_creds.json in this folder, or point to an absolute JSON key path.
GOOGLE_APPLICATION_CREDENTIALS=google_creds.json

# Optional: set to 1 to force local demo behavior without API calls.
DEMO_MODE=0
