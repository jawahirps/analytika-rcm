{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=analytika.db",
    "Postgres": ""
  },
  "Database": {
    "Provider": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/analytika-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "StartupMaintenance": {
    "RunDatabaseSetupOnStartup": true,
    "CreateIndexesOnStartup": false,
    "SeedDataOnStartup": true
  },
  "AllowedHosts": "*",
  "Portal": {
    "AllowInvalidCertificates": false
  },
  "Security": {
    "MigrateCredentialsOnStartup": true
  },
  "Backup": {
    "RetentionCount": 14
  },
  "Retention": {
    "Enabled": true,
    "XmlContentMonths": 12,
    "FetchLogDays": 90
  },
  "Alerting": {
    "AdminEmails": ""
  },
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "noreply@ghafservices.com",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromAddress": "noreply@ghafservices.com",
    "FromName": "GhafBI Reports"
  },
  "BackgroundJobs": {
    "HangfireServerEnabled": false,
    "HangfireDashboardEnabled": false,
    "RecurringJobsEnabled": false,
    "PendingDownloads": {
      "HostedServiceEnabled": false,
      "ScheduledRunEnabled": true,
      "ScheduledLocalTime": "02:30",
      "BatchSize": 25,
      "AutoParseRemittance": false
    }
  }
}
