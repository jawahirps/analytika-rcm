{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=analytika.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Hangfire": "Warning"
    }
  },
  "StartupMaintenance": {
    "CreateIndexesOnStartup": false
  },
  "AllowedHosts": "*",
  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "noreply@ghafservices.com",
    "Password": "YOUR_SMTP_PASSWORD",
    "FromAddress": "noreply@ghafservices.com",
    "FromName": "GhafBI Reports"
  },
  "BackgroundJobs": {
    "HangfireServerEnabled": false,
    "RecurringJobsEnabled": false,
    "PendingDownloads": {
      "ScheduledRunEnabled": true,
      "ScheduledLocalTime": "02:30",
      "BatchSize": 25,
      "AutoParseRemittance": false
    }
  }
}
