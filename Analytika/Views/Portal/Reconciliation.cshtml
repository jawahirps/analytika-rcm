@model Analytika.Models.ViewModels.ReconciliationViewModel
@{
    ViewData["Title"] = "Claim Reconciliation";
    string Badge(string status) => status switch {
        "Paid"     => "background:#e8f7ef;color:#1e6b45;",
        "Partial"  => "background:#fff3cd;color:#856404;",
        "Rejected" => "background:#ffe8e8;color:#dc3545;",
        _          => "background:#f0f0f0;color:#6c757d;"
    };
}

<div class="container-fluid py-4 px-4">

    <!-- Header -->
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Claim Reconciliation</h4>
            <small class="text-muted">Remittance advice matched against claim submissions · DHA portal step 4</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Sync" class="btn btn-ghost btn-sm"><i class="fas fa-sync me-1"></i> Run Sync</a>
            <button onclick="exportCsv()" class="btn btn-sm btn-outline-secondary" style="border-radius:6px;font-size:.8rem;">
                <i class="fas fa-file-csv me-1"></i> Export CSV
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3 px-4">
            <form method="get" asp-action="Reconciliation" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Facility</label>
                    <select name="facilityId" id="reconFacilityFilter" class="form-select form-select-sm select2-multi" multiple style="min-width:200px;">
                        @foreach (var f in Model.Facilities)
                        {
                            if (Model.FacilityIds.Contains(int.Parse(f.Value))) { <option value="@f.Value" selected>@f.Text</option> }
                            else { <option value="@f.Value">@f.Text</option> }
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label">Service Date From</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <label class="form-label">To</label>
                    <input type="date" name="dateTo" value="@Model.DateTo" class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <label class="form-label">&nbsp;</label>
                    <div class="d-flex gap-1">
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setReconRange(1)">1M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setReconRange(3)">3M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setReconRange(6)">6M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setReconRange(12)">1Y</button>
                    </div>
                </div>
                <div class="col-auto">
                    <label class="form-label">Status</label>
                    <select name="status" id="reconStatusFilter" class="form-select form-select-sm select2-multi" multiple style="min-width:160px;">
                        @{ var sf = Model.StatusFilters; }
                        @if (sf.Contains("Paid"))     { <option value="Paid"     selected>Paid</option>     } else { <option value="Paid">Paid</option>     }
                        @if (sf.Contains("Partial"))  { <option value="Partial"  selected>Partial</option>  } else { <option value="Partial">Partial</option>  }
                        @if (sf.Contains("Rejected")) { <option value="Rejected" selected>Rejected</option> } else { <option value="Rejected">Rejected</option> }
                        @if (sf.Contains("Pending"))  { <option value="Pending"  selected>Pending</option>  } else { <option value="Pending">Pending</option>  }
                    </select>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-filter me-1"></i> Filter</button>
                    <a asp-action="Reconciliation" class="btn btn-ghost btn-sm ms-1">Reset</a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.TotalClaims > 0)
    {
        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body p-3 text-center">
                        <div class="fw-bold" style="font-size:1.5rem;color:#0d1b3e;">@Model.TotalClaims</div>
                        <div class="text-muted small">Total Claims</div>
                        <div class="mt-2 d-flex justify-content-center gap-1 flex-wrap" style="font-size:.68rem;">
                            <span class="badge rounded-pill" style="background:#e8f7ef;color:#1e6b45;">@Model.PaidCount Paid</span>
                            <span class="badge rounded-pill" style="background:#fff3cd;color:#856404;">@Model.PartialCount Partial</span>
                            <span class="badge rounded-pill" style="background:#ffe8e8;color:#dc3545;">@Model.RejectedCount Rejected</span>
                            <span class="badge rounded-pill" style="background:#f0f0f0;color:#6c757d;">@Model.PendingCount Pending</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body p-3 text-center">
                        <div class="fw-bold" style="font-size:1.5rem;color:#0d1b3e;">@Model.TotalSubmitted.ToString("N2")</div>
                        <div class="text-muted small">Total Submitted (AED)</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-body p-3 text-center">
                        <div class="fw-bold" style="font-size:1.5rem;color:#1e6b45;">@Model.TotalPaid.ToString("N2")</div>
                        <div class="text-muted small">Total Paid (AED)</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm" style="border-radius:12px;border-left:3px solid #dc3545;">
                    <div class="card-body p-3 text-center">
                        <div class="fw-bold" style="font-size:1.5rem;color:#dc3545;">@Model.TotalOutstanding.ToString("N2")</div>
                        <div class="text-muted small">Outstanding (AED)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progress bar -->
        @if (Model.TotalSubmitted > 0)
        {
            var pct = (int)(Model.TotalPaid / Model.TotalSubmitted * 100);
            <div class="mb-4">
                <div class="d-flex justify-content-between mb-1" style="font-size:.75rem;">
                    <span class="text-muted">Recovery rate</span>
                    <span class="fw-semibold">@pct%</span>
                </div>
                <div class="progress" style="height:8px;border-radius:4px;">
                    <div class="progress-bar" style="width:@pct%;background:#2ec4b6;border-radius:4px;"></div>
                </div>
            </div>
        }

        <!-- Table -->
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="font-size:.82rem;" id="reconTable">
                        <thead style="background:#f8f9fa;position:sticky;top:0;">
                            <tr>
                                <th class="ps-4 py-2 fw-semibold text-muted border-0">Claim ID</th>
                                <th class="py-2 fw-semibold text-muted border-0">Payer</th>
                                <th class="py-2 fw-semibold text-muted border-0">Service Date</th>
                                <th class="py-2 fw-semibold text-muted border-0 text-end">Submitted</th>
                                <th class="py-2 fw-semibold text-muted border-0">Remittance Date</th>
                                <th class="py-2 fw-semibold text-muted border-0 text-end">Paid</th>
                                <th class="py-2 fw-semibold text-muted border-0 text-end">Difference</th>
                                <th class="pe-4 py-2 fw-semibold text-muted border-0">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Rows)
                            {
                                <tr>
                                    <td class="ps-4 py-2 align-middle fw-semibold" style="color:#0d1b3e;font-size:.78rem;">@r.ClaimId</td>
                                    <td class="py-2 align-middle text-muted">@(r.Payer ?? "—")</td>
                                    <td class="py-2 align-middle text-muted">@(r.ServiceDate ?? "—")</td>
                                    <td class="py-2 align-middle text-end">
                                        @if (r.SubmittedAmount.HasValue)
                                        {
                                            <span class="fw-semibold">@r.SubmittedAmount.Value.ToString("N2")</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="py-2 align-middle text-muted">@(r.RemittanceDate ?? "—")</td>
                                    <td class="py-2 align-middle text-end">
                                        @if (r.PaidAmount.HasValue)
                                        {
                                            <span class="fw-semibold" style="color:#1e6b45;">@r.PaidAmount.Value.ToString("N2")</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="py-2 align-middle text-end">
                                        @if (r.SubmittedAmount.HasValue)
                                        {
                                            var diff = r.Difference;
                                            var col  = diff > 0 ? "#dc3545" : diff < 0 ? "#1e6b45" : "#6c757d";
                                            <span style="color:@col;font-weight:600;">@diff.ToString("N2")</span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td class="pe-4 py-2 align-middle">
                                        <span class="badge rounded-pill px-2" style="@Badge(r.PaymentStatus);font-size:.7rem;">
                                            @r.PaymentStatus
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm d-flex align-items-center justify-content-center" style="border-radius:12px;min-height:300px;">
            <div class="text-center text-muted py-5">
                <i class="fas fa-balance-scale fa-3x mb-3" style="color:#dee2e6;"></i>
                <p class="mb-1 fw-semibold">No reconciliation data found</p>
                <small>Run a DHA Sync first to download Claim and Remittance files, then return here.</small><br/>
                <a asp-action="Sync" class="btn btn-sm mt-3" style="background:#0d1b3e;color:#fff;border-radius:8px;">
                    <i class="fas fa-sync me-1"></i> Go to Sync
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
function setReconRange(months) {
    const today = new Date(), from = new Date(today);
    from.setMonth(from.getMonth() - months);
    document.querySelector('input[name="dateFrom"]').value = from.toISOString().split('T')[0];
    document.querySelector('input[name="dateTo"]').value   = today.toISOString().split('T')[0];
}
function exportCsv() {
    const t = document.getElementById('reconTable');
    if (!t) return;
    const rows = [...t.querySelectorAll('tr')].map(r =>
        [...r.querySelectorAll('th,td')].map(c => '"' + c.innerText.trim().replace(/"/g,'""') + '"').join(','));
    const a = document.createElement('a');
    a.href = URL.createObjectURL(new Blob([rows.join('\n')], { type: 'text/csv' }));
    a.download = 'reconciliation_' + new Date().toISOString().slice(0,10) + '.csv';
    a.click();
}
</script>
}
