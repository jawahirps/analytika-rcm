@model Analytika.Models.ViewModels.SyncedDataViewModel
@{
    ViewData["Title"] = "Synced Transactions";
}

<div class="container-fluid py-4 px-4">

    <!-- Header -->
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Synced Transactions</h4>
            <div class="d-flex gap-2 mt-1 flex-wrap">
                <small class="text-muted">@Model.TotalCount.ToString("N0") records total</small>
                <small class="text-muted">·</small>
                <small style="color:#3aac8a;font-weight:600;">
                    <i class="fas fa-file-download me-1" style="font-size:.65rem;"></i>@Model.FilesDownloadedCount.ToString("N0") files downloaded
                </small>
                <small class="text-muted">·</small>
                <small style="color:var(--amber-dark);font-weight:600;">
                    <i class="fas fa-history me-1" style="font-size:.65rem;"></i>@Model.PendingFilesCount.ToString("N0") pending download
                </small>
            </div>
        </div>
        <div class="d-flex gap-2">
            @if (Model.PendingFilesCount > 0)
            {
                <button id="dlPendingBtn" class="btn btn-sm fw-semibold"
                        style="background:var(--amber);color:#fff;border:none;"
                        onclick="startDownloadPending()">
                    <i class="fas fa-cloud-download-alt me-1"></i>
                    Download @Model.PendingFilesCount.ToString("N0") Pending Files
                </button>
            }
            <a asp-action="Sync" class="btn btn-primary btn-sm">
                <i class="fas fa-sync me-1"></i> Run Sync
            </a>
        </div>
    </div>

    <!-- Download Pending Resume Banner -->
    <div id="dlResumeBanner" class="alert mb-3" role="alert"
         style="display:none;border-left:4px solid var(--amber);background:var(--amber-light);color:var(--amber-dark);border-radius:var(--radius);">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <i class="fas fa-history me-2"></i>
                <strong>Download interrupted</strong>
                <span id="dlResumeBannerDetail" class="ms-2" style="font-size:.82rem;"></span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm fw-semibold" style="background:var(--amber);color:#fff;border:none;" onclick="resumeDownloadPending()">
                    <i class="fas fa-play me-1"></i> Resume
                </button>
                <button class="btn btn-ghost btn-sm" onclick="discardDlCheckpoint()">
                    <i class="fas fa-times me-1"></i> Discard
                </button>
            </div>
        </div>
    </div>

    <!-- Download Pending Progress Panel -->
    <div id="dlPendingPanel" class="card border-0 shadow-sm mb-4" style="display:none;border-left:3px solid var(--amber)!important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold" style="color:var(--navy);font-size:.85rem;">
                    <i class="fas fa-cloud-download-alt fa-spin me-1" id="dlPendingSpinner"></i>
                    Downloading Pending Files
                </h6>
                <div class="d-flex align-items-center gap-2">
                    <span id="dlPendingTally" class="badge" style="background:#ccf7f7;color:#0A1828;font-size:.75rem;"></span>
                    <button id="dlPauseBtn" class="btn btn-xs fw-semibold" style="display:none;background:var(--amber);color:#fff;border:none;" onclick="pauseDownloadPending()">
                        <i class="fas fa-pause me-1"></i>Pause
                    </button>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="progress flex-grow-1" style="height:8px;border-radius:4px;">
                    <div id="dlPendingBar" class="progress-bar" style="background:var(--amber);width:0%;transition:width .3s;"></div>
                </div>
                <span id="dlPendingPct" style="font-size:.72rem;font-weight:600;color:var(--amber-dark);min-width:32px;text-align:right;">0%</span>
            </div>
            <div id="dlPendingCurrent" style="font-size:.75rem;color:#555;margin-bottom:6px;min-height:18px;"></div>
            <div id="dlPendingLog" style="max-height:260px;overflow-y:auto;font-size:.71rem;font-family:monospace;background:#f8f9fa;border-radius:6px;padding:8px;line-height:1.9;">
                <span class="text-muted">Initialising…</span>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3 px-4">
            <form method="get" asp-action="SyncedData" class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label">Portal</label>
                    <select name="portal" class="form-select form-select-sm" style="min-width:100px;">
                        <option value="">All</option>
                        <option value="DHA" selected="@(Model.Portal == "DHA" ? "selected" : null)">DHA</option>
                        <option value="RHA" selected="@(Model.Portal == "RHA" ? "selected" : null)">RHA</option>
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label">Facility</label>
                    <select name="facilityId" id="syncFacilityFilter" class="form-select form-select-sm select2-multi" multiple style="min-width:200px;">
                        @foreach (var f in Model.Facilities)
                        {
                            if (Model.FacilityIds.Contains(int.Parse(f.Value))) { <option value="@f.Value" selected>@f.Text</option> }
                            else { <option value="@f.Value">@f.Text</option> }
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label">From</label>
                    <input type="date" name="dateFrom" value="@Model.DateFrom" class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <label class="form-label">To</label>
                    <input type="date" name="dateTo" value="@Model.DateTo" class="form-control form-control-sm" />
                </div>
                <div class="col-auto">
                    <label class="form-label d-block">&nbsp;</label>
                    <div class="d-flex gap-1">
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setSyncedRange(1)">1M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setSyncedRange(3)">3M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setSyncedRange(6)">6M</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setSyncedRange(12)">1Y</button>
                        <button type="button" class="btn btn-ghost btn-sm" onclick="setSyncedRange(24)">2Y</button>
                    </div>
                </div>
                <div class="col">
                    <label class="form-label">Search</label>
                    <input type="text" name="search" value="@Model.SearchText" class="form-control form-control-sm" placeholder="Transaction ID, Payer, Status..." />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fas fa-filter me-1"></i> Filter
                    </button>
                    <a asp-action="SyncedData" class="btn btn-ghost btn-sm ms-1">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Transactions.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-database"></i>
                    <p class="fw-semibold mb-1">No records found</p>
                    <p>Run a sync first, or adjust your filters.</p>
                    <a asp-action="Sync" class="btn btn-primary btn-sm mt-2">
                        <i class="fas fa-sync me-1"></i> Go to Sync
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="syncedTable">
                        <thead>
                            <tr>
                                <th class="ps-4">Transaction ID</th>
                                <th>Portal</th>
                                <th>Facility</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Payer</th>
                                <th>Amount</th>
                                <th>Tx Date</th>
                                <th class="text-center">File</th>
                                <th class="pe-4">Synced</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Transactions)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold" style="color:var(--navy);font-size:.8rem;">@t.TransactionId</td>
                                    <td>
                                        <span class="badge @(t.Portal == "DHA" ? "badge-info" : "badge-emerald")">@t.Portal</span>
                                    </td>
                                    <td class="text-muted" style="font-size:.8rem;">@(t.Facility?.Name ?? "—")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(t.Type) && t.Type != "-")
                                        { <span class="badge badge-navy">@t.Type</span> }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td style="font-size:.8rem;">
                                        @{
                                            var st = t.Status?.ToLower() ?? "";
                                            var stClass = st.Contains("complete") || st == "1" ? "success" :
                                                          st.Contains("reject") || st.Contains("fail") ? "failed" :
                                                          st.Contains("pend") ? "warning" : "inactive";
                                        }
                                        <span class="status-pill @stClass">@(t.Status ?? "—")</span>
                                    </td>
                                    <td class="text-muted" style="font-size:.8rem;">@(t.Payer ?? "—")</td>
                                    <td class="text-muted" style="font-size:.8rem;">@(t.Amount ?? "—")</td>
                                    <td class="text-muted" style="font-size:.8rem;">@(t.TransactionDate ?? "—")</td>
                                    <td class="text-center">
                                        @if (t.FileDownloaded)
                                        {
                                            <a href="/Portal/DownloadFile/@t.Id" class="status-pill success" style="text-decoration:none;" title="Download XML@(t.FileSizeBytes.HasValue ? $" — {t.FileSizeBytes:N0} bytes" : "")">
                                                <i class="fas fa-download" style="font-size:.6rem;"></i>
                                                @(t.FileSizeBytes.HasValue ? $"{t.FileSizeBytes / 1024.0:N1}KB" : "XML")
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="status-pill inactive" style="font-size:.68rem;">pending</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-muted" style="font-size:.75rem;">@t.SyncedAt.ToString("dd MMM HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top" style="border-color:var(--border-light)!important;">
                        <small class="text-muted">
                            Showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalCount)) of @Model.TotalCount.ToString("N0")
                        </small>
                        <div class="d-flex gap-1">
                            @if (Model.Page > 1)
                            {
                                <a asp-action="SyncedData"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-portal="@Model.Portal"
                                   asp-route-facilityId="@Model.FacilityId"
                                   asp-route-dateFrom="@Model.DateFrom"
                                   asp-route-dateTo="@Model.DateTo"
                                   asp-route-search="@Model.SearchText"
                                   class="btn btn-ghost btn-sm">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            }
                            @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                            {
                                <a asp-action="SyncedData"
                                   asp-route-page="@p"
                                   asp-route-portal="@Model.Portal"
                                   asp-route-facilityId="@Model.FacilityId"
                                   asp-route-dateFrom="@Model.DateFrom"
                                   asp-route-dateTo="@Model.DateTo"
                                   asp-route-search="@Model.SearchText"
                                   class="btn btn-sm @(p == Model.Page ? "" : "btn-ghost")"
                                   style="@(p == Model.Page ? "background:var(--navy);color:#fff;" : "")">
                                    @p
                                </a>
                            }
                            @if (Model.Page < Model.TotalPages)
                            {
                                <a asp-action="SyncedData"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-portal="@Model.Portal"
                                   asp-route-facilityId="@Model.FacilityId"
                                   asp-route-dateFrom="@Model.DateFrom"
                                   asp-route-dateTo="@Model.DateTo"
                                   asp-route-search="@Model.SearchText"
                                   class="btn btn-ghost btn-sm">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function setSyncedRange(months) {
    const today = new Date();
    const from  = new Date(today);
    from.setMonth(from.getMonth() - months);
    document.querySelector('input[name="dateFrom"]').value = from.toISOString().split('T')[0];
    document.querySelector('input[name="dateTo"]').value   = today.toISOString().split('T')[0];
}

// ── Download Pending Files ─────────────────────────────────────
const DL_CKPT_KEY = 'analytika_dl_checkpoint';
let dlSource = null;
let dlCompleted = false;

function saveDlCkpt(data) { localStorage.setItem(DL_CKPT_KEY, JSON.stringify({ ...data, savedAt: new Date().toISOString() })); }
function loadDlCkpt() { try { return JSON.parse(localStorage.getItem(DL_CKPT_KEY)); } catch { return null; } }
function clearDlCkpt() { localStorage.removeItem(DL_CKPT_KEY); }

function showDlResumeBanner(cp) {
    if (!cp) return;
    const banner = document.getElementById('dlResumeBanner');
    const detail = document.getElementById('dlResumeBannerDetail');
    const parts  = [];
    if (cp.done)    parts.push(`<strong>${cp.done}</strong> downloaded`);
    if (cp.failed)  parts.push(`${cp.failed} failed`);
    if (cp.lastId)  parts.push(`last record #${cp.lastId}`);
    if (cp.savedAt) parts.push(`at ${new Date(cp.savedAt).toLocaleTimeString()}`);
    const verb = cp.reason === 'paused' ? 'Paused' : 'Disconnected';
    detail.innerHTML = `${verb} — ${parts.join(' · ')}`;
    banner.style.display = 'block';
}

function discardDlCheckpoint() {
    clearDlCkpt();
    document.getElementById('dlResumeBanner').style.display = 'none';
}

function resumeDownloadPending() {
    const cp = loadDlCkpt();
    if (!cp) return;
    discardDlCheckpoint();
    startDownloadPending(cp.lastId || 0, cp.done || 0, cp.failed || 0);
}

function pauseDownloadPending() {
    if (!dlSource) return;
    const cp = loadDlCkpt() || {};
    cp.reason = 'paused';
    saveDlCkpt(cp);
    dlCompleted = true;
    dlSource.close(); dlSource = null;
    document.getElementById('dlPauseBtn').style.display = 'none';
    document.getElementById('dlPendingSpinner').classList.remove('fa-spin');
    if (document.getElementById('dlPendingBtn')) {
        document.getElementById('dlPendingBtn').disabled = false;
        document.getElementById('dlPendingBtn').innerHTML = '<i class="fas fa-cloud-download-alt me-1"></i> Resume Download';
    }
    const logDiv = document.getElementById('dlPendingLog');
    const line   = document.createElement('div');
    line.style.color = '#C87A10'; line.style.fontWeight = '600';
    line.textContent = '⏸ Paused — use the Resume button above to continue.';
    logDiv.appendChild(line);
    showDlResumeBanner(loadDlCkpt());
}

function startDownloadPending(resumeFromId, seedDone, seedFailed) {
    resumeFromId = resumeFromId || 0;
    let dlDone   = seedDone   || 0;
    let dlFailed = seedFailed || 0;

    const panel   = document.getElementById('dlPendingPanel');
    const logDiv  = document.getElementById('dlPendingLog');
    const bar     = document.getElementById('dlPendingBar');
    const pctLbl  = document.getElementById('dlPendingPct');
    const tally   = document.getElementById('dlPendingTally');
    const curLbl  = document.getElementById('dlPendingCurrent');
    const spinner = document.getElementById('dlPendingSpinner');
    const pauseBtn= document.getElementById('dlPauseBtn');
    const startBtn= document.getElementById('dlPendingBtn');

    if (startBtn) { startBtn.disabled = true; startBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Downloading…'; }
    panel.style.display = 'block';
    if (!resumeFromId) logDiv.innerHTML = '';
    bar.style.width = '0%'; pctLbl.textContent = '0%';
    tally.textContent = ''; curLbl.textContent = '';
    pauseBtn.style.display = 'inline-flex';
    panel.scrollIntoView({ behavior: 'smooth' });

    // Init checkpoint
    let ckpt = { lastId: resumeFromId, done: dlDone, failed: dlFailed, reason: 'running' };
    saveDlCkpt(ckpt);

    dlCompleted = false;
    const params = new URLSearchParams();
    if (resumeFromId) params.append('resumeFromId', resumeFromId);
    dlSource = new EventSource('/Portal/DownloadPendingStream' + (params.toString() ? '?' + params : ''));
    const source = dlSource;

    function addLog(msg, color) {
        const line = document.createElement('div');
        line.style.color = color || '#333';
        line.textContent = msg;
        logDiv.appendChild(line);
        logDiv.scrollTop = logDiv.scrollHeight;
        return line;
    }

    function done() {
        spinner.classList.remove('fa-spin');
        pauseBtn.style.display = 'none';
        if (startBtn) { startBtn.disabled = false; startBtn.innerHTML = '<i class="fas fa-cloud-download-alt me-1"></i> Download Pending Files'; }
    }

    source.onmessage = function(e) {
        const d = JSON.parse(e.data);

        if (d.status === 'start') {
            addLog(`▶ ${d.message}`, '#C87A10');
            tally.textContent = `0 / ${d.total}`;

        } else if (d.status === 'resumed') {
            addLog(`⏩ Resuming — ${d.message}`, '#C87A10');

        } else if (d.status === 'progress') {
            dlDone = d.done; dlFailed = d.failed;
            bar.style.width = (d.pct || 0) + '%';
            pctLbl.textContent = (d.pct || 0) + '%';
            tally.textContent = `${d.done + d.failed} / ${d.total}`;
            curLbl.textContent = d.facilityName || '';
            ckpt.lastId  = d.lastId || d.txId;
            ckpt.done    = d.done;
            ckpt.failed  = d.failed;
            saveDlCkpt(ckpt);

        } else if (d.status === 'progress_fail' || d.status === 'skip') {
            dlFailed = d.failed;
            ckpt.lastId = d.txId; ckpt.failed = d.failed;
            saveDlCkpt(ckpt);
            addLog(`  ✗ #${d.txId} — ${d.message || d.error || 'failed'}`, '#dc3545');

        } else if (d.status === 'done') {
            dlCompleted = true;
            bar.style.width = '100%'; pctLbl.textContent = '100%';
            tally.textContent = `${d.done} / ${d.total}`;
            addLog('', '');
            addLog(`✅ ${d.message}`, '#3aac8a');
            if (d.failed > 0) addLog(`  ⚠ ${d.failed} file(s) could not be downloaded`, '#856404');
            clearDlCkpt();
            source.close(); done();
            // Reload page after 2 s so counts update
            setTimeout(() => location.reload(), 2000);
        }
    };

    source.onerror = function() {
        source.close();
        if (dlCompleted) return;
        const cp = loadDlCkpt() || ckpt;
        cp.reason = 'disconnected';
        saveDlCkpt(cp);
        addLog('⚠ Connection dropped — checkpoint saved. Use Resume to continue.', '#856404');
        pauseBtn.style.display = 'none';
        showDlResumeBanner(loadDlCkpt());
        done();
    };
}

document.addEventListener('DOMContentLoaded', () => {
    const cp = loadDlCkpt();
    if (cp && cp.reason !== 'running') showDlResumeBanner(cp);
    // If reason is 'running', it was an unexpected disconnect — also show banner
    if (cp && cp.reason === 'running') { cp.reason = 'disconnected'; saveDlCkpt(cp); showDlResumeBanner(cp); }
});
</script>
}
