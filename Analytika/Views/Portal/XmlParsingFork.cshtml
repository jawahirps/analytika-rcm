@model Analytika.Models.ViewModels.XmlParsingViewModel
@{
    ViewData["Title"] = "XML Parsing Fork";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .xp-page { max-width: 1500px; margin: 0 auto; padding: 22px 20px 56px; }
    .xp-topbar { display:flex; align-items:center; justify-content:space-between; gap:14px; margin-bottom:14px; }
    .xp-title { display:flex; align-items:center; gap:10px; color:#011C40; }
    .xp-title h4 { margin:0; font-size:1.15rem; font-weight:800; letter-spacing:0; }
    .xp-filters { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .xp-shell { background:#fff; border:1px solid #EAF4FB; border-radius:8px; box-shadow:0 1px 4px rgba(8,20,35,.05); }
    .xp-toolbar { display:flex; align-items:center; justify-content:space-between; gap:12px; padding:12px 14px; border-bottom:1px solid #edf2f7; }
    .xp-actions { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .xp-stats { display:grid; grid-template-columns:repeat(9, minmax(110px,1fr)); gap:8px; margin:14px 0; }
    .xp-stat { background:#fff; border:1px solid #EAF4FB; border-radius:8px; padding:12px; min-height:82px; }
    .xp-stat .num { color:#011C40; font-size:1.35rem; font-weight:800; line-height:1.1; }
    .xp-stat .lbl { color:#35577D; font-size:.67rem; font-weight:700; text-transform:uppercase; margin-top:6px; }
    .xp-stat.sub { border-top:3px solid #A7EBF2; }
    .xp-stat.rem { border-top:3px solid #805ad5; }
    .xp-stat.ok { border-top:3px solid #16a34a; }
    .xp-stat.warn { border-top:3px solid #f59e0b; }
    .xp-progress { display:none; margin:12px 0 14px; background:#fff; border:1px solid #EAF4FB; border-radius:8px; padding:12px 14px; }
    .xp-progress-head { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:8px; color:#334155; font-size:.83rem; font-weight:700; }
    .xp-progress-track { height:9px; border-radius:99px; background:#EAF4FB; overflow:hidden; }
    .xp-progress-fill { height:100%; width:0; border-radius:99px; background:#A7EBF2; transition:width .25s ease; }
    .xp-log { margin-top:8px; color:#35577D; font-size:.78rem; min-height:18px; }
    table.xp-table { width:100%; border-collapse:collapse; }
    .xp-table thead th { background:#EAF4FB; color:#35577D; font-size:.68rem; font-weight:800; text-transform:uppercase; padding:10px 12px; border-bottom:1px solid #EAF4FB; white-space:nowrap; }
    .xp-table td { padding:10px 12px; border-bottom:1px solid #f1f5f9; color:#334155; font-size:.82rem; vertical-align:middle; }
    .xp-table tbody tr:hover { background:#fbfdff; }
    .xp-table .facility { color:#011C40; font-weight:700; }
    .xp-table .file { max-width:260px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .xp-table .amount { text-align:right; font-variant-numeric:tabular-nums; white-space:nowrap; }
    .xp-badge { display:inline-flex; align-items:center; justify-content:center; gap:4px; border-radius:999px; padding:3px 8px; font-size:.7rem; font-weight:800; white-space:nowrap; }
    .xp-badge.ready { background:#dcfce7; color:#166534; }
    .xp-badge.pending { background:#EAF4FB; color:#92400e; }
    .xp-badge.match { background:#EAF4FB; color:#1d4ed8; }
    .xp-badge.sub { background:#ccfbf1; color:#115e59; }
    .xp-badge.rem { background:#ede9fe; color:#6d28d9; }
    .xp-btn-icon { width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; padding:0; }
    .xp-empty { text-align:center; color:#35577D; padding:34px 12px; }
    .xp-modal-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; }
    .xp-modal-grid .full { grid-column:1 / -1; }
    .xp-modal-grid label { font-size:.72rem; font-weight:800; color:#54ACBF; text-transform:uppercase; }
    .xp-textarea { min-height:190px; font-family:ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size:.78rem; }
    @@media (max-width: 1200px) { .xp-stats { grid-template-columns:repeat(4,1fr); } }
    @@media (max-width: 760px) {
        .xp-topbar, .xp-toolbar { align-items:stretch; flex-direction:column; }
        .xp-stats { grid-template-columns:repeat(2,1fr); }
        .xp-modal-grid { grid-template-columns:1fr; }
        .xp-page { padding: 14px 12px 80px; }
        .xp-filters { width:100%; }
        .xp-filters > * { width:100% !important; min-width:0 !important; }
        .xp-filters .select2-container { width:100% !important; }
        .xp-actions { width:100%; }
        .xp-actions > * { flex:1 1 0; }
        .xp-shell { border-radius: 14px; }
        .xp-stat { min-height: 74px; }
        .xp-table { min-width: 1080px; }
        .table-responsive { overflow-x:auto; }
    }
    @@media (max-width: 520px) {
        .xp-stats { grid-template-columns:1fr; }
        .xp-topbar { gap: 10px; }
        .xp-title h4 { font-size: 1rem; }
        .xp-toolbar { padding: 12px; }
    }
</style>
}

<div class="xp-page">
    @Html.AntiForgeryToken()

    <div class="xp-topbar">
        <div class="xp-title">
            <i class="fas fa-file-code text-primary"></i>
            <h4>XML Parsing Fork</h4>
        </div>
        <form method="get" class="xp-filters" id="xpFilterForm">
            <select name="facilityId" multiple class="form-select form-select-sm select2-multi" style="min-width:230px;">
                @foreach (var f in Model.Facilities)
                {
                    if (Model.FacilityIds.Contains(int.Parse(f.Value)))
                    {
                        <option value="@f.Value" selected>@f.Text</option>
                    }
                    else
                    {
                        <option value="@f.Value">@f.Text</option>
                    }
                }
            </select>
            <select name="kind" class="form-select form-select-sm" style="width:150px;">
                <option value="All" selected="@(Model.Kind == "All" ? "selected" : null)">All XML</option>
                <option value="Submission" selected="@(Model.Kind == "Submission" ? "selected" : null)">Submissions</option>
                <option value="Remittance" selected="@(Model.Kind == "Remittance" ? "selected" : null)">Remittances</option>
            </select>
            <input name="search" value="@Model.SearchText" class="form-control form-control-sm" style="width:220px;" placeholder="Claim, file, payer" />
            <button type="submit" class="btn btn-dark btn-sm px-3"><i class="fas fa-filter me-1"></i>Apply</button>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2">@TempData["Error"]</div>
    }

    <div class="xp-toolbar xp-shell">
        <div class="xp-actions">
            <button type="button" class="btn btn-primary btn-sm" onclick="startXmlPrepare(false)">
                <i class="fas fa-play me-1"></i>Prepare
            </button>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="startXmlPrepare(true)">
                <i class="fas fa-rotate me-1"></i>Rebuild
            </button>
            <button type="button" class="btn btn-outline-success btn-sm" onclick="postMatch()">
                <i class="fas fa-link me-1"></i>Match
            </button>
        </div>
        <div class="xp-actions">
            <button type="button" class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#addXmlModal">
                <i class="fas fa-plus me-1"></i>Add
            </button>
            <a class="btn btn-outline-secondary btn-sm" asp-controller="Portal" asp-action="SyncedData">
                <i class="fas fa-table me-1"></i>Synced Data
            </a>
        </div>
    </div>

    <div class="xp-progress" id="xpProgress">
        <div class="xp-progress-head">
            <span id="xpProgressTitle">Preparing</span>
            <span id="xpProgressPct">0%</span>
        </div>
        <div class="xp-progress-track"><div class="xp-progress-fill" id="xpProgressFill"></div></div>
        <div class="xp-log" id="xpProgressLog"></div>
    </div>

    <div class="xp-stats">
        <div class="xp-stat sub"><div class="num">@Model.TotalSubmission.ToString("N0")</div><div class="lbl">Sub Files</div></div>
        <div class="xp-stat rem"><div class="num">@Model.TotalRemittance.ToString("N0")</div><div class="lbl">RA Files</div></div>
        <div class="xp-stat rem"><div class="num">@Model.TotalRaRecords.ToString("N0")</div><div class="lbl">RA Rows</div></div>
        <div class="xp-stat rem"><div class="num">@Model.TotalRaClaimRefs.ToString("N0")</div><div class="lbl">RA Claim Refs</div></div>
        <div class="xp-stat sub"><div class="num">@Model.TotalSubmissionRecords.ToString("N0")</div><div class="lbl">Sub Rows</div></div>
        <div class="xp-stat"><div class="num">@Model.TotalClaimCount.ToString("N0")</div><div class="lbl">Sub Claim Refs</div></div>
        <div class="xp-stat ok"><div class="num">@Model.TotalMatched.ToString("N0")</div><div class="lbl">Matched Refs</div></div>
        <div class="xp-stat warn"><div class="num">@Model.TotalUnmatched.ToString("N0")</div><div class="lbl">Open Sub Refs</div></div>
        <div class="xp-stat warn"><div class="num">@Model.TotalUnmatchedRemittances.ToString("N0")</div><div class="lbl">Unmatched RA Refs</div></div>
    </div>

    <div class="xp-shell mb-3">
        <div class="xp-toolbar">
            <strong style="color:#011C40;font-size:.9rem;"><i class="fas fa-hospital me-2 text-muted"></i>Facility Readiness</strong>
            <span class="text-muted small">@Model.FacilityRows.Count.ToString("N0") facilities</span>
        </div>
        <div class="table-responsive">
            <table class="xp-table">
                <thead>
                    <tr>
                        <th>Facility</th>
                        <th>Sub Files</th>
                        <th>RA Files</th>
                        <th>RA Rows</th>
                        <th>RA Claim Refs</th>
                        <th>Sub Rows</th>
                        <th>Sub Claim Refs</th>
                        <th>Matched Refs</th>
                        <th>Open Sub Refs</th>
                        <th>Unmatched RA Refs</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.FacilityRows.Any())
                    {
                        <tr><td colspan="10" class="xp-empty">No XML records found.</td></tr>
                    }
                    @foreach (var r in Model.FacilityRows)
                    {
                        <tr>
                            <td class="facility">@r.FacilityName</td>
                            <td>@r.SubmissionTotal.ToString("N0")</td>
                            <td>@r.RemittanceTotal.ToString("N0")</td>
                            <td>@r.RemittanceRecordCount.ToString("N0")</td>
                            <td>@r.RemittanceClaimRefCount.ToString("N0")</td>
                            <td>@r.SubmissionRecordCount.ToString("N0")</td>
                            <td>@r.ClaimCount.ToString("N0")</td>
                            <td><span class="xp-badge match">@r.Matched.ToString("N0") · @r.MatchRate%</span></td>
                            <td>@r.UnmatchedSubmissions.ToString("N0")</td>
                            <td>@r.UnmatchedRemittances.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="xp-shell mb-3">
        <div class="xp-toolbar">
            <strong style="color:#011C40;font-size:.9rem;">
                <i class="fas fa-list-check me-2 text-muted"></i>
                @(Model.Kind == "Remittance" ? "Parsed RA Records" : Model.Kind == "Submission" ? "Parsed Submission Records" : "Parsed XML Records")
            </strong>
            <span class="text-muted small">Showing @Model.ParsedRecords.Count.ToString("N0") of @Model.ParsedRecordTotal.ToString("N0") parsed rows</span>
        </div>
        <div class="table-responsive">
            <table class="xp-table">
                <thead>
                    <tr>
                        <th>Facility</th>
                        <th>Claim Ref</th>
                        <th>File</th>
                        <th>Type</th>
                        <th>Sender</th>
                        <th>Receiver</th>
                        <th class="text-end">RA Received</th>
                        <th class="text-end">Paid</th>
                        <th>Settlement</th>
                        <th>Payment Ref</th>
                        <th>Denial</th>
                        <th>Matched</th>
                        <th>Ready</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.ParsedRecords.Any())
                    {
                        <tr><td colspan="13" class="xp-empty">No parsed RA records found. Click Prepare or Rebuild after downloading XML files.</td></tr>
                    }
                    @foreach (var r in Model.ParsedRecords)
                    {
                        var fileLabel = !string.IsNullOrWhiteSpace(r.FileName) ? r.FileName : r.FileId ?? "-";
                        <tr>
                            <td class="facility">@r.FacilityName</td>
                            <td class="fw-semibold">@r.ClaimId</td>
                            <td><div class="file" title="@fileLabel">@fileLabel</div></td>
                            <td>
                                @if (r.RecordKind == "Remittance")
                                {
                                    <span class="xp-badge rem">RA</span>
                                }
                                else
                                {
                                    <span class="xp-badge sub">Submission</span>
                                }
                            </td>
                            <td>@(r.SenderId ?? "-")</td>
                            <td>@(r.ReceiverId ?? "-")</td>
                            <td class="amount">@r.NetAmount.ToString("N2")</td>
                            <td class="amount">@r.PaidAmount.ToString("N2")</td>
                            <td>@(r.SettlementDate ?? r.TransactionDate ?? "-")</td>
                            <td>@(r.PaymentReference ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(r.DenialCodes))
                                {
                                    <span title="@r.Comments">@r.DenialCodes</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(r.Comments))
                                {
                                    <span title="@r.Comments">@r.Comments</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (r.IsMatched)
                                {
                                    <span class="xp-badge match">Matched</span>
                                }
                                else
                                {
                                    <span class="xp-badge pending">Unmatched</span>
                                }
                            </td>
                            <td>
                                @if (r.ReadyForReport)
                                {
                                    <span class="xp-badge ready">Ready</span>
                                }
                                else
                                {
                                    <span class="xp-badge pending">Hold</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="xp-shell">
        <div class="xp-toolbar">
            <strong style="color:#011C40;font-size:.9rem;"><i class="fas fa-database me-2 text-muted"></i>Downloaded Records</strong>
            <span class="text-muted small">Showing @Model.Records.Count.ToString("N0") newest records</span>
        </div>
        <div class="table-responsive">
            <table class="xp-table">
                <thead>
                    <tr>
                        <th>Facility</th>
                        <th>File</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Claim Ref</th>
                        <th>Parsed</th>
                        <th>Ready</th>
                        <th>Matched</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Records.Any())
                    {
                        <tr><td colspan="9" class="xp-empty">No downloaded records in this view.</td></tr>
                    }
                    @foreach (var r in Model.Records)
                    {
                        var fileLabel = !string.IsNullOrWhiteSpace(r.FileName) ? r.FileName : r.FileId ?? r.TransactionId;
                        <tr>
                            <td class="facility">@r.FacilityName</td>
                            <td>
                                <div class="file" title="@fileLabel">@fileLabel</div>
                                <div class="text-muted small">@r.TransactionId</div>
                            </td>
                            <td>
                                @if (r.SubmissionRows > 0)
                                {
                                    <span class="xp-badge sub">Submission</span>
                                }
                                else if (r.RemittanceRows > 0)
                                {
                                    <span class="xp-badge rem">Remittance</span>
                                }
                                else
                                {
                                    <span>@r.Type</span>
                                }
                            </td>
                            <td>@(r.TransactionDate ?? "-")</td>
                            <td>@(string.IsNullOrWhiteSpace(r.SampleClaimId) ? "-" : r.SampleClaimId)</td>
                            <td>@r.ParsedRows.ToString("N0")</td>
                            <td>
                                @if (r.IsReady)
                                {
                                    <span class="xp-badge ready">Ready</span>
                                }
                                else if (r.HasXml)
                                {
                                    <span class="xp-badge pending">Needs Parse</span>
                                }
                                else
                                {
                                    <span class="xp-badge pending">No XML</span>
                                }
                            </td>
                            <td>
                                @if (r.IsMatched)
                                {
                                    <span class="xp-badge match">@r.MatchedRows.ToString("N0")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button"
                                            class="btn btn-outline-secondary xp-btn-icon js-edit-record"
                                            title="Edit"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editXmlModal"
                                            data-id="@r.TransactionDbId"
                                            data-facility-id="@r.FacilityId"
                                            data-transaction-id="@r.TransactionId"
                                            data-type="@r.Type"
                                            data-direction="@r.Direction"
                                            data-status="@r.Status"
                                            data-file-id="@r.FileId"
                                            data-file-name="@r.FileName"
                                            data-transaction-date="@r.TransactionDate"
                                            data-payer="@r.Payer"
                                            data-amount="@r.Amount">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <form asp-action="ParseXmlRecord" asp-route-returnTo="XmlParsingFork" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@r.TransactionDbId" />
                                        <button type="submit" class="btn btn-outline-primary xp-btn-icon" title="Parse">
                                            <i class="fas fa-code"></i>
                                        </button>
                                    </form>
                                    @if (r.HasXml)
                                    {
                                        <a class="btn btn-outline-dark xp-btn-icon" title="Download XML" asp-action="DownloadFile" asp-route-id="@r.TransactionDbId">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    }
                                    <form asp-action="DeleteXmlRecord" asp-route-returnTo="XmlParsingFork" method="post" class="d-inline" onsubmit="return confirm('Delete this downloaded XML record?');">
                                        <input type="hidden" name="id" value="@r.TransactionDbId" />
                                        <button type="submit" class="btn btn-outline-danger xp-btn-icon" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addXmlModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="AddXmlRecord" asp-route-returnTo="XmlParsingFork" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Add XML Record</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="xp-modal-grid">
                        <div>
                            <label>Facility</label>
                            <select name="FacilityId" class="form-select form-select-sm" required>
                                <option value="">Select</option>
                                @foreach (var f in Model.Facilities)
                                {
                                    <option value="@f.Value">@f.Text</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Type</label>
                            <select name="Type" class="form-select form-select-sm">
                                <option value="Claim">Claim</option>
                                <option value="Remittance">Remittance</option>
                            </select>
                        </div>
                        <div><label>Transaction Ref</label><input name="TransactionId" class="form-control form-control-sm" /></div>
                        <div><label>Status</label><input name="Status" class="form-control form-control-sm" value="Manual" /></div>
                        <div><label>File ID</label><input name="FileId" class="form-control form-control-sm" /></div>
                        <div><label>File Name</label><input name="FileName" class="form-control form-control-sm" /></div>
                        <div><label>Date</label><input name="TransactionDate" class="form-control form-control-sm" /></div>
                        <div><label>Payer</label><input name="Payer" class="form-control form-control-sm" /></div>
                        <div><label>Amount</label><input name="Amount" class="form-control form-control-sm" /></div>
                        <div><label>Direction</label><input name="Direction" class="form-control form-control-sm" /></div>
                        <div class="full"><label>XML</label><textarea name="FileContentXml" class="form-control xp-textarea"></textarea></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editXmlModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <form asp-action="EditXmlRecord" asp-route-returnTo="XmlParsingFork" method="post">
                <input type="hidden" name="Id" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit XML Record</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="xp-modal-grid">
                        <div>
                            <label>Facility</label>
                            <select name="FacilityId" id="editFacilityId" class="form-select form-select-sm" required>
                                @foreach (var f in Model.Facilities)
                                {
                                    <option value="@f.Value">@f.Text</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Type</label>
                            <select name="Type" id="editType" class="form-select form-select-sm">
                                <option value="Claim">Claim</option>
                                <option value="Remittance">Remittance</option>
                            </select>
                        </div>
                        <div><label>Transaction Ref</label><input name="TransactionId" id="editTransactionId" class="form-control form-control-sm" /></div>
                        <div><label>Status</label><input name="Status" id="editStatus" class="form-control form-control-sm" /></div>
                        <div><label>File ID</label><input name="FileId" id="editFileId" class="form-control form-control-sm" /></div>
                        <div><label>File Name</label><input name="FileName" id="editFileName" class="form-control form-control-sm" /></div>
                        <div><label>Date</label><input name="TransactionDate" id="editTransactionDate" class="form-control form-control-sm" /></div>
                        <div><label>Payer</label><input name="Payer" id="editPayer" class="form-control form-control-sm" /></div>
                        <div><label>Amount</label><input name="Amount" id="editAmount" class="form-control form-control-sm" /></div>
                        <div><label>Direction</label><input name="Direction" id="editDirection" class="form-control form-control-sm" /></div>
                        <div class="full"><label>Replace XML</label><textarea name="FileContentXml" class="form-control xp-textarea"></textarea></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        $('.select2-multi').select2({ width: 'element', placeholder: 'All facilities', allowClear: true });
    });

    function selectedFacilityParams() {
        const params = new URLSearchParams();
        document.querySelectorAll('select[name="facilityId"] option:checked').forEach(opt => params.append('facilityId', opt.value));
        return params;
    }

    function setProgress(done, total, message) {
        const pct = total > 0 ? Math.min(100, Math.round((done / total) * 100)) : 0;
        document.getElementById('xpProgress').style.display = 'block';
        document.getElementById('xpProgressFill').style.width = `${pct}%`;
        document.getElementById('xpProgressPct').textContent = `${pct}%`;
        document.getElementById('xpProgressLog').textContent = message || '';
    }

    function startXmlPrepare(rebuild) {
        const params = selectedFacilityParams();
        params.set('rebuild', rebuild ? 'true' : 'false');
        document.getElementById('xpProgressTitle').textContent = rebuild ? 'Rebuilding XML cache' : 'Preparing XML cache';
        setProgress(0, 1, 'Starting...');

        const source = new EventSource(`/Portal/XmlParsingPrepareStream?${params.toString()}`);
        source.onmessage = event => {
            const data = JSON.parse(event.data);
            const done = data.done ?? 0;
            const total = data.total ?? 1;
            setProgress(done, total, data.message);
            if (data.result) {
                const r = data.result;
                document.getElementById('xpProgressLog').textContent =
                    `${data.message || ''} · saved ${r.RecordsSaved ?? r.recordsSaved ?? 0} rows · matched ${r.MatchedClaimRefs ?? r.matchedClaimRefs ?? 0}`;
            }
            if (data.status === 'done' || data.status === 'error') {
                source.close();
                setTimeout(() => window.location.reload(), 900);
            }
        };
        source.onerror = () => {
            source.close();
            document.getElementById('xpProgressLog').textContent = 'Connection closed. Refreshing status.';
            setTimeout(() => window.location.reload(), 1200);
        };
    }

    function postMatch() {
        const form = document.createElement('form');
        form.method = 'post';
        form.action = '@Url.Action("XmlParsingForkMatch", "Portal")';
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        form.innerHTML = `<input type="hidden" name="__RequestVerificationToken" value="${token}">`;
        document.querySelectorAll('select[name="facilityId"] option:checked').forEach(opt => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'facilityId';
            input.value = opt.value;
            form.appendChild(input);
        });
        document.body.appendChild(form);
        form.submit();
    }

    document.querySelectorAll('.js-edit-record').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('editId').value = btn.dataset.id || '';
            document.getElementById('editFacilityId').value = btn.dataset.facilityId || '';
            document.getElementById('editTransactionId').value = btn.dataset.transactionId || '';
            document.getElementById('editType').value = btn.dataset.type || 'Claim';
            document.getElementById('editDirection').value = btn.dataset.direction || '';
            document.getElementById('editStatus').value = btn.dataset.status || '';
            document.getElementById('editFileId').value = btn.dataset.fileId || '';
            document.getElementById('editFileName').value = btn.dataset.fileName || '';
            document.getElementById('editTransactionDate').value = btn.dataset.transactionDate || '';
            document.getElementById('editPayer').value = btn.dataset.payer || '';
            document.getElementById('editAmount').value = btn.dataset.amount || '';
        });
    });
</script>
}
