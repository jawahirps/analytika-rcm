@model Analytika.Models.ViewModels.PortalFetchViewModel
@{
    ViewData["Title"] = "Portal Data Fetch";
}

<div class="container-fluid py-4 px-4">
    <div class="mb-4">
        <h4 class="mb-0 fw-bold" style="color:#011C40;">Portal Data Fetch</h4>
        <small class="text-muted">Retrieve transactions from RHA (Riayati) and DHA (eClaimLink) portals</small>
    </div>

    <div class="row g-4">
        <!-- Fetch Form -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:#011C40;">Fetch Parameters</h6>
                    <form asp-action="Fetch" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Portal</label>
                            <div class="d-flex gap-2">
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="DHA" @(Model.Portal == "DHA" ? "checked" : "") onchange="updateOperations()" class="d-none" />
                                    <span>
                                        <i class="fas fa-building me-1"></i> DHA
                                        <small class="d-block text-muted" style="font-size:.68rem;">eClaimLink</small>
                                    </span>
                                </label>
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="RHA" @(Model.Portal == "RHA" ? "checked" : "") onchange="updateOperations()" class="d-none" />
                                    <span>
                                        <i class="fas fa-hospital me-1"></i> RHA
                                        <small class="d-block text-muted" style="font-size:.68rem;">Riayati</small>
                                    </span>
                                </label>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Facility</label>
                            <select name="FacilityIds" id="fetchFacilitySelect" class="form-select form-select-sm select2-multi" multiple>
                                @foreach (var f in Model.Facilities)
                                {
                                    if (Model.FacilityIds.Contains(int.Parse(f.Value))) { <option value="@f.Value" selected>@f.Text</option> }
                                    else { <option value="@f.Value">@f.Text</option> }
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Operation</label>
                            <select name="Operation" class="form-select form-select-sm" id="operationSelect" onchange="updateFormFields()">
                                <!-- rebuilt dynamically by updateOperations() -->
                            </select>
                        </div>

                        @* File ID field — shown only for DownloadTransactionFile *@
                        <div class="mb-3" id="fileIdSection" style="display:none;">
                            <label class="form-label small fw-semibold">File ID <span class="text-danger">*</span></label>
                            <input asp-for="FileId" class="form-control form-control-sm" placeholder="e.g. 123456 or filename" />
                            <div class="form-text" style="font-size:.7rem;">The fileId returned from SearchTransactions or GetNewTransactions.</div>
                        </div>

                        <div class="mb-3" id="dateRange">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small fw-semibold">Date From</label>
                                    <input asp-for="DateFrom" type="date" class="form-control form-control-sm" />
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-semibold">Date To</label>
                                    <input asp-for="DateTo" type="date" class="form-control form-control-sm" />
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-1 flex-wrap">
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setFetchRange(1)">1 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setFetchRange(3)">3 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setFetchRange(6)">6 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setFetchRange(12)">1 Year</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setFetchRange(24)">2 Years</button>
                            </div>
                        </div>

                        <div class="mb-3" id="searchOptions" style="display:none;">
                            <label class="form-label small fw-semibold">Direction <span class="text-muted fw-normal">(per DHPO spec)</span></label>
                            <select name="Directions" id="directionSelect" class="form-select form-select-sm select2-multi" multiple>
                                @if (Model.Directions.Contains(1)) { <option value="1" selected>1 — Sent (Outbound)</option> } else { <option value="1">1 — Sent (Outbound)</option> }
                                @if (Model.Directions.Contains(2)) { <option value="2" selected>2 — Received (Inbound)</option> } else { <option value="2" selected>2 — Received (Inbound)</option> }
                            </select>
                        </div>

                        <div class="mb-3" id="txStatusSection" style="display:none;">
                            <label class="form-label small fw-semibold">Transaction Status</label>
                            <select name="TransactionStatuses" id="txStatusSelect" class="form-select form-select-sm select2-multi" multiple>
                                <option value="1" selected>1 — New (not yet downloaded)</option>
                                <option value="2" selected>2 — Already downloaded</option>
                            </select>
                        </div>

                        <div class="mb-3" id="txTypeSection" style="display:none;">
                            <label class="form-label small fw-semibold">Transaction Type <span class="text-muted fw-normal">(portal rejects "all")</span></label>
                            <select name="TransactionIds" id="txTypeSelect" class="form-select form-select-sm select2-multi" multiple>
                                <option value="2"  selected>2 — Claim submission</option>
                                <option value="8"  selected>8 — Remittance advice</option>
                                <option value="16">16 — Prior Request</option>
                                <option value="32">32 — Prior Authorization</option>
                            </select>
                        </div>

                        <div class="mb-3" id="recordRangeSection" style="display:none;">
                            <label class="form-label small fw-semibold">Claims Count Filter <span class="text-muted fw-normal">(optional)</span></label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text" style="font-size:.72rem;">Min</span>
                                        <input asp-for="MinRecord" type="number" class="form-control" placeholder="-1" />
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text" style="font-size:.72rem;">Max</span>
                                        <input asp-for="MaxRecord" type="number" class="form-control" placeholder="-1" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-text" style="font-size:.7rem;">Filters by # of claims inside each file. Use -1 to disable. Max 500 files returned per call.</div>
                        </div>

                        <button type="submit" class="btn w-100" style="background:#A7EBF2;color:#fff;border-radius:8px;font-weight:600;">
                            <i class="fas fa-cloud-download-alt me-1"></i> Fetch Data
                        </button>
                    </form>
                </div>
            </div>

            <!-- Recent Fetch Log -->
            @if (Model.RecentLogs.Any())
            {
                <div class="card border-0 shadow-sm mt-3" style="border-radius:12px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3" style="color:#011C40;">Recent Fetches</h6>
                        @foreach (var log in Model.RecentLogs)
                        {
                            <div class="d-flex align-items-start gap-2 mb-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:28px;height:28px;background:@(log.Status == "Success" ? "#EAF4FB" : "#ffe8e8");">
                                    <i class="fas fa-@(log.Status == "Success" ? "check" : "times") fa-xs"
                                       style="color:@(log.Status == "Success" ? "#011C40" : "#dc3545");"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold" style="color:#011C40;">@log.Portal — @log.Operation</div>
                                    <div class="text-muted">@(log.Facility?.Name) · @log.RecordsFetched records</div>
                                    <div class="text-muted">@log.FetchedAt.ToString("dd MMM HH:mm")</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Results Panel -->
        <div class="col-lg-8">
            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible fade show mb-3" role="alert">
                    <i class="fas fa-@(Model.IsError ? "exclamation-circle" : "check-circle") me-2"></i>@Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Results.Any())
            {
                <div class="card border-0 shadow-sm" style="border-radius:12px;">
                    <div class="card-header bg-transparent border-0 py-3 px-4 d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-bold" style="color:#011C40;">Fetch Results</span>
                            <span class="badge ms-2" style="background:#EAF4FB;color:#011C40;">@Model.TotalFetched records</span>
                        </div>
                        <div class="d-flex gap-2">
                            @if (Model.Operation == "SearchTransactions" && Model.Portal == "DHA")
                            {
                                <form id="saveAllForm" style="display:none;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Portal"            value="@Model.Portal" />
                                    <input type="hidden" name="FacilityId"        value="@Model.FacilityId" />
                                    <input type="hidden" name="DateFrom"          value="@Model.DateFrom" />
                                    <input type="hidden" name="DateTo"            value="@Model.DateTo" />
                                    <input type="hidden" name="Direction"         value="@Model.Direction" />
                                    <input type="hidden" name="TransactionStatus" value="@Model.TransactionStatus" />
                                    <input type="hidden" name="TransactionId"     value="@Model.TransactionId" />
                                    <input type="hidden" name="MinRecord"         value="@Model.MinRecord" />
                                    <input type="hidden" name="MaxRecord"         value="@Model.MaxRecord" />
                                </form>
                                <button type="button" id="bulkSaveBtn" onclick="bulkSave()" class="btn btn-sm" style="background:#A7EBF2;color:#fff;border-radius:6px;font-size:.78rem;">
                                    <i class="fas fa-database me-1"></i> Bulk Save
                                </button>
                            }
                            <button class="btn btn-sm btn-outline-secondary" onclick="exportCsv()" style="border-radius:6px;font-size:.78rem;">
                                <i class="fas fa-file-csv me-1"></i> Export CSV
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
                            <table class="table table-hover mb-0" style="font-size:.82rem;" id="resultsTable">
                                <thead style="background:#EAF4FB;position:sticky;top:0;">
                                    <tr>
                                        <th class="ps-4 py-2 fw-semibold text-muted border-0">Transaction ID</th>
                                        <th class="py-2 fw-semibold text-muted border-0">Type</th>
                                        <th class="py-2 fw-semibold text-muted border-0">Status</th>
                                        <th class="py-2 fw-semibold text-muted border-0">Payer</th>
                                        <th class="py-2 fw-semibold text-muted border-0">Amount</th>
                                        <th class="py-2 fw-semibold text-muted border-0">Date</th>
                                        <th class="pe-4 py-2 fw-semibold text-muted border-0">File / Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in Model.Results)
                                    {
                                        <tr>
                                            <td class="ps-4 py-2 align-middle fw-semibold" style="color:#011C40;">@r.FileId</td>
                                            <td class="py-2 align-middle">
                                                <span class="badge rounded-pill" style="background:#EAF4FB;color:#54ACBF;font-size:.7rem;">@r.Type</span>
                                            </td>
                                            <td class="py-2 align-middle">
                                                <span class="badge rounded-pill @(r.Status.Contains("Complete") || r.Status == "1" ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")" style="font-size:.7rem;">
                                                    @r.Status
                                                </span>
                                            </td>
                                            <td class="py-2 align-middle text-muted">@(r.Payer ?? "—")</td>
                                            <td class="py-2 align-middle text-muted">@(r.Amount ?? "—")</td>
                                            <td class="py-2 align-middle text-muted">@(r.Date ?? "—")</td>
                                            <td class="pe-4 py-2 align-middle" style="font-size:.75rem;">
                                                @if (!string.IsNullOrEmpty(r.FileName))
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-info" style="border-radius:6px;font-size:.72rem;"
                                                            onclick="prefillDownload('@r.FileName')">
                                                        <i class="fas fa-download me-1"></i>@r.FileName
                                                    </button>
                                                }
                                                else if (r.FileId != "-")
                                                {
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" style="border-radius:6px;font-size:.72rem;"
                                                            onclick="prefillDownload('@r.FileId')">
                                                        <i class="fas fa-download me-1"></i>Download
                                                    </button>
                                                }
                                                else { <span class="text-muted">—</span> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            <!-- Bulk Save Status Panel -->
            <div id="saveStatusCard" class="card border-0 shadow-sm mt-3" style="border-radius:12px;display:none;">
                <div class="card-body p-4">
                    <!-- header row -->
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div id="saveStatusIcon" class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;background:#EAF4FB;">
                            <i class="fas fa-spinner fa-spin" style="color:#54ACBF;font-size:.85rem;"></i>
                        </div>
                        <div>
                            <div class="fw-bold" id="saveStatusTitle" style="color:#011C40;">Searching portal…</div>
                            <div class="text-muted small" id="saveStatusSubtitle">Fetching transaction list</div>
                        </div>
                    </div>
                    <!-- progress bar -->
                    <div class="progress mb-3" style="height:6px;border-radius:4px;">
                        <div id="saveProgressBar" class="progress-bar" role="progressbar" style="width:0%;background:#A7EBF2;transition:width .3s;"></div>
                    </div>
                    <!-- counters -->
                    <div class="row g-2 text-center">
                        <div class="col">
                            <div class="fw-bold" style="font-size:1.4rem;color:#011C40;" id="statFound">—</div>
                            <div class="text-muted" style="font-size:.72rem;">Found</div>
                        </div>
                        <div class="col">
                            <div class="fw-bold" style="font-size:1.4rem;color:#A7EBF2;" id="statSaved">—</div>
                            <div class="text-muted" style="font-size:.72rem;">Saved</div>
                        </div>
                        <div class="col">
                            <div class="fw-bold" style="font-size:1.4rem;color:#54ACBF;" id="statFiles">—</div>
                            <div class="text-muted" style="font-size:.72rem;">Downloaded</div>
                        </div>
                        <div class="col">
                            <div class="fw-bold" style="font-size:1.4rem;color:#6c757d;" id="statDups">—</div>
                            <div class="text-muted" style="font-size:.72rem;">Duplicates</div>
                        </div>
                        <div class="col">
                            <div class="fw-bold" style="font-size:1.4rem;color:#e07b00;" id="statPending">—</div>
                            <div class="text-muted" style="font-size:.72rem;">Pending</div>
                        </div>
                    </div>
                    <div id="saveStatusError" class="text-danger mt-3" style="display:none;">
                        <i class="fas fa-exclamation-circle me-2"></i><span id="saveStatusErrorMsg"></span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.DownloadedFileName))
            {
                <div class="card border-0 shadow-sm mt-3" style="border-radius:12px;border-left:4px solid #A7EBF2;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#e8fff7;flex-shrink:0;">
                                <i class="fas fa-file-download" style="color:#A7EBF2;font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <div class="fw-bold" style="color:#011C40;">@Model.DownloadedFileName</div>
                                <div class="text-muted small">Transaction file downloaded and marked on portal</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.DownloadedFileBase64))
                        {
                            <a href="data:application/octet-stream;base64,@Model.DownloadedFileBase64"
                               download="@Model.DownloadedFileName"
                               class="btn btn-sm" style="background:#A7EBF2;color:#fff;border-radius:8px;">
                                <i class="fas fa-download me-1"></i> Save File
                            </a>
                        }
                    </div>
                </div>
            }

            else if (Model.StatusMessage == null)
            {
                <div class="card border-0 shadow-sm d-flex align-items-center justify-content-center" style="border-radius:12px;min-height:300px;">
                    <div class="text-center text-muted py-5">
                        <i class="fas fa-cloud-download-alt fa-3x mb-3" style="color:#EAF4FB;"></i>
                        <p class="mb-0">Select a portal and operation, then click <strong>Fetch Data</strong></p>
                        <small>Fetched transactions will appear here</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
.portal-toggle { cursor:pointer; }
.portal-toggle span {
    display:block; padding:10px 12px; border-radius:8px; text-align:center;
    border:1.5px solid #EAF4FB; background:#EAF4FB; font-size:.82rem;
    font-weight:600; color:#495057; transition:all .15s; user-select:none;
}
.portal-toggle input:checked + span {
    background:#011C40; color:#fff; border-color:#011C40;
}
</style>
}

@section Scripts {
<script>
const PORTAL_OPS = {
    DHA: [
        { value: 'SearchTransactions',         label: 'Search Transactions' },
        { value: 'GetNewTransactions',          label: 'Get New Transactions' },
        { value: 'GetNewPriorAuthorizations',   label: 'Get New Prior Authorizations' },
        { value: 'DownloadTransactionFile',     label: 'Download Transaction File' },
    ],
    RHA: [
        { value: 'GetClaims',                  label: 'Get Claims' },
        { value: 'GetRemittances',             label: 'Get Remittances' },
        { value: 'GetPriorAuthorizations',     label: 'Get Prior Authorizations' },
    ]
};

// Server-rendered value to restore on first load
let _serverOperation = '@Model.Operation';

function updateOperations() {
    const portal = document.querySelector('input[name="Portal"]:checked')?.value || 'DHA';
    const sel    = document.getElementById('operationSelect');
    const ops    = PORTAL_OPS[portal] || [];

    // Determine which value to restore: server value on first load, else current selection
    const restore = _serverOperation || sel.value;
    _serverOperation = null; // use only once

    sel.innerHTML = '';
    ops.forEach(op => {
        const opt = document.createElement('option');
        opt.value       = op.value;
        opt.textContent = op.label;
        sel.appendChild(opt);
    });

    // Restore previous selection if it belongs to the new portal's ops
    if (restore && ops.some(op => op.value === restore)) {
        sel.value = restore;
    }

    updateFormFields();
}

function updateFormFields() {
    var op = document.getElementById('operationSelect').value;
    var isDownload = op === 'DownloadTransactionFile';
    var isSearch   = op === 'SearchTransactions';
    document.getElementById('fileIdSection').style.display    = isDownload ? '' : 'none';
    document.getElementById('dateRange').style.display        = isDownload ? 'none' : '';
    document.getElementById('searchOptions').style.display    = isSearch ? '' : 'none';
    document.getElementById('txStatusSection').style.display  = isSearch ? '' : 'none';
    document.getElementById('txTypeSection').style.display    = isSearch ? '' : 'none';
    document.getElementById('recordRangeSection').style.display = isSearch ? '' : 'none';
}

function prefillDownload(fileId) {
    var sel = document.getElementById('operationSelect');
    sel.value = 'DownloadTransactionFile';
    updateFormFields();
    document.getElementById('FileId').value = fileId;
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

async function bulkSave() {
    const btn = document.getElementById('bulkSaveBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Saving…';

    const card = document.getElementById('saveStatusCard');
    card.style.display = '';
    card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    updateSaveUI({ status: 'searching', total: 0, found: 0, saved: 0, downloaded: 0, duplicates: 0, pending: 0 });

    const data = new FormData(document.getElementById('saveAllForm'));
    try {
        const resp = await fetch('/Portal/FetchAndSaveStream', { method: 'POST', body: data });
        if (!resp.ok) throw new Error('Server error ' + resp.status);

        const reader  = resp.body.getReader();
        const decoder = new TextDecoder();
        let buffer    = '';

        while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            buffer += decoder.decode(value, { stream: true });
            const parts = buffer.split('\n\n');
            buffer = parts.pop();
            for (const part of parts) {
                const line = part.trim();
                if (!line.startsWith('data: ')) continue;
                try {
                    const json = JSON.parse(line.slice(6));
                    updateSaveUI(json);
                    if (json.status === 'done') {
                        btn.innerHTML = '<i class="fas fa-check me-1"></i> Done';
                        btn.style.background = '#011C40';
                    }
                } catch {}
            }
        }
    } catch (e) {
        document.getElementById('saveStatusErrorMsg').textContent = e.message;
        document.getElementById('saveStatusError').style.display = '';
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-database me-1"></i> Bulk Save';
    }
}

function updateSaveUI(d) {
    const titles = {
        searching:  ['Searching portal…',         'Fetching transaction list across all types'],
        found:      ['Records found — processing…','Downloading &amp; saving to database'],
        processing: ['Saving files…',              `${d.saved ?? 0} saved · ${d.downloaded ?? 0} downloaded · ${d.pending ?? 0} pending`],
        done:       ['Complete',                   `${d.saved} new saved · ${d.downloaded} files downloaded · ${d.duplicates} duplicates`],
        error:      ['Error',                      d.message ?? 'An error occurred']
    };
    const [title, sub] = titles[d.status] ?? ['Working…', ''];
    document.getElementById('saveStatusTitle').textContent   = title;
    document.getElementById('saveStatusSubtitle').innerHTML  = sub;

    const icon = document.getElementById('saveStatusIcon');
    if (d.status === 'done') {
        icon.style.background = '#EAF4FB';
        icon.innerHTML = '<i class="fas fa-check" style="color:#011C40;font-size:.85rem;"></i>';
    } else if (d.status === 'error') {
        icon.style.background = '#ffe8e8';
        icon.innerHTML = '<i class="fas fa-times" style="color:#dc3545;font-size:.85rem;"></i>';
    }

    const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v ?? '—'; };
    set('statFound',   d.found   ?? (d.status === 'searching' ? '…' : '—'));
    set('statSaved',   d.saved   ?? '—');
    set('statFiles',   d.downloaded ?? '—');
    set('statDups',    d.duplicates ?? '—');
    set('statPending', d.pending  ?? '—');

    const pct = d.total > 0 ? Math.round(((d.saved ?? 0) + (d.duplicates ?? 0)) / d.total * 100) : (d.status === 'done' ? 100 : 0);
    document.getElementById('saveProgressBar').style.width = pct + '%';

    if (d.status === 'error') {
        document.getElementById('saveStatusErrorMsg').textContent = d.message ?? '';
        document.getElementById('saveStatusError').style.display = '';
    }
}

function setFetchRange(months) {
    const today = new Date();
    const from  = new Date(today);
    from.setMonth(from.getMonth() - months);
    document.getElementById('DateFrom').value = from.toISOString().split('T')[0];
    document.getElementById('DateTo').value   = today.toISOString().split('T')[0];
}

// Init on load
document.addEventListener('DOMContentLoaded', function() { updateOperations(); });

function exportCsv() {
    var table = document.getElementById('resultsTable');
    if (!table) return;
    var csv = [];
    table.querySelectorAll('tr').forEach(function(row) {
        var cells = row.querySelectorAll('th,td');
        csv.push([...cells].map(c => '"' + c.innerText.replace(/"/g, '""') + '"').join(','));
    });
    var blob = new Blob([csv.join('\n')], { type: 'text/csv' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'portal_fetch_' + new Date().toISOString().slice(0,10) + '.csv';
    a.click();
}
</script>
