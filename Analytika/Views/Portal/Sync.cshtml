@model Analytika.Models.ViewModels.PortalSyncViewModel
@{
    ViewData["Title"] = "Sync Portal Data";
}

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Portal Data Sync</h4>
            <small class="text-muted">Fetch 1-year transaction history from DHA / RHA portals and persist to database</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SyncedData" class="btn btn-ghost btn-sm">
                <i class="fas fa-database me-1"></i> View Synced Data
            </a>
            <a asp-action="Fetch" class="btn btn-ghost btn-sm">
                <i class="fas fa-bolt me-1"></i> Manual Fetch
            </a>
            <button id="syncAllBtn" class="btn btn-primary btn-sm" onclick="startSyncAll()">
                <i class="fas fa-calendar-alt me-1"></i> Month-wise Sync 2024–2026
            </button>
        </div>
    </div>

    <!-- Sync All Progress Panel (hidden until started) -->
    <div id="syncAllPanel" class="card border-0 shadow-sm mb-4" style="display:none;border-left:3px solid #0d6efd!important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold" style="color:var(--navy);font-size:.85rem;">
                    <i class="fas fa-calendar-alt fa-spin me-1" id="syncAllSpinner"></i>
                    Month-wise Sync — Jan 2024 → Today
                </h6>
                <span id="syncAllGrandTotal" class="badge" style="background:#e8f0fe;color:#1a2f6e;font-size:.75rem;"></span>
            </div>
            <!-- Overall progress -->
            <div class="d-flex align-items-center gap-2 mb-1">
                <div class="progress flex-grow-1" style="height:8px;border-radius:4px;">
                    <div id="syncAllProgress" class="progress-bar" style="background:#0d6efd;width:0%;transition:width .3s;"></div>
                </div>
                <span id="syncAllPct" style="font-size:.72rem;font-weight:600;color:#1a2f6e;min-width:32px;text-align:right;">0%</span>
            </div>
            <!-- Current facility + month -->
            <div id="syncAllCurrent" style="font-size:.75rem;color:#555;margin-bottom:6px;min-height:18px;"></div>
            <!-- Scrollable log -->
            <div id="syncAllLog" style="max-height:300px;overflow-y:auto;font-size:.71rem;font-family:monospace;background:#f8f9fa;border-radius:6px;padding:8px;line-height:1.9;">
                <span class="text-muted">Initialising…</span>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- Left: Config -->
        <div class="col-lg-4">

            <!-- DHA Sync Strategy Info -->
            <div class="card border-0 shadow-sm mb-3" style="border-left:3px solid var(--emerald)!important;">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.82rem;color:var(--navy);">
                        <i class="fas fa-info-circle me-1 text-emerald"></i> DHA Sync Strategy
                    </div>
                    <div style="font-size:.75rem;color:var(--text-secondary);line-height:1.7;">
                        <div class="mb-1"><span class="badge badge-navy me-1">1</span> <strong>SearchTransactions</strong> — Discovers file references for the date range, all types, both directions</div>
                        <div class="mb-1"><span class="badge badge-navy me-1">2</span> <strong>DownloadTransactionFile</strong> — Downloads the actual XML file for each transaction</div>
                        <div class="mb-1"><span class="badge badge-navy me-1">3</span> <strong>Save</strong> — Persists files and parsed claim records to the local database</div>
                        <div><span class="badge badge-navy me-1">4</span> <strong>Reconcile</strong> — Matches Remittance files against Claim submissions using Claim ID</div>
                    </div>
                </div>
            </div>

            <!-- Full Historical Sync Form -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-1" style="color:var(--navy);">
                        <i class="fas fa-history me-1 text-emerald"></i> Full Historical Sync
                    </h6>
                    <p class="text-muted mb-3" style="font-size:.75rem;">Fetches &amp; downloads all transactions for the selected date range</p>

                    <form asp-action="Sync" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Portal -->
                        <div class="mb-3">
                            <label class="form-label">Portal</label>
                            <div class="d-flex gap-2">
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="DHA" @(Model.Portal == "DHA" ? "checked" : "") class="d-none" />
                                    <span><i class="fas fa-building me-1"></i> DHA<small class="d-block" style="font-size:.65rem;opacity:.6;">eClaimLink</small></span>
                                </label>
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="RHA" @(Model.Portal == "RHA" ? "checked" : "") class="d-none" />
                                    <span><i class="fas fa-hospital me-1"></i> RHA<small class="d-block" style="font-size:.65rem;opacity:.6;">Riayati</small></span>
                                </label>
                            </div>
                        </div>

                        <!-- Facility -->
                        <div class="mb-3">
                            <label class="form-label">Facility</label>
                            <select asp-for="FacilityId" asp-items="Model.Facilities" class="form-select" id="facilitySelect">
                                <option value="">— Select Facility —</option>
                            </select>
                        </div>

                        <!-- Date Range -->
                        <div class="mb-3">
                            <label class="form-label">Date Range</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input asp-for="DateFrom" type="date" class="form-control" />
                                    <small class="text-muted" style="font-size:.68rem;">From</small>
                                </div>
                                <div class="col-6">
                                    <input asp-for="DateTo" type="date" class="form-control" />
                                    <small class="text-muted" style="font-size:.68rem;">To</small>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-1 flex-wrap">
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(1)">1 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(3)">3 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(6)">6 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(12)">1 Year</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(24)">2 Years</button>
                            </div>
                        </div>

                        <button type="submit" class="btn w-100 mb-2" style="background:var(--navy);color:#fff;font-weight:600;padding:10px;" id="syncBtn">
                            <i class="fas fa-sync me-2"></i> Start Full Sync
                        </button>
                    </form>

                    <!-- Sync New (GetNewTransactions) -->
                    <div class="divider my-3"></div>
                    <h6 class="fw-bold mb-1" style="color:var(--navy);">
                        <i class="fas fa-bolt me-1" style="color:var(--warning);"></i> Sync New Transactions
                    </h6>
                    <p class="text-muted mb-2" style="font-size:.75rem;">
                        Uses <strong>GetNewTransactions</strong> to fetch &amp; download only unacknowledged new transactions from the DHA queue
                    </p>

                    <div class="mb-2">
                        <select class="form-select" id="syncNewFacility">
                            <option value="">— Select Facility —</option>
                            @foreach (var f in Model.Facilities)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>

                    <button type="button" class="btn btn-ghost w-100" id="syncNewBtn" onclick="syncNew()" style="border-color:var(--warning);color:#b45309;">
                        <i class="fas fa-sync me-1"></i> Sync New Only
                    </button>
                    <div id="syncNewResult" class="mt-2" style="font-size:.78rem;display:none;"></div>
                </div>
            </div>

            <!-- DB Stats Card -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">Database</h6>
                    <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-light);">
                        <span style="font-size:.82rem;color:var(--text-secondary);">Total records</span>
                        <span class="fw-bold" style="color:var(--navy);">@Model.TotalInDb.ToString("N0")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span style="font-size:.82rem;color:var(--text-secondary);">Files downloaded</span>
                        <span class="fw-bold text-emerald">@Model.TotalFilesInDb.ToString("N0")</span>
                    </div>
                    <div class="pt-2">
                        <a asp-action="SyncedData" class="btn btn-ghost btn-sm w-100">
                            <i class="fas fa-table me-1"></i> Browse Data
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Results -->
        <div class="col-lg-8">

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-@(Model.IsError ? "exclamation-circle" : "check-circle") me-2"></i>@Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.HasRun && Model.BatchResults.Any())
            {
                <!-- Summary Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">Discovered</div>
                            <div class="stat-value" style="color:var(--navy);">@Model.BatchResults.Sum(b => b.Fetched).ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">New Saved</div>
                            <div class="stat-value text-emerald">@Model.TotalNew.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">Files Downloaded</div>
                            <div class="stat-value" style="color:var(--info);">@Model.TotalFilesDownloaded.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">Duplicates Skipped</div>
                            <div class="stat-value" style="color:var(--text-muted);">@Model.TotalDuplicates.ToString("N0")</div>
                        </div>
                    </div>
                </div>

                <!-- Batch Results Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 py-3 px-4 d-flex align-items-center justify-content-between">
                        <span class="fw-bold" style="color:var(--navy);font-size:.95rem;">Results by Period</span>
                        <span class="badge badge-emerald">@Model.BatchResults.Count batches</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Period</th>
                                        <th>Operation</th>
                                        <th class="text-center">Found</th>
                                        <th class="text-center">New</th>
                                        <th class="text-center">Files DL</th>
                                        <th class="text-center">Dups</th>
                                        <th class="pe-4">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var b in Model.BatchResults)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold" style="color:var(--navy);">@b.Label</td>
                                            <td><span class="badge badge-info" style="font-size:.65rem;">@b.Operation</span></td>
                                            <td class="text-center text-muted">@b.Fetched</td>
                                            <td class="text-center">
                                                @if (b.NewRecords > 0) { <span class="fw-semibold text-emerald">+@b.NewRecords</span> }
                                                else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (b.FilesDownloaded > 0) { <span class="fw-semibold" style="color:var(--info);">@b.FilesDownloaded</span> }
                                                else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center text-muted">@b.Duplicates</td>
                                            <td class="pe-4">
                                                @if (b.IsSuccess) { <span class="status-pill success"><i class="fas fa-check" style="font-size:.55rem;"></i> OK</span> }
                                                else { <span class="status-pill failed" title="@b.Error"><i class="fas fa-times" style="font-size:.55rem;"></i> Err</span> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot style="background:var(--bg);">
                                    <tr>
                                        <td class="ps-4 fw-bold" colspan="2" style="color:var(--navy);">Total</td>
                                        <td class="text-center fw-bold text-muted">@Model.BatchResults.Sum(b => b.Fetched)</td>
                                        <td class="text-center fw-bold text-emerald">+@Model.TotalNew</td>
                                        <td class="text-center fw-bold" style="color:var(--info);">@Model.TotalFilesDownloaded</td>
                                        <td class="text-center fw-bold text-muted">@Model.TotalDuplicates</td>
                                        <td class="pe-4">
                                            @if (Model.TotalErrors == 0) { <span class="status-pill success">All OK</span> }
                                            else { <span class="status-pill warning">@Model.TotalErrors errors</span> }
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>

                @if (Model.TotalNew > 0)
                {
                    <div class="mt-3 text-center">
                        <a asp-action="SyncedData" class="btn btn-emerald px-4">
                            <i class="fas fa-database me-2"></i>Browse @Model.TotalNew New Records
                        </a>
                    </div>
                }
            }
            else if (!Model.HasRun)
            {
                <div class="card border-0" style="border:2px dashed var(--border)!important;background:transparent!important;box-shadow:none!important;">
                    <div class="empty-state" style="padding:60px 24px;">
                        <i class="fas fa-sync" style="color:var(--emerald);opacity:.3;"></i>
                        <p class="fw-semibold mb-1" style="font-size:.95rem;color:var(--text-secondary);">Ready to Sync</p>
                        <p style="font-size:.82rem;color:var(--text-muted);max-width:400px;margin:0 auto;">
                            <strong>Full Sync</strong> uses SearchTransactions to discover file references, then DownloadTransactionFile to fetch each file and persist the XML content to the database.<br/><br/>
                            <strong>Sync New</strong> uses GetNewTransactions to pick up any new unacknowledged transactions from the DHA queue.
                        </p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    function setRange(months) {
        const today = new Date();
        const from = new Date(today);
        from.setMonth(from.getMonth() - months);
        document.querySelector('input[name="DateFrom"]').value = from.toISOString().split('T')[0];
        document.querySelector('input[name="DateTo"]').value = today.toISOString().split('T')[0];
    }

    document.querySelector('form').addEventListener('submit', function() {
        const btn = document.getElementById('syncBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Syncing… fetching &amp; downloading files (this may take several minutes)';
    });

    async function syncNew() {
        const facilityId = document.getElementById('syncNewFacility').value;
        if (!facilityId) { alert('Please select a facility first.'); return; }

        const btn = document.getElementById('syncNewBtn');
        const result = document.getElementById('syncNewResult');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Fetching new transactions…';
        result.style.display = 'none';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const resp = await fetch('/Portal/SyncNew', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `facilityId=${facilityId}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await resp.json();

            result.style.display = 'block';
            result.className = data.ok ? 'mt-2 text-emerald' : 'mt-2 text-danger';
            result.innerHTML = `<i class="fas fa-${data.ok ? 'check-circle' : 'exclamation-circle'} me-1"></i>${data.message}`;
        } catch (e) {
            result.style.display = 'block';
            result.className = 'mt-2 text-danger';
            result.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>Request failed';
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync me-1"></i> Sync New Only';
    }

    // ── Month-wise Sync 2024–2026 ──────────────────────────────────
    function startSyncAll() {
        const btn      = document.getElementById('syncAllBtn');
        const panel    = document.getElementById('syncAllPanel');
        const logDiv   = document.getElementById('syncAllLog');
        const bar      = document.getElementById('syncAllProgress');
        const pctLbl   = document.getElementById('syncAllPct');
        const grandLbl = document.getElementById('syncAllGrandTotal');
        const spinner  = document.getElementById('syncAllSpinner');
        const curLbl   = document.getElementById('syncAllCurrent');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Syncing…';
        panel.style.display = 'block';
        logDiv.innerHTML = '';
        bar.style.width = '0%';
        pctLbl.textContent = '0%';
        curLbl.textContent = '';
        panel.scrollIntoView({ behavior: 'smooth' });

        // Track current facility header line so month rows can be indented under it
        let lastFacilityEl = null;

        const source = new EventSource('/Portal/SyncAllFacilitiesStream');

        function addLog(msg, color, indent) {
            const line = document.createElement('div');
            line.style.color = color || '#333';
            if (indent) line.style.paddingLeft = '16px';
            line.textContent = msg;
            logDiv.appendChild(line);
            logDiv.scrollTop = logDiv.scrollHeight;
            return line;
        }

        function setProgress(pct) {
            bar.style.width = pct + '%';
            pctLbl.textContent = pct + '%';
        }

        source.onmessage = function(e) {
            const d = JSON.parse(e.data);

            if (d.status === 'start') {
                addLog(`▶ ${d.message}`, '#0d6efd');

            } else if (d.status === 'facility_start') {
                lastFacilityEl = addLog(`\n◆ ${d.facilityName}`, '#0f172a');
                curLbl.textContent = `Facility ${d.facilityIndex}: ${d.facilityName}`;

            } else if (d.status === 'month_done') {
                const found = d.found > 0 ? `+${d.found}` : '—';
                addLog(`${d.month}  ${found}`, d.found > 0 ? '#198754' : '#94a3b8', true);
                setProgress(d.pct || 0);
                grandLbl.textContent = `Found: ${(d.grandTotal||0).toLocaleString()}`;

            } else if (d.status === 'processing') {
                grandLbl.textContent = `Saved: ${(d.saved||0).toLocaleString()} · Dup: ${(d.dups||0).toLocaleString()} · Files: ${(d.files||0).toLocaleString()}`;
                setProgress(d.pct || 0);

            } else if (d.status === 'facility_done') {
                addLog(`  ✓ ${d.saved} new · ${d.dups} dup · ${d.files} files`, '#198754', true);
                setProgress(d.pct || 0);

            } else if (d.status === 'warning') {
                addLog(`⚠ ${d.message}`, '#856404');

            } else if (d.status === 'error') {
                addLog(`✗ ${d.message}`, '#dc3545');
                source.close();
                done();

            } else if (d.status === 'done') {
                setProgress(100);
                addLog('', '');
                addLog(`✅ ${d.message}`, '#198754');
                grandLbl.textContent = `${(d.grandSaved||0).toLocaleString()} new · ${(d.grandDups||0).toLocaleString()} dup · ${(d.grandFiles||0).toLocaleString()} files`;
                curLbl.textContent = 'Complete';
                source.close();
                done();
            }
        };

        source.onerror = function() {
            source.close();
            addLog('Connection closed.', '#6c757d');
            done();
        };

        function done() {
            spinner.classList.remove('fa-spin');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-calendar-alt me-1"></i> Month-wise Sync 2024–2026';
        }
    }
</script>
}
