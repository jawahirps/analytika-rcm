@model Analytika.Models.ViewModels.PortalSyncViewModel
@{
    ViewData["Title"] = "Sync Portal Data";
}

<div class="container-fluid py-4 px-4">

    <!-- Page Header -->
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Portal Data Sync</h4>
            <small class="text-muted">Fetch 1-year transaction history from DHA / RHA portals and persist to database</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="SyncedData" class="btn btn-ghost btn-sm">
                <i class="fas fa-database me-1"></i> View Synced Data
            </a>
            <button class="btn btn-ghost btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#syncAllOptions">
                <i class="fas fa-sliders-h me-1"></i> Options
            </button>
            <button class="btn btn-ghost btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#manualFetchPanel" onclick="mfInit()">
                <i class="fas fa-bolt me-1" style="color:var(--emerald);"></i> Manual Fetch
            </button>
            <button id="syncAllBtn" class="btn btn-primary btn-sm" onclick="startSyncAll()">
                <i class="fas fa-calendar-alt me-1"></i> Month-wise Sync 2024–2026
            </button>
        </div>
    </div>

    <!-- Resume Banner (shown when a checkpoint exists in localStorage) -->
    <div id="syncResumeBanner" class="alert mb-3" role="alert"
         style="display:none;border-left:4px solid var(--amber);background:var(--amber-light);color:var(--amber-dark);border-radius:var(--radius);">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <i class="fas fa-history me-2"></i>
                <strong id="resumeBannerTitle">Sync interrupted</strong>
                <span id="resumeBannerDetail" class="ms-2" style="font-size:.82rem;"></span>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm fw-semibold" style="background:var(--amber);color:#fff;border:none;" onclick="resumeFromCheckpoint()">
                    <i class="fas fa-play me-1"></i> Resume
                </button>
                <button class="btn btn-ghost btn-sm" onclick="discardCheckpoint()">
                    <i class="fas fa-times me-1"></i> Discard
                </button>
            </div>
        </div>
    </div>

    <!-- Month-wise Sync Options (collapsible) -->
    <div class="collapse mb-3" id="syncAllOptions">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Facilities <span class="text-muted fw-normal">(leave blank = all active)</span></label>
                        <select id="syncAllFacilities" class="form-select form-select-sm select2-multi" multiple>
                            @foreach (var f in Model.Facilities)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Transaction Types</label>
                        <div class="d-flex gap-3 flex-wrap pt-1">
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input sync-txtype" type="checkbox" id="tt2" value="2" checked>
                                <label class="form-check-label" for="tt2" style="font-size:.8rem;">Claim (2)</label>
                            </div>
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input sync-txtype" type="checkbox" id="tt8" value="8" checked>
                                <label class="form-check-label" for="tt8" style="font-size:.8rem;">Remittance (8)</label>
                            </div>
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input sync-txtype" type="checkbox" id="tt16" value="16" checked>
                                <label class="form-check-label" for="tt16" style="font-size:.8rem;">PA Req (16)</label>
                            </div>
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input sync-txtype" type="checkbox" id="tt32" value="32" checked>
                                <label class="form-check-label" for="tt32" style="font-size:.8rem;">PA Auth (32)</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button id="syncAllBtn2" class="btn btn-primary btn-sm w-100" onclick="startSyncAll()">
                            <i class="fas fa-play me-1"></i> Start
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Single-Facility Sync Panel (hidden until started) -->
    <div id="syncOnePanel" class="card border-0 shadow-sm mb-4" style="display:none;border-left:3px solid #A7EBF2!important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold" style="color:var(--navy);font-size:.85rem;">
                    <i class="fas fa-calendar-alt fa-spin me-1" id="syncOneSpinner"></i>
                    <span id="syncOneTitle">Facility Sync</span>
                </h6>
                <div class="d-flex align-items-center gap-2">
                    <span id="syncOneGrandTotal" class="badge" style="background:#EAF4FB;color:#011C40;font-size:.75rem;"></span>
                    <button id="pauseOneBtn" class="btn btn-xs fw-semibold" style="display:none;background:var(--amber);color:#fff;border:none;" onclick="pauseSyncOne()">
                        <i class="fas fa-pause me-1"></i>Pause
                    </button>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <div class="progress flex-grow-1" style="height:8px;border-radius:4px;">
                    <div id="syncOneProgress" class="progress-bar" style="background:var(--classic-teal);width:0%;transition:width .3s;"></div>
                </div>
                <span id="syncOnePct" style="font-size:.72rem;font-weight:600;color:var(--forest-teal);min-width:32px;text-align:right;">0%</span>
            </div>
            <div id="syncOneCounters" class="d-flex gap-2 mt-1 mb-1 flex-wrap" style="font-size:.72rem;">
                <span class="px-2 py-1 rounded" style="background:rgba(58,172,138,0.12);color:#3aac8a;">
                    <i class="fas fa-plus-circle me-1"></i>New: <strong id="syncOneCtrNew">0</strong>
                </span>
                <span class="px-2 py-1 rounded" style="background:var(--amber-light);color:var(--amber-dark);">
                    <i class="fas fa-history me-1"></i>Already in DB: <strong id="syncOneCtrDup">0</strong>
                </span>
                <span class="px-2 py-1 rounded" style="background:rgba(0,139,139,0.12);color:var(--forest-teal);">
                    <i class="fas fa-file-download me-1"></i>Files: <strong id="syncOneCtrFiles">0</strong>
                </span>
            </div>
            <div id="syncOneCurrent" style="font-size:.75rem;color:#555;margin-bottom:6px;min-height:18px;"></div>
            <div id="syncOneLog" style="max-height:300px;overflow-y:auto;font-size:.71rem;font-family:monospace;background:#EAF4FB;border-radius:6px;padding:8px;line-height:1.9;">
                <span class="text-muted">Initialising…</span>
            </div>
        </div>
    </div>

    <!-- Sync All Progress Panel (hidden until started) -->
    <div id="syncAllPanel" class="card border-0 shadow-sm mb-4" style="display:none;border-left:3px solid #A7EBF2!important;">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0 fw-bold" style="color:var(--navy);font-size:.85rem;">
                    <i class="fas fa-calendar-alt fa-spin me-1" id="syncAllSpinner"></i>
                    Month-wise Sync — Jan 2024 → Today
                </h6>
                <div class="d-flex align-items-center gap-2">
                    <span id="syncAllGrandTotal" class="badge" style="background:#EAF4FB;color:#011C40;font-size:.75rem;"></span>
                    <button id="pauseAllBtn" class="btn btn-xs fw-semibold" style="display:none;background:var(--amber);color:#fff;border:none;" onclick="pauseSyncAll()">
                        <i class="fas fa-pause me-1"></i>Pause
                    </button>
                </div>
            </div>
            <!-- Overall progress -->
            <div class="d-flex align-items-center gap-2 mb-1">
                <div class="progress flex-grow-1" style="height:8px;border-radius:4px;">
                    <div id="syncAllProgress" class="progress-bar" style="background:var(--classic-teal);width:0%;transition:width .3s;"></div>
                </div>
                <span id="syncAllPct" style="font-size:.72rem;font-weight:600;color:#011C40;min-width:32px;text-align:right;">0%</span>
            </div>
            <!-- Live tally counters -->
            <div id="syncAllCounters" class="d-flex gap-2 mt-1 mb-1 flex-wrap" style="font-size:.72rem;">
                <span class="px-2 py-1 rounded" style="background:rgba(58,172,138,0.12);color:#3aac8a;">
                    <i class="fas fa-plus-circle me-1"></i>New: <strong id="syncAllCtrNew">0</strong>
                </span>
                <span class="px-2 py-1 rounded" style="background:var(--amber-light);color:var(--amber-dark);">
                    <i class="fas fa-history me-1"></i>Already in DB: <strong id="syncAllCtrDup">0</strong>
                </span>
                <span class="px-2 py-1 rounded" style="background:rgba(0,139,139,0.12);color:var(--forest-teal);">
                    <i class="fas fa-file-download me-1"></i>Files: <strong id="syncAllCtrFiles">0</strong>
                </span>
            </div>
            <!-- Current facility + month -->
            <div id="syncAllCurrent" style="font-size:.75rem;color:#555;margin-bottom:6px;min-height:18px;"></div>
            <!-- Scrollable log -->
            <div id="syncAllLog" style="max-height:300px;overflow-y:auto;font-size:.71rem;font-family:monospace;background:#EAF4FB;border-radius:6px;padding:8px;line-height:1.9;">
                <span class="text-muted">Initialising…</span>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- Manual Fetch (consolidated) -->
    <div class="card border-0 shadow-sm mb-4 collapse" id="manualFetchPanel">
        <div class="card-body p-3">
            <h6 class="fw-bold mb-3" style="color:var(--navy);font-size:.88rem;">
                <i class="fas fa-bolt me-1" style="color:var(--emerald);"></i> Manual API Fetch
                <small class="text-muted fw-normal ms-2" style="font-size:.72rem;">Raw portal call — results not auto-saved</small>
            </h6>
            <form id="fetchForm" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <!-- Portal -->
                <div class="col-auto">
                    <label class="form-label">Portal</label>
                    <div class="d-flex gap-2">
                        <label class="portal-toggle flex-fill">
                            <input type="radio" name="mfPortal" value="DHA" checked class="d-none" onchange="mfUpdateOps()"/>
                            <span><i class="fas fa-building me-1"></i>DHA</span>
                        </label>
                        <label class="portal-toggle flex-fill">
                            <input type="radio" name="mfPortal" value="RHA" class="d-none" onchange="mfUpdateOps()"/>
                            <span><i class="fas fa-hospital me-1"></i>RHA</span>
                        </label>
                    </div>
                </div>
                <!-- Facility -->
                <div class="col-md-3">
                    <label class="form-label">Facility</label>
                    <select id="mfFacility" class="form-select form-select-sm">
                        <option value="">— Select —</option>
                        @foreach (var f in Model.Facilities)
                        {
                            <option value="@f.Value">@f.Text</option>
                        }
                    </select>
                </div>
                <!-- Operation -->
                <div class="col-md-2">
                    <label class="form-label">Operation</label>
                    <select id="mfOperation" class="form-select form-select-sm" onchange="mfUpdateFields()"></select>
                </div>
                <!-- Dates -->
                <div class="col-md-2" id="mfDateSection">
                    <label class="form-label">From</label>
                    <input type="date" id="mfDateFrom" class="form-control form-control-sm"/>
                </div>
                <div class="col-md-2" id="mfDateSection2">
                    <label class="form-label">To</label>
                    <input type="date" id="mfDateTo" class="form-control form-control-sm"/>
                </div>
                <!-- File ID (download only) -->
                <div class="col-md-3" id="mfFileIdSection" style="display:none;">
                    <label class="form-label">File ID</label>
                    <input type="text" id="mfFileId" class="form-control form-control-sm" placeholder="e.g. 123456"/>
                </div>
                <div class="col-auto">
                    <button type="button" class="btn btn-sm" style="background:var(--emerald);color:#fff;" onclick="mfFetch()">
                        <i class="fas fa-cloud-download-alt me-1"></i> Fetch
                    </button>
                </div>
            </form>
            <!-- Results -->
            <div id="mfResults" class="mt-3" style="display:none;">
                <div id="mfStatus" class="mb-2" style="font-size:.82rem;"></div>
                <div class="table-responsive" style="max-height:320px;overflow-y:auto;">
                    <table class="table table-hover mb-0" style="font-size:.78rem;">
                        <thead><tr>
                            <th class="ps-3">File ID / Tx ID</th>
                            <th>Type</th><th>Status</th><th>Payer</th><th>Amount</th><th>Date</th>
                            <th class="pe-3">File</th>
                        </tr></thead>
                        <tbody id="mfTableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Left: Config -->
        <div class="col-lg-4">

            <!-- DHA Sync Strategy Info -->
            <div class="card border-0 shadow-sm mb-3" style="border-left:3px solid var(--emerald)!important;">
                <div class="card-body p-3">
                    <div class="fw-semibold mb-2" style="font-size:.82rem;color:var(--navy);">
                        <i class="fas fa-info-circle me-1 text-emerald"></i> DHA Sync Strategy
                    </div>
                    <div style="font-size:.75rem;color:var(--text-secondary);line-height:1.7;">
                        <div class="mb-1"><span class="badge badge-navy me-1">1</span> <strong>SearchTransactions</strong> — Discovers file references for the date range, all types, both directions</div>
                        <div class="mb-1"><span class="badge badge-navy me-1">2</span> <strong>DownloadTransactionFile</strong> — Downloads the actual XML file for each transaction</div>
                        <div class="mb-1"><span class="badge badge-navy me-1">3</span> <strong>Save</strong> — Persists files and parsed claim records to the local database</div>
                        <div><span class="badge badge-navy me-1">4</span> <strong>Reconcile</strong> — Matches Remittance files against Claim submissions using Claim ID</div>
                    </div>
                </div>
            </div>

            <!-- Full Historical Sync Form -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-1" style="color:var(--navy);">
                        <i class="fas fa-history me-1 text-emerald"></i> Full Historical Sync
                    </h6>
                    <p class="text-muted mb-3" style="font-size:.75rem;">Fetches &amp; downloads all transactions for the selected date range</p>

                    <form asp-action="Sync" method="post">
                        @Html.AntiForgeryToken()

                        <!-- Portal -->
                        <div class="mb-3">
                            <label class="form-label">Portal</label>
                            <div class="d-flex gap-2">
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="DHA" @(Model.Portal == "DHA" ? "checked" : "") class="d-none" />
                                    <span><i class="fas fa-building me-1"></i> DHA<small class="d-block" style="font-size:.65rem;opacity:.6;">eClaimLink</small></span>
                                </label>
                                <label class="portal-toggle flex-fill">
                                    <input type="radio" name="Portal" value="RHA" @(Model.Portal == "RHA" ? "checked" : "") class="d-none" />
                                    <span><i class="fas fa-hospital me-1"></i> RHA<small class="d-block" style="font-size:.65rem;opacity:.6;">Riayati</small></span>
                                </label>
                            </div>
                        </div>

                        <!-- Facility -->
                        <div class="mb-3">
                            <label class="form-label">Facility</label>
                            <select asp-for="FacilityId" asp-items="Model.Facilities" class="form-select" id="facilitySelect">
                                <option value="">— Select Facility —</option>
                            </select>
                        </div>

                        <!-- Date Range -->
                        <div class="mb-3">
                            <label class="form-label">Date Range</label>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input asp-for="DateFrom" type="date" class="form-control" />
                                    <small class="text-muted" style="font-size:.68rem;">From</small>
                                </div>
                                <div class="col-6">
                                    <input asp-for="DateTo" type="date" class="form-control" />
                                    <small class="text-muted" style="font-size:.68rem;">To</small>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-1 flex-wrap">
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(1)">1 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(3)">3 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(6)">6 Mo</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(12)">1 Year</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange(24)">2 Years</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange('thisYear')">This Year</button>
                                <button type="button" class="btn btn-ghost btn-xs" onclick="setRange('lastYear')">Last Year</button>
                            </div>
                        </div>

                        <button type="submit" class="btn w-100 mb-2" style="background:var(--navy);color:#fff;font-weight:600;padding:10px;" id="syncBtn">
                            <i class="fas fa-sync me-2"></i> Start Full Sync
                        </button>
                    </form>

                    <!-- Facility-wise Sync -->
                    <div class="divider my-3"></div>
                    <h6 class="fw-bold mb-1" style="color:var(--navy);">
                        <i class="fas fa-hospital me-1" style="color:var(--emerald);"></i> Facility-wise Sync
                    </h6>
                    <p class="text-muted mb-2" style="font-size:.75rem;">
                        Select a facility, set date range and trigger month-wise or new-only sync
                    </p>

                    <div class="mb-2">
                        <select class="form-select" id="syncNewFacility">
                            <option value="">— Select Facility —</option>
                            @foreach (var f in Model.Facilities)
                            {
                                <option value="@f.Value">@f.Text</option>
                            }
                        </select>
                    </div>

                    <!-- Per-facility date range -->
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <input type="date" id="facSyncFrom" class="form-control form-control-sm" />
                            <small class="text-muted" style="font-size:.68rem;">From (leave blank = 1 yr)</small>
                        </div>
                        <div class="col-6">
                            <input type="date" id="facSyncTo" class="form-control form-control-sm" />
                            <small class="text-muted" style="font-size:.68rem;">To (leave blank = today)</small>
                        </div>
                    </div>
                    <div class="mt-2 d-flex gap-1 flex-wrap">
                        <button type="button" class="btn btn-ghost btn-xs" onclick="setFacilityRange('thisYear')">This Year</button>
                        <button type="button" class="btn btn-ghost btn-xs" onclick="setFacilityRange('lastYear')">Last Year</button>
                    </div>

                    <div class="d-flex gap-2 mb-2">
                        <button type="button" class="btn btn-ghost flex-fill" id="syncNewBtn" onclick="syncNew()" style="border-color:var(--warning);color:#b45309;font-size:.78rem;">
                            <i class="fas fa-bolt me-1"></i> New Only
                        </button>
                        <button type="button" class="btn btn-ghost flex-fill" id="syncOneBtn" onclick="startSyncOne()" style="border-color:var(--emerald);color:var(--emerald);font-size:.78rem;">
                            <i class="fas fa-calendar-alt me-1"></i> Month-wise
                        </button>
                    </div>
                    <div id="syncNewResult" class="mt-2" style="font-size:.78rem;display:none;"></div>
                </div>
            </div>

            <!-- DB Stats Card -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">Database</h6>
                    <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border-light);">
                        <span style="font-size:.82rem;color:var(--text-secondary);">Total records</span>
                        <span class="fw-bold" style="color:var(--navy);">@Model.TotalInDb.ToString("N0")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span style="font-size:.82rem;color:var(--text-secondary);">Files downloaded</span>
                        <span class="fw-bold text-emerald">@Model.TotalFilesInDb.ToString("N0")</span>
                    </div>
                    <div class="pt-2">
                        <a asp-action="SyncedData" class="btn btn-ghost btn-sm w-100">
                            <i class="fas fa-table me-1"></i> Browse Data
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Results -->
        <div class="col-lg-8">

            @if (!string.IsNullOrEmpty(Model.StatusMessage))
            {
                <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-@(Model.IsError ? "exclamation-circle" : "check-circle") me-2"></i>@Model.StatusMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.HasRun && Model.BatchResults.Any())
            {
                <!-- Summary Cards -->
                <div class="row g-3 mb-4">
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">Discovered</div>
                            <div class="stat-value" style="color:var(--navy);">@Model.BatchResults.Sum(b => b.Fetched).ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">New Saved</div>
                            <div class="stat-value text-emerald">@Model.TotalNew.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center">
                            <div class="stat-label">Files Downloaded</div>
                            <div class="stat-value" style="color:var(--info);">@Model.TotalFilesDownloaded.ToString("N0")</div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="stat-card text-center" style="border-top:3px solid var(--amber);">
                            <div class="stat-label">Already in DB</div>
                            <div class="stat-value" style="color:var(--amber);">@Model.TotalDuplicates.ToString("N0")</div>
                        </div>
                    </div>
                </div>

                <!-- Batch Results Table -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 py-3 px-4 d-flex align-items-center justify-content-between">
                        <span class="fw-bold" style="color:var(--navy);font-size:.95rem;">Results by Period</span>
                        <span class="badge badge-emerald">@Model.BatchResults.Count batches</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Period</th>
                                        <th>Operation</th>
                                        <th class="text-center">Found</th>
                                        <th class="text-center">New</th>
                                        <th class="text-center">Files DL</th>
                                        <th class="text-center" style="color:var(--amber);">Already in DB</th>
                                        <th class="pe-4">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var b in Model.BatchResults)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold" style="color:var(--navy);">@b.Label</td>
                                            <td><span class="badge badge-info" style="font-size:.65rem;">@b.Operation</span></td>
                                            <td class="text-center text-muted">@b.Fetched</td>
                                            <td class="text-center">
                                                @if (b.NewRecords > 0) { <span class="fw-semibold text-emerald">+@b.NewRecords</span> }
                                                else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (b.FilesDownloaded > 0) { <span class="fw-semibold" style="color:var(--info);">@b.FilesDownloaded</span> }
                                                else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="text-center">
                                                @if (b.Duplicates > 0) { <span class="fw-semibold" style="color:var(--amber);">@b.Duplicates</span> }
                                                else { <span class="text-muted">0</span> }
                                            </td>
                                            <td class="pe-4">
                                                @if (b.IsSuccess) { <span class="status-pill success"><i class="fas fa-check" style="font-size:.55rem;"></i> OK</span> }
                                                else { <span class="status-pill failed" title="@b.Error"><i class="fas fa-times" style="font-size:.55rem;"></i> Err</span> }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot style="background:var(--bg);">
                                    <tr>
                                        <td class="ps-4 fw-bold" colspan="2" style="color:var(--navy);">Total</td>
                                        <td class="text-center fw-bold text-muted">@Model.BatchResults.Sum(b => b.Fetched)</td>
                                        <td class="text-center fw-bold text-emerald">+@Model.TotalNew</td>
                                        <td class="text-center fw-bold" style="color:var(--info);">@Model.TotalFilesDownloaded</td>
                                        <td class="text-center fw-bold" style="color:var(--amber);">@Model.TotalDuplicates</td>
                                        <td class="pe-4">
                                            @if (Model.TotalErrors == 0) { <span class="status-pill success">All OK</span> }
                                            else { <span class="status-pill warning">@Model.TotalErrors errors</span> }
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>

                @if (Model.TotalNew > 0)
                {
                    <div class="mt-3 text-center">
                        <a asp-action="SyncedData" class="btn btn-emerald px-4">
                            <i class="fas fa-database me-2"></i>Browse @Model.TotalNew New Records
                        </a>
                    </div>
                }
            }
            else if (!Model.HasRun)
            {
                <!-- Facility Quick Sync Panel -->
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent border-0 py-3 px-4 d-flex align-items-center justify-content-between">
                        <span class="fw-bold" style="color:var(--navy);font-size:.95rem;">
                            <i class="fas fa-hospital me-2" style="color:var(--emerald);"></i>Facility-wise Sync Overview
                        </span>
                        <small class="text-muted">@Model.Facilities.Count facilities</small>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th class="ps-4">Facility</th>
                                        <th class="text-center">Month-wise (1 yr)</th>
                                        <th class="text-center">Month-wise (2 yr)</th>
                                        <th class="text-center">New Only</th>
                                        <th class="pe-4 text-center">Download XML</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var f in Model.Facilities)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-semibold" style="color:var(--navy);font-size:.82rem;">
                                                <i class="fas fa-hospital-alt me-1 text-muted" style="font-size:.7rem;"></i>@f.Text
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-ghost btn-xs"
                                                    style="border-color:var(--emerald);color:var(--emerald);"
                                                    onclick="quickSyncFacility('@f.Value', 12)">
                                                    <i class="fas fa-calendar-alt me-1"></i>1 yr
                                                </button>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-ghost btn-xs"
                                                    style="border-color:var(--navy);color:var(--navy);"
                                                    onclick="quickSyncFacility('@f.Value', 24)">
                                                    <i class="fas fa-calendar-alt me-1"></i>2 yr
                                                </button>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-ghost btn-xs"
                                                    style="border-color:var(--warning);color:#b45309;"
                                                    onclick="quickSyncNew('@f.Value')">
                                                    <i class="fas fa-bolt me-1"></i>New
                                                </button>
                                            </td>
                                            <td class="pe-4 text-center">
                                                <div class="d-flex align-items-center gap-1 justify-content-center flex-nowrap">
                                                    <button class="btn btn-xs dl-toggle"
                                                            data-fid="@f.Value" data-type="2"
                                                            title="Submission / Claims XML"
                                                            onclick="dlToggle(this)"
                                                            style="font-size:.66rem;border:1px solid #A7EBF2;background:rgba(0,139,139,0.12);color:var(--forest-teal);border-radius:4px;padding:2px 6px;white-space:nowrap;">
                                                        <i class="fas fa-file-medical me-1"></i>Claim
                                                    </button>
                                                    <button class="btn btn-xs dl-toggle"
                                                            data-fid="@f.Value" data-type="8"
                                                            title="Remittance XML"
                                                            onclick="dlToggle(this)"
                                                            style="font-size:.66rem;border:1px solid var(--amber);background:var(--amber-light);color:var(--amber-dark);border-radius:4px;padding:2px 6px;white-space:nowrap;">
                                                        <i class="fas fa-file-invoice-dollar me-1"></i>Remit
                                                    </button>
                                                    <button class="btn btn-xs"
                                                            title="Download selected XML files as ZIP"
                                                            onclick="dlXml('@f.Value', this)"
                                                            style="font-size:.66rem;border:1px solid var(--navy);color:var(--navy);border-radius:4px;padding:2px 7px;">
                                                        <i class="fas fa-download"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Pause/Resume Checkpoint ────────────────────────────────────
    const CKPT_KEY = 'analytika_sync_checkpoint';
    let syncAllSource = null;   // module-level so pauseSyncAll() can close it
    let syncOneSource = null;
    let syncAllCompleted = false;
    let syncOneCompleted = false;

    function saveCkpt(data) {
        localStorage.setItem(CKPT_KEY, JSON.stringify({ ...data, savedAt: new Date().toISOString() }));
    }
    function loadCkpt() {
        try { return JSON.parse(localStorage.getItem(CKPT_KEY)); } catch { return null; }
    }
    function clearCkpt() { localStorage.removeItem(CKPT_KEY); }

    function showResumeBanner(cp) {
        if (!cp) return;
        const banner = document.getElementById('syncResumeBanner');
        const title  = document.getElementById('resumeBannerTitle');
        const detail = document.getElementById('resumeBannerDetail');
        const icon   = cp.reason === 'paused' ? 'pause-circle' : 'exclamation-triangle';
        const verb   = cp.reason === 'paused' ? 'Paused' : cp.reason === 'error' ? 'Interrupted (error)' : 'Disconnected';
        const who    = cp.type === 'all' ? 'Month-wise Sync' : `Facility sync`;
        title.innerHTML = `<i class="fas fa-${icon} me-1"></i>${verb} — ${who}`;
        const parts = [];
        if (cp.lastFacilityName) parts.push(`Last: <strong>${cp.lastFacilityName}</strong>`);
        if (cp.lastMonth)        parts.push(`Month: <strong>${cp.lastMonth}</strong>`);
        if (cp.totalSaved)       parts.push(`${cp.totalSaved.toLocaleString()} saved so far`);
        if (cp.savedAt) {
            const d = new Date(cp.savedAt);
            parts.push(`at ${d.toLocaleTimeString()}`);
        }
        detail.innerHTML = parts.join(' · ');
        banner.style.display = 'block';
        banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function discardCheckpoint() {
        clearCkpt();
        document.getElementById('syncResumeBanner').style.display = 'none';
    }

    function resumeFromCheckpoint() {
        const cp = loadCkpt();
        if (!cp) return;
        discardCheckpoint();
        if (cp.type === 'all') {
            // Restore options selections
            if (cp.facilityIds?.length) {
                const sel = document.getElementById('syncAllFacilities');
                if (sel) { Array.from(sel.options).forEach(o => o.selected = cp.facilityIds.includes(parseInt(o.value))); try { $(sel).trigger('change'); } catch {} }
            }
            startSyncAll({ facilityIdx: cp.facilityIdx, monthIdx: cp.monthIdx, facilityIds: cp.facilityIds, txTypes: cp.txTypes, totalSaved: cp.totalSaved || 0, totalDups: cp.totalDups || 0, totalFiles: cp.totalFiles || 0 });
        } else {
            // Restore facility selection
            if (cp.facilityId) document.getElementById('syncNewFacility').value = cp.facilityId;
            if (cp.from) document.getElementById('facSyncFrom').value = cp.from;
            if (cp.to)   document.getElementById('facSyncTo').value   = cp.to;
            startSyncOne({ monthIdx: cp.monthIdx, totalSaved: cp.totalSaved || 0, totalDups: cp.totalDups || 0, totalFiles: cp.totalFiles || 0 });
        }
    }

    // Check for saved checkpoint on page load
    document.addEventListener('DOMContentLoaded', () => {
        const cp = loadCkpt();
        if (cp) showResumeBanner(cp);
    });

    function setRange(range) {
        const today = new Date();
        let from, to;

        if (range === 'thisYear') {
            from = new Date(today.getFullYear(), 0, 1);
            to = new Date(today.getFullYear(), 11, 31);
        } else if (range === 'lastYear') {
            from = new Date(today.getFullYear() - 1, 0, 1);
            to = new Date(today.getFullYear() - 1, 11, 31);
        } else {
            const months = Number(range);
            from = new Date(today);
            from.setMonth(from.getMonth() - months);
            to = today;
        }

        document.querySelector('input[name="DateFrom"]').value = from.toISOString().split('T')[0];
        document.querySelector('input[name="DateTo"]').value = to.toISOString().split('T')[0];
    }

    function setFacilityRange(range) {
        const today = new Date();
        let from, to;

        if (range === 'thisYear') {
            from = new Date(today.getFullYear(), 0, 1);
            to = new Date(today.getFullYear(), 11, 31);
        } else if (range === 'lastYear') {
            from = new Date(today.getFullYear() - 1, 0, 1);
            to = new Date(today.getFullYear() - 1, 11, 31);
        } else {
            const months = Number(range);
            from = new Date(today);
            from.setMonth(from.getMonth() - months);
            to = today;
        }

        document.getElementById('facSyncFrom').value = from.toISOString().split('T')[0];
        document.getElementById('facSyncTo').value = to.toISOString().split('T')[0];
    }

    document.querySelector('form').addEventListener('submit', function() {
        const btn = document.getElementById('syncBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Syncing… fetching &amp; downloading files (this may take several minutes)';
    });

    async function syncNew() {
        const facilityId = document.getElementById('syncNewFacility').value;
        if (!facilityId) { alert('Please select a facility first.'); return; }

        const btn = document.getElementById('syncNewBtn');
        const result = document.getElementById('syncNewResult');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Fetching new transactions…';
        result.style.display = 'none';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            const resp = await fetch('/Portal/SyncNew', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `facilityId=${facilityId}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await resp.json();

            result.style.display = 'block';
            if (!data.ok) {
                result.className = 'mt-2 text-danger';
                result.innerHTML = `<i class="fas fa-exclamation-circle me-1"></i>${data.message}`;
            } else {
                result.className = 'mt-2';
                result.innerHTML = `
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <span class="px-2 py-1 rounded" style="background:rgba(58,172,138,0.12);color:#3aac8a;font-size:.75rem;">
                            <i class="fas fa-plus-circle me-1"></i>New: <strong>${data.newRecords ?? 0}</strong>
                        </span>
                        <span class="px-2 py-1 rounded" style="background:rgba(102,178,178,0.15);color:#54ACBF;font-size:.75rem;">
                            <i class="fas fa-history me-1"></i>Already in DB: <strong>${data.dups ?? 0}</strong>
                        </span>
                        <span class="px-2 py-1 rounded" style="background:rgba(0,139,139,0.12);color:var(--forest-teal);font-size:.75rem;">
                            <i class="fas fa-file-download me-1"></i>Files: <strong>${data.filesDownloaded ?? 0}</strong>
                        </span>
                    </div>`;
            }
        } catch (e) {
            result.style.display = 'block';
            result.className = 'mt-2 text-danger';
            result.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>Request failed';
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-sync me-1"></i> Sync New Only';
    }

    // ── Month-wise Sync 2024–2026 ──────────────────────────────────
    function pauseSyncAll() {
        if (!syncAllSource) return;
        const cp = JSON.parse(localStorage.getItem(CKPT_KEY) || '{}');
        cp.reason = 'paused';
        saveCkpt(cp);
        syncAllCompleted = true;  // prevent onerror from overwriting reason
        syncAllSource.close();
        syncAllSource = null;
        document.getElementById('pauseAllBtn').style.display = 'none';
        const logDiv = document.getElementById('syncAllLog');
        const line = document.createElement('div');
        line.style.color = '#35577D'; line.style.fontWeight = '600';
        line.textContent = '⏸ Sync paused — use the Resume button above to continue.';
        logDiv.appendChild(line);
        document.getElementById('syncAllSpinner').classList.remove('fa-spin');
        document.getElementById('syncAllBtn').disabled = false;
        if (document.getElementById('syncAllBtn2')) document.getElementById('syncAllBtn2').disabled = false;
        document.getElementById('syncAllBtn').innerHTML = '<i class="fas fa-calendar-alt me-1"></i> Month-wise Sync 2024–2026';
        showResumeBanner(loadCkpt());
    }

    function startSyncAll(resumeState) {
        const btn      = document.getElementById('syncAllBtn');
        const btn2     = document.getElementById('syncAllBtn2');
        const panel    = document.getElementById('syncAllPanel');
        const logDiv   = document.getElementById('syncAllLog');
        const bar      = document.getElementById('syncAllProgress');
        const pctLbl   = document.getElementById('syncAllPct');
        const grandLbl = document.getElementById('syncAllGrandTotal');
        const spinner  = document.getElementById('syncAllSpinner');
        const curLbl   = document.getElementById('syncAllCurrent');

        // Collect options (or inherit from resume state)
        const selFacilities = resumeState?.facilityIds?.map(String) ?? Array.from(document.querySelectorAll('#syncAllFacilities option:checked')).map(o => o.value);
        const selTypes      = resumeState?.txTypes?.map(String)     ?? Array.from(document.querySelectorAll('.sync-txtype:checked')).map(c => c.value);

        const params = new URLSearchParams();
        selFacilities.forEach(f => params.append('facilityIds', f));
        selTypes.forEach(t => params.append('txTypes', t));
        if (resumeState?.facilityIdx) params.append('resumeFacilityIdx', resumeState.facilityIdx);
        if (resumeState?.monthIdx)    params.append('resumeMonthIdx',    resumeState.monthIdx);
        const qs = '?' + params.toString();

        btn.disabled = true;
        if (btn2) btn2.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Syncing…';
        panel.style.display = 'block';
        logDiv.innerHTML = '';
        bar.style.width = '0%';
        pctLbl.textContent = '0%';
        curLbl.textContent = '';
        document.getElementById('pauseAllBtn').style.display = 'inline-flex';
        panel.scrollIntoView({ behavior: 'smooth' });

        // Live tally counters (pre-seed from resume state)
        let ctrNew = resumeState?.totalSaved || 0, ctrDup = resumeState?.totalDups || 0, ctrFiles = resumeState?.totalFiles || 0;
        const ctrNewEl   = document.getElementById('syncAllCtrNew');
        const ctrDupEl   = document.getElementById('syncAllCtrDup');
        const ctrFilesEl = document.getElementById('syncAllCtrFiles');
        ctrNewEl.textContent = ctrNew.toLocaleString(); ctrDupEl.textContent = ctrDup.toLocaleString(); ctrFilesEl.textContent = ctrFiles.toLocaleString();
        function updateAllCtrs(n, d, f) { ctrNew += n; ctrDup += d; ctrFiles += f; ctrNewEl.textContent = ctrNew.toLocaleString(); ctrDupEl.textContent = ctrDup.toLocaleString(); ctrFilesEl.textContent = ctrFiles.toLocaleString(); }

        // Checkpoint state
        let ckpt = { type: 'all', facilityIdx: resumeState?.facilityIdx || 0, monthIdx: resumeState?.monthIdx || 0, facilityIds: selFacilities.map(Number), txTypes: selTypes.map(Number), totalSaved: ctrNew, totalDups: ctrDup, totalFiles: ctrFiles, lastFacilityName: '', lastMonth: '', reason: 'running' };
        saveCkpt(ckpt);

        syncAllCompleted = false;
        syncAllSource = new EventSource('/Portal/SyncAllFacilitiesStream' + qs);
        const source = syncAllSource;
        let syncCompleted = false;

        function addLog(msg, color, indent) {
            const line = document.createElement('div');
            line.style.color = color || '#333';
            if (indent) line.style.paddingLeft = '16px';
            line.textContent = msg;
            logDiv.appendChild(line);
            logDiv.scrollTop = logDiv.scrollHeight;
            return line;
        }

        function setProgress(pct) {
            bar.style.width = pct + '%';
            pctLbl.textContent = pct + '%';
        }

        source.onmessage = function(e) {
            const d = JSON.parse(e.data);

            if (d.status === 'start') {
                addLog(`▶ ${d.message}`, '#A7EBF2');

            } else if (d.status === 'resumed') {
                addLog(`⏩ Resuming — ${d.message || ''}`, '#35577D');

            } else if (d.status === 'facility_start') {
                lastFacilityEl = addLog(`\n◆ ${d.facilityName}`, '#011C40');
                curLbl.textContent = `Facility ${d.facilityIndex}: ${d.facilityName}`;
                ckpt.facilityIdx = d.facilityIndex || 0;
                ckpt.lastFacilityName = d.facilityName || '';
                ckpt.monthIdx = 0;
                saveCkpt(ckpt);

            } else if (d.status === 'month_done') {
                const found = d.found > 0 ? `+${d.found}` : '—';
                addLog(`${d.month}  ${found}`, d.found > 0 ? '#3aac8a' : '#35577D', true);
                setProgress(d.pct || 0);
                grandLbl.textContent = `Found: ${(d.grandTotal||0).toLocaleString()}`;
                ckpt.monthIdx = (d.monthIdx ?? 0) + 1;   // next month to resume from
                ckpt.lastMonth = d.month || '';
                saveCkpt(ckpt);

            } else if (d.status === 'processing') {
                grandLbl.textContent = `Saved: ${(d.saved||0).toLocaleString()} · Already in DB: ${(d.dups||0).toLocaleString()} · Files: ${(d.files||0).toLocaleString()}`;
                setProgress(d.pct || 0);

            } else if (d.status === 'facility_done') {
                updateAllCtrs(d.saved||0, d.dups||0, d.files||0);
                addLog(`  ✓ ${d.saved} new · ${d.dups} already in DB · ${d.files} files`, '#3aac8a', true);
                setProgress(d.pct || 0);
                ckpt.facilityIdx = (d.facilityFi ?? ckpt.facilityIdx ?? 0) + 1;
                ckpt.monthIdx = 0;
                ckpt.totalSaved = ctrNew; ckpt.totalDups = ctrDup; ckpt.totalFiles = ctrFiles;
                saveCkpt(ckpt);

            } else if (d.status === 'warning') {
                addLog(`⚠ ${d.message}`, '#54ACBF');

            } else if (d.status === 'error') {
                syncCompleted = true;
                addLog(`✗ ${d.message}`, '#dc3545');
                source.close();
                done();

            } else if (d.status === 'done') {
                syncCompleted = true;
                syncAllCompleted = true;
                setProgress(100);
                addLog('', '');
                addLog(`✅ ${d.message}`, '#3aac8a');
                grandLbl.textContent = `${(d.grandSaved||0).toLocaleString()} new · ${(d.grandDups||0).toLocaleString()} already in DB · ${(d.grandFiles||0).toLocaleString()} files`;
                curLbl.textContent = 'Complete';
                clearCkpt();
                source.close();
                done();
            }
        };

        source.onerror = function() {
            source.close();
            if (syncAllCompleted) return;   // clean close after done — not a real error
            const existCp = loadCkpt() || {};
            existCp.reason = 'disconnected';
            existCp.totalSaved = ctrNew; existCp.totalDups = ctrDup; existCp.totalFiles = ctrFiles;
            saveCkpt(existCp);
            addLog('⚠ Connection dropped — checkpoint saved. Use Resume to continue.', '#54ACBF');
            document.getElementById('pauseAllBtn').style.display = 'none';
            showResumeBanner(loadCkpt());
            done();
        };

        function done() {
            spinner.classList.remove('fa-spin');
            btn.disabled = false;
            if (btn2) btn2.disabled = false;
            btn.innerHTML = '<i class="fas fa-calendar-alt me-1"></i> Month-wise Sync 2024–2026';
            document.getElementById('pauseAllBtn').style.display = 'none';
        }
    }

    // ── Single-Facility Pause ──────────────────────────────────────
    function pauseSyncOne() {
        if (!syncOneSource) return;
        const cp = JSON.parse(localStorage.getItem(CKPT_KEY) || '{}');
        cp.reason = 'paused';
        saveCkpt(cp);
        syncOneCompleted = true;  // prevent onerror from overwriting reason
        syncOneSource.close();
        syncOneSource = null;
        document.getElementById('pauseOneBtn').style.display = 'none';
        const logDiv = document.getElementById('syncOneLog');
        const line = document.createElement('div');
        line.style.color = '#35577D'; line.style.fontWeight = '600';
        line.textContent = '⏸ Sync paused — use the Resume button above to continue.';
        logDiv.appendChild(line);
        document.getElementById('syncOneSpinner').classList.remove('fa-spin');
        document.getElementById('syncOneBtn').disabled = false;
        document.getElementById('syncOneBtn').innerHTML = '<i class="fas fa-calendar-alt me-1"></i> Month-wise';
        showResumeBanner(loadCkpt());
    }

    // ── Single-Facility 1-Year Sync ────────────────────────────────
    function startSyncOne(resumeState) {
        const facilityId = resumeState?.facilityId || document.getElementById('syncNewFacility').value;
        if (!facilityId) { alert('Please select a facility first.'); return; }

        const btn      = document.getElementById('syncOneBtn');
        const panel    = document.getElementById('syncOnePanel');
        const logDiv   = document.getElementById('syncOneLog');
        const bar      = document.getElementById('syncOneProgress');
        const pctLbl   = document.getElementById('syncOnePct');
        const grandLbl = document.getElementById('syncOneGrandTotal');
        const spinner  = document.getElementById('syncOneSpinner');
        const curLbl   = document.getElementById('syncOneCurrent');
        const title    = document.getElementById('syncOneTitle');

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Syncing…';
        panel.style.display = 'block';
        logDiv.innerHTML = '';
        bar.style.width  = '0%';
        pctLbl.textContent = '0%';
        grandLbl.textContent = '';
        curLbl.textContent   = '';
        title.textContent    = 'Loading…';
        document.getElementById('pauseOneBtn').style.display = 'inline-flex';
        panel.scrollIntoView({ behavior: 'smooth' });

        const fromInput = resumeState?.from || document.getElementById('facSyncFrom').value;
        const toInput   = resumeState?.to   || document.getElementById('facSyncTo').value;
        const defFrom = new Date(); defFrom.setFullYear(defFrom.getFullYear() - 1);
        const fromStr = fromInput || defFrom.toISOString().split('T')[0];
        const toStr   = toInput   || new Date().toISOString().split('T')[0];

        // Live tally counters for SyncOne (pre-seed from resume state)
        let oneCtrNew   = resumeState?.totalSaved  || 0;
        let oneCtrDup   = resumeState?.totalDups   || 0;
        let oneCtrFiles = resumeState?.totalFiles  || 0;
        const oneCtrNewEl   = document.getElementById('syncOneCtrNew');
        const oneCtrDupEl   = document.getElementById('syncOneCtrDup');
        const oneCtrFilesEl = document.getElementById('syncOneCtrFiles');
        oneCtrNewEl.textContent = oneCtrNew.toLocaleString();
        oneCtrDupEl.textContent = oneCtrDup.toLocaleString();
        oneCtrFilesEl.textContent = oneCtrFiles.toLocaleString();
        function updateOneCtrs(n, d, f) { oneCtrNew += n; oneCtrDup += d; oneCtrFiles += f; oneCtrNewEl.textContent = oneCtrNew.toLocaleString(); oneCtrDupEl.textContent = oneCtrDup.toLocaleString(); oneCtrFilesEl.textContent = oneCtrFiles.toLocaleString(); }

        // Build SSE URL with optional resume param
        const params = new URLSearchParams({ facilityId, from: fromStr, to: toStr });
        if (resumeState?.monthIdx) params.append('resumeMonthIdx', resumeState.monthIdx);
        const qs = '?' + params.toString();

        // Checkpoint state
        let oneCkpt = { type: 'one', facilityId, from: fromStr, to: toStr, monthIdx: resumeState?.monthIdx || 0, totalSaved: oneCtrNew, totalDups: oneCtrDup, totalFiles: oneCtrFiles, lastMonth: '', reason: 'running' };
        saveCkpt(oneCkpt);

        syncOneCompleted = false;
        syncOneSource = new EventSource('/Portal/SyncFacilityStream' + qs);
        const source = syncOneSource;
        let syncCompleted = false;

        function addLog(msg, color, indent) {
            const line = document.createElement('div');
            line.style.color = color || '#333';
            if (indent) line.style.paddingLeft = '16px';
            line.textContent = msg;
            logDiv.appendChild(line);
            logDiv.scrollTop = logDiv.scrollHeight;
        }

        source.onmessage = function(e) {
            const d = JSON.parse(e.data);

            if (d.status === 'start') {
                title.textContent = d.message;
                addLog(`▶ ${d.message}`, '#A7EBF2');

            } else if (d.status === 'resumed') {
                addLog(`⏩ Resuming — ${d.message || ''}`, '#35577D');

            } else if (d.status === 'facility_start') {
                addLog(`◆ ${d.facilityName}`, '#011C40');
                curLbl.textContent = d.facilityName;
                oneCkpt.lastFacilityName = d.facilityName || '';
                saveCkpt(oneCkpt);

            } else if (d.status === 'month_done') {
                const found = d.found > 0 ? `+${d.found}` : '—';
                addLog(`${d.month}  ${found}`, d.found > 0 ? '#3aac8a' : '#35577D', true);
                bar.style.width = (d.pct || 0) + '%';
                pctLbl.textContent = (d.pct || 0) + '%';
                grandLbl.textContent = `Found: ${(d.grandTotal||0).toLocaleString()}`;
                oneCkpt.monthIdx = (d.monthIdx ?? 0) + 1;  // next month to resume from
                oneCkpt.lastMonth = d.month || '';
                saveCkpt(oneCkpt);

            } else if (d.status === 'processing') {
                grandLbl.textContent = `Saved: ${(d.saved||0).toLocaleString()} · Already in DB: ${(d.dups||0).toLocaleString()} · Files: ${(d.files||0).toLocaleString()}`;
                bar.style.width = (d.pct || 0) + '%';
                pctLbl.textContent = (d.pct || 0) + '%';

            } else if (d.status === 'facility_done') {
                updateOneCtrs(d.saved||0, d.dups||0, d.files||0);
                addLog(`✓ ${d.saved} new · ${d.dups} already in DB · ${d.files} files`, '#3aac8a');
                bar.style.width = '100%'; pctLbl.textContent = '100%';
                oneCkpt.totalSaved = oneCtrNew; oneCkpt.totalDups = oneCtrDup; oneCkpt.totalFiles = oneCtrFiles;
                saveCkpt(oneCkpt);

            } else if (d.status === 'error') {
                syncCompleted = true;
                addLog(`✗ ${d.message}`, '#dc3545');
                source.close(); done();

            } else if (d.status === 'done') {
                syncCompleted = true;
                syncOneCompleted = true;
                bar.style.width = '100%'; pctLbl.textContent = '100%';
                addLog('', '');
                addLog(`✅ ${d.message}`, '#3aac8a');
                grandLbl.textContent = `${(d.grandSaved||0).toLocaleString()} new · ${(d.grandDups||0).toLocaleString()} already in DB · ${(d.grandFiles||0).toLocaleString()} files`;
                curLbl.textContent = 'Complete';
                clearCkpt();
                source.close(); done();
            }
        };

        source.onerror = function() {
            source.close();
            if (syncOneCompleted) return;   // clean close — not a real error
            const existCp = loadCkpt() || oneCkpt;
            existCp.reason = 'disconnected';
            existCp.totalSaved = oneCtrNew; existCp.totalDups = oneCtrDup; existCp.totalFiles = oneCtrFiles;
            saveCkpt(existCp);
            addLog('⚠ Connection dropped — checkpoint saved. Use Resume to continue.', '#54ACBF');
            document.getElementById('pauseOneBtn').style.display = 'none';
            showResumeBanner(loadCkpt());
            done();
        };

        function done() {
            spinner.classList.remove('fa-spin');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-calendar-alt me-1"></i> Month-wise';
            document.getElementById('pauseOneBtn').style.display = 'none';
        }
    }

    // ── Quick per-facility helpers (from overview table) ──────────
    function quickSyncFacility(facilityId, months) {
        document.getElementById('syncNewFacility').value = facilityId;
        const from = new Date(); from.setMonth(from.getMonth() - months);
        document.getElementById('facSyncFrom').value = from.toISOString().split('T')[0];
        document.getElementById('facSyncTo').value   = new Date().toISOString().split('T')[0];
        // Scroll to the left panel and trigger
        document.getElementById('syncNewFacility').scrollIntoView({ behavior: 'smooth' });
        setTimeout(() => startSyncOne(), 400);
    }
    function quickSyncNew(facilityId) {
        document.getElementById('syncNewFacility').value = facilityId;
        document.getElementById('syncNewFacility').scrollIntoView({ behavior: 'smooth' });
        setTimeout(() => syncNew(), 400);
    }

    // ── Download XML toggles ───────────────────────────────────────
    function dlToggle(btn) {
        const on = btn.getAttribute('data-on') !== 'true';
        btn.setAttribute('data-on', on);
        const type = btn.dataset.type;
        if (type === '2') {
            btn.style.background  = on ? 'rgba(0,139,139,0.12)' : 'transparent';
            btn.style.opacity     = on ? '1' : '0.35';
        } else {
            btn.style.background  = on ? 'var(--amber-light)' : 'transparent';
            btn.style.opacity     = on ? '1' : '0.35';
        }
    }
    // Initialise all toggles to "on"
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.dl-toggle').forEach(b => b.setAttribute('data-on', 'true'));
    });

    function dlXml(facilityId, btn) {
        const row   = btn.closest('tr');
        const types = Array.from(row.querySelectorAll('.dl-toggle'))
            .filter(b => b.getAttribute('data-on') === 'true')
            .map(b => b.dataset.type);
        if (!types.length) { alert('Enable at least one XML type (Claim or Remit) before downloading.'); return; }
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
        btn.disabled  = true;
        setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 4000);
        window.location.href = `/Portal/DownloadFacilityXml?facilityId=${facilityId}&types=${types.join(',')}`;
    }

    // ── Manual Fetch ───────────────────────────────────────────────
    const MF_OPS = {
        DHA: ['SearchTransactions','GetNewTransactions','GetNewPriorAuthorizations','DownloadTransactionFile'],
        RHA: ['GetClaims','GetRemittances','GetPriorAuthorizations']
    };
    let mfInited = false;
    function mfInit() {
        if (mfInited) return;
        mfInited = true;
        mfUpdateOps();
        const today = new Date().toISOString().split('T')[0];
        const from  = new Date(); from.setMonth(from.getMonth() - 1);
        document.getElementById('mfDateFrom').value = from.toISOString().split('T')[0];
        document.getElementById('mfDateTo').value   = today;
    }
    function mfUpdateOps() {
        const portal = document.querySelector('input[name="mfPortal"]:checked')?.value || 'DHA';
        const sel = document.getElementById('mfOperation');
        sel.innerHTML = '';
        (MF_OPS[portal] || []).forEach(op => {
            const o = document.createElement('option'); o.value = op; o.textContent = op; sel.appendChild(o);
        });
        mfUpdateFields();
    }
    function mfUpdateFields() {
        const op = document.getElementById('mfOperation')?.value || '';
        const isDl = op === 'DownloadTransactionFile';
        const isDate = !['GetNewTransactions','GetNewPriorAuthorizations'].includes(op);
        document.getElementById('mfDateSection').style.display  = (isDate && !isDl) ? '' : 'none';
        document.getElementById('mfDateSection2').style.display = (isDate && !isDl) ? '' : 'none';
        document.getElementById('mfFileIdSection').style.display= isDl ? '' : 'none';
    }
    async function mfFetch() {
        const facility = document.getElementById('mfFacility').value;
        if (!facility) { alert('Select a facility.'); return; }
        const portal  = document.querySelector('input[name="mfPortal"]:checked')?.value || 'DHA';
        const op      = document.getElementById('mfOperation').value;
        const from    = document.getElementById('mfDateFrom').value;
        const to      = document.getElementById('mfDateTo').value;
        const fileId  = document.getElementById('mfFileId')?.value || '';
        const token   = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        const statusEl = document.getElementById('mfStatus');
        const resultsEl= document.getElementById('mfResults');
        const tbody    = document.getElementById('mfTableBody');

        statusEl.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Fetching…';
        resultsEl.style.display = 'block';
        tbody.innerHTML = '';

        try {
            const body = new URLSearchParams({ portal, facilityId: facility, operation: op, dateFrom: from, dateTo: to, fileId, __RequestVerificationToken: token });
            const resp = await fetch('/Portal/FetchAjax', { method: 'POST', body });
            const data = await resp.json();

            if (!data.ok) {
                statusEl.innerHTML = `<span class="text-danger"><i class="fas fa-exclamation-circle me-1"></i>${data.message}</span>`;
                return;
            }
            statusEl.innerHTML = `<span class="text-success"><i class="fas fa-check-circle me-1"></i>${data.message}</span>`;
            (data.rows || []).forEach(r => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td class="ps-3 fw-semibold" style="color:var(--navy);font-size:.75rem;">${r.fileId || '—'}</td>
                    <td><span class="badge badge-navy" style="font-size:.65rem;">${r.type||'—'}</span></td>
                    <td><span class="badge badge-success" style="font-size:.65rem;">${r.status||'—'}</span></td>
                    <td class="text-muted">${r.payer||'—'}</td>
                    <td class="text-muted">${r.amount||'—'}</td>
                    <td class="text-muted">${r.date||'—'}</td>
                    <td class="pe-3"><small class="text-muted">${r.fileName||''}</small></td>`;
                tbody.appendChild(tr);
            });
            if (!data.rows?.length) tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3">No results</td></tr>';
        } catch (e) {
            statusEl.innerHTML = `<span class="text-danger"><i class="fas fa-exclamation-circle me-1"></i>Request failed</span>`;
        }
    }
</script>
}
