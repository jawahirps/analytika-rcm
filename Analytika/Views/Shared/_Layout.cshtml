<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ghaf Business Intelligence</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar navbar-expand-lg analytika-navbar">
    <div class="container-fluid px-3">
        @{
            var canAccessRcm = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst) || User.IsInRole(AppRoles.Billing) || User.IsInRole(AppRoles.Finance) || User.IsInRole(AppRoles.Auditor);
            var canAccessResubmission = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst);
            var canAccessAdmin = User.IsInRole(AppRoles.Admin);
            var brandAction = canAccessRcm ? "RCMDashboard" : "Dashboard";
        }

        <!-- Brand -->
        <a class="analytika-brand navbar-brand me-0" asp-controller="Home" asp-action="@brandAction">
            <svg class="brand-icon-sm" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Ghaf tree + data: branching canopy of data nodes over a trunk -->
                <path d="M22 21 C22 14 17 10 11 10" stroke="#26658C" stroke-width="2.2" stroke-linecap="round"/>
                <path d="M22 21 C22 12 28 8 34 10" stroke="#54ACBF" stroke-width="2.2" stroke-linecap="round"/>
                <path d="M22 21 C22 16 18 14 14 15" stroke="#54ACBF" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M22 21 C22 15 26 13 30 15" stroke="#A7EBF2" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M22 21 V7" stroke="#011C40" stroke-width="2" stroke-linecap="round"/>
                <circle cx="22" cy="7"  r="2.3" fill="#011C40"/>
                <circle cx="11" cy="10" r="2"   fill="#26658C"/>
                <circle cx="34" cy="10" r="2"   fill="#54ACBF"/>
                <circle cx="14" cy="15" r="1.5" fill="#54ACBF"/>
                <circle cx="30" cy="15" r="1.5" fill="#A7EBF2"/>
                <path d="M22 21 V36" stroke="#011C40" stroke-width="2.6" stroke-linecap="round"/>
                <path d="M15 38 H29" stroke="#26658C" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <div class="brand-name-wrap">
                <span class="brand-text">Ghaf Bi</span>
                <span class="brand-sub">Business Intelligence</span>
            </div>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <!-- Left nav -->
            <ul class="navbar-nav me-auto mb-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Dashboard" or "RCMDashboard" ? "active" : "")"
                       asp-controller="Home" asp-action="Dashboard">
                        <i class="fas fa-signal nav-ico" style="font-size:.75rem;"></i><span class="nav-label">Dashboard</span>
                    </a>
                </li>
                @if (canAccessRcm)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RCMDashboard" ? "active" : "")"
                           asp-controller="Home" asp-action="RCMDashboard"><i class="fas fa-chart-column nav-ico"></i><span class="nav-label">BI Reports</span></a>
                    </li>
                }
                @if (canAccessRcm)
                {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"><i class="fas fa-folder-tree nav-ico"></i><span class="nav-label">Advanced Reports</span></a>
                    <ul class="dropdown-menu">
                        <li class="dropdown-submenu">
                            <a class="dropdown-item dropdown-toggle" href="#">Claim Processing</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimSummaryReport">Claim Summary</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimActivityReports">Claim Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="RemittanceActivityReport">Remittance Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimReceiverReport">Claim Receiver</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimClinicianReport">Claim Clinician</a></li>
                                <li><a class="dropdown-item" asp-controller="AdvancedReports" asp-action="SubmissionXMLFileReport">Submission XML File</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="FinanceTATReport">Finance TAT</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="DenialReport">Denial Query</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimLifeCycleReport">Claim Life Cycle</a></li>
                            </ul>
                        </li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Portal" ? "active" : "")"
                       href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-cloud-download-alt nav-ico" style="font-size:.78rem;"></i><span class="nav-label">Portal</span>
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="Sync">
                            <i class="fas fa-sync me-2 text-muted"></i>Sync &amp; Fetch
                        </a></li>
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="SyncedData">
                            <i class="fas fa-database me-2 text-muted"></i>Synced Data
                        </a></li>
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="XmlParsing">
                            <i class="fas fa-file-code me-2 text-muted"></i>XML Parsing
                        </a></li>
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="DataValidation">
                            <i class="fas fa-clipboard-check me-2 text-muted"></i>Data Validation
                        </a></li>
                    </ul>
                </li>
                }
                @if (canAccessAdmin)
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-shield-alt nav-ico" style="font-size:.8rem;"></i><span class="nav-label">Admin</span>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                <i class="fas fa-users me-2 text-muted"></i>User Management
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Roles">
                                <i class="fas fa-user-shield me-2 text-muted"></i>User Roles
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Credentials">
                                <i class="fas fa-key me-2 text-muted"></i>Portal Credentials
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="CodingSets">
                                <i class="fas fa-table me-2 text-muted"></i>DHPO Coding Sets
                            </a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="EmailSettings">
                                <i class="fas fa-envelope me-2 text-muted"></i>Email Settings
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="ReportSchedules">
                                <i class="fas fa-calendar-alt me-2 text-muted"></i>Report Schedules
                            </a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Database">
                                <i class="fas fa-database me-2 text-muted"></i>Database Migration
                            </a></li>
                        </ul>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" href="#Support"><i class="fas fa-headset nav-ico"></i><span class="nav-label" data-i18n="support">Support</span></a>
                </li>
            </ul>

            <!-- Right side -->
            <ul class="navbar-nav ms-auto align-items-center mb-0">
                <li class="nav-item d-flex align-items-center gap-2 me-2 lang-theme-tools">
                    <div class="btn-group btn-group-sm lang-toggle-group" role="group" aria-label="Language toggle">
                        <button type="button" class="btn btn-outline-secondary lang-toggle-btn active" data-lang="en" id="langToggleEn">EN</button>
                        <button type="button" class="btn btn-outline-secondary lang-toggle-btn" data-lang="ar" id="langToggleAr">AR</button>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm theme-toggle-btn" id="themeToggleBtn">
                        <i class="fas fa-moon me-1"></i><span id="themeToggleLabel">Dark</span>
                    </button>
                </li>
                <!-- Bell -->
                <li class="nav-item dropdown">
                    <button class="bell-btn position-relative" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <i class="fas fa-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge" id="bellBadge">3</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-0 shadow notification-menu">
                        <div class="d-flex align-items-center justify-content-between px-3 py-2 notification-menu-header">
                            <span class="fw-semibold text-white" style="font-size:.85rem;" data-i18n="notifications">Notifications</span>
                            <button class="btn btn-link btn-sm text-white p-0" style="font-size:.72rem;text-decoration:none;" onclick="clearNotifications()" data-i18n="mark_all_read">Mark all read</button>
                        </div>
                        <div id="notificationList">
                            <a class="notification-item d-flex gap-2 px-3 py-2 border-bottom" href="/Portal/Sync">
                                <div class="notif-icon flex-shrink-0 notification-icon-muted">
                                    <i class="fas fa-file-download"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">New transactions available</div>
                                    <div class="text-muted">DHA portal has undownloaded files</div>
                                    <div class="text-muted" style="font-size:.7rem;">Just now</div>
                                </div>
                            </a>
                            <a class="notification-item d-flex gap-2 px-3 py-2 border-bottom" href="/Portal/XmlParsing">
                                <div class="notif-icon flex-shrink-0 notification-icon-accent">
                                    <i class="fas fa-file-code"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">XML Parsing summary</div>
                                    <div class="text-muted">Some claims have no remittance match</div>
                                    <div class="text-muted" style="font-size:.7rem;">Today</div>
                                </div>
                            </a>
                            <a class="notification-item d-flex gap-2 px-3 py-2" href="/Portal/Sync">
                                <div class="notif-icon flex-shrink-0 notification-icon-primary">
                                    <i class="fas fa-sync"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">Daily sync complete</div>
                                    <div class="text-muted">Last cron run finished successfully</div>
                                    <div class="text-muted" style="font-size:.7rem;">2 hours ago</div>
                                </div>
                            </a>
                        </div>
                        <div class="text-center py-2 notification-menu-footer">
                            <a href="/Portal/Sync" class="notification-footer-link" data-i18n="view_all_activity">View all activity</a>
                        </div>
                    </div>
                </li>

                <!-- Profile -->
                <li class="nav-item dropdown">
                    <a class="nav-link profile-btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <div class="profile-avatar-circle">
                            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                        </div>
                        <span class="d-none d-lg-inline text-truncate" style="max-width:120px;">
                            @User.Identity?.Name?.Split('@')[0]
                        </span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2 text-muted"></i><span data-i18n="profile">Profile</span></a></li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-controller="Home" asp-action="LogOut" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt me-2"></i><span data-i18n="sign_out">Sign Out</span>
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mt-3 mb-0" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3 mb-0" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
function clearNotifications() {
    document.getElementById('notificationList').innerHTML =
        '<div class="text-center text-muted py-4" style="font-size:.8rem;"><i class="fas fa-check-circle me-1 text-primary"></i><span data-i18n="all_caught_up">All caught up!</span></div>';
    const badge = document.getElementById('bellBadge');
    if (badge) badge.style.display = 'none';
}

(function initThemeLanguageControls() {
    const root = document.documentElement;
    const langButtons = {
        en: document.getElementById('langToggleEn'),
        ar: document.getElementById('langToggleAr')
    };
    const themeButton = document.getElementById('themeToggleBtn');

    const dict = {
        en: {
            support: 'Support',
            notifications: 'Notifications',
            mark_all_read: 'Mark all read',
            view_all_activity: 'View all activity',
            profile: 'Profile',
            sign_out: 'Sign Out',
            theme: 'Dark',
            all_caught_up: 'All caught up!'
        },
        ar: {
            support: 'الدعم',
            notifications: 'الإشعارات',
            mark_all_read: 'تعليم الكل كمقروء',
            view_all_activity: 'عرض كل النشاط',
            profile: 'الملف الشخصي',
            sign_out: 'تسجيل الخروج',
            theme: 'داكن',
            all_caught_up: 'تمت المزامنة!'
        }
    };

    function applyLanguage(lang) {
        root.lang = lang;
        root.dir = lang === 'ar' ? 'rtl' : 'ltr';
        root.dataset.lang = lang;
        try { localStorage.setItem('analytika-lang', lang); } catch (_) {}

        document.querySelectorAll('[data-i18n]').forEach(function (node) {
            var key = node.getAttribute('data-i18n');
            if (dict[lang] && dict[lang][key]) {
                node.textContent = dict[lang][key];
            }
        });

        Object.keys(langButtons).forEach(function (key) {
            var btn = langButtons[key];
            if (!btn) return;
            btn.classList.toggle('active', key === lang);
            btn.setAttribute('aria-pressed', key === lang ? 'true' : 'false');
        });
    }

    function applyTheme(theme) {
        root.dataset.theme = theme;
        try { localStorage.setItem('analytika-theme', theme); } catch (_) {}
        if (themeButton) {
            var icon = themeButton.querySelector('i');
            var label = document.getElementById('themeToggleLabel');
            if (icon) {
                icon.className = theme === 'dark' ? 'fas fa-sun me-1' : 'fas fa-moon me-1';
            }
            if (label) {
                var lang = root.dataset.lang || 'en';
                var labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                label.textContent = (labels[lang] || labels.en)[theme === 'dark' ? 'light' : 'dark'];
            }
            themeButton.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
        }
    }

    const currentLang = root.dataset.lang || (function () { try { return localStorage.getItem('analytika-lang'); } catch (_) { return null; } })() || 'en';
    const currentTheme = root.dataset.theme || (function () { try { return localStorage.getItem('analytika-theme'); } catch (_) { return null; } })() || 'light';

    applyLanguage(currentLang);
    applyTheme(currentTheme);

    Object.keys(langButtons).forEach(function (key) {
        var btn = langButtons[key];
        if (!btn) return;
        btn.addEventListener('click', function () {
            applyLanguage(key);
        });
    });

    if (themeButton) {
        themeButton.addEventListener('click', function () {
            var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            applyTheme(next);
        });
    }
})();
</script>
</body>
</html>
