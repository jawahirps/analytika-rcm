<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ghaf Business Intelligence</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --shell-bg: linear-gradient(145deg, #051F20 0%, #141E30 55%, #023859 100%);
            --shell-panel: rgba(11,43,38,.84);
            --shell-panel-2: rgba(20,30,48,.88);
            --shell-line: rgba(84,172,191,.22);
            --shell-text: #DAF1DE;
            --shell-muted: #8EB69B;
            --shell-accent: #54ACBF;
            --shell-accent-2: #26658C;
            --shell-glow: 0 18px 42px rgba(1,28,64,.32);
        }

        body {
            background: var(--shell-bg) !important;
            color: var(--shell-text);
        }

        .analytika-navbar {
            position: sticky;
            top: 0;
            z-index: 1030;
            margin: 0;
            padding: .9rem 0;
            background: rgba(11,43,38,.82) !important;
            border-bottom: 1px solid var(--shell-line);
            backdrop-filter: blur(18px) saturate(160%);
            -webkit-backdrop-filter: blur(18px) saturate(160%);
            box-shadow: 0 12px 32px rgba(1,28,64,.18);
        }
        .analytika-navbar .container-fluid {
            max-width: 1600px;
            gap: .75rem;
        }
        .analytika-brand {
            background: linear-gradient(180deg, rgba(20,30,48,.92), rgba(11,43,38,.94)) !important;
            border: 1px solid var(--shell-line) !important;
            border-radius: 18px !important;
            padding: .75rem .9rem !important;
            box-shadow: var(--shell-glow);
        }
        .brand-text,
        .brand-sub {
            color: var(--shell-text) !important;
        }
        .brand-sub {
            opacity: .78;
            letter-spacing: .06em;
        }
        .analytika-navbar .nav-link,
        .analytika-navbar .profile-btn,
        .analytika-navbar .bell-btn,
        .analytika-navbar .theme-toggle-btn,
        .analytika-navbar .lang-toggle-btn {
            color: var(--shell-text) !important;
        }
        .analytika-navbar .nav-link {
            border-radius: 12px;
            padding: .7rem .95rem !important;
        }
        .analytika-navbar .nav-link.active,
        .analytika-navbar .nav-link:hover {
            background: rgba(84,172,191,.12);
            color: #A7EBF2 !important;
        }
        .analytika-navbar .dropdown-menu {
            background: rgba(11,43,38,.96);
            border: 1px solid var(--shell-line);
            box-shadow: var(--shell-glow);
            border-radius: 16px;
            color: var(--shell-text);
        }
        .analytika-navbar .dropdown-item {
            color: var(--shell-text);
            border-radius: 10px;
            margin: 2px 6px;
        }
        .analytika-navbar .dropdown-item:hover {
            background: rgba(84,172,191,.12);
            color: #A7EBF2;
        }
        .analytika-navbar .navbar-toggler {
            border-color: var(--shell-line);
            background: rgba(20,30,48,.92);
        }
        .analytika-navbar .navbar-toggler-icon {
            filter: invert(1) brightness(1.2);
        }
        .theme-toggle-btn,
        .lang-toggle-btn {
            background: rgba(20,30,48,.92) !important;
            border-color: var(--shell-line) !important;
        }
        .lang-toggle-btn.active {
            background: rgba(84,172,191,.16) !important;
            color: #A7EBF2 !important;
        }
        .bell-btn,
        .profile-btn {
            background: rgba(20,30,48,.92) !important;
            border-color: var(--shell-line) !important;
        }
        main {
            position: relative;
        }
        main::before {
            content: "";
            position: fixed;
            inset: 72px 0 0 0;
            pointer-events: none;
            background:
                linear-gradient(90deg, rgba(84,172,191,.04) 1px, transparent 1px),
                linear-gradient(180deg, rgba(84,172,191,.04) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: linear-gradient(180deg, rgba(0,0,0,.7), transparent 92%);
            z-index: 0;
        }
        @@media (max-width: 991px) {
            .analytika-brand {
                padding: .65rem .8rem !important;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar navbar-expand-lg analytika-navbar">
    <div class="container-fluid px-3">
        @{
            var canAccessRcm = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst) || User.IsInRole(AppRoles.Billing) || User.IsInRole(AppRoles.Finance) || User.IsInRole(AppRoles.Auditor);
            var canAccessResubmission = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst);
            var canAccessAdmin = User.IsInRole(AppRoles.Admin);
            var brandAction = canAccessRcm ? "RCMDashboard" : "Dashboard";
        }

        <!-- Brand -->
        <a class="analytika-brand navbar-brand me-0" asp-controller="Home" asp-action="@brandAction">
            <svg class="brand-icon-sm" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="22" cy="22" r="20" stroke="#54ACBF" stroke-width="2.5"/>
                <rect x="10"   y="29" width="5" height="8"  rx="1" fill="#051F20"/>
                <rect x="16.5" y="24" width="5" height="13" rx="1" fill="#26658C"/>
                <rect x="23"   y="19" width="5" height="18" rx="1" fill="#54ACBF"/>
                <rect x="29.5" y="14" width="4" height="23" rx="1" fill="#8EB69B"/>
                <polyline points="12.5,27 19,21 25.5,16 32,10" stroke="#051F20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polygon points="35,7 31,9 33.5,13" fill="#051F20"/>
            </svg>
            <div class="brand-name-wrap">
                <span class="brand-text">Ghaf Bi</span>
