                            <i class="fas fa-shield-alt me-1" style="font-size:.8rem;"></i>Admin
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                <i class="fas fa-users me-2 text-muted"></i>User Management
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Roles">
                                <i class="fas fa-user-shield me-2 text-muted"></i>User Roles
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Credentials">
                                <i class="fas fa-key me-2 text-muted"></i>Portal Credentials
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="CodingSets">
                                <i class="fas fa-table me-2 text-muted"></i>DHPO Coding Sets
                            </a></li>
