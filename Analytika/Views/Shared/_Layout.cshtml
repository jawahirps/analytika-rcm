<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ghaf Business Intelligence</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        :root {
            color-scheme: light;
            --ops-bg: #eef7fc;
            --ops-bg-2: #f7fbfe;
            --ops-surface: rgba(255, 255, 255, .92);
            --ops-surface-soft: rgba(244, 250, 254, .86);
            --ops-surface-strong: #ffffff;
            --ops-ink: #10233f;
            --ops-ink-2: #24415f;
            --ops-muted: #6d8196;
            --ops-line: rgba(177, 208, 231, .76);
            --ops-line-strong: rgba(127, 174, 211, .52);
            --ops-primary: #2478ff;
            --ops-primary-2: #63b7ff;
            --ops-cyan: #37c7dc;
            --ops-mint: #55d7b7;
            --ops-success: #078766;
            --ops-warning: #b87516;
            --ops-danger: #d93f55;
            --ops-radius: 16px;
            --ops-radius-sm: 10px;
            --ops-shadow: 0 18px 44px rgba(22, 75, 128, .10), 0 6px 18px rgba(16, 35, 63, .06);
            --ops-shadow-soft: 0 10px 28px rgba(36, 120, 255, .08);
            --ops-focus: 0 0 0 .2rem rgba(36, 120, 255, .15);
            --ops-wall:
                radial-gradient(circle at 12% 7%, rgba(99, 183, 255, .28), transparent 30%),
                radial-gradient(circle at 86% 10%, rgba(55, 199, 220, .16), transparent 32%),
                linear-gradient(180deg, var(--ops-bg) 0%, var(--ops-bg-2) 48%, #f4f9fd 100%);
        }

        [data-theme="dark"] {
            color-scheme: dark;
            --ops-bg: #0e2034;
            --ops-bg-2: #122940;
            --ops-surface: rgba(18, 41, 64, .92);
            --ops-surface-soft: rgba(27, 57, 84, .88);
            --ops-surface-strong: #162f49;
            --ops-ink: #eef8ff;
            --ops-ink-2: #cbe2f5;
            --ops-muted: #9fb7ca;
            --ops-line: rgba(125, 177, 214, .28);
            --ops-line-strong: rgba(125, 177, 214, .42);
            --ops-shadow: 0 20px 46px rgba(0, 0, 0, .22);
            --ops-shadow-soft: 0 12px 30px rgba(0, 0, 0, .18);
            --ops-wall:
                radial-gradient(circle at 12% 7%, rgba(36, 120, 255, .22), transparent 30%),
                radial-gradient(circle at 86% 10%, rgba(55, 199, 220, .13), transparent 32%),
                linear-gradient(180deg, #0b1b2d 0%, #11253a 56%, #0e2034 100%);
        }

        html,
        body {
            min-height: 100%;
            background: var(--ops-wall) !important;
            background-attachment: fixed !important;
            color: var(--ops-ink) !important;
            font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif !important;
            font-size: 14px;
        }

        body { overflow-x: hidden; }
        main,
        .dash-section,
        .bi-shell,
        .bi-layout,
        .bi-content,
        .xp-page,
        .rsb-page,
        .portal-page,
        .xml-page {
            background: transparent !important;
            color: var(--ops-ink) !important;
        }
        main { position: relative; isolation: isolate; }
        main::before {
            content: "";
            position: fixed;
            inset: 72px 0 0;
            pointer-events: none;
            z-index: -1;
            opacity: .7;
            background:
                linear-gradient(90deg, rgba(36, 120, 255, .035) 1px, transparent 1px),
                linear-gradient(180deg, rgba(36, 120, 255, .035) 1px, transparent 1px);
            background-size: 42px 42px;
            mask-image: linear-gradient(180deg, rgba(0,0,0,.68), transparent 92%);
        }

        .analytika-navbar {
            position: sticky;
            top: 0;
            z-index: 1030;
            margin: 0;
            padding: .7rem 0;
            background: rgba(255,255,255,.82) !important;
            border-bottom: 1px solid var(--ops-line) !important;
            box-shadow: var(--ops-shadow-soft) !important;
            backdrop-filter: blur(20px) saturate(160%);
            -webkit-backdrop-filter: blur(20px) saturate(160%);
        }
        [data-theme="dark"] .analytika-navbar { background: rgba(15, 32, 52, .86) !important; }
        .analytika-navbar .container-fluid { max-width: 1640px; gap: .6rem; }
        .analytika-brand {
            background: var(--ops-surface) !important;
            border: 1px solid var(--ops-line) !important;
            border-radius: 14px !important;
            padding: .62rem .78rem !important;
            box-shadow: var(--ops-shadow-soft) !important;
            gap: .62rem;
        }
        .brand-icon-sm { width: 38px; height: 38px; flex: 0 0 auto; }
        .brand-icon-sm circle { stroke: var(--ops-primary) !important; }
        .brand-icon-sm rect:nth-of-type(1), .brand-icon-sm polygon { fill: var(--ops-ink) !important; }
        .brand-icon-sm rect:nth-of-type(2), .brand-icon-sm polyline { fill: var(--ops-primary) !important; stroke: var(--ops-primary) !important; }
        .brand-icon-sm rect:nth-of-type(3) { fill: var(--ops-primary-2) !important; }
        .brand-icon-sm rect:nth-of-type(4) { fill: var(--ops-mint) !important; }
        .brand-text { color: var(--ops-ink) !important; font-weight: 800; letter-spacing: -.01em; line-height: 1; }
        .brand-sub { color: var(--ops-muted) !important; font-size: .72rem; font-weight: 800; letter-spacing: .055em; text-transform: uppercase; }

        .analytika-navbar .nav-link,
        .analytika-navbar .dropdown-item,
        .profile-btn,
        .bell-btn,
        .theme-toggle-btn,
        .lang-toggle-btn {
            color: var(--ops-ink-2) !important;
        }
        .analytika-navbar .nav-link {
            border-radius: 999px;
            padding: .58rem .82rem !important;
            font-size: .86rem;
            font-weight: 750;
            border: 1px solid transparent;
        }
        .analytika-navbar .nav-link.active,
        .analytika-navbar .nav-link:hover,
        .lang-toggle-btn.active {
            background: var(--ops-surface-strong) !important;
            border-color: var(--ops-line) !important;
            color: var(--ops-primary) !important;
            box-shadow: 0 8px 18px rgba(36, 120, 255, .10) !important;
        }
        .dropdown-menu {
            background: var(--ops-surface-strong) !important;
            border: 1px solid var(--ops-line) !important;
            border-radius: 14px !important;
            box-shadow: var(--ops-shadow) !important;
            padding: .45rem !important;
        }
        .analytika-navbar .dropdown-item { border-radius: 10px; margin: 1px 0; font-weight: 650; }
        .analytika-navbar .dropdown-item:hover { background: var(--ops-surface-soft) !important; color: var(--ops-primary) !important; }
        .navbar-toggler,
        .bell-btn,
        .profile-btn,
        .theme-toggle-btn,
        .lang-toggle-btn {
            background: var(--ops-surface) !important;
            border: 1px solid var(--ops-line) !important;
            border-radius: 999px !important;
            box-shadow: none !important;
        }
        .navbar-toggler { min-width: 48px; min-height: 48px; border-radius: 14px !important; }
        .profile-avatar-circle { background: linear-gradient(135deg, var(--ops-primary), var(--ops-cyan)) !important; color: #fff !important; }

        .card,
        .panel,
        .dashboard-hero,
        .metric-card,
        .dd-card,
        .filter-card,
        .table-card,
        .info-card,
        .stat-card,
        .filter-bar,
        .cs-card,
        .rsb-card,
        .wl-card,
        .detail-card,
        .xp-shell,
        .xp-stat,
        .xp-progress,
        .upload-zone,
        .list-group-item,
        .modal-content,
        .toast,
        .alert,
        .ss-card,
        .fac-status-card,
        .summary-card,
        .sync-card,
        .sync-panel,
        .portal-card,
        .bi-tabs,
        .bi-filter-card,
        .bi-header,
        .bi-content > section,
        .bi-shell .panel,
        .bi-filter-agent-drawer,
        .bi-date-form,
        .bi-agent-card,
        .bi-chat-card,
        .flatpickr-calendar,
        .select2-dropdown {
            background: var(--ops-surface) !important;
            border: 1px solid var(--ops-line) !important;
            border-radius: var(--ops-radius) !important;
            box-shadow: var(--ops-shadow) !important;
            color: var(--ops-ink) !important;
        }
        .dashboard-hero,
        .bi-header,
        .xp-toolbar,
        .metric-card,
        .ss-card {
            background: linear-gradient(180deg, var(--ops-surface-strong), var(--ops-surface-soft)) !important;
        }
        .bi-shell::before,
        .bi-shell::after,
        .dash-section::before,
        .dash-section::after {
            opacity: .22 !important;
            pointer-events: none !important;
        }

        h1, h2, h3, h4, h5, h6,
        .page-title,
        .panel-title,
        .metric-title,
        .metric-value,
        .metric-card h3,
        .metric-card strong,
        .bi-title,
        .bi-shell .metric-value,
        .dashboard-hero h1,
        .dashboard-hero h2,
        .fac-name,
        .xp-title h4,
        .xp-stat .num,
        .xp-table .facility,
        .table,
        .data-table,
        .search-results {
            color: var(--ops-ink) !important;
        }
        .page-subtitle,
        .text-muted,
        .small,
        small,
        .form-text,
        .bi-desc,
        .summary,
        .breakdown-detail,
        .insight-detail,
        .trend-label,
        .metric-caption,
        .metric-subtitle,
        .dashboard-hero p,
        .fac-meta,
        .table td,
        .data-table td,
        .search-results td,
        .xp-table td,
        .xp-stat .lbl,
        .xp-empty {
            color: var(--ops-muted) !important;
        }

        .btn-primary,
        .btn-success,
        .btn-emerald,
        .btn-teal,
        .btn-submit-report,
        .btn-download,
        .btn-login,
        .bi-filter-submit,
        .bi-date-submit,
        .bi-filter-agent-run,
        .bi-ai-launcher,
        .bi-ai-pet,
        .page-item.active .page-link,
        button[type="submit"]:not(.btn-link):not(.dropdown-item) {
            background: linear-gradient(180deg, var(--ops-primary-2), var(--ops-primary)) !important;
            border: 1px solid rgba(36,120,255,.34) !important;
            color: #fff !important;
            border-radius: 999px !important;
            box-shadow: 0 12px 24px rgba(36, 120, 255, .22) !important;
            font-weight: 800 !important;
        }
        .btn-outline-secondary,
        .btn-light,
        .btn-secondary,
        .btn-outline-primary,
        .btn-outline-dark,
        .btn-outline-success,
        .btn-ghost,
        .bi-tabs-toggle,
        .bi-filter-reset,
        .bi-date-reset,
        .bi-chat-icon,
        .xp-btn-icon,
        .form-control,
        .form-select,
        .input-group-text,
        .select2-container--default .select2-selection--single,
        .select2-container--default .select2-selection--multiple,
        .bi-date-input,
        .bi-filter-field select,
        .bi-filter-agent-input,
        input,
        select,
        textarea {
            background: var(--ops-surface-strong) !important;
            border: 1px solid var(--ops-line) !important;
            border-radius: var(--ops-radius-sm) !important;
            color: var(--ops-ink) !important;
            box-shadow: none !important;
        }
        .btn-outline-primary,
        .btn-outline-success,
        .btn-outline-dark,
        .btn-outline-secondary,
        .btn-ghost { color: var(--ops-primary) !important; }
        .form-control:focus,
        .form-select:focus,
        .bi-date-input:focus,
        .bi-filter-field select:focus,
        .bi-filter-agent-input:focus {
            border-color: var(--ops-primary) !important;
            box-shadow: var(--ops-focus) !important;
        }

        .bi-tab,
        .nav-pills .nav-link,
        .filter-tabs .nav-link {
            border-radius: 999px !important;
            color: var(--ops-ink-2) !important;
            font-weight: 800 !important;
            border: 1px solid transparent !important;
        }
        .bi-tab.active,
        .bi-tab:hover,
        .nav-pills .nav-link.active,
        .filter-tabs .nav-link.active {
            background: var(--ops-surface-strong) !important;
            border-color: var(--ops-line) !important;
            color: var(--ops-primary) !important;
        }

        .table,
        .data-table,
        .search-results,
        .xp-table {
            --bs-table-bg: transparent !important;
            --bs-table-striped-bg: rgba(232,245,255,.56) !important;
            --bs-table-hover-bg: rgba(36,120,255,.07) !important;
            border-color: var(--ops-line) !important;
        }
        .table thead th,
        .data-table thead th,
        .search-results th,
        .table-card thead th,
        .xp-table thead th {
            background: #eaf6ff !important;
            color: var(--ops-ink-2) !important;
            border-color: var(--ops-line) !important;
            font-weight: 900 !important;
            letter-spacing: .025em !important;
        }
        .table-responsive { overflow-x: auto; }
        .table-card,
        .sync-table,
        .xml-table,
        .search-results,
        .data-table {
            overflow-x: auto !important;
        }

        .badge,
        .status-badge,
        .metric-delta,
        .insight-badge,
        .fac-portal,
        .status-pill,
        .xp-badge,
        .pct-badge,
        .overdue-badge {
            border-radius: 999px !important;
            border: 1px solid rgba(255,255,255,.58) !important;
            background: #eaf6ff !important;
            color: var(--ops-primary) !important;
            font-weight: 800 !important;
        }
        .text-success, .status-connected, .connected, .badge-success, .xp-badge.ready, .xp-badge.sub { color: var(--ops-success) !important; }
        .text-danger, .status-disconnected, .disconnected, .badge-danger { color: var(--ops-danger) !important; }
        .text-warning, .status-degraded, .degraded, .badge-warning, .xp-badge.pending { color: var(--ops-warning) !important; }
        .progress, .xp-progress-track, .breakdown-track, .bar-bg { background: rgba(177, 208, 231, .42) !important; border-radius: 999px !important; }
        .progress-bar, .xp-progress-fill, .breakdown-fill, .metric-progress, .fac-progress-fill, .bar-fill { background: linear-gradient(90deg, var(--ops-primary), var(--ops-primary-2), var(--ops-mint)) !important; }
        .metric-card i, .ss-icon, .notif-icon, .xp-title i, .fac-status-card .status-dot, .bi-shell .metric-icon, .bi-shell article i { color: var(--ops-primary) !important; }
        .metric-card,
        .bi-shell .metric-card {
            min-height: 176px !important;
            display: flex !important;
            flex-direction: column !important;
            justify-content: space-between !important;
        }
        .metric-grid,
        .bi-shell .metric-grid {
            align-items: stretch !important;
        }

        [style*="background:#051F20"], [style*="background: #051F20"],
        [style*="background:#0B2B26"], [style*="background: #0B2B26"],
        [style*="background:#011C40"], [style*="background: #011C40"],
        [style*="background:#070e22"], [style*="background: #070e22"],
        [style*="background:var(--navy)"], [style*="background: var(--navy)"] {
            background: var(--ops-primary) !important;
            color: #fff !important;
        }

        .global-ai-pet {
            position: fixed;
            right: 16px;
            bottom: 16px;
            z-index: 1800;
            width: 68px;
            height: 68px;
            border: 1px solid var(--ops-line);
            border-radius: 999px;
            background: radial-gradient(circle at 35% 25%, #fff 0%, #e8f7ff 48%, #bfeaff 100%);
            box-shadow: 0 18px 42px rgba(36,120,255,.20), inset 0 1px 0 rgba(255,255,255,.94);
            display: grid;
            place-items: center;
        }
        .global-ai-pet::before {
            content: "";
            width: 42px;
            height: 23px;
            border-radius: 999px;
            background: radial-gradient(circle at 50% 45%, #81e8ff 0%, var(--ops-primary-2) 52%, var(--ops-primary) 100%);
            box-shadow: 0 0 14px rgba(99,183,255,.55);
        }
        .global-ai-pet-label {
            position: fixed;
            right: 88px;
            bottom: 38px;
            z-index: 1799;
            background: rgba(16,35,63,.88);
            color: #fff;
            border: 1px solid rgba(255,255,255,.22);
            border-radius: 999px;
            padding: 6px 10px;
            font-size: .76rem;
            font-weight: 800;
            white-space: nowrap;
            backdrop-filter: blur(18px);
        }

        @@media (max-width: 991px) {
            html, body { font-size: 13px; }
            .analytika-navbar .container-fluid { gap: .5rem !important; }
            .analytika-brand { max-width: calc(100vw - 104px) !important; border-radius: 14px !important; }
            .analytika-navbar .navbar-toggler { min-width: 52px !important; min-height: 52px !important; border-radius: 14px !important; }
            .dashboard-hero, .bi-header, .xp-toolbar { padding: 1rem !important; }
            .metric-card, .ss-card, .fac-status-card { min-height: 168px !important; }
            .global-ai-pet { width: 58px; height: 58px; right: 12px; bottom: 12px; }
            .global-ai-pet-label { display: none; }
        }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg analytika-navbar">
    <div class="container-fluid px-3">
        @{
            var canAccessRcm = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst) || User.IsInRole(AppRoles.Billing) || User.IsInRole(AppRoles.Finance) || User.IsInRole(AppRoles.Auditor);
            var canAccessResubmission = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.FacilityAdmin) || User.IsInRole(AppRoles.Analyst);
            var canAccessAdmin = User.IsInRole(AppRoles.Admin);
            var brandAction = canAccessRcm ? "RCMDashboard" : "Dashboard";
        }

        <!-- Brand -->
        <a class="analytika-brand navbar-brand me-0" asp-controller="Home" asp-action="@brandAction">
            <svg class="brand-icon-sm" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="22" cy="22" r="20" stroke="#54ACBF" stroke-width="2.5"/>
                <rect x="10"   y="29" width="5" height="8"  rx="1" fill="#051F20"/>
                <rect x="16.5" y="24" width="5" height="13" rx="1" fill="#26658C"/>
                <rect x="23"   y="19" width="5" height="18" rx="1" fill="#54ACBF"/>
                <rect x="29.5" y="14" width="4" height="23" rx="1" fill="#8EB69B"/>
                <polyline points="12.5,27 19,21 25.5,16 32,10" stroke="#051F20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polygon points="35,7 31,9 33.5,13" fill="#051F20"/>
            </svg>
            <div class="brand-name-wrap">
                <span class="brand-text">Ghaf Bi</span>
                <span class="brand-sub">Business Intelligence</span>
            </div>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <!-- Left nav -->
            <ul class="navbar-nav me-auto mb-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Dashboard" or "RCMDashboard" ? "active" : "")"
                       asp-controller="Home" asp-action="Dashboard">
                        <i class="fas fa-signal me-1" style="font-size:.75rem;"></i>Dashboard
                    </a>
                </li>
                @if (canAccessRcm)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RCMDashboard" ? "active" : "")"
                           asp-controller="Home" asp-action="RCMDashboard">BI Reports</a>
                    </li>
                }
                @if (canAccessResubmission)
                {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Resubmission" ? "active" : "")"
                       href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-tasks me-1" style="font-size:.75rem;"></i>Resubmission
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-controller="Resubmission" asp-action="Index">
                            <i class="fas fa-list-ul me-2 text-muted" style="width:14px;"></i>Allocation Board</a></li>
                        <li><a class="dropdown-item" asp-controller="Resubmission" asp-action="Workload">
                            <i class="fas fa-users me-2 text-muted" style="width:14px;"></i>Workload</a></li>
                        <li><a class="dropdown-item" asp-controller="Resubmission" asp-action="DenialDashboard">
                            <i class="fas fa-chart-pie me-2 text-muted" style="width:14px;"></i>Denial Dashboard</a></li>
                    </ul>
                </li>
                }
                @if (canAccessRcm)
                {
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Advanced Reports</a>
                    <ul class="dropdown-menu">
                        <li class="dropdown-submenu">
                            <a class="dropdown-item dropdown-toggle" href="#">Claim Processing</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimSummaryReport">Claim Summary</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimActivityReports">Claim Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="RemittanceActivityReport">Remittance Activity</a></li>
