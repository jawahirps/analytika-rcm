                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="RemittanceActivityReport">Remittance Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimReceiverReport">Claim Receiver</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimClinicianReport">Claim Clinician</a></li>
                                <li><a class="dropdown-item" asp-controller="AdvancedReports" asp-action="SubmissionXMLFileReport">Submission XML File</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="FinanceTATReport">Finance TAT</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="DenialReport">Denial Query</a></li>
