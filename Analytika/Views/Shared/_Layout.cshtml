@await RenderSectionAsync("Scripts", required: false)
<script>
function clearNotifications() {
    document.getElementById('notificationList').innerHTML =
        '<div class="text-center text-muted py-4" style="font-size:.8rem;"><i class="fas fa-check-circle me-1" style="color:#54ACBF;"></i><span data-i18n="all_caught_up">All caught up!</span></div>';
    const badge = document.getElementById('bellBadge');
    if (badge) badge.style.display = 'none';
}

(function initThemeLanguageControls() {
    const root = document.documentElement;
    const langButtons = {
        en: document.getElementById('langToggleEn'),
        ar: document.getElementById('langToggleAr')
    };
    const themeButton = document.getElementById('themeToggleBtn');

    const dict = {
        en: {
            support: 'Support',
            notifications: 'Notifications',
            mark_all_read: 'Mark all read',
            view_all_activity: 'View all activity',
            profile: 'Profile',
            sign_out: 'Sign Out',
            theme: 'Dark',
            all_caught_up: 'All caught up!'
        },
        ar: {
            support: 'الدعم',
            notifications: 'الإشعارات',
            mark_all_read: 'تعليم الكل كمقروء',
            view_all_activity: 'عرض كل النشاط',
            profile: 'الملف الشخصي',
            sign_out: 'تسجيل الخروج',
            theme: 'داكن',
            all_caught_up: 'تمت المزامنة!'
        }
    };

    function applyLanguage(lang) {
        root.lang = lang;
        root.dir = lang === 'ar' ? 'rtl' : 'ltr';
        root.dataset.lang = lang;
        try { localStorage.setItem('analytika-lang', lang); } catch (_) {}

        document.querySelectorAll('[data-i18n]').forEach(function (node) {
            var key = node.getAttribute('data-i18n');
            if (dict[lang] && dict[lang][key]) {
                node.textContent = dict[lang][key];
            }
        });

        Object.keys(langButtons).forEach(function (key) {
            var btn = langButtons[key];
            if (!btn) return;
            btn.classList.toggle('active', key === lang);
            btn.setAttribute('aria-pressed', key === lang ? 'true' : 'false');
        });
    }

    function applyTheme(theme) {
        root.dataset.theme = theme;
        try { localStorage.setItem('analytika-theme', theme); } catch (_) {}
        if (themeButton) {
            var icon = themeButton.querySelector('i');
            var label = document.getElementById('themeToggleLabel');
            if (icon) {
                icon.className = theme === 'dark' ? 'fas fa-sun me-1' : 'fas fa-moon me-1';
            }
            if (label) {
                var lang = root.dataset.lang || 'en';
                var labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                label.textContent = (labels[lang] || labels.en)[theme === 'dark' ? 'light' : 'dark'];
            }
            themeButton.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
        }
    }

    const currentLang = root.dataset.lang || (function () { try { return localStorage.getItem('analytika-lang'); } catch (_) { return null; } })() || 'en';
    const currentTheme = root.dataset.theme || (function () { try { return localStorage.getItem('analytika-theme'); } catch (_) { return null; } })() || 'light';

    applyLanguage(currentLang);
    applyTheme(currentTheme);

    Object.keys(langButtons).forEach(function (key) {
        var btn = langButtons[key];
        if (!btn) return;
        btn.addEventListener('click', function () {
            applyLanguage(key);
        });
    });

    if (themeButton) {
        themeButton.addEventListener('click', function () {
            var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
            applyTheme(next);
        });
    }
})();

(function initGlobalAiPet() {
    const pet = document.getElementById('globalAiPet');
    const label = document.getElementById('globalAiPetLabel');
    if (!pet) return;

    pet.addEventListener('click', function () {
        const drawer = document.getElementById('biFilterAgentDrawer');
        const drawerInput = document.getElementById('biFilterAgentInputDrawer');
        if (drawer) {
            drawer.removeAttribute('hidden');
            if (drawerInput) drawerInput.focus();
            if (label) label.style.display = 'none';
            return;
        }
        window.location.href = '/Home/RCMDashboard';
    });
})();
</script>
</body>
