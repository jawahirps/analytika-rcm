<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ghaf Bi Analytix</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar navbar-expand-lg analytika-navbar">
    <div class="container-fluid px-3">

        <!-- Brand -->
        <a class="analytika-brand navbar-brand me-0" asp-controller="Home" asp-action="RCMDashboard">
            <svg class="brand-icon-sm" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="22" cy="22" r="20" stroke="#0A1828" stroke-width="2.5"/>
                <rect x="10"   y="29" width="5" height="8"  rx="1" fill="#0A1828"/>
                <rect x="16.5" y="24" width="5" height="13" rx="1" fill="#0A1828"/>
                <rect x="23"   y="19" width="5" height="18" rx="1" fill="#0A1828"/>
                <rect x="29.5" y="14" width="4" height="23" rx="1" fill="#0A1828"/>
                <polyline points="12.5,27 19,21 25.5,16 32,10" stroke="#C87A10" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <polygon points="35,7 31,9 33.5,13" fill="#C87A10"/>
            </svg>
            <div class="brand-name-wrap">
                <span class="brand-text">Ghaf Bi Analytix</span>
                <span class="brand-sub">Business Intelligence</span>
            </div>
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <!-- Left nav -->
            <ul class="navbar-nav me-auto mb-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() is "Dashboard" or "RCMDashboard" ? "active" : "")"
                       asp-controller="Home" asp-action="Dashboard">
                        <i class="fas fa-signal me-1" style="font-size:.75rem;"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RCMDashboard" ? "active" : "")"
                       asp-controller="Home" asp-action="RCMDashboard">BI Reports</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Advanced Reports</a>
                    <ul class="dropdown-menu">
                        <li class="dropdown-submenu">
                            <a class="dropdown-item dropdown-toggle" href="#">Claim Processing</a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimSummaryReport">Claim Summary</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimActivityReports">Claim Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="RemittanceActivityReport">Remittance Activity</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimReceiverReport">Claim Receiver</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimClinicianReport">Claim Clinician</a></li>
                                <li><a class="dropdown-item" asp-controller="AdvancedReports" asp-action="SubmissionXMLFileReport">Submission XML File</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="FinanceTATReport">Finance TAT</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="DenialReport">Denial Query</a></li>
                                <li><a class="dropdown-item" asp-controller="ReportScheduler" asp-action="ClaimLifeCycleReport">Claim Life Cycle</a></li>
                            </ul>
                        </li>
                    </ul>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Portal" ? "active" : "")"
                       href="#" role="button" data-bs-toggle="dropdown">
                        <i class="fas fa-cloud-download-alt me-1" style="font-size:.78rem;"></i>Portal
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="Sync">
                            <i class="fas fa-sync me-2 text-muted"></i>Sync &amp; Fetch
                        </a></li>
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="SyncedData">
                            <i class="fas fa-database me-2 text-muted"></i>Synced Data
                        </a></li>
                        <li><a class="dropdown-item" asp-controller="Portal" asp-action="XmlParsing">
                            <i class="fas fa-file-code me-2 text-muted"></i>XML Parsing
                        </a></li>
                    </ul>
                </li>
                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-shield-alt me-1" style="font-size:.8rem;"></i>Admin
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users">
                                <i class="fas fa-users me-2 text-muted"></i>User Management
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="Credentials">
                                <i class="fas fa-key me-2 text-muted"></i>Portal Credentials
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="CodingSets">
                                <i class="fas fa-table me-2 text-muted"></i>DHPO Coding Sets
                            </a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="EmailSettings">
                                <i class="fas fa-envelope me-2 text-muted"></i>Email Settings
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="ReportSchedules">
                                <i class="fas fa-calendar-alt me-2 text-muted"></i>Report Schedules
                            </a></li>
                            <li><a class="dropdown-item" asp-controller="Admin" asp-action="PowerBIReports">
                                <i class="fas fa-chart-pie me-2 text-muted"></i>Power BI Reports
                            </a></li>
                        </ul>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" href="#Support">Support</a>
                </li>
            </ul>

            <!-- Right side -->
            <ul class="navbar-nav ms-auto align-items-center mb-0">
                <!-- Bell -->
                <li class="nav-item dropdown">
                    <button class="bell-btn position-relative" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                        <i class="fas fa-bell"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge" id="bellBadge">3</span>
                    </button>
                    <div class="dropdown-menu dropdown-menu-end p-0 shadow" style="min-width:320px;border-radius:12px;overflow:hidden;">
                        <div class="d-flex align-items-center justify-content-between px-3 py-2" style="background:#0A1828;">
                            <span class="fw-semibold text-white" style="font-size:.85rem;">Notifications</span>
                            <button class="btn btn-link btn-sm text-white p-0" style="font-size:.72rem;text-decoration:none;" onclick="clearNotifications()">Mark all read</button>
                        </div>
                        <div id="notificationList">
                            <a class="notification-item d-flex gap-2 px-3 py-2 border-bottom" href="/Portal/Sync">
                                <div class="notif-icon flex-shrink-0" style="background:#ccf7f7;">
                                    <i class="fas fa-file-download" style="color:#C87A10;"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">New transactions available</div>
                                    <div class="text-muted">DHA portal has undownloaded files</div>
                                    <div class="text-muted" style="font-size:.7rem;">Just now</div>
                                </div>
                            </a>
                            <a class="notification-item d-flex gap-2 px-3 py-2 border-bottom" href="/Portal/XmlParsing">
                                <div class="notif-icon flex-shrink-0" style="background:#fff3cd;">
                                    <i class="fas fa-file-code" style="color:#856404;"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">XML Parsing summary</div>
                                    <div class="text-muted">Some claims have no remittance match</div>
                                    <div class="text-muted" style="font-size:.7rem;">Today</div>
                                </div>
                            </a>
                            <a class="notification-item d-flex gap-2 px-3 py-2" href="/Portal/Sync">
                                <div class="notif-icon flex-shrink-0" style="background:#ccf7f7;">
                                    <i class="fas fa-sync" style="color:#0A1828;"></i>
                                </div>
                                <div style="font-size:.78rem;">
                                    <div class="fw-semibold text-dark">Daily sync complete</div>
                                    <div class="text-muted">Last cron run finished successfully</div>
                                    <div class="text-muted" style="font-size:.7rem;">2 hours ago</div>
                                </div>
                            </a>
                        </div>
                        <div class="text-center py-2" style="background:#f8f9fa;border-top:1px solid #eee;">
                            <a href="/Portal/Sync" style="font-size:.75rem;color:#C87A10;text-decoration:none;">View all activity</a>
                        </div>
                    </div>
                </li>

                <!-- Profile -->
                <li class="nav-item dropdown">
                    <a class="nav-link profile-btn dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                        <div class="profile-avatar-circle">
                            @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U")
                        </div>
                        <span class="d-none d-lg-inline text-truncate" style="max-width:120px;">
                            @User.Identity?.Name?.Split('@')[0]
                        </span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#"><i class="fas fa-user me-2 text-muted"></i>Profile</a></li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li>
                            <form asp-controller="Home" asp-action="LogOut" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt me-2"></i>Sign Out
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main>
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mx-3 mt-3 mb-0" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3 mb-0" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>

<!-- ── Live Status Bar — floating pill ──────────────────────────── -->
<div id="statusBar">
    <span id="sb-sync" class="sb-chip sb-idle" title="Last sync">
        <i class="fas fa-circle-check sb-icon"></i>
        <span id="sb-sync-text">Idle</span>
    </span>

    <!-- Live sync progress chip (hidden when idle) -->
    <span id="sb-progress-wrap" class="sb-chip sb-progress-chip" title="" style="display:none;">
        <i class="fas fa-bolt sb-icon" style="color:#38bdf8;"></i>
        <span id="sb-progress-label" style="color:#e2e8f0;"></span>
        <span class="sb-progress-track">
            <span id="sb-progress-fill" class="sb-progress-fill"></span>
        </span>
        <span id="sb-progress-pct" style="color:#38bdf8;font-weight:600;min-width:28px;text-align:right;"></span>
    </span>

    <span class="sb-div"></span>

    <span class="sb-chip" title="Records in DB">
        <i class="fas fa-database sb-icon"></i>
        <span id="sb-tx">—</span>
    </span>

    <span class="sb-chip" title="XML files downloaded">
        <i class="fas fa-file-code sb-icon"></i>
        <span id="sb-files">—</span>
    </span>

    <span class="sb-chip" title="Active facilities">
        <i class="fas fa-hospital sb-icon"></i>
        <span id="sb-fac">—</span>
    </span>

    <span class="sb-chip" title="DHA / RHA credentials">
        <i class="fas fa-key sb-icon"></i>
        DHA <span id="sb-dha">—</span> &middot; RHA <span id="sb-rha">—</span>
    </span>

    <span class="sb-div"></span>

    <span class="sb-chip" title="Last sync time">
        <i class="fas fa-history sb-icon"></i>
        <span id="sb-lastsync">—</span>
    </span>

    <span class="sb-chip" title="Logged in as">
        <i class="fas fa-user sb-icon"></i>
        <span id="sb-user">—</span>
    </span>

    <span class="sb-chip sb-clock" title="Current time">
        <i class="fas fa-clock sb-icon"></i>
        <span id="sb-time">—</span>
    </span>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
<script>
function clearNotifications() {
    document.getElementById('notificationList').innerHTML =
        '<div class="text-center text-muted py-4" style="font-size:.8rem;"><i class="fas fa-check-circle me-1" style="color:#0A1828;"></i>All caught up!</div>';
    const badge = document.getElementById('bellBadge');
    if (badge) badge.style.display = 'none';
}

// ── Live Status Bar ────────────────────────────────────────────
(function initStatusBar() {
    const $ = id => document.getElementById(id);

    // Local clock — ticks every second independently of API
    function tickClock() {
        const now = new Date();
        const pad = n => String(n).padStart(2,'0');
        const t = $('sb-time');
        if (t) t.textContent = `${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;
    }
    setInterval(tickClock, 1000);
    tickClock();

    function fmt(n) { return n != null ? Number(n).toLocaleString() : '—'; }

    let pollInterval = null;

    function applyStatus(d) {
        $('sb-tx').textContent    = fmt(d.txCount);
        $('sb-files').textContent = fmt(d.fileCount);
        $('sb-fac').textContent   = fmt(d.facCount);
        $('sb-dha').textContent   = fmt(d.dhaCreds);
        $('sb-rha').textContent   = fmt(d.rhaCreds);
        $('sb-user').textContent  = d.user || '—';
        $('sb-lastsync').textContent = d.lastSyncTime ? d.lastSyncTime : 'Never';

        const syncEl = $('sb-sync');
        const syncTx = $('sb-sync-text');
        if (d.syncRunning) {
            syncEl.className   = 'sb-chip sb-ok';
            syncTx.textContent = 'Syncing…';
        } else if (d.lastSyncStatus === 'Success') {
            syncEl.className   = 'sb-chip sb-ok';
            syncTx.textContent = (d.lastSyncPortal || '') + ' · ' + (d.lastSyncOp || 'Sync') + ' ✓';
        } else if (d.lastSyncStatus) {
            syncEl.className   = 'sb-chip sb-warn';
            syncTx.textContent = d.lastSyncStatus;
        } else {
            syncEl.className   = 'sb-chip sb-idle';
            syncTx.textContent = 'Idle';
        }

        // ── Live progress chip ───────────────────────────────────────
        const pw   = $('sb-progress-wrap');
        const fill = $('sb-progress-fill');
        const lbl  = $('sb-progress-label');
        const pct  = $('sb-progress-pct');
        if (d.syncRunning) {
            const p = d.syncPct || 0;
            lbl.textContent  = d.syncFacility
                ? `${d.syncFacilityIndex}/${d.syncTotalFacilities} · ${d.syncMonth}`
                : 'Starting…';
            fill.style.width = p + '%';
            pct.textContent  = p + '%';
            pw.title         = `${d.syncFacility || ''} — ${d.syncMonth || ''}\n${fmt(d.syncRecordsSaved)} saved · ${fmt(d.syncFilesDownloaded)} files`;
            pw.style.display = 'inline-flex';
            setPollRate(2000);   // faster while running
        } else {
            pw.style.display = 'none';
            setPollRate(15000);  // back to slow
        }
    }

    function setPollRate(ms) {
        if (pollInterval && pollInterval._ms === ms) return;
        if (pollInterval) clearInterval(pollInterval._id);
        const id = setInterval(poll, ms);
        pollInterval = { _id: id, _ms: ms };
    }

    async function poll() {
        try {
            const r = await fetch('/Portal/StatusBar', { credentials: 'same-origin' });
            if (r.ok) applyStatus(await r.json());
        } catch (_) {}
    }

    poll();                          // immediate on load
    setPollRate(15000);              // start at 15 s; tightens to 2 s during sync
})();
</script>
</body>
</html>
