@{
    ViewData["Title"] = "Database Backup & Migration";
}

<div class="container-fluid py-4" style="max-width:860px;">
    <h4 class="fw-bold mb-1"><i class="fas fa-database me-2" style="color:#35577D;"></i>Database Backup &amp; Migration</h4>
    <p class="text-muted mb-4" style="font-size:.85rem;">Download the local database and upload it to the cloud instance after deployment.</p>

    @if (ViewBag.PendingExists == true)
    {
        <div class="alert alert-warning">
            <i class="fas fa-clock me-2"></i>
            A database restore is pending. <strong>Restart the service</strong> to apply it.
        </div>
    }

    <!-- ── Storage statistics ───────────────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-3"><i class="fas fa-chart-pie me-2" style="color:#35577D;"></i>Storage Statistics</h6>
            <div class="row g-3" style="font-size:.85rem;">
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Transactions</div>
                    <div class="fw-semibold">@(((int?)ViewBag.TxCount)?.ToString("N0"))</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Stored XML</div>
                    <div class="fw-semibold">@ViewBag.XmlSizeMb MB <span class="text-muted fw-normal" style="font-size:.75rem;">(@(((int?)ViewBag.XmlCount)?.ToString("N0")) files)</span></div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Parsed Records</div>
                    <div class="fw-semibold">@(((int?)ViewBag.ParsedCount)?.ToString("N0"))</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Fetch Logs</div>
                    <div class="fw-semibold">@(((int?)ViewBag.FetchLogCount)?.ToString("N0"))</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Disk Downloads</div>
                    <div class="fw-semibold">@ViewBag.DownloadSizeMb MB <span class="text-muted fw-normal" style="font-size:.75rem;">(@(((int?)ViewBag.DownloadFiles)?.ToString("N0")) files)</span></div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-muted" style="font-size:.75rem;">Backups</div>
                    <div class="fw-semibold">@(((int?)ViewBag.BackupCount)?.ToString("N0"))</div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="text-muted" style="font-size:.75rem;">Latest Backup</div>
                    <div class="fw-semibold">@(ViewBag.LatestBackup ?? "none yet")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Step 1: Download ──────────────────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">
                <span class="badge rounded-pill me-2" style="background:#011C40;">1</span>
                Download from this machine
            </h6>
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div>
                    <div class="text-muted" style="font-size:.78rem;">Current database</div>
                    <div class="fw-semibold">@ViewBag.DbSizeMb MB &nbsp;<span class="text-muted fw-normal" style="font-size:.8rem;">last modified @ViewBag.DbModified</span></div>
                    <div class="text-muted" style="font-size:.72rem; word-break:break-all;">@ViewBag.DbPath</div>
                </div>
                <a href="/Admin/ExportDatabase" class="btn btn-sm btn-primary ms-auto" style="background:#011C40;border-color:#011C40;">
                    <i class="fas fa-download me-1"></i> Download .db file
                </a>
            </div>
        </div>
    </div>

    <!-- ── Step 2: Deploy ───────────────────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-2">
                <span class="badge rounded-pill me-2" style="background:#011C40;">2</span>
                Deploy on Render
            </h6>
            <ol class="mb-0" style="font-size:.85rem; padding-left:1.2rem;">
                <li class="mb-1">Go to <strong>render.com</strong> → <em>New → Web Service</em></li>
                <li class="mb-1">Connect <code>jawahirps/analytika-rcm</code> — Render will read <code>render.yaml</code> automatically</li>
                <li class="mb-1">Wait for the first deploy to finish (app starts with a fresh seed database)</li>
                <li class="mb-1">Log in as <strong>admin@ghafbi.ae</strong> with the seed password, then open <em>Admin → Database Migration</em></li>
                <li>Upload the <code>.db</code> file you downloaded in Step 1, then restart the service from the Render dashboard</li>
            </ol>
        </div>
    </div>

    <!-- ── Step 3: Upload ───────────────────────────────────────────────── -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">
                <span class="badge rounded-pill me-2" style="background:#011C40;">3</span>
                Upload to this instance
            </h6>
            <p class="text-muted mb-3" style="font-size:.83rem;">
                Do this step from the cloud instance after deployment. The uploaded file is staged as
                <code>analytika.db.pending</code> and replaces the live database on the next restart.
            </p>

            <div class="border rounded p-3" style="background:#EAF4FB;">
                <div class="mb-3">
                    <label class="form-label fw-semibold" style="font-size:.85rem;">Select <code>.db</code> file</label>
                    <input type="file" id="dbFileInput" accept=".db" class="form-control" style="font-size:.85rem;" />
                </div>
                <div id="uploadProgress" class="mb-3" style="display:none;">
                    <div class="d-flex justify-content-between mb-1" style="font-size:.78rem;">
                        <span id="uploadLabel">Uploading…</span>
                        <span id="uploadPct">0%</span>
                    </div>
                    <div class="progress" style="height:6px;">
                        <div id="uploadBar" class="progress-bar" style="width:0%;background:#35577D;"></div>
                    </div>
                </div>
                <div id="uploadResult" class="mb-3" style="display:none;font-size:.83rem;"></div>
                <button id="uploadBtn" class="btn btn-sm btn-warning" style="font-size:.83rem;" onclick="startUpload()">
                    <i class="fas fa-upload me-1"></i> Upload &amp; Stage
                </button>
            </div>

            <div class="alert alert-info mt-3 mb-0" style="font-size:.8rem;">
                <i class="fas fa-info-circle me-1"></i>
                After a successful upload, go to the Render dashboard → your service → <strong>Manual Deploy → Restart</strong>.
                The staged database will be applied automatically on startup.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function startUpload() {
    const fileInput = document.getElementById('dbFileInput');
    const file = fileInput.files[0];
    if (!file) { alert('Please select a .db file first.'); return; }

    const bar      = document.getElementById('uploadBar');
    const pct      = document.getElementById('uploadPct');
    const lbl      = document.getElementById('uploadLabel');
    const prog     = document.getElementById('uploadProgress');
    const result   = document.getElementById('uploadResult');
    const btn      = document.getElementById('uploadBtn');

    prog.style.display = 'block';
    result.style.display = 'none';
    btn.disabled = true;

    const formData = new FormData();
    formData.append('dbFile', file);
    formData.append('__RequestVerificationToken',
        document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '');

    const xhr = new XMLHttpRequest();
    xhr.open('POST', '/Admin/ImportDatabase', true);

    xhr.upload.onprogress = e => {
        if (e.lengthComputable) {
            const p = Math.round(e.loaded / e.total * 100);
            bar.style.width = p + '%';
            pct.textContent = p + '%';
            lbl.textContent = `Uploading ${(e.loaded / 1048576).toFixed(0)} / ${(e.total / 1048576).toFixed(0)} MB…`;
        }
    };

    xhr.onload = () => {
        btn.disabled = false;
        prog.style.display = 'none';
        try {
            const r = JSON.parse(xhr.responseText);
            result.style.display = 'block';
            result.innerHTML = r.ok
                ? `<div class="alert alert-success mb-0"><i class="fas fa-check-circle me-1"></i>${r.message}</div>`
                : `<div class="alert alert-danger mb-0"><i class="fas fa-times-circle me-1"></i>${r.message}</div>`;
        } catch {
            result.style.display = 'block';
            result.innerHTML = '<div class="alert alert-danger mb-0">Unexpected server response.</div>';
        }
    };

    xhr.onerror = () => {
        btn.disabled = false;
        prog.style.display = 'none';
        result.style.display = 'block';
        result.innerHTML = '<div class="alert alert-danger mb-0">Upload failed — check network and try again.</div>';
    };

    xhr.send(formData);
}
</script>
<!-- Anti-forgery token for XHR upload -->
<form style="display:none;">@Html.AntiForgeryToken()</form>
}
