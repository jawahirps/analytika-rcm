@model Analytika.Models.ViewModels.RoleListViewModel
@{
    ViewData["Title"] = "Roles";
}

<div class="container-fluid py-4 px-4">
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">User Roles</h4>
            <small class="text-muted">Create, edit, and manage standard application roles</small>
        </div>
        <div class="d-flex gap-2">
            <form asp-action="EnsureStandardRoles" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-secondary" style="border-radius:8px;">
                    <i class="fas fa-shield-alt me-1"></i>Ensure Standard Roles
                </button>
            </form>
            <a asp-action="Users" class="btn btn-sm" style="background:#003B4D;color:#fff;border-radius:8px;">
                <i class="fas fa-users me-1"></i>Users
            </a>
        </div>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success border-0 shadow-sm" style="border-radius:8px;">
            <i class="fas fa-check-circle me-1"></i>@success
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger border-0 shadow-sm" style="border-radius:8px;">
            <i class="fas fa-exclamation-circle me-1"></i>@error
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">Create Role</h6>
                    <form asp-action="CreateRole" method="post">
                        @Html.AntiForgeryToken()
                        <label class="form-label small fw-semibold">Role Name</label>
                        <input name="newRoleName" class="form-control mb-3" maxlength="64" placeholder="e.g. ClaimsManager" />
                        <button type="submit" class="btn w-100" style="background:#008B8B;color:#fff;border-radius:8px;">
                            <i class="fas fa-plus me-1"></i>Create Role
                        </button>
                    </form>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-4" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">Standard Roles</h6>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var role in Model.StandardRoles)
                        {
                            <span class="badge" style="background:#C6E2E9;color:#334155;border-radius:999px;padding:.45rem .65rem;">@role</span>
                        }
                    </div>
                    <p class="text-muted small mb-0 mt-3">
                        Admin and FacilityAdmin are protected because they control administration and access boundaries.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Role</th>
                                <th>Type</th>
                                <th class="text-center">Users</th>
                                <th class="pe-4 text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model.Roles)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <form asp-action="EditRole" method="post" class="d-flex align-items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@role.Id" />
                                            <input name="roleName" value="@role.Name" class="form-control form-control-sm"
                                                   style="max-width:260px;" maxlength="64" @(role.IsProtected ? "readonly" : "") />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Save role name"
                                                    @(role.IsProtected ? "disabled" : "")>
                                                <i class="fas fa-save"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td>
                                        @if (role.IsProtected)
                                        {
                                            <span class="badge" style="background:rgba(102,178,178,.14);color:#006666;">Protected</span>
                                        }
                                        else if (role.IsStandard)
                                        {
                                            <span class="badge" style="background:rgba(0,139,139,.12);color:#008B8B;">Standard</span>
                                        }
                                        else
                                        {
                                            <span class="badge" style="background:#C6E2E9;color:#334155;">Custom</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-semibold" style="color:var(--navy);">@role.UserCount</span>
                                    </td>
                                    <td class="pe-4 text-end">
                                        <form asp-action="DeleteRole" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@role.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    onclick="return confirm('Delete role @role.Name?')"
                                                    @(role.IsProtected || role.UserCount > 0 ? "disabled" : "")>
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Roles.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">No roles found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
