@model Analytika.Services.SmtpSettings
@{
    ViewData["Title"] = "Email Settings";
}

<div class="container-fluid py-4 px-4">
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Email Settings</h4>
            <small class="text-muted">SMTP configuration for automated report delivery</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">
                        <i class="fas fa-server me-2" style="color:#0D7272;"></i>SMTP Server
                    </h6>
                    <form asp-action="SaveEmailSettings" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-md-8">
                                <label class="form-label">Host</label>
                                <input name="host" class="form-control" value="@Model.Host"
                                       placeholder="smtp.office365.com" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Port</label>
                                <input name="port" type="number" class="form-control" value="@Model.Port" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Username</label>
                                <input name="userName" class="form-control" value="@Model.UserName"
                                       placeholder="reports@yourdomain.com" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Password
                                    <small class="text-muted fw-normal">(leave blank to keep current)</small>
                                </label>
                                <input name="password" type="password" class="form-control"
                                       placeholder="••••••••" autocomplete="new-password" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">From Address</label>
                                <input name="fromAddress" class="form-control" value="@Model.FromAddress"
                                       placeholder="noreply@yourdomain.com" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">From Name</label>
                                <input name="fromName" class="form-control" value="@Model.FromName"
                                       placeholder="GhafBI Reports" />
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="enableSsl"
                                           value="true" id="sslCheck" @(Model.EnableSsl ? "checked" : "") />
                                    <label class="form-check-label" for="sslCheck">Enable SSL / TLS</label>
                                </div>
                            </div>
                            <div class="col-12 d-flex gap-2 pt-1">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="fas fa-save me-1"></i> Save Settings
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" style="color:var(--navy);">
                        <i class="fas fa-paper-plane me-2" style="color:var(--amber);"></i>Test Connection
                    </h6>
                    <p class="text-muted mb-3" style="font-size:.82rem;">
                        Send a test message to verify the SMTP settings are working.
                    </p>
                    <div class="input-group mb-2">
                        <input id="testTo" type="email" class="form-control form-control-sm"
                               placeholder="your@email.com" />
                        <button class="btn btn-sm" style="background:var(--amber);color:#fff;border:none;"
                                onclick="testEmail(this)">
                            <i class="fas fa-paper-plane me-1"></i> Send Test
                        </button>
                    </div>
                    <div id="testResult" style="font-size:.8rem;display:none;"></div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-2" style="color:var(--navy);">
                        <i class="fas fa-info-circle me-2" style="color:#0D7272;"></i>Common SMTP Hosts
                    </h6>
                    <table class="table table-sm mb-0" style="font-size:.78rem;">
                        <tbody>
                            <tr><td class="fw-semibold">Office 365</td><td>smtp.office365.com : 587</td></tr>
                            <tr><td class="fw-semibold">Gmail</td><td>smtp.gmail.com : 587</td></tr>
                            <tr><td class="fw-semibold">Outlook.com</td><td>smtp-mail.outlook.com : 587</td></tr>
                            <tr><td class="fw-semibold">AWS SES (UAE)</td><td>email-smtp.me-south-1.amazonaws.com : 587</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
@Html.AntiForgeryToken()
function getToken() {
    return document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

async function testEmail(btn) {
    const to   = document.getElementById('testTo').value.trim();
    if (!to) { alert('Enter an email address.'); return; }
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Sending…';
    btn.disabled  = true;
    const el = document.getElementById('testResult');

    const form = new FormData();
    form.append('testTo', to);
    form.append('__RequestVerificationToken', getToken());

    try {
        const r = await fetch('/Admin/TestEmailSettings', { method: 'POST', body: form });
        const d = await r.json();
        el.style.display = 'block';
        el.className     = d.ok ? 'text-success' : 'text-danger';
        el.innerHTML     = `<i class="fas fa-${d.ok ? 'check' : 'times'}-circle me-1"></i>${d.message}`;
    } catch { el.style.display = 'block'; el.className = 'text-danger'; el.textContent = 'Request failed'; }
    btn.innerHTML = orig; btn.disabled = false;
}
</script>
}
