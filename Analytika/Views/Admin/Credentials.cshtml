@model Analytika.Models.ViewModels.CredentialListViewModel
@{
    ViewData["Title"] = "Portal Credentials";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:#0d1b3e;">Portal Credentials</h4>
            <small class="text-muted">Configure RHA (Riayati) and DHA (eClaimLink) portal credentials per facility</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm px-3 py-2 btn-outline-secondary" style="border-radius:8px;" onclick="testAll()" id="testAllBtn">
                <i class="fas fa-plug me-1"></i> Test All
            </button>
            <a class="btn btn-sm px-3 py-2 btn-outline-success" style="border-radius:8px;"
               asp-action="ExportCredentials">
                <i class="fas fa-file-export me-1"></i> Export CSV
            </a>
            <button class="btn btn-sm px-3 py-2 btn-outline-info" style="border-radius:8px;"
                    onclick="document.getElementById('importCredFile').click()">
                <i class="fas fa-file-import me-1"></i> Import CSV
            </button>
            <form asp-action="ImportCredentials" method="post" enctype="multipart/form-data" id="importCredForm">
                @Html.AntiForgeryToken()
                <input type="file" id="importCredFile" name="file" accept=".csv" class="d-none"
                       onchange="this.form.submit()" />
            </form>
            <button class="btn btn-sm px-3 py-2" style="background:#0d1b3e;color:#fff;border-radius:8px;"
                    data-bs-toggle="modal" data-bs-target="#credModal" onclick="openNewCred()">
                <i class="fas fa-plus me-1"></i> Add Credential
            </button>
        </div>
    </div>

    <!-- Portal cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px;border-left:4px solid #1e6b45!important;">
                <div class="card-body py-3 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#e8f7ef;">
                            <i class="fas fa-hospital" style="color:#1e6b45;"></i>
                        </div>
                        <div>
                            <div class="fw-bold" style="color:#0d1b3e;">RHA — Riayati (TMB API)</div>
                            <div class="text-muted small">tmbapi.riayati.ae:8083 · REST API · Bearer Token</div>
                        </div>
                        <span class="badge ms-auto" style="background:#e8f7ef;color:#1e6b45;font-size:.72rem;">
                            @Model.Credentials.Count(c => c.Portal == "RHA") configured
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm" style="border-radius:12px;border-left:4px solid #0055a5!important;">
                <div class="card-body py-3 px-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;background:#e8f0ff;">
                            <i class="fas fa-building" style="color:#0055a5;"></i>
                        </div>
                        <div>
                            <div class="fw-bold" style="color:#0d1b3e;">DHA — eClaimLink</div>
                            <div class="text-muted small">dhpo.eclaimlink.ae · SOAP Web Service · Login/Pwd</div>
                        </div>
                        <span class="badge ms-auto" style="background:#e8f0ff;color:#0055a5;font-size:.72rem;">
                            @Model.Credentials.Count(c => c.Portal == "DHA") configured
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Credentials Table -->
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:.85rem;">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-muted border-0">Portal</th>
                            <th class="py-3 fw-semibold text-muted border-0">Facility</th>
                            <th class="py-3 fw-semibold text-muted border-0">Name</th>
                            <th class="py-3 fw-semibold text-muted border-0">Username</th>
                            <th class="py-3 fw-semibold text-muted border-0">API URL</th>
                            <th class="py-3 fw-semibold text-muted border-0">Status</th>
                            <th class="py-3 fw-semibold text-muted border-0">Updated</th>
                            <th class="py-3 fw-semibold text-muted border-0">Connection</th>
                            <th class="pe-4 py-3 fw-semibold text-muted border-0 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Credentials)
                        {
                            <tr>
                                <td class="ps-4 py-3 align-middle">
                                    <span class="badge rounded-pill" style="font-size:.72rem;@(c.Portal == "RHA" ? "background:#e8f7ef;color:#1e6b45;" : "background:#e8f0ff;color:#0055a5;")">
                                        @c.Portal
                                    </span>
                                </td>
                                <td class="py-3 align-middle fw-semibold" style="color:#0d1b3e;">@c.FacilityName</td>
                                <td class="py-3 align-middle text-muted">
                                    @if (!string.IsNullOrEmpty(c.CredentialName))
                                    {
                                        <span class="badge rounded-pill" style="background:#f0f0ff;color:#4a4a8a;font-size:.72rem;">@c.CredentialName</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="py-3 align-middle text-muted">@c.Username</td>
                                <td class="py-3 align-middle text-muted" style="font-size:.78rem;">@(c.ApiBaseUrl ?? "—")</td>
                                <td class="py-3 align-middle">
                                    <span class="badge rounded-pill @(c.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")" style="font-size:.72rem;">
                                        @(c.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="py-3 align-middle text-muted">@(c.UpdatedAt?.ToString("dd MMM yyyy") ?? "—")</td>
                                <td class="py-3 align-middle" id="check-@c.Id">
                                    <button class="btn btn-sm btn-outline-info test-btn" style="border-radius:6px;font-size:.76rem;"
                                            onclick="testOne(@c.Id, this)">
                                        <i class="fas fa-plug me-1"></i>Test
                                    </button>
                                </td>
                                <td class="pe-4 py-3 align-middle text-end">
                                    <button class="btn btn-sm btn-outline-secondary me-1" style="border-radius:6px;font-size:.78rem;"
                                            onclick="openEditCred(@c.Id, '@c.Portal', @c.FacilityId, '@(c.CredentialName ?? "")', '@c.Username', '@(c.ApiBaseUrl ?? "")', '@(c.LicenseCode ?? "")', @(c.IsActive ? "true" : "false"))"
                                            data-bs-toggle="modal" data-bs-target="#credModal">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <form asp-action="DeleteCredential" asp-route-id="@c.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete this credential?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" style="border-radius:6px;font-size:.78rem;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (!Model.Credentials.Any())
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">No credentials configured yet. Click "Add Credential" to get started.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Credential Modal -->
<div class="modal fade" id="credModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h6 class="modal-title fw-bold" id="credModalTitle">Add Portal Credential</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="SaveCredential" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="Id" id="credId" value="0" />
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Portal</label>
                            <select name="Portal" id="credPortal" class="form-select form-select-sm" onchange="updatePortalDefaults(this.value)">
                                <option value="DHA">DHA — eClaimLink</option>
                                <option value="RHA">RHA — Riayati</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Facility</label>
                            <select name="FacilityId" id="credFacility" class="form-select form-select-sm">
                                @foreach (var f in Model.Facilities)
                                {
                                    <option value="@f.Value">@f.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">Credential Name <span class="text-muted fw-normal">(display label)</span></label>
                            <input type="text" name="CredentialName" id="credName" class="form-control form-control-sm"
                                   placeholder="e.g. Alnoor Deira — DHA Production" maxlength="100" />
                            <div class="form-text" style="font-size:.7rem;">Optional. Renames this credential for easy identification.</div>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Username / Login</label>
                            <input type="text" name="Username" id="credUsername" class="form-control form-control-sm" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-semibold">Password</label>
                            <input type="password" name="Password" id="credPassword" class="form-control form-control-sm" />
                            <div class="form-text" style="font-size:.7rem;">Leave blank to keep existing.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">API Base URL</label>
                            <input type="text" name="ApiBaseUrl" id="credApiUrl" class="form-control form-control-sm"
                                   placeholder="https://tmbapi.riayati.ae:8083" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-semibold">License Code <span class="text-muted">(optional)</span></label>
                            <input type="text" name="LicenseCode" id="credLicense" class="form-control form-control-sm" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input type="checkbox" name="IsActive" id="credActive" class="form-check-input" role="switch" checked />
                                <label class="form-check-label small" for="credActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm" style="background:#0d1b3e;color:#fff;">Save Credential</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openNewCred() {
    document.getElementById('credModalTitle').textContent = 'Add Portal Credential';
    document.getElementById('credId').value = '0';
    document.getElementById('credPortal').value = 'DHA';
    document.getElementById('credFacility').selectedIndex = 0;
    document.getElementById('credName').value = '';
    document.getElementById('credUsername').value = '';
    document.getElementById('credPassword').value = '';
    document.getElementById('credApiUrl').value = '';
    document.getElementById('credLicense').value = '';
    document.getElementById('credActive').checked = true;
    updatePortalDefaults('DHA');
}
function openEditCred(id, portal, facilityId, credName, username, apiUrl, license, isActive) {
    document.getElementById('credModalTitle').textContent = 'Edit Portal Credential';
    document.getElementById('credId').value = id;
    document.getElementById('credPortal').value = portal;
    document.getElementById('credFacility').value = String(facilityId);
    document.getElementById('credName').value = credName;
    document.getElementById('credUsername').value = username;
    document.getElementById('credPassword').value = '';
    document.getElementById('credApiUrl').value = apiUrl;
    document.getElementById('credLicense').value = license;
    document.getElementById('credActive').checked = isActive;
}
function updatePortalDefaults(portal) {
    var urlField = document.getElementById('credApiUrl');
    if (portal === 'RHA' && !urlField.value) urlField.value = 'https://tmbapi.riayati.ae:8083';
    else if (portal === 'DHA' && !urlField.value) urlField.value = 'https://dhpo.eclaimlink.ae';
}

function renderResult(cell, ok, message) {
    cell.innerHTML = ok
        ? `<span class="badge rounded-pill d-inline-flex align-items-center gap-1" style="background:#e8f7ef;color:#1e6b45;font-size:.72rem;max-width:220px;white-space:normal;text-align:left;">
               <i class="fas fa-check-circle"></i><span>${message}</span>
           </span>`
        : `<span class="badge rounded-pill d-inline-flex align-items-center gap-1" style="background:#ffe8e8;color:#dc3545;font-size:.72rem;max-width:220px;white-space:normal;text-align:left;">
               <i class="fas fa-times-circle"></i><span>${message}</span>
           </span>`;
}

async function testOne(id, btn) {
    const cell = document.getElementById('check-' + id);
    cell.innerHTML = '<span class="text-muted" style="font-size:.75rem;"><i class="fas fa-spinner fa-spin me-1"></i>Testing…</span>';
    btn.disabled = true;
    try {
        const res = await fetch(`/Admin/TestCredential?id=${id}`);
        const data = await res.json();
        renderResult(cell, data.ok, data.message);
    } catch(e) {
        renderResult(cell, false, 'Request failed: ' + e.message);
    }
    btn.disabled = false;
}

async function testAll() {
    const btn = document.getElementById('testAllBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Testing…';

    // Show spinner in all check cells
    document.querySelectorAll('[id^="check-"]').forEach(function(cell) {
        cell.innerHTML = '<span class="text-muted" style="font-size:.75rem;"><i class="fas fa-spinner fa-spin me-1"></i>Testing…</span>';
    });

    try {
        const res = await fetch('/Admin/TestAllCredentials');
        const results = await res.json();
        results.forEach(function(r) {
            const cell = document.getElementById('check-' + r.id);
            if (cell) renderResult(cell, r.ok, r.message);
        });
        btn.innerHTML = '<i class="fas fa-plug me-1"></i> Test All';
    } catch(e) {
        document.querySelectorAll('[id^="check-"]').forEach(function(cell) {
            renderResult(cell, false, 'Request failed');
        });
        btn.innerHTML = '<i class="fas fa-plug me-1"></i> Test All';
    }
    btn.disabled = false;
}
</script>
}
