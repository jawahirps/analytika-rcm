@model List<Analytika.Models.DashboardEmbed>
@{
    ViewData["Title"] = "Power BI Reports";
}

<div class="container-fluid py-4 px-4">
    <div class="page-header mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--navy);">Power BI Reports</h4>
            <small class="text-muted">Azure AD credentials with hardcoded workspace / report IDs</small>
        </div>
        <a asp-controller="Home" asp-action="RCMDashboard" class="btn btn-ghost btn-sm">
            <i class="fas fa-external-link-alt me-1"></i> Open Dashboard
        </a>
    </div>

    <!-- Azure AD Credentials (read-only from appsettings — shown for reference) -->
    <div class="card border-0 shadow-sm mb-4" style="border-left:3px solid var(--amber)!important;">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0" style="color:var(--navy);">
                    <i class="fas fa-key me-2" style="color:var(--amber);"></i>Azure AD Credentials
                </h6>
                <button class="btn btn-sm" style="background:var(--amber);color:#fff;border:none;"
                        onclick="testPbiConnection(this)">
                    <i class="fas fa-plug me-1"></i> Test Connection
                </button>
            </div>
            <div class="alert mb-3" style="background:rgba(200,122,16,0.08);border:1px solid var(--amber);border-radius:8px;font-size:.82rem;color:var(--amber-dark);">
                <i class="fas fa-info-circle me-1"></i>
                These values are read from <code>appsettings.json</code> → <code>PowerBI</code> section.
                Edit that file to change them, then restart the application.
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" style="font-size:.78rem;">Tenant ID</label>
                    <input class="form-control form-control-sm font-monospace" readonly value="@(string.IsNullOrEmpty(ViewBag.TenantId as string) ? "(not set)" : ViewBag.TenantId)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" style="font-size:.78rem;">Client ID</label>
                    <input class="form-control form-control-sm font-monospace" readonly value="@(string.IsNullOrEmpty(ViewBag.ClientId as string) ? "(not set)" : ViewBag.ClientId)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label" style="font-size:.78rem;">Client Secret</label>
                    <input class="form-control form-control-sm font-monospace" readonly type="password"
                           value="@(string.IsNullOrEmpty(ViewBag.ClientSecret as string) ? "" : "●●●●●●●●")" />
                </div>
            </div>
            <div id="pbiTestResult" class="mt-2" style="font-size:.8rem;display:none;"></div>
        </div>
    </div>

    <!-- Per-tab report configuration -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 py-3 px-4">
            <span class="fw-bold" style="color:var(--navy);font-size:.95rem;">
                <i class="fas fa-chart-pie me-2" style="color:#0D7272;"></i>Dashboard Tabs
            </span>
            <small class="text-muted ms-2" style="font-size:.75rem;">Workspace ID and Report ID are hardcoded in the application</small>
        </div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width:130px;">Tab</th>
                        <th>Workspace ID <small class="text-muted fw-normal">(Group ID)</small></th>
                        <th>Report ID</th>
                        <th class="text-center" style="width:90px;">Active</th>
                        <th class="pe-4 text-center" style="width:130px;">Source</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var embed in Model)
                    {
                        var hasRealIds    = !string.IsNullOrWhiteSpace(embed.ReportId)
                                         && embed.ReportId.Length >= 32;

                        // Display value: blank out seeded/placeholder IDs (no real GUID entered yet)
                        var displayGroupId  = hasRealIds ? embed.GroupId  : "";
                        var displayReportId = hasRealIds ? embed.ReportId : "";

                        <tr id="row-@embed.Id">
                            <td class="ps-4 fw-semibold" style="color:var(--navy);font-size:.82rem;vertical-align:middle;">
                                @embed.TabName
                            </td>
                            <td style="vertical-align:middle;">
                                <input id="gid-@embed.Id" class="form-control form-control-sm font-monospace"
                                       placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                       value="@displayGroupId" readonly />
                            </td>
                            <td style="vertical-align:middle;">
                                <input id="rid-@embed.Id" class="form-control form-control-sm font-monospace"
                                       placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                       value="@displayReportId" readonly />
                            </td>
                            <td class="text-center" style="vertical-align:middle;">
                                <div class="form-check form-switch d-flex justify-content-center">
                                    <input class="form-check-input" type="checkbox" id="act-@embed.Id"
                                           @(embed.IsActive ? "checked" : "") role="switch" disabled>
                                </div>
                            </td>
                            <td class="pe-4 text-center" style="vertical-align:middle;">
                                <span class="badge" style="background:rgba(13,114,114,0.12);color:#0D7272;">Hardcoded</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 p-3 rounded" style="background:var(--bg);border:1px solid var(--border-light);font-size:.78rem;color:var(--text-secondary);">
        <i class="fas fa-lightbulb me-1" style="color:var(--amber);"></i>
        <strong>Dashboard IDs are code-owned:</strong>
        update <code>Services/HardcodedDashboardCatalog.cs</code> to change the Workspace ID or Report ID.
        Your Service Principal must still be added to each workspace with at least Viewer role.
    </div>
</div>

@section Scripts {
<script>
const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
           || '@Html.AntiForgeryToken()';

function getToken() {
    return document.querySelector('meta[name="csrf"]')?.content
        || document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
}

async function saveEmbed(id, btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    btn.disabled  = true;

    const groupId  = document.getElementById('gid-' + id).value.trim();
    const reportId = document.getElementById('rid-' + id).value.trim();
    const isActive = document.getElementById('act-' + id).checked;

    const form = new FormData();
    form.append('id', id); form.append('groupId', groupId);
    form.append('reportId', reportId); form.append('isActive', isActive);
    form.append('__RequestVerificationToken', getToken());

    try {
        const r = await fetch('/Admin/SavePowerBIEmbed', { method: 'POST', body: form });
        const d = await r.json();
        btn.innerHTML = d.ok ? '<i class="fas fa-check"></i>' : '<i class="fas fa-times"></i>';
        btn.style.background = d.ok ? '#3aac8a' : '#dc3545';
        setTimeout(() => { btn.innerHTML = orig; btn.style.background = '#0D7272'; btn.disabled = false; }, 2000);
    } catch {
        btn.innerHTML = '<i class="fas fa-times"></i>'; btn.disabled = false;
        setTimeout(() => { btn.innerHTML = orig; btn.style.background = '#0D7272'; }, 2000);
    }
}

async function testPbiConnection(btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Testing…';
    btn.disabled  = true;
    const el = document.getElementById('pbiTestResult');
    el.style.display = 'none';

    const form = new FormData();
    form.append('__RequestVerificationToken', getToken());

    try {
        const r = await fetch('/Admin/TestPowerBIConnection', { method: 'POST', body: form });
        const d = await r.json();
        el.style.display = 'block';
        el.className     = d.ok ? 'mt-2 text-success' : 'mt-2 text-danger';
        el.innerHTML     = `<i class="fas fa-${d.ok ? 'check' : 'times'}-circle me-1"></i>${d.message}`;
    } catch (e) {
        el.style.display = 'block'; el.className = 'mt-2 text-danger';
        el.textContent = 'Request failed';
    }
    btn.innerHTML = orig; btn.disabled = false;
}

// Embed hidden anti-forgery in a form so getToken() works
</script>
@Html.AntiForgeryToken()
}
