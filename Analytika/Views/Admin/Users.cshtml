@model Analytika.Models.ViewModels.UserListViewModel
@{
    ViewData["Title"] = "User Management";
    var globalCount = Model.Users.Count(u => u.UserType == "Global");
    var facilityCount = Model.Users.Count(u => u.UserType == "Facility");
    var activeCount = Model.Users.Count(u => u.IsActive);
}

<div class="container-fluid py-4 px-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold" style="color:#0d1b3e;">User Management</h4>
            <small class="text-muted">Manage global and facility-level users, roles, and access</small>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-sm px-3 py-2 btn-outline-success" style="border-radius:8px;"
               asp-action="ExportUsers">
                <i class="fas fa-file-export me-1"></i> Export CSV
            </a>
            <button class="btn btn-sm px-3 py-2 btn-outline-info" style="border-radius:8px;"
                    onclick="document.getElementById('importUserFile').click()">
                <i class="fas fa-file-import me-1"></i> Import CSV
            </button>
            <form asp-action="ImportUsers" method="post" enctype="multipart/form-data" id="importUserForm">
                @Html.AntiForgeryToken()
                <input type="file" id="importUserFile" name="file" accept=".csv" class="d-none"
                       onchange="this.form.submit()" />
            </form>
            <a asp-action="CreateUser" class="btn btn-sm px-3 py-2" style="background:#0d1b3e;color:#fff;border-radius:8px;">
                <i class="fas fa-plus me-1"></i> Create User
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm" style="border-radius:10px;">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:#e8f4ff;">
                            <i class="fas fa-users" style="color:#0d1b3e;font-size:1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5" style="color:#0d1b3e;">@Model.TotalUsers</div>
                            <div class="text-muted" style="font-size:.75rem;">Total Users</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm" style="border-radius:10px;">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:#e8fff7;">
                            <i class="fas fa-globe" style="color:#1e6b45;font-size:1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5" style="color:#0d1b3e;">@globalCount</div>
                            <div class="text-muted" style="font-size:.75rem;">Global Users</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm" style="border-radius:10px;">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:#fff8e8;">
                            <i class="fas fa-hospital" style="color:#b8860b;font-size:1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5" style="color:#0d1b3e;">@facilityCount</div>
                            <div class="text-muted" style="font-size:.75rem;">Facility Users</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm" style="border-radius:10px;">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:40px;height:40px;background:#e8ffe8;">
                            <i class="fas fa-check-circle" style="color:#28a745;font-size:1rem;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-5" style="color:#0d1b3e;">@activeCount</div>
                            <div class="text-muted" style="font-size:.75rem;">Active</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="d-flex gap-2 mb-3 flex-wrap">
        @foreach (var f in new[] { "All", "Global", "Facility", "Active", "Inactive" })
        {
            <a asp-action="Users" asp-route-filter="@f"
               class="btn btn-sm @(Model.Filter == f ? "btn-primary-custom" : "btn-outline-secondary")"
               style="border-radius:20px;font-size:.82rem;@(Model.Filter == f ? "background:#0d1b3e;color:#fff;border-color:#0d1b3e;" : "")">
                @f
            </a>
        }
    </div>

    <!-- Users Table -->
    <div class="card border-0 shadow-sm" style="border-radius:12px;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size:.85rem;">
                    <thead style="background:#f8f9fa;">
                        <tr>
                            <th class="ps-4 py-3 fw-semibold text-muted border-0">User</th>
                            <th class="py-3 fw-semibold text-muted border-0">Type</th>
                            <th class="py-3 fw-semibold text-muted border-0">Role</th>
                            <th class="py-3 fw-semibold text-muted border-0">Facilities</th>
                            <th class="py-3 fw-semibold text-muted border-0">Status</th>
                            <th class="py-3 fw-semibold text-muted border-0">Created</th>
                            <th class="pe-4 py-3 fw-semibold text-muted border-0 text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="ps-4 py-3 align-middle">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white"
                                             style="width:34px;height:34px;background:#0d1b3e;font-size:.8rem;flex-shrink:0;">
                                            @(user.FullName.Length > 0 ? user.FullName[0].ToString().ToUpper() : "U")
                                        </div>
                                        <div>
                                            <div class="fw-semibold" style="color:#0d1b3e;">@user.FullName</div>
                                            <div class="text-muted" style="font-size:.75rem;">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 align-middle">
                                    <span class="badge rounded-pill" style="font-size:.72rem;@(user.UserType == "Global" ? "background:#e3f2fd;color:#1565c0;" : "background:#fff8e1;color:#b8860b;")">
                                        @user.UserType
                                    </span>
                                </td>
                                <td class="py-3 align-middle">
                                    <span class="badge rounded-pill" style="font-size:.72rem;background:#f0faf6;color:#1e6b45;">@user.Role</span>
                                </td>
                                <td class="py-3 align-middle" style="max-width:180px;">
                                    @if (user.Facilities.Any())
                                    {
                                        @string.Join(", ", user.Facilities)
                                    }
                                    else
                                    {
                                        <span class="text-muted">All</span>
                                    }
                                </td>
                                <td class="py-3 align-middle">
                                    <span class="badge rounded-pill @(user.IsActive ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")" style="font-size:.72rem;">
                                        @(user.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="py-3 align-middle text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td class="pe-4 py-3 align-middle text-end">
                                    <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-secondary me-1" style="border-radius:6px;font-size:.78rem;">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                    <form asp-action="ToggleUser" asp-route-id="@user.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm me-1 @(user.IsActive ? "btn-outline-warning" : "btn-outline-success")" style="border-radius:6px;font-size:.78rem;">
                                            <i class="fas @(user.IsActive ? "fa-ban" : "fa-check")"></i>
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-sm btn-outline-info" style="border-radius:6px;font-size:.78rem;"
                                            data-bs-toggle="modal" data-bs-target="#resetModal" data-userid="@user.Id" data-email="@user.Email">
                                        <i class="fas fa-key"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!Model.Users.Any())
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">No users found.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal fade" id="resetModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h6 class="modal-title fw-bold">Reset Password</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="ResetPassword" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="id" id="resetUserId" />
                    <p class="text-muted small" id="resetUserEmail"></p>
                    <div class="mb-2">
                        <label class="form-label small fw-semibold">New Password</label>
                        <input type="password" name="newPassword" class="form-control form-control-sm" required minlength="6" />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm" style="background:#0d1b3e;color:#fff;">Reset</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('resetModal').addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('resetUserId').value = btn.dataset.userid;
    document.getElementById('resetUserEmail').textContent = btn.dataset.email;
});
</script>
}
