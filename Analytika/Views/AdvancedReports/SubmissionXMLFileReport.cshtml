@model Analytika.Models.ViewModels.ReportSchedulerViewModel
@{
    ViewData["Title"] = "Submission XML File Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" style="color:#7b4fd4">Home</a></li>
            <li class="breadcrumb-item">Advanced Reports</li>
            <li class="breadcrumb-item active">Submission XML File Report</li>
        </ol>
    </nav>
    <div class="card border-0 shadow-sm">
        <div class="card-header text-white" style="background:linear-gradient(135deg,#011C40,#2541a0)">
            <i class="fas fa-file-code me-2"></i>Submission XML File Report
        </div>
        <div class="card-body p-4 text-center text-muted py-5">
            <i class="fas fa-file-code fa-4x mb-3"></i>
            <p class="fs-5">Submission XML File Report</p>
            <small>Configure and download XML submission files for your claims.</small>
        </div>
