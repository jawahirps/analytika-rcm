@model Analytika.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ghaf Business Intelligence — Login</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            background: #EAF4FB;
            -webkit-font-smoothing: antialiased;
        }
        html[data-theme="dark"] body {
            background: linear-gradient(140deg, #011C40 0%, rgba(1,28,64,0.88) 42%, rgba(38,101,140,0.20) 72%, #023859 100%);
            color: #EAF4FB;
        }

        /* ── Left panel ── */
        .login-left {
            width: 42%;
            background:
                radial-gradient(circle at 16% 12%, rgba(167,235,242,0.12), transparent 24%),
                linear-gradient(155deg, rgba(1,28,64,0.96) 0%, rgba(1,28,64,0.90) 42%, rgba(38,101,140,0.74) 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 44px 48px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(18px) saturate(150%);
            -webkit-backdrop-filter: blur(18px) saturate(150%);
        }
        .login-left::before,
        .login-left::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }
        .login-left::before {
            width: 360px;
            height: 360px;
            border: 1px solid rgba(167,235,242,0.10);
            filter: blur(1px);
            bottom: -150px;
            right: -110px;
        }
        .login-left::after {
            width: 220px;
            height: 220px;
            border: 1px solid rgba(167,235,242,0.06);
            filter: blur(1px);
            top: 40px;
            right: 32px;
        }
        .login-brand {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .login-brand-mark {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: 0.22em;
            text-transform: uppercase;
            color: #EAF4FB;
        }
        .login-brand-mark::before {
            content: '';
            width: 12px;
            height: 12px;
            border-radius: 999px;
            background: linear-gradient(135deg, #A7EBF2 0%, #54ACBF 100%);
            box-shadow: 0 0 0 6px rgba(167,235,242,0.10);
        }
        .login-brand-sub {
            color: rgba(234,244,251,0.74);
            font-size: .72rem;
            font-weight: 600;
            letter-spacing: .18em;
            text-transform: uppercase;
        }
        .left-tagline {
            position: relative;
            z-index: 1;
            max-width: 420px;
        }
        .left-tagline h2 {
            font-size: 1.95rem;
            font-weight: 750;
            color: #ffffff;
            line-height: 1.18;
            margin-bottom: 14px;
            letter-spacing: -0.6px;
        }
        .left-tagline h2 span { color: #A7EBF2; }
        .left-tagline p {
            font-size: 0.92rem;
            color: rgba(255,255,255,0.60);
            line-height: 1.7;
            max-width: 36ch;
        }
        .feature-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 20px;
        }
        .feature-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 999px;
            padding: 5px 12px;
            font-size: 0.72rem;
            color: rgba(255,255,255,0.72);
        }
        .feature-pill i { color: #A7EBF2; font-size: 0.65rem; }
        .login-tiles {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 20px;
            max-width: 420px;
        }
        .login-tile {
            border-radius: 16px;
            border: 1px solid rgba(167,235,242,0.12);
            background: rgba(1,28,64,0.28);
            padding: 14px;
            backdrop-filter: blur(10px);
        }
        .login-tile strong {
            display: block;
            font-size: .9rem;
            color: #EAF4FB;
            margin-bottom: 4px;
        }
        .login-tile span {
            display: block;
            font-size: .76rem;
            line-height: 1.45;
            color: rgba(234,244,251,0.72);
        }
        .left-footer {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.28);
            position: relative;
            z-index: 1;
        }

        /* ── Right panel ── */
        .login-right {
            flex: 1;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 64px;
            position: relative;
        }
        html[data-theme="dark"] .login-right {
            background: rgba(1,28,64,0.86);
            color: #EAF4FB;
        }
        .login-right-inner {
            max-width: 420px;
            width: 100%;
            padding: 28px;
            border-radius: 28px;
            background: rgba(255,255,255,0.94);
            border: 1px solid rgba(8,20,35,0.10);
            box-shadow: 0 24px 64px rgba(1,28,64,0.10);
        }
        .login-top-tools {
            position: absolute;
            top: 18px;
            right: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 2;
        }
        html[dir="rtl"] .login-top-tools {
            right: auto;
            left: 18px;
            flex-direction: row-reverse;
        }
        .login-top-tools .btn {
            border-radius: 999px;
            font-size: .72rem;
        }
        .codex-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            border: 1px solid rgba(8,20,35,0.14);
            border-radius: 14px;
            font-weight: 700;
            line-height: 1;
            transition: transform .18s ease, box-shadow .18s ease, background .18s ease, border-color .18s ease, filter .18s ease;
        }
        .codex-btn:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(1,28,64,0.10); }
        .codex-btn:active { transform: translateY(0); filter: brightness(.98); }
        .codex-btn-primary {
            color: #ffffff;
            background: linear-gradient(180deg, #54ACBF 0%, #023859 100%);
            border-color: rgba(1,28,64,0.16);
            box-shadow: 0 12px 24px rgba(38,101,140,0.18);
        }
        .codex-btn-primary:hover { background: linear-gradient(180deg, #67b7ca 0%, #023859 100%); }
        .codex-btn-secondary {
            color: #011C40;
            background: rgba(234,244,251,0.88);
        }
        .codex-btn-ghost {
            color: #023859;
            background: rgba(255,255,255,0.74);
        }
        .codex-btn-chip {
            min-width: 42px;
            height: 32px;
            border-radius: 999px;
            padding: 0 .7rem;
            background: rgba(255,255,255,0.82);
            color: #023859;
        }
        .lang-toggle-btn.active {
            background: #011C40;
            color: #fff;
            border-color: #011C40;
        }
        html[data-theme="dark"] .lang-toggle-btn,
        html[data-theme="dark"] .theme-toggle-btn {
            border-color: rgba(167,235,242,0.16);
            background: rgba(1,28,64,0.72);
            color: #EAF4FB;
        }
        html[data-theme="dark"] .lang-toggle-btn.active {
            background: rgba(167,235,242,0.16);
            border-color: rgba(167,235,242,0.32);
            color: #A7EBF2;
        }

        .login-right h1 {
            font-size: 1.58rem;
            font-weight: 700;
            color: #011C40;
            margin-bottom: 6px;
            letter-spacing: -0.4px;
        }
        html[data-theme="dark"] .login-right h1,
        html[data-theme="dark"] .login-right .subtitle,
        html[data-theme="dark"] .form-label,
        html[data-theme="dark"] .forgot-link,
        html[data-theme="dark"] .right-footer {
            color: #EAF4FB;
        }
        .login-right .subtitle {
            font-size: 0.88rem;
            color: #023859;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 0.73rem;
            font-weight: 700;
            color: #023859;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        .form-control {
            font-family: 'Inter', system-ui, sans-serif;
            border: 1.5px solid rgba(1,28,64,0.10);
            border-radius: 9px;
            padding: 10px 14px;
            font-size: 0.9rem;
            color: #011C40;
            background: rgba(234,244,251,0.86);
            transition: border-color 0.18s, box-shadow 0.18s;
        }
        html[data-theme="dark"] .form-control,
        html[data-theme="dark"] .input-icon,
        html[data-theme="dark"] .input-group-text {
            background: rgba(1,28,64,0.82);
            color: #EAF4FB;
            border-color: rgba(167,235,242,0.14);
        }
        html[data-theme="dark"] .form-control::placeholder { color: rgba(234,244,251,0.5); }
        .form-control:focus {
            border-color: #54ACBF;
            box-shadow: 0 0 0 3px rgba(84,172,191,0.14);
            background: #fff;
            outline: none;
        }
        .form-control::placeholder { color: rgba(2,56,89,0.36); }
        .input-group .form-control { border-right: none; border-radius: 9px 0 0 9px; }
        .input-group-text {
            background: rgba(234,244,251,0.86);
            border: 1.5px solid rgba(1,28,64,0.10);
            border-left: none;
            color: #023859;
            border-radius: 0 9px 9px 0;
            cursor: pointer;
            font-size: 0.85rem;
            transition: border-color 0.18s;
        }
        .input-group:focus-within .input-group-text { border-color: #54ACBF; }
        .input-icon {
            background: rgba(234,244,251,0.86);
            border: 1.5px solid rgba(1,28,64,0.10);
            border-right: none;
            color: #023859;
            border-radius: 9px 0 0 9px;
            padding: 10px 12px;
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            transition: border-color 0.18s;
        }
        .input-group:focus-within .input-icon { border-color: #54ACBF; }

        .btn-signin {
            font-family: 'Inter', system-ui, sans-serif;
            background: linear-gradient(180deg, #54ACBF 0%, #023859 100%);
            color: #fff;
            border: 1px solid rgba(1,28,64,0.16);
            border-radius: 14px;
            padding: 11px 24px;
            font-size: 0.9rem;
            font-weight: 700;
            width: 100%;
            letter-spacing: 0.1px;
            transition: background 0.18s, transform 0.15s, box-shadow 0.18s, filter 0.18s;
            cursor: pointer;
        }
        html[data-theme="dark"] .btn-signin {
            background: linear-gradient(135deg, #011C40 0%, #26658C 100%);
            box-shadow: 0 12px 26px rgba(0,0,0,0.22);
        }
        .btn-signin:hover {
            filter: brightness(1.04);
            transform: translateY(-1px);
            box-shadow: 0 12px 26px rgba(1,28,64,0.18);
        }
        .btn-signin:active { transform: translateY(0); }

        .forgot-link {
            font-size: 0.78rem;
            color: #023859;
            text-decoration: none;
            font-weight: 500;
        }
        .forgot-link:hover { text-decoration: underline; }

        .form-check-input:checked {
            background-color: #54ACBF;
            border-color: #54ACBF;
        }
        .form-check-input:focus { box-shadow: 0 0 0 3px rgba(84,172,191,0.15); }

        .alert-danger {
            font-size: 0.82rem;
            border-radius: 9px;
            background: rgba(239,68,68,0.07);
            border: none;
            border-left: 3px solid #ef4444;
            color: #b91c1c;
            padding: 10px 14px;
        }
        .right-footer {
            position: absolute;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.72rem;
            color: #023859;
            white-space: nowrap;
        }
        html[dir="rtl"] .login-right-inner,
        html[dir="rtl"] .left-tagline {
            text-align: right;
        }
        html[dir="rtl"] .left-tagline .feature-pills {
            justify-content: flex-end;
        }
        html[dir="rtl"] .login-right-inner { max-width: 420px; }

        @@media (max-width: 900px) {
            .login-left { width: 44%; padding: 40px 36px; }
        }
        @@media (max-width: 768px) {
            .login-left { display: none; }
            .login-right { padding: 40px 28px; }
            .login-right-inner { max-width: 100%; }
        }
    </style>
</head>
<body>
    <!-- Left Brand Panel -->
    <div class="login-left">
        <div class="login-brand">
            <div class="login-brand-mark">Ghaf BI</div>
            <div class="login-brand-sub">Business Intelligence</div>
        </div>

        <div class="left-tagline">
            <h2>Smarter decisions,<br/><span>without visual clutter.</span></h2>
            <p>A focused healthcare analytics workspace for submissions, resubmissions, remittance, and operational review.</p>
            <div class="feature-pills">
                <span class="feature-pill"><i class="fas fa-circle-check"></i> RCM Analytics</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> Facility Scope</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> Faster Reports</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> Arabic & English</span>
            </div>

            <div class="login-tiles">
                <div class="login-tile">
                    <strong>Submission view</strong>
                    <span>Review the shared encounter-based timeline across report sets.</span>
                </div>
                <div class="login-tile">
                    <strong>Resubmission view</strong>
                    <span>Track follow-up work with cleaner, date-anchored rollups.</span>
                </div>
                <div class="login-tile">
                    <strong>Operational view</strong>
                    <span>Keep the interface readable on smaller screens and dense dashboards.</span>
                </div>
                <div class="login-tile">
                    <strong>Secure access</strong>
                    <span>Role-based login with a simpler, more legible entry point.</span>
                </div>
            </div>
        </div>

        <div class="left-footer">&copy; 2026 Ghaf Bi Solutions. All rights reserved.</div>
    </div>

    <!-- Right Login Form -->
    <div class="login-right">
        <div class="login-top-tools">
            <div class="btn-group btn-group-sm" role="group" aria-label="Language toggle">
                <button type="button" class="btn codex-btn codex-btn-chip lang-toggle-btn active" id="loginLangEn">EN</button>
                <button type="button" class="btn codex-btn codex-btn-chip lang-toggle-btn" id="loginLangAr">AR</button>
            </div>
            <button type="button" class="btn codex-btn codex-btn-ghost btn-sm theme-toggle-btn" id="loginThemeToggle">
                <i class="fas fa-moon me-1"></i><span id="loginThemeLabel">Dark</span>
            </button>
        </div>
        <div class="login-right-inner">
            <h1 data-i18n="welcome_back">Welcome back</h1>
            <p class="subtitle" data-i18n="sign_in_subtitle">Sign in to your Ghaf Business Intelligence account</p>

            <form asp-controller="Home" asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i><span data-i18n="invalid_login">Invalid email or password.</span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label" data-i18n="email_address">Email address</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="username" />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label mb-0" data-i18n="password">Password</label>
                        <a href="#" class="forgot-link" data-i18n="forgot_password">Forgot password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" id="pwdInput" />
                        <span class="input-group-text" onclick="togglePwd()"><i class="fas fa-eye" id="pwdIcon"></i></span>
                    </div>
                </div>

                <div class="mb-4 d-flex align-items-center gap-2">
                    <input asp-for="RememberMe" class="form-check-input mt-0" style="width:16px;height:16px;" />
                    <label asp-for="RememberMe" class="form-label mb-0" style="font-weight:400;font-size:.82rem;color:#35577D;text-transform:none;letter-spacing:0;" data-i18n="remember_me">Keep me signed in</label>
                </div>

                <button type="submit" class="btn-signin codex-btn codex-btn-primary">
                    <span data-i18n="sign_in">Sign In</span> <i class="fas fa-arrow-right" style="font-size:.75rem;opacity:.9;"></i>
                </button>
            </form>
        </div>

        <div class="right-footer" data-i18n="copyright">© Copyright. All Rights Reserved. Ghaf Bi Solutions</div>
    </div>

    <script>
        function togglePwd() {
            const input = document.getElementById('pwdInput');
            const icon = document.getElementById('pwdIcon');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('fa-eye');
            icon.classList.toggle('fa-eye-slash');
        }

        (function initLoginLanguageTheme() {
            const root = document.documentElement;
            const langEn = document.getElementById('loginLangEn');
            const langAr = document.getElementById('loginLangAr');
            const themeBtn = document.getElementById('loginThemeToggle');
            const themeLabel = document.getElementById('loginThemeLabel');
            const dict = {
                en: {
                    welcome_back: 'Welcome back',
                    sign_in_subtitle: 'Sign in to your Ghaf Business Intelligence account',
                    invalid_login: 'Invalid email or password.',
                    email_address: 'Email address',
                    password: 'Password',
                    forgot_password: 'Forgot password?',
                    remember_me: 'Keep me signed in',
                    sign_in: 'Sign In',
                    copyright: '© Copyright. All Rights Reserved. Ghaf Bi Solutions'
                },
                ar: {
                    welcome_back: 'مرحبًا بعودتك',
                    sign_in_subtitle: 'سجّل الدخول إلى حساب غاف بزنس إنتليجنس',
                    invalid_login: 'البريد الإلكتروني أو كلمة المرور غير صحيحة.',
                    email_address: 'البريد الإلكتروني',
                    password: 'كلمة المرور',
                    forgot_password: 'هل نسيت كلمة المرور؟',
                    remember_me: 'تذكرني',
                    sign_in: 'تسجيل الدخول',
                    copyright: '© جميع الحقوق محفوظة. غاف بي سوليوشنز'
                }
            };

            function applyLanguage(lang) {
                root.lang = lang;
                root.dir = lang === 'ar' ? 'rtl' : 'ltr';
                root.dataset.lang = lang;
                try { localStorage.setItem('analytika-lang', lang); } catch (_) {}
                document.querySelectorAll('[data-i18n]').forEach(node => {
                    const key = node.getAttribute('data-i18n');
                    if (dict[lang] && dict[lang][key]) node.textContent = dict[lang][key];
                });
                if (themeLabel) {
                    const currentTheme = root.dataset.theme || 'light';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeLabel.textContent = (labels[lang] || labels.en)[currentTheme === 'dark' ? 'light' : 'dark'];
                }
                if (langEn && langAr) {
                    langEn.classList.toggle('active', lang === 'en');
                    langAr.classList.toggle('active', lang === 'ar');
                }
            }

            function applyTheme(theme) {
                root.dataset.theme = theme;
                try { localStorage.setItem('analytika-theme', theme); } catch (_) {}
                if (themeBtn && themeLabel) {
                    const lang = root.dataset.lang || 'en';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeBtn.querySelector('i').className = theme === 'dark' ? 'fas fa-sun me-1' : 'fas fa-moon me-1';
                    themeLabel.textContent = (labels[lang] || labels.en)[theme === 'dark' ? 'light' : 'dark'];
                }
            }

            const currentLang = root.dataset.lang || (function(){ try { return localStorage.getItem('analytika-lang'); } catch (_) { return null; } })() || 'en';
            const currentTheme = root.dataset.theme || (function(){ try { return localStorage.getItem('analytika-theme'); } catch (_) { return null; } })() || 'light';

            applyLanguage(currentLang);
            applyTheme(currentTheme);

            if (langEn) langEn.addEventListener('click', () => applyLanguage('en'));
            if (langAr) langAr.addEventListener('click', () => applyLanguage('ar'));
            if (themeBtn) themeBtn.addEventListener('click', () => applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark'));
        })();
    </script>
</body>
</html>
