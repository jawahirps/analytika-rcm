@model Analytika.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ghaf Business Intelligence — Login</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            min-height: 100vh;
            display: flex;
            background: #EAF4FB;
            -webkit-font-smoothing: antialiased;
        }
        html[data-theme="dark"] body {
            background: linear-gradient(140deg, #011C40 0%, rgba(1,28,64,0.88) 42%, rgba(38,101,140,0.20) 72%, #023859 100%);
            color: #EAF4FB;
        }

        /* ── Left panel ── */
        .login-left {
            width: 40%;
            background:
                radial-gradient(circle at 18% 14%, rgba(167,235,242,0.10), transparent 28%),
                linear-gradient(160deg, rgba(1,28,64,0.94) 0%, rgba(1,28,64,0.88) 46%, rgba(38,101,140,0.70) 100%);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 44px 48px;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(18px) saturate(150%);
            -webkit-backdrop-filter: blur(18px) saturate(150%);
        }
        /* Subtle geometric accents */
        .login-left::before {
            content: '';
            position: absolute;
            width: 380px; height: 380px;
            border-radius: 50%;
            border: 1px solid rgba(167,235,242,0.10);
            filter: blur(1px);
            bottom: -140px; right: -120px;
        }
        .login-left::after {
            content: '';
            position: absolute;
            width: 220px; height: 220px;
            border-radius: 50%;
            border: 1px solid rgba(167,235,242,0.06);
            filter: blur(1px);
            top: 40px; right: 40px;
        }
        .accent-ring {
            position: absolute;
            width: 160px; height: 160px;
            border-radius: 50%;
            border: 1px solid rgba(167,235,242,0.05);
            filter: blur(1px);
            bottom: 120px; left: -50px;
        }
        .brand-logo {
            display: flex;
            align-items: flex-start;
            gap: 0;
            position: relative;
            z-index: 1;
            opacity: 0.86;
        }
        .brand-logo-img {
            width: 164px;
            max-width: 100%;
            height: auto;
            display: block;
            filter: drop-shadow(0 8px 20px rgba(0,0,0,0.12));
        }
        .brand-name {
            font-size: 1.1rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.2px;
            line-height: 1.2;
        }
        .brand-sub {
            font-size: 0.62rem;
            color: #A7EBF2;
            font-weight: 600;
            letter-spacing: 1.6px;
            text-transform: uppercase;
        }
        .left-tagline {
            position: relative;
            z-index: 1;
        }
        .left-tagline h2 {
            font-size: 1.9rem;
            font-weight: 700;
            color: #ffffff;
            line-height: 1.25;
            margin-bottom: 14px;
            letter-spacing: -0.5px;
        }
        .left-tagline h2 span { color: #A7EBF2; }
        .left-tagline p {
            font-size: 0.875rem;
            color: rgba(255,255,255,0.45);
            line-height: 1.65;
        }
        /* Feature pills */
        .feature-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 22px;
        }
        .feature-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 100px;
            padding: 5px 12px;
            font-size: 0.72rem;
            color: rgba(255,255,255,0.6);
        }
        .feature-pill i { color: #A7EBF2; font-size: 0.65rem; }
        .login-globe-shell {
            display: flex;
            justify-content: center;
            margin-top: 18px;
        }
        .login-globe-card {
            position: relative;
            width: min(100%, 320px);
            aspect-ratio: 1;
            border-radius: 22px;
            border: 1px solid rgba(167,235,242,0.08);
            background:
                radial-gradient(circle at 35% 30%, rgba(167,235,242,0.12), rgba(1,28,64,0.68) 54%, rgba(1,28,64,0.90) 100%);
            box-shadow: 0 18px 44px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.06);
            overflow: hidden;
        }
        .login-globe-canvas {
            width: 100%;
            height: 100%;
            display: block;
            border-radius: 22px;
            touch-action: none;
            cursor: grab;
            opacity: 0.92;
            filter: saturate(0.92) brightness(0.98);
        }
        .login-globe-canvas:active { cursor: grabbing; }
        .login-globe-overlay {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }
        .login-globe-marker {
            position: absolute;
            pointer-events: auto;
            transform: translate(-50%, -50%);
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            padding: 6px 8px;
            border-radius: 10px;
            border: 1px solid rgba(167,235,242,0.12);
            background: rgba(1,28,64,0.78);
            color: #EAF4FB;
            box-shadow: 0 10px 18px rgba(0,0,0,0.16);
            opacity: 0;
            transition: opacity 0.3s ease, transform 0.2s ease, background 0.2s ease;
            min-width: 68px;
            text-align: center;
        }
        .login-globe-marker:hover {
            transform: translate(-50%, -50%) scale(1.04);
            background: rgba(167,235,242,0.12);
        }
        .login-globe-marker.is-expanded {
            background: rgba(167,235,242,0.14);
        }
        .login-globe-marker-name {
            font-size: 0.6rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }
        .login-globe-marker-meta {
            font-size: 0.56rem;
            opacity: 0.85;
        }
        .left-footer {
            font-size: 0.72rem;
            color: rgba(255,255,255,0.22);
            position: relative;
            z-index: 1;
        }

        /* ── Right panel ── */
        .login-right {
            flex: 1;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px 64px;
            position: relative;
        }
        html[data-theme="dark"] .login-right {
            background: rgba(1,28,64,0.86);
            color: #EAF4FB;
        }
        .login-right-inner { max-width: 380px; }
        .login-top-tools {
            position: absolute;
            top: 18px;
            right: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
            z-index: 2;
        }
        html[dir="rtl"] .login-top-tools {
            right: auto;
            left: 18px;
            flex-direction: row-reverse;
        }
        .login-top-tools .btn {
            border-radius: 999px;
            font-size: .72rem;
        }
        .lang-toggle-btn.active {
            background: #011C40;
            color: #fff;
            border-color: #011C40;
        }
        html[data-theme="dark"] .lang-toggle-btn,
        html[data-theme="dark"] .theme-toggle-btn {
            border-color: rgba(167,235,242,0.16);
            background: rgba(1,28,64,0.72);
            color: #EAF4FB;
        }
        html[data-theme="dark"] .lang-toggle-btn.active {
            background: rgba(167,235,242,0.16);
            border-color: rgba(167,235,242,0.32);
            color: #A7EBF2;
        }

        .login-right h1 {
            font-size: 1.55rem;
            font-weight: 700;
            color: #011C40;
            margin-bottom: 6px;
            letter-spacing: -0.4px;
        }
        html[data-theme="dark"] .login-right h1,
        html[data-theme="dark"] .login-right .subtitle,
        html[data-theme="dark"] .form-label,
        html[data-theme="dark"] .forgot-link,
        html[data-theme="dark"] .right-footer {
            color: #EAF4FB;
        }
        .login-right .subtitle {
            font-size: 0.85rem;
            color: #35577D;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 0.73rem;
            font-weight: 600;
            color: #54ACBF;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }
        .form-control {
            font-family: 'Inter', system-ui, sans-serif;
            border: 1.5px solid #EAF4FB;
            border-radius: 9px;
            padding: 10px 14px;
            font-size: 0.9rem;
            color: #011C40;
            background: #EAF4FB;
            transition: border-color 0.18s, box-shadow 0.18s;
        }
        html[data-theme="dark"] .form-control,
        html[data-theme="dark"] .input-icon,
        html[data-theme="dark"] .input-group-text {
            background: rgba(1,28,64,0.82);
            color: #EAF4FB;
            border-color: rgba(167,235,242,0.14);
        }
        html[data-theme="dark"] .form-control::placeholder { color: rgba(234,244,251,0.5); }
        .form-control:focus {
            border-color: #A7EBF2;
            box-shadow: 0 0 0 3px rgba(16,185,129,0.12);
            background: #fff;
            outline: none;
        }
        .form-control::placeholder { color: #EAF4FB; }
        .input-group .form-control { border-right: none; border-radius: 9px 0 0 9px; }
        .input-group-text {
            background: #EAF4FB;
            border: 1.5px solid #EAF4FB;
            border-left: none;
            color: #35577D;
            border-radius: 0 9px 9px 0;
            cursor: pointer;
            font-size: 0.85rem;
            transition: border-color 0.18s;
        }
        .input-group:focus-within .input-group-text { border-color: #A7EBF2; }
        .input-icon {
            background: #EAF4FB;
            border: 1.5px solid #EAF4FB;
            border-right: none;
            color: #35577D;
            border-radius: 9px 0 0 9px;
            padding: 10px 12px;
            font-size: 0.8rem;
            display: flex;
            align-items: center;
            transition: border-color 0.18s;
        }
        .input-group:focus-within .input-icon { border-color: #A7EBF2; }

        .btn-signin {
            font-family: 'Inter', system-ui, sans-serif;
            background: #0f172a;
            color: #fff;
            border: none;
            border-radius: 9px;
            padding: 11px 24px;
            font-size: 0.875rem;
            font-weight: 600;
            width: 100%;
            letter-spacing: 0.1px;
            transition: background 0.18s, transform 0.15s, box-shadow 0.18s;
            cursor: pointer;
        }
        html[data-theme="dark"] .btn-signin {
            background: linear-gradient(135deg, #011C40 0%, #26658C 100%);
            box-shadow: 0 12px 26px rgba(0,0,0,0.22);
        }
        .btn-signin:hover {
            background: #1e293b;
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(15,23,42,0.2);
        }
        .btn-signin:active { transform: translateY(0); }

        .forgot-link {
            font-size: 0.78rem;
            color: #A7EBF2;
            text-decoration: none;
            font-weight: 500;
        }
        .forgot-link:hover { text-decoration: underline; }

        .form-check-input:checked {
            background-color: #A7EBF2;
            border-color: #A7EBF2;
        }
        .form-check-input:focus { box-shadow: 0 0 0 3px rgba(16,185,129,0.15); }

        .alert-danger {
            font-size: 0.82rem;
            border-radius: 9px;
            background: rgba(239,68,68,0.07);
            border: none;
            border-left: 3px solid #ef4444;
            color: #b91c1c;
            padding: 10px 14px;
        }
        .right-footer {
            position: absolute;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.72rem;
            color: #EAF4FB;
            white-space: nowrap;
        }
        html[dir="rtl"] .login-right-inner,
        html[dir="rtl"] .left-tagline {
            text-align: right;
        }
        html[dir="rtl"] .left-tagline .feature-pills {
            justify-content: flex-end;
        }
        html[dir="rtl"] .login-right-inner { max-width: 420px; }

        @@media (max-width: 900px) {
            .login-left { width: 44%; padding: 40px 36px; }
        }
        @@media (max-width: 768px) {
            .login-left { display: none; }
            .login-right { padding: 40px 28px; }
            .login-right-inner { max-width: 100%; }
        }
    </style>
</head>
<body>
    <!-- Left Brand Panel -->
    <div class="login-left">
        <div class="accent-ring"></div>

        <div class="brand-logo">
            <img
                class="brand-logo-img"
                src="@Url.Content("~/images/ghaf-logo-primary-006884.jpg")"
                srcset="@Url.Content("~/images/ghaf-logo-primary-006884.jpg") 1x, @Url.Content("~/images/ghaf-logo-primary-006884-2x.jpg") 2x"
                width="176"
                height="224"
                alt="Ghaf Business Intelligence" />
        </div>

        <div class="left-tagline">
            <h2>Smarter decisions,<br/><span>faster insights.</span></h2>
            <p>A unified analytics platform for healthcare revenue cycle management — built for UAE-based facilities.</p>
            <div class="feature-pills">
                <span class="feature-pill"><i class="fas fa-circle-check"></i> RCM Analytics</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> DHA · RHA Portals</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> Real-time Reports</span>
                <span class="feature-pill"><i class="fas fa-circle-check"></i> Multi-facility</span>
            </div>

            <div class="login-globe-shell">
                <div class="login-globe-card" aria-label="Interactive globe">
                    <canvas id="loginGlobeCanvas" class="login-globe-canvas" aria-hidden="true"></canvas>
                    <div id="loginGlobeOverlay" class="login-globe-overlay" aria-hidden="true"></div>
                </div>
            </div>
        </div>

        <div class="left-footer">&copy; 2026 Ghaf Bi Solutions. All rights reserved.</div>
    </div>

    <!-- Right Login Form -->
    <div class="login-right">
        <div class="login-top-tools">
            <div class="btn-group btn-group-sm" role="group" aria-label="Language toggle">
                <button type="button" class="btn btn-outline-secondary lang-toggle-btn active" id="loginLangEn">EN</button>
                <button type="button" class="btn btn-outline-secondary lang-toggle-btn" id="loginLangAr">AR</button>
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm theme-toggle-btn" id="loginThemeToggle">
                <i class="fas fa-moon me-1"></i><span id="loginThemeLabel">Dark</span>
            </button>
        </div>
        <div class="login-right-inner">
            <h1 data-i18n="welcome_back">Welcome back</h1>
            <p class="subtitle" data-i18n="sign_in_subtitle">Sign in to your Ghaf Business Intelligence account</p>

            <form asp-controller="Home" asp-action="Index" method="post">
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger mb-4" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i><span data-i18n="invalid_login">Invalid email or password.</span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="Email" class="form-label" data-i18n="email_address">Email address</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="username" />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label mb-0" data-i18n="password">Password</label>
                        <a href="#" class="forgot-link" data-i18n="forgot_password">Forgot password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" id="pwdInput" />
                        <span class="input-group-text" onclick="togglePwd()"><i class="fas fa-eye" id="pwdIcon"></i></span>
                    </div>
                </div>

                <div class="mb-4 d-flex align-items-center gap-2">
                    <input asp-for="RememberMe" class="form-check-input mt-0" style="width:16px;height:16px;" />
                    <label asp-for="RememberMe" class="form-label mb-0" style="font-weight:400;font-size:.82rem;color:#35577D;text-transform:none;letter-spacing:0;" data-i18n="remember_me">Keep me signed in</label>
                </div>

                <button type="submit" class="btn-signin">
                    <span data-i18n="sign_in">Sign In</span> &nbsp;<i class="fas fa-arrow-right" style="font-size:.75rem;opacity:.8;"></i>
                </button>
            </form>
        </div>

        <div class="right-footer" data-i18n="copyright">© Copyright. All Rights Reserved. Ghaf Bi Solutions</div>
    </div>

    <script>
        function togglePwd() {
            const input = document.getElementById('pwdInput');
            const icon = document.getElementById('pwdIcon');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('fa-eye');
            icon.classList.toggle('fa-eye-slash');
        }

        (function initLoginLanguageTheme() {
            const root = document.documentElement;
            const langEn = document.getElementById('loginLangEn');
            const langAr = document.getElementById('loginLangAr');
            const themeBtn = document.getElementById('loginThemeToggle');
            const themeLabel = document.getElementById('loginThemeLabel');
            const dict = {
                en: {
                    welcome_back: 'Welcome back',
                    sign_in_subtitle: 'Sign in to your Ghaf Business Intelligence account',
                    invalid_login: 'Invalid email or password.',
                    email_address: 'Email address',
                    password: 'Password',
                    forgot_password: 'Forgot password?',
                    remember_me: 'Keep me signed in',
                    sign_in: 'Sign In',
                    copyright: '© Copyright. All Rights Reserved. Ghaf Bi Solutions'
                },
                ar: {
                    welcome_back: 'مرحبًا بعودتك',
                    sign_in_subtitle: 'سجّل الدخول إلى حساب غاف بزنس إنتليجنس',
                    invalid_login: 'البريد الإلكتروني أو كلمة المرور غير صحيحة.',
                    email_address: 'البريد الإلكتروني',
                    password: 'كلمة المرور',
                    forgot_password: 'هل نسيت كلمة المرور؟',
                    remember_me: 'تذكرني',
                    sign_in: 'تسجيل الدخول',
                    copyright: '© جميع الحقوق محفوظة. غاف بي سوليوشنز'
                }
            };

            function applyLanguage(lang) {
                root.lang = lang;
                root.dir = lang === 'ar' ? 'rtl' : 'ltr';
                root.dataset.lang = lang;
                try { localStorage.setItem('analytika-lang', lang); } catch (_) {}
                document.querySelectorAll('[data-i18n]').forEach(node => {
                    const key = node.getAttribute('data-i18n');
                    if (dict[lang] && dict[lang][key]) node.textContent = dict[lang][key];
                });
                if (themeLabel) {
                    const currentTheme = root.dataset.theme || 'light';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeLabel.textContent = (labels[lang] || labels.en)[currentTheme === 'dark' ? 'light' : 'dark'];
                }
                if (langEn && langAr) {
                    langEn.classList.toggle('active', lang === 'en');
                    langAr.classList.toggle('active', lang === 'ar');
                }
            }

            function applyTheme(theme) {
                root.dataset.theme = theme;
                try { localStorage.setItem('analytika-theme', theme); } catch (_) {}
                if (themeBtn && themeLabel) {
                    const lang = root.dataset.lang || 'en';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeBtn.querySelector('i').className = theme === 'dark' ? 'fas fa-sun me-1' : 'fas fa-moon me-1';
                    themeLabel.textContent = (labels[lang] || labels.en)[theme === 'dark' ? 'light' : 'dark'];
                }
            }

            const currentLang = root.dataset.lang || (function(){ try { return localStorage.getItem('analytika-lang'); } catch (_) { return null; } })() || 'en';
            const currentTheme = root.dataset.theme || (function(){ try { return localStorage.getItem('analytika-theme'); } catch (_) { return null; } })() || 'light';

            applyLanguage(currentLang);
            applyTheme(currentTheme);

            if (langEn) langEn.addEventListener('click', () => applyLanguage('en'));
            if (langAr) langAr.addEventListener('click', () => applyLanguage('ar'));
            if (themeBtn) themeBtn.addEventListener('click', () => applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark'));
        })();

        (() => {
            const canvas = document.getElementById('loginGlobeCanvas');
            const overlay = document.getElementById('loginGlobeOverlay');
            if (!canvas || !overlay) return;

            const markers = [
                { id: 'hq', location: [37.78, -122.44], name: 'HQ', users: 1420 },
                { id: 'eu', location: [52.52, 13.41], name: 'EU', users: 892 },
                { id: 'asia', location: [35.68, 139.65], name: 'Asia', users: 2103 },
                { id: 'latam', location: [-23.55, -46.63], name: 'LATAM', users: 567 },
                { id: 'mena', location: [25.2, 55.27], name: 'MENA', users: 734 },
                { id: 'oceania', location: [-33.87, 151.21], name: 'APAC', users: 445 }
            ];

            const ctx = canvas.getContext('2d');
            const dprMax = Math.min(window.devicePixelRatio || 1, 2);
            const state = {
                phi: -0.8,
                theta: 0.34,
                drag: null,
                dragging: false,
                expanded: null,
                nodes: []
            };

            function resize() {
                const size = Math.max(240, Math.min(320, canvas.parentElement?.clientWidth || 280));
                const dpr = Math.min(window.devicePixelRatio || 1, 2);
                canvas.width = Math.round(size * dpr);
                canvas.height = Math.round(size * dpr);
                canvas.style.width = size + 'px';
                canvas.style.height = size + 'px';
                overlay.style.width = size + 'px';
                overlay.style.height = size + 'px';
                ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
            }

            function createNode(marker) {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'login-globe-marker';
                btn.setAttribute('aria-label', marker.name);
                btn.innerHTML = `
                    <span class="login-globe-marker-name">${marker.name}</span>
                    <span class="login-globe-marker-meta">${marker.users.toLocaleString()} users</span>
                `;
                btn.addEventListener('click', () => {
                    state.expanded = state.expanded === marker.id ? null : marker.id;
                    syncExpanded();
                });
                overlay.appendChild(btn);
                return { marker, btn };
            }

            function syncExpanded() {
                state.nodes.forEach(({ marker, btn }) => {
                    const expanded = state.expanded === marker.id;
                    btn.classList.toggle('is-expanded', expanded);
                    btn.querySelector('.login-globe-marker-meta').style.display = expanded ? 'block' : 'none';
                });
            }

            function project(marker, cx, cy, radius) {
                const lon = (marker.location[1] * Math.PI) / 180;
                const lat = (marker.location[0] * Math.PI) / 180;
                const rot = lon + state.phi;
                const tilt = lat * state.theta;
                const x = cx + Math.cos(rot) * radius * 0.72;
                const y = cy + Math.sin(tilt) * radius * 0.7;
                const visibility = Math.max(0, Math.min(1, 0.5 + 0.5 * Math.cos(rot) * Math.cos(tilt)));
                return { x, y, visibility };
            }

            function draw(tick) {
                const w = canvas.width / dprMax;
                const h = canvas.height / dprMax;
                const size = Math.min(w, h);
                const cx = w / 2;
                const cy = h / 2;
                const radius = size * 0.38;

                ctx.clearRect(0, 0, w, h);

                const glow = ctx.createRadialGradient(cx - radius * 0.2, cy - radius * 0.25, radius * 0.2, cx, cy, radius * 1.5);
                glow.addColorStop(0, 'rgba(167,235,242,0.22)');
                glow.addColorStop(0.45, 'rgba(38,101,140,0.16)');
                glow.addColorStop(1, 'rgba(1,28,64,0.04)');
                ctx.fillStyle = glow;
                ctx.beginPath();
                ctx.arc(cx, cy, radius * 1.6, 0, Math.PI * 2);
                ctx.fill();

                const sphere = ctx.createRadialGradient(cx, cy, radius * 0.2, cx, cy, radius * 1.2);
                sphere.addColorStop(0, 'rgba(1,28,64,0.94)');
                sphere.addColorStop(0.72, 'rgba(84,172,191,0.90)');
                sphere.addColorStop(1, 'rgba(1,28,64,0.98)');
                ctx.fillStyle = sphere;
                ctx.beginPath();
                ctx.arc(cx, cy, radius, 0, Math.PI * 2);
                ctx.fill();

                ctx.save();
                ctx.beginPath();
                ctx.arc(cx, cy, radius, 0, Math.PI * 2);
                ctx.clip();

                const lineColor = 'rgba(167,235,242,0.36)';
                const lineColorMuted = 'rgba(246,248,252,0.14)';
                for (let i = -3; i <= 3; i++) {
                    const y = cy + (i / 3) * radius * 0.78 * state.theta;
                    ctx.strokeStyle = i === 0 ? lineColor : lineColorMuted;
                    ctx.lineWidth = i === 0 ? 1.8 : 1;
                    ctx.beginPath();
                    ctx.ellipse(cx, y, radius * 0.92, radius * (0.12 + Math.abs(i) * 0.035), 0, 0, Math.PI * 2);
                    ctx.stroke();
                }
                for (let i = -4; i <= 4; i++) {
                    const x = cx + (i / 4) * radius * 0.84;
                    ctx.strokeStyle = i === 0 ? lineColor : lineColorMuted;
                    ctx.lineWidth = i === 0 ? 1.8 : 1;
                    ctx.beginPath();
                    ctx.ellipse(x, cy, radius * 0.12, radius * 0.82, state.phi * 0.55, 0, Math.PI * 2);
                    ctx.stroke();
                }

                markers.forEach((marker, idx) => {
                    const proj = project(marker, cx, cy, radius);
                    const pulse = 0.5 + 0.5 * Math.sin((tick / 900) + idx);
                    const dot = ctx.createRadialGradient(proj.x, proj.y, 0, proj.x, proj.y, radius * 0.06);
                    dot.addColorStop(0, `rgba(246,248,252,${0.82 * pulse})`);
                    dot.addColorStop(0.5, 'rgba(167,235,242,0.52)');
                    dot.addColorStop(1, 'rgba(53,87,125,0.05)');
                    ctx.fillStyle = dot;
                    ctx.beginPath();
                    ctx.arc(proj.x, proj.y, radius * (0.028 + pulse * 0.01), 0, Math.PI * 2);
                    ctx.fill();
                });

                ctx.restore();
                ctx.strokeStyle = 'rgba(246,248,252,0.18)';
                ctx.lineWidth = 1.2;
                ctx.beginPath();
                ctx.arc(cx, cy, radius + 1, 0, Math.PI * 2);
                ctx.stroke();

                state.nodes.forEach(({ marker, btn }) => {
                    const proj = project(marker, cx, cy, radius);
                    btn.style.left = proj.x + 'px';
                    btn.style.top = proj.y + 'px';
                    btn.style.opacity = proj.visibility.toFixed(2);
                    btn.style.display = proj.visibility < 0.08 ? 'none' : 'inline-flex';
                    if (state.expanded !== marker.id) {
                        btn.classList.remove('is-expanded');
                        btn.querySelector('.login-globe-marker-meta').style.display = 'none';
                    }
                });

                if (!state.dragging) {
                    state.phi += 0.003;
                }
                requestAnimationFrame(draw);
            }

            canvas.addEventListener('pointerdown', (ev) => {
                state.drag = { x: ev.clientX, y: ev.clientY };
                state.dragging = true;
                canvas.setPointerCapture(ev.pointerId);
            });
            canvas.addEventListener('pointermove', (ev) => {
                if (!state.drag) return;
                state.phi += (ev.clientX - state.drag.x) / 300;
                state.theta += (ev.clientY - state.drag.y) / 1200;
                state.drag = { x: ev.clientX, y: ev.clientY };
            });
            window.addEventListener('pointerup', () => {
                state.drag = null;
                state.dragging = false;
            });
            window.addEventListener('pointercancel', () => {
                state.drag = null;
                state.dragging = false;
            });
            window.addEventListener('resize', resize);

            state.nodes = markers.map(createNode);
            syncExpanded();
            resize();
            draw(performance.now());
        })();
    </script>
</body>
</html>
