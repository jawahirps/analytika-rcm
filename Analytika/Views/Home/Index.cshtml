@model Analytika.Models.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ghaf Business Intelligence - Login</title>
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('analytika-lang') || 'en';
                var theme = localStorage.getItem('analytika-theme') || 'light';
                document.documentElement.lang = lang;
                document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
                document.documentElement.dataset.lang = lang;
                document.documentElement.dataset.theme = theme;
            } catch (_) {}
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            -webkit-font-smoothing: antialiased;
            background:
                radial-gradient(circle at 12% 18%, rgba(167,235,242,0.08), transparent 18%),
                linear-gradient(140deg, #011C40 0%, #0a2b55 38%, #f1f6fb 38%, #eef4fa 100%);
        }
        html[data-theme="dark"] body {
            background:
                radial-gradient(circle at 16% 16%, rgba(167,235,242,0.10), transparent 18%),
                linear-gradient(140deg, #011C40 0%, #071f41 42%, #062f53 100%);
            color: #EAF4FB;
        }

        .login-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(0, 1.35fr) minmax(360px, 0.75fr);
        }

        .viz-stage {
            position: relative;
            overflow: hidden;
            padding: 44px 44px 36px;
            color: #EAF4FB;
        }
        .viz-stage::before,
        .viz-stage::after {
            content: '';
            position: absolute;
            border: 1px solid rgba(167,235,242,0.08);
            border-radius: 28px;
            pointer-events: none;
        }
        .viz-stage::before { width: 520px; height: 520px; right: -260px; top: -180px; }
        .viz-stage::after { width: 300px; height: 300px; left: -120px; bottom: -120px; }

        .viz-head {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 28px;
        }
        .brand-lockup {
            display: flex;
            flex-direction: column;
            gap: 8px;
            max-width: 640px;
        }
        .brand-kicker {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            width: fit-content;
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid rgba(167,235,242,0.14);
            background: rgba(1,28,64,0.36);
            color: rgba(234,244,251,0.82);
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .16em;
            text-transform: uppercase;
        }
        .brand-kicker::before {
            content: '';
            width: 10px;
            height: 10px;
            border-radius: 999px;
            background: #A7EBF2;
            box-shadow: 0 0 0 5px rgba(167,235,242,0.12);
        }
        .brand-lockup h2 {
            max-width: 12ch;
            color: #fff;
            font-size: clamp(2rem, 4vw, 3.7rem);
            line-height: 1.02;
            font-weight: 800;
            letter-spacing: -0.06em;
        }
        .brand-lockup h2 span { color: #A7EBF2; }
        .brand-lockup p {
            max-width: 52ch;
            color: rgba(234,244,251,0.72);
            font-size: .98rem;
            line-height: 1.75;
        }
        .viz-status {
            display: grid;
            gap: 10px;
            min-width: 210px;
        }
        .viz-chip {
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(167,235,242,0.12);
            color: rgba(234,244,251,0.78);
            font-size: .76rem;
        }
        .viz-chip strong {
            display: block;
            color: #fff;
            font-size: 1rem;
            margin-top: 2px;
        }

        .viz-metrics {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
            margin-bottom: 18px;
        }
        .viz-metric {
            padding: 14px;
            border-radius: 18px;
            border: 1px solid rgba(167,235,242,0.10);
            background: rgba(1,28,64,0.26);
            backdrop-filter: blur(14px);
        }
        .viz-metric .label {
            color: rgba(234,244,251,0.68);
            font-size: .7rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
        }
        .viz-metric .value {
            margin-top: 6px;
            color: #fff;
            font-size: 1.55rem;
            font-weight: 800;
            line-height: 1.1;
        }
        .viz-metric .delta {
            margin-top: 4px;
            color: #A7EBF2;
            font-size: .74rem;
            font-weight: 700;
        }

        .viz-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1.55fr .95fr;
            gap: 14px;
        }
        .viz-panel {
            border-radius: 22px;
            border: 1px solid rgba(167,235,242,0.12);
            background: rgba(1,28,64,0.26);
            backdrop-filter: blur(18px) saturate(150%);
            -webkit-backdrop-filter: blur(18px) saturate(150%);
            box-shadow: 0 24px 56px rgba(0,0,0,0.18);
            overflow: hidden;
        }
        .viz-panel-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 16px 18px 0;
        }
        .viz-panel-title {
            color: #fff;
            font-size: .86rem;
            font-weight: 800;
            letter-spacing: .08em;
            text-transform: uppercase;
        }
        .viz-panel-sub {
            color: rgba(234,244,251,0.68);
            font-size: .73rem;
            font-weight: 600;
        }
        .viz-panel-body { padding: 12px 18px 18px; }
        .viz-line-chart { width: 100%; height: 230px; display: block; }
        .grid-note {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            margin-top: 8px;
            color: rgba(234,244,251,0.68);
            font-size: .72rem;
            font-weight: 600;
        }
        .mini-list { display: grid; gap: 10px; }
        .mini-row {
            display: grid;
            grid-template-columns: 88px 1fr 56px;
            gap: 10px;
            align-items: center;
        }
        .mini-label { color: #fff; font-size: .78rem; font-weight: 700; }
        .mini-track {
            height: 10px;
            border-radius: 999px;
            background: rgba(234,244,251,0.10);
            overflow: hidden;
        }
        .mini-fill {
            height: 100%;
            border-radius: 999px;
            background: linear-gradient(90deg, #A7EBF2 0%, #54ACBF 55%, #35577D 100%);
        }
        .mini-value {
            text-align: right;
            color: #A7EBF2;
            font-size: .74rem;
            font-weight: 800;
        }
        .donut-wrap {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 14px;
            align-items: center;
        }
        .donut {
            width: 138px;
            aspect-ratio: 1;
            border-radius: 50%;
            background:
                conic-gradient(#A7EBF2 0 34%, #54ACBF 34% 58%, #35577D 58% 76%, #0e4878 76% 100%);
            position: relative;
            box-shadow: inset 0 0 0 16px rgba(1,28,64,0.38);
        }
        .donut::after {
            content: '';
            position: absolute;
            inset: 34px;
            border-radius: 50%;
            background: rgba(1,28,64,0.92);
        }
        .donut-copy {
            display: grid;
            gap: 10px;
        }
        .donut-copy strong {
            color: #fff;
            font-size: 1.45rem;
            line-height: 1;
        }
        .donut-copy span { color: rgba(234,244,251,0.68); font-size: .76rem; }
        .legend {
            display: grid;
            gap: 8px;
            margin-top: 12px;
        }
        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            color: rgba(234,244,251,0.78);
            font-size: .74rem;
        }
        .legend-item .left {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .swatch {
            width: 10px;
            height: 10px;
            border-radius: 999px;
        }
        .swatch.teal { background: #A7EBF2; }
        .swatch.green { background: #54ACBF; }
        .swatch.gold { background: #35577D; }
        .swatch.blue { background: #0e4878; }

        .login-rail {
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 24px;
            background: linear-gradient(180deg, rgba(241,246,251,0.98) 0%, rgba(234,244,251,0.98) 100%);
        }
        html[data-theme="dark"] .login-rail {
            background: linear-gradient(180deg, rgba(1,28,64,0.88) 0%, rgba(5,24,52,0.94) 100%);
            color: #EAF4FB;
        }
        .login-top-tools {
            position: absolute;
            top: 18px;
            right: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        html[dir="rtl"] .login-top-tools {
            right: auto;
            left: 18px;
            flex-direction: row-reverse;
        }
        .auth-card {
            max-width: 460px;
            width: 100%;
            margin: 0 auto;
            padding: 30px 28px 26px;
            border-radius: 24px;
            background: rgba(255,255,255,0.94);
            border: 1px solid rgba(8,20,35,0.10);
            box-shadow: 0 24px 64px rgba(1,28,64,0.12);
        }
        html[data-theme="dark"] .auth-card {
            background: rgba(1,28,64,0.86);
            border-color: rgba(167,235,242,0.12);
            box-shadow: 0 24px 64px rgba(0,0,0,0.24);
        }
        .auth-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            width: fit-content;
            padding: 7px 10px;
            border-radius: 999px;
            background: rgba(167,235,242,0.16);
            color: #023859;
            font-size: .7rem;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }
        html[data-theme="dark"] .auth-kicker {
            background: rgba(167,235,242,0.12);
            color: #A7EBF2;
        }
        .auth-card h1 {
            margin: 18px 0 6px;
            color: #011C40;
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: -0.05em;
        }
        html[data-theme="dark"] .auth-card h1 { color: #fff; }
        .subtitle {
            color: #35577D;
            font-size: .92rem;
            line-height: 1.65;
            margin-bottom: 22px;
        }
        html[data-theme="dark"] .subtitle { color: rgba(234,244,251,0.72); }
        .form-label {
            color: #011C40;
            font-size: .78rem;
            font-weight: 700;
            margin-bottom: 6px;
            letter-spacing: .02em;
        }
        html[data-theme="dark"] .form-label { color: #EAF4FB; }
        .input-group { border-radius: 14px; overflow: hidden; }
        .input-icon,
        .input-group-text {
            background: rgba(167,235,242,0.12);
            color: #35577D;
            border: 1px solid rgba(84,172,191,0.18);
        }
        .input-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 42px;
            border-right: 0;
        }
        .form-control {
            border-color: rgba(84,172,191,0.18);
            box-shadow: none !important;
        }
        .form-control:focus {
            border-color: #54ACBF;
            box-shadow: 0 0 0 .18rem rgba(167,235,242,0.18) !important;
        }
        html[data-theme="dark"] .input-icon,
        html[data-theme="dark"] .input-group-text,
        html[data-theme="dark"] .form-control {
            background: rgba(1,28,64,0.82);
            color: #EAF4FB;
            border-color: rgba(167,235,242,0.14);
        }
        html[data-theme="dark"] .form-control::placeholder { color: rgba(234,244,251,0.5); }
        .form-control::placeholder { color: rgba(2,56,89,0.36); }
        .input-group .form-control { border-right: none; border-radius: 9px 0 0 9px; }
        .input-group-text {
            border-left: none;
            border-radius: 0 9px 9px 0;
            cursor: pointer;
            font-size: 0.85rem;
        }
        .input-group:focus-within .input-group-text { border-color: #54ACBF; }
        .input-group:focus-within .input-icon { border-color: #54ACBF; }

        .btn-signin {
            width: 100%;
            border: 1px solid rgba(1,28,64,0.16);
            border-radius: 16px;
            padding: 14px 18px;
            font-size: .92rem;
            font-weight: 800;
            letter-spacing: .02em;
            color: #011C40;
            background: linear-gradient(90deg, #A7EBF2 0%, #54ACBF 100%);
            box-shadow: 0 16px 36px rgba(84,172,191,0.24);
        }
        .btn-signin:hover { filter: brightness(1.02); }
        .forgot-link {
            color: #35577D;
            text-decoration: none;
            font-size: .76rem;
            font-weight: 700;
        }
        .forgot-link:hover { text-decoration: underline; }
        html[data-theme="dark"] .forgot-link { color: #A7EBF2; }
        .form-check-input:checked {
            background-color: #54ACBF;
            border-color: #54ACBF;
        }
        .form-check-input:focus { box-shadow: 0 0 0 .18rem rgba(84,172,191,0.18); }
        .alert-danger {
            font-size: .82rem;
            border-radius: 10px;
            background: rgba(239,68,68,0.07);
            border: none;
            border-left: 3px solid #ef4444;
            color: #b91c1c;
            padding: 10px 14px;
        }
        .auth-meta {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-top: 18px;
        }
        .auth-meta-item {
            padding: 12px;
            border-radius: 16px;
            background: rgba(167,235,242,0.12);
            border: 1px solid rgba(84,172,191,0.14);
        }
        .auth-meta-item strong {
            display: block;
            color: #011C40;
            font-size: .92rem;
        }
        .auth-meta-item span {
            color: #35577D;
            font-size: .72rem;
        }
        html[data-theme="dark"] .auth-meta-item {
            background: rgba(1,28,64,0.60);
            border-color: rgba(167,235,242,0.12);
        }
        html[data-theme="dark"] .auth-meta-item strong,
        html[data-theme="dark"] .auth-meta-item span { color: rgba(234,244,251,0.82); }

        .right-footer {
            max-width: 460px;
            margin: 14px auto 0;
            color: rgba(53,87,125,0.76);
            font-size: .72rem;
            text-align: center;
        }
        html[data-theme="dark"] .right-footer { color: rgba(234,244,251,0.54); }

        html[dir="rtl"] .brand-lockup,
        html[dir="rtl"] .auth-card {
            text-align: right;
        }
        html[dir="rtl"] .brand-lockup h2 { margin-inline-start: auto; }
        html[dir="rtl"] .brand-lockup p { margin-inline-start: auto; }

        @@media (max-width: 1120px) {
            .login-shell { grid-template-columns: 1fr; }
            .login-rail { padding-top: 72px; }
        }
        @@media (max-width: 780px) {
            .viz-stage { padding: 28px 18px 18px; }
            .viz-head { flex-direction: column; }
            .viz-metrics { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .viz-grid { grid-template-columns: 1fr; }
            .auth-meta { grid-template-columns: 1fr; }
            .auth-card { padding: 24px 18px 20px; }
            .login-top-tools { position: static; justify-content: flex-end; margin-bottom: 12px; }
            .login-rail { padding: 18px; }
        }
        @@media (max-width: 520px) {
            .viz-metrics { grid-template-columns: 1fr; }
            .donut-wrap { grid-template-columns: 1fr; justify-items: start; }
            .mini-row { grid-template-columns: 1fr; }
            .mini-value { text-align: left; }
        }
    </style>
</head>
<body>
    <div class="login-shell">
        <section class="viz-stage">
            <div class="viz-head">
                <div class="brand-lockup">
                    <div class="brand-kicker">Ghaf Business Intelligence</div>
                    <h2>Chart-first access for healthcare operations.</h2>
                    <p>Sign in to the analytics workspace for submissions, remittance, recovery, and operational review.</p>
                </div>
                <div class="viz-status">
                    <div class="viz-chip">Refresh cycle<strong>Live analytics</strong></div>
                    <div class="viz-chip">Scope<strong>Submissions and remittance</strong></div>
                    <div class="viz-chip">Locale<strong>Arabic and English</strong></div>
                </div>
            </div>

            <div class="viz-metrics">
                <div class="viz-metric">
                    <div class="label">Total Claims</div>
                    <div class="value">124K</div>
                    <div class="delta">+8.4% vs last month</div>
                </div>
                <div class="viz-metric">
                    <div class="label">Net Value</div>
                    <div class="value">AED 18M</div>
                    <div class="delta">+5.1% growth</div>
                </div>
                <div class="viz-metric">
                    <div class="label">Clean Rate</div>
                    <div class="value">96%</div>
                    <div class="delta">+2.7 points</div>
                </div>
                <div class="viz-metric">
                    <div class="label">Turnaround</div>
                    <div class="value">4.2d</div>
                    <div class="delta">-1.3 days</div>
                </div>
            </div>

            <div class="viz-grid">
                <article class="viz-panel">
                    <div class="viz-panel-head">
                        <div>
                            <div class="viz-panel-title">Monthly trend</div>
                            <div class="viz-panel-sub">Claims and remittance movement over time</div>
                        </div>
                        <div class="viz-panel-sub">Updated just now</div>
                    </div>
                    <div class="viz-panel-body">
                        <svg class="viz-line-chart" viewBox="0 0 720 240" preserveAspectRatio="none" aria-hidden="true">
                            <defs>
                                <linearGradient id="lineGlow" x1="0" x2="0" y1="0" y2="1">
                                    <stop offset="0%" stop-color="#A7EBF2" stop-opacity="0.9" />
                                    <stop offset="100%" stop-color="#A7EBF2" stop-opacity="0.1" />
                                </linearGradient>
                            </defs>
                            <g opacity="0.16" stroke="#EAF4FB">
                                <line x1="0" y1="36" x2="720" y2="36" />
                                <line x1="0" y1="84" x2="720" y2="84" />
                                <line x1="0" y1="132" x2="720" y2="132" />
                                <line x1="0" y1="180" x2="720" y2="180" />
                                <line x1="0" y1="228" x2="720" y2="228" />
                            </g>
                            <path d="M0,188 C70,170 100,78 160,92 C230,108 245,186 310,152 C370,122 402,42 470,68 C540,95 572,165 640,126 C680,102 700,88 720,74 L720,240 L0,240 Z"
                                  fill="url(#lineGlow)" opacity="0.32"></path>
                            <path d="M0,188 C70,170 100,78 160,92 C230,108 245,186 310,152 C370,122 402,42 470,68 C540,95 572,165 640,126 C680,102 700,88 720,74"
                                  fill="none" stroke="#A7EBF2" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"></path>
                            <circle cx="160" cy="92" r="5" fill="#fff" />
                            <circle cx="310" cy="152" r="5" fill="#fff" />
                            <circle cx="470" cy="68" r="5" fill="#fff" />
                            <circle cx="640" cy="126" r="5" fill="#fff" />
                        </svg>
                        <div class="grid-note">
                            <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span><span>May</span><span>Jun</span>
                        </div>
                    </div>
                </article>

                <article class="viz-panel">
                    <div class="viz-panel-head">
                        <div>
                            <div class="viz-panel-title">Payer mix</div>
                            <div class="viz-panel-sub">Distribution by network and status</div>
                        </div>
                    </div>
                    <div class="viz-panel-body">
                        <div class="donut-wrap">
                            <div class="donut" aria-hidden="true"></div>
                            <div class="donut-copy">
                                <strong>78%</strong>
                                <span>clean, payable and reconciled records</span>
                            </div>
                        </div>
                        <div class="legend">
                            <div class="legend-item"><span class="left"><span class="swatch teal"></span>Clean</span><span>34%</span></div>
                            <div class="legend-item"><span class="left"><span class="swatch green"></span>Pending</span><span>24%</span></div>
                            <div class="legend-item"><span class="left"><span class="swatch gold"></span>Denied</span><span>18%</span></div>
                            <div class="legend-item"><span class="left"><span class="swatch blue"></span>Open</span><span>24%</span></div>
                        </div>
                    </div>
                </article>

                <article class="viz-panel" style="grid-column: 1 / -1;">
                    <div class="viz-panel-head">
                        <div>
                            <div class="viz-panel-title">Department throughput</div>
                            <div class="viz-panel-sub">Volume, follow-up work and turnaround markers</div>
                        </div>
                    </div>
                    <div class="viz-panel-body">
                        <div class="mini-list">
                            <div class="mini-row">
                                <div class="mini-label">Emergency</div>
                                <div class="mini-track"><div class="mini-fill" style="width: 88%;"></div></div>
                                <div class="mini-value">88%</div>
                            </div>
                            <div class="mini-row">
                                <div class="mini-label">Cardiology</div>
                                <div class="mini-track"><div class="mini-fill" style="width: 76%;"></div></div>
                                <div class="mini-value">76%</div>
                            </div>
                            <div class="mini-row">
                                <div class="mini-label">Radiology</div>
                                <div class="mini-track"><div class="mini-fill" style="width: 64%;"></div></div>
                                <div class="mini-value">64%</div>
                            </div>
                            <div class="mini-row">
                                <div class="mini-label">Orthopedics</div>
                                <div class="mini-track"><div class="mini-fill" style="width: 52%;"></div></div>
                                <div class="mini-value">52%</div>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        </section>

        <aside class="login-rail">
            <div class="login-top-tools">
                <div class="btn-group btn-group-sm" role="group" aria-label="Language toggle">
                    <button type="button" class="btn btn-outline-secondary lang-toggle-btn active" id="loginLangEn">EN</button>
                    <button type="button" class="btn btn-outline-secondary lang-toggle-btn" id="loginLangAr">AR</button>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm theme-toggle-btn" id="loginThemeToggle">
                    <i class="fas fa-moon me-1"></i><span id="loginThemeLabel">Dark</span>
                </button>
            </div>

            <div class="auth-card">
                <div class="auth-kicker" data-i18n="welcome_back">Welcome back</div>
                <h1>Access the dashboard</h1>
                <p class="subtitle">Sign in to your Ghaf Business Intelligence account</p>

                <form asp-controller="Home" asp-action="Index" method="post">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-4" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i><span data-i18n="invalid_login">Invalid email or password.</span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label" data-i18n="email_address">Email address</label>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" autocomplete="username" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label asp-for="Password" class="form-label mb-0" data-i18n="password">Password</label>
                            <a href="#" class="forgot-link" data-i18n="forgot_password">Forgot password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-icon"><i class="fas fa-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" id="pwdInput" />
                            <span class="input-group-text" onclick="togglePwd()"><i class="fas fa-eye" id="pwdIcon"></i></span>
                        </div>
                    </div>

                    <div class="mb-4 d-flex align-items-center gap-2">
                        <input asp-for="RememberMe" class="form-check-input mt-0" style="width:16px;height:16px;" />
                        <label asp-for="RememberMe" class="form-label mb-0" style="font-weight:500;font-size:.82rem;text-transform:none;letter-spacing:0;" data-i18n="remember_me">Keep me signed in</label>
                    </div>

                    <button type="submit" class="btn-signin">
                        <span data-i18n="sign_in">Sign In</span> <i class="fas fa-arrow-right ms-2" style="font-size:.75rem;opacity:.9;"></i>
                    </button>
                </form>

                <div class="auth-meta">
                    <div class="auth-meta-item">
                        <strong>Secure</strong>
                        <span>Role-based access</span>
                    </div>
                    <div class="auth-meta-item">
                        <strong>Fast</strong>
                        <span>Low-friction entry</span>
                    </div>
                    <div class="auth-meta-item">
                        <strong>Clear</strong>
                        <span>Chart-first UI</span>
                    </div>
                </div>
            </div>

            <div class="right-footer" data-i18n="copyright">© Copyright. All Rights Reserved. Ghaf Bi Solutions</div>
        </aside>
    </div>

    <script>
        function togglePwd() {
            const input = document.getElementById('pwdInput');
            const icon = document.getElementById('pwdIcon');
            input.type = input.type === 'password' ? 'text' : 'password';
            icon.classList.toggle('fa-eye');
            icon.classList.toggle('fa-eye-slash');
        }

        (function initLoginLanguageTheme() {
            const root = document.documentElement;
            const langEn = document.getElementById('loginLangEn');
            const langAr = document.getElementById('loginLangAr');
            const themeBtn = document.getElementById('loginThemeToggle');
            const themeLabel = document.getElementById('loginThemeLabel');
            const dict = {
                en: {
                    welcome_back: 'Welcome back',
                    sign_in_subtitle: 'Sign in to your Ghaf Business Intelligence account',
                    invalid_login: 'Invalid email or password.',
                    email_address: 'Email address',
                    password: 'Password',
                    forgot_password: 'Forgot password?',
                    remember_me: 'Keep me signed in',
                    sign_in: 'Sign In',
                    copyright: '© Copyright. All Rights Reserved. Ghaf Bi Solutions'
                },
                ar: {
                    welcome_back: 'مرحبًا بعودتك',
                    sign_in_subtitle: 'سجّل الدخول إلى حساب غاف بزنس إنتليجنس',
                    invalid_login: 'البريد الإلكتروني أو كلمة المرور غير صحيحة.',
                    email_address: 'البريد الإلكتروني',
                    password: 'كلمة المرور',
                    forgot_password: 'هل نسيت كلمة المرور؟',
                    remember_me: 'تذكرني',
                    sign_in: 'تسجيل الدخول',
                    copyright: '© جميع الحقوق محفوظة. غاف بي سوليوشنز'
                }
            };

            function applyLanguage(lang) {
                root.lang = lang;
                root.dir = lang === 'ar' ? 'rtl' : 'ltr';
                root.dataset.lang = lang;
                try { localStorage.setItem('analytika-lang', lang); } catch (_) {}
                document.querySelectorAll('[data-i18n]').forEach(node => {
                    const key = node.getAttribute('data-i18n');
                    if (dict[lang] && dict[lang][key]) node.textContent = dict[lang][key];
                });
                if (themeLabel) {
                    const currentTheme = root.dataset.theme || 'light';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeLabel.textContent = (labels[lang] || labels.en)[currentTheme === 'dark' ? 'light' : 'dark'];
                }
                if (langEn && langAr) {
                    langEn.classList.toggle('active', lang === 'en');
                    langAr.classList.toggle('active', lang === 'ar');
                }
            }

            function applyTheme(theme) {
                root.dataset.theme = theme;
                try { localStorage.setItem('analytika-theme', theme); } catch (_) {}
                if (themeBtn && themeLabel) {
                    const lang = root.dataset.lang || 'en';
                    const labels = { en: { dark: 'Dark', light: 'Light' }, ar: { dark: 'داكن', light: 'فاتح' } };
                    themeBtn.querySelector('i').className = theme === 'dark' ? 'fas fa-sun me-1' : 'fas fa-moon me-1';
                    themeLabel.textContent = (labels[lang] || labels.en)[theme === 'dark' ? 'light' : 'dark'];
                }
            }

            const currentLang = root.dataset.lang || (function(){ try { return localStorage.getItem('analytika-lang'); } catch (_) { return null; } })() || 'en';
            const currentTheme = root.dataset.theme || (function(){ try { return localStorage.getItem('analytika-theme'); } catch (_) { return null; } })() || 'light';

            applyLanguage(currentLang);
            applyTheme(currentTheme);

            if (langEn) langEn.addEventListener('click', () => applyLanguage('en'));
            if (langAr) langAr.addEventListener('click', () => applyLanguage('ar'));
            if (themeBtn) themeBtn.addEventListener('click', () => applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark'));
        })();
    </script>
</body>
</html>
