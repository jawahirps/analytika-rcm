@model Analytika.Models.ViewModels.FacilityStatusViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    .dash-section {
        --dash-paper: #fbfaf7;
        --dash-bg: #f2f1ee;
        --dash-ink: #111111;
        --dash-muted: #5f6260;
        --dash-line: #d9d6cf;
        --dash-indigo: #332985;
        --dash-ochre: #c0863f;
        --dash-red: #c61f32;
        max-width: 1500px;
        margin: 0 auto;
        padding: 28px 24px 80px;
        color: var(--dash-ink);
    }
    body {
        background:
            linear-gradient(115deg, transparent 0 22%, rgba(51,41,133,.055) 22.1% 22.7%, transparent 22.8% 100%),
            radial-gradient(circle at 86% 8%, rgba(192,134,63,.14), transparent 28%),
            linear-gradient(180deg, #fbfaf7 0%, var(--dash-bg) 100%) !important;
    }

    .dashboard-hero {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        margin-bottom: 24px;
        padding: 22px 24px;
        border-radius: 24px;
        border: 1px solid var(--dash-line);
        background:
            repeating-linear-gradient(0deg, transparent 0 13px, rgba(17,17,17,.035) 13px 14px),
            radial-gradient(circle at top right, rgba(192,134,63,.16), transparent 24%),
            linear-gradient(145deg, rgba(251,250,247,.94) 0%, rgba(242,241,238,.92) 100%);
        box-shadow: 0 18px 46px rgba(17,17,17,.08);
        position: relative;
        overflow: hidden;
    }
    .dashboard-hero::after {
        content: "";
        position: absolute;
        right: 24px;
        bottom: 18px;
        width: 108px;
        height: 8px;
        background: linear-gradient(90deg, var(--dash-indigo) 0 32%, var(--dash-ochre) 32% 64%, var(--dash-red) 64% 100%);
        opacity: .85;
        pointer-events: none;
    }
    .dashboard-hero-copy {
        display: grid;
        gap: 8px;
        max-width: 760px;
    }
    .dashboard-kicker {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(51,41,133,.10);
        color: var(--dash-indigo);
        font-size: .625rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
    }
    .dashboard-hero h4 {
        margin: 0;
        color: var(--dash-ink);
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -.04em;
        line-height: 1.15;
    }
    .dashboard-hero p {
        margin: 0;
        color: var(--dash-muted);
        max-width: 66ch;
        font-size: .625rem;
        font-weight: 200;
        line-height: 1.7;
    }
    .dashboard-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
    }
    .dashboard-hero .btn {
        border-radius: 999px;
    }
    .dashboard-hero .btn-outline-secondary {
        background: rgba(251,250,247,.78) !important;
        border-color: var(--dash-line) !important;
        color: var(--dash-ink) !important;
    }
    .dashboard-hero-stats {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 2px;
    }
    .dashboard-stat-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 11px;
        border-radius: 999px;
        background: rgba(251,250,247,.78);
        border: 1px solid var(--dash-line);
        color: var(--dash-ink);
        font-size: .625rem;
        font-weight: 500;
    }
    .dashboard-stat-pill i { color: var(--dash-ochre); }

    /* Summary chips */
    .status-summary {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
        margin-bottom: 28px;
    }
    .ss-card {
        background: rgba(251,250,247,.90);
        border-radius: 20px;
        padding: 20px 18px 16px;
        box-shadow: 0 18px 42px rgba(17,17,17,.08), inset 0 1px 0 rgba(255,255,255,.84);
        display: flex; align-items: center; gap: 14px;
        border: 1px solid var(--dash-line);
    }
    .ss-icon {
        width: 46px; height: 46px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; flex-shrink: 0;
    }
    .ss-icon.green  { background: rgba(51,41,133,.10); color: var(--dash-indigo); }
    .ss-icon.amber  { background: rgba(192,134,63,.15); color: #8a551b; }
    .ss-icon.red    { background: rgba(198,31,50,.10); color: var(--dash-red); }
    .ss-icon.blue   { background: rgba(17,17,17,.07); color: var(--dash-ink); }
    .ss-icon.purple { background: rgba(51,41,133,.10); color: var(--dash-indigo); }
    .ss-num  { font-size: 1.8rem; font-weight: 700; color: var(--dash-ink); line-height: 1; }
    .ss-lbl  { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; color: var(--dash-muted); margin-top: 2px; }

    /* Facility grid */
    .facility-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }
    .fac-status-card {
        background: rgba(251,250,247,.90);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 18px 42px rgba(17,17,17,.08), inset 0 1px 0 rgba(255,255,255,.84);
        border: 1px solid var(--dash-line);
        border-left: 4px solid var(--dash-line);
        position: relative;
        transition: box-shadow .15s, transform .15s;
        cursor: pointer;
    }
    .fac-status-card:hover {
        box-shadow: 0 18px 42px rgba(17,17,17,.12);
        transform: translateY(-2px);
    }
    .fac-status-card a { text-decoration: none; color: inherit; display: block; }
    .fac-status-card a:hover { text-decoration: none; }
    .fac-status-card.connected    { border-left-color: var(--dash-indigo); }
    .fac-status-card.degraded     { border-left-color: var(--dash-ochre); }
    .fac-status-card.disconnected { border-left-color: var(--dash-red); }

    .fac-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
    .fac-title-wrap { min-width: 0; }
    .fac-name   { font-size: .92rem; font-weight: 700; color: var(--dash-ink); line-height: 1.3; max-width: 190px; }
    .fac-portal { font-size: .68rem; font-weight: 700; letter-spacing: .4px; color: var(--dash-indigo); background: rgba(51,41,133,.10); padding: 2px 8px; border-radius: 99px; white-space: nowrap; }
    .fac-status-wrap {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 4px;
        min-width: 84px;
        text-align: right;
    }

    .status-dot {
        width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; margin-top: 4px;
    }
    .status-dot.connected    { background: var(--dash-indigo); box-shadow: 0 0 0 3px rgba(51,41,133,.10); }
    .status-dot.degraded     { background: var(--dash-ochre); box-shadow: 0 0 0 3px rgba(192,134,63,.14); }
    .status-dot.disconnected { background: var(--dash-red); box-shadow: 0 0 0 3px rgba(198,31,50,.10); }

    .fac-meta { display: flex; flex-direction: column; gap: 6px; }
    .fac-meta-row { display: flex; align-items: center; gap: 6px; font-size: .78rem; color: var(--dash-muted); }
    .fac-meta-row i { width: 14px; text-align: center; color: var(--dash-ochre); font-size: .7rem; }
    .fac-meta-row .val { color: var(--dash-ink); font-weight: 600; }

    .fac-status-bar { margin-top: 12px; margin-bottom: 12px; }
    .fac-status-label { font-size: .68rem; color: var(--dash-muted); font-weight: 700; margin-bottom: 6px; display: flex; justify-content: space-between; }
    .fac-progress-container {
        width: 100%; height: 8px; background: rgba(17,17,17,.08); border-radius: 4px; overflow: hidden;
    }
    .fac-progress-bar {
        height: 100%; background: linear-gradient(90deg, var(--dash-indigo) 0%, var(--dash-ochre) 100%); border-radius: 4px;
        transition: width .3s ease;
    }
    .fac-status-counts { font-size: .65rem; color: var(--dash-muted); font-weight: 600; }
    .fac-status-counts .downloaded { color: var(--dash-indigo); font-weight: 600; }
    .fac-status-counts .pending { color: #8a551b; font-weight: 600; }

    .fac-stats { display: flex; gap: 16px; margin-top: 14px; padding-top: 12px; border-top: 1px solid var(--dash-line); }
    .fac-stat  { text-align: center; flex: 1; }
    .fac-stat .n  { font-size: 1.1rem; font-weight: 700; color: var(--dash-ink); }
    .fac-stat .l  { font-size: .65rem; color: var(--dash-muted); text-transform: uppercase; letter-spacing: .4px; font-weight: 700; }
    .fac-stat .meta-inline { font-size: .72rem; color: var(--dash-muted); font-weight: 600; margin-top: 2px; line-height: 1.2; }

    .status-label { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .5px; }
    .status-label.connected    { color: var(--dash-indigo); }
    .status-label.degraded     { color: #8a551b; }
    .status-label.disconnected { color: var(--dash-red); }

    @@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.5} }
    .dot-pulse { animation: pulse 2s infinite; }

    @@media (max-width: 1100px) {
        .dashboard-hero {
            align-items: flex-start;
            flex-direction: column;
        }
        .dashboard-hero-actions {
            justify-content: flex-start;
            width: 100%;
        }
        .status-summary { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @@media (max-width: 720px) {
        .status-summary { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .dashboard-hero-actions .btn { flex: 1 1 180px; justify-content: center; }
        .dashboard-stat-pill { flex: 1 1 150px; justify-content: center; }
    }
    @@media (max-width: 480px) {
        .dash-section { padding: 14px 10px 72px; }
        .dashboard-hero { padding: 16px 14px; border-radius: 12px; gap: 14px; }
        .dashboard-kicker { font-size: .62rem; letter-spacing: .08em; max-width: 100%; white-space: normal; }
        .dashboard-hero h4 { font-size: 1.18rem; line-height: 1.22; letter-spacing: -0.025em; }
        .dashboard-hero p { font-size: .82rem; line-height: 1.55; }
        .dashboard-hero-actions { justify-content: flex-start; }
        .dashboard-hero-actions .btn { flex-basis: 100%; }
        .status-summary { grid-template-columns: 1fr; gap: 10px; margin-bottom: 20px; }
        .ss-card { padding: 14px 13px; border-radius: 12px; }
        .ss-icon { width: 40px; height: 40px; border-radius: 8px; }
        .ss-num { font-size: 1.45rem; }
        .facility-grid { grid-template-columns: 1fr; gap: 12px; }
        .fac-status-card { padding: 14px; border-radius: 12px; }
        .fac-name { max-width: 100%; font-size: .88rem; }
        .fac-header { gap: 10px; flex-wrap: wrap; }
        .fac-title-wrap { flex: 1 1 100%; }
        .fac-status-wrap {
            flex-direction: row;
            align-items: center;
            justify-content: flex-start;
            min-width: 0;
            width: 100%;
            text-align: left;
            order: 3;
        }
        .fac-portal { max-width: 100%; overflow: hidden; text-overflow: ellipsis; }
        .fac-stats { gap: 10px; }
        .fac-stat { min-width: 0; }
        .fac-stat .n { font-size: 1rem; }
        .d-flex.align-items-center.justify-content-between.mb-4 {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 12px;
        }
        .d-flex.gap-2 {
            width: 100%;
        }
        .d-flex.gap-2 > a.btn {
            flex: 1 1 0;
            justify-content: center;
        }
    }
</style>
}

<div class="dash-section">
    <!-- Page hero -->
    <div class="dashboard-hero">
        <div class="dashboard-hero-copy">
            <div class="dashboard-kicker">Operations overview</div>
            <h4>Facility Status</h4>
            <p>Live connectivity and sync health across registered facilities, with quick access into portal sync and credential management.</p>
            <div class="dashboard-hero-stats">
                <span class="dashboard-stat-pill"><i class="fas fa-check-circle"></i>@Model.ConnectedCount connected</span>
                <span class="dashboard-stat-pill"><i class="fas fa-exclamation-circle"></i>@Model.DegradedCount degraded</span>
                <span class="dashboard-stat-pill"><i class="fas fa-times-circle"></i>@Model.DisconnectedCount disconnected</span>
            </div>
        </div>
        <div class="dashboard-hero-actions">
            <a href="/Portal/Sync" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-sync-alt me-1"></i> Sync Portal
            </a>
            <a href="/Admin/Credentials" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-key me-1"></i> Credentials
            </a>
        </div>
    </div>

    <!-- Summary row -->
    <div class="status-summary">
        <div class="ss-card">
            <div class="ss-icon green"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="ss-num">@Model.ConnectedCount</div>
                <div class="ss-lbl">Connected</div>
            </div>
        </div>
        <div class="ss-card">
            <div class="ss-icon amber"><i class="fas fa-exclamation-circle"></i></div>
            <div>
                <div class="ss-num">@Model.DegradedCount</div>
                <div class="ss-lbl">Degraded</div>
            </div>
        </div>
        <div class="ss-card">
            <div class="ss-icon red"><i class="fas fa-times-circle"></i></div>
            <div>
                <div class="ss-num">@Model.DisconnectedCount</div>
                <div class="ss-lbl">Disconnected</div>
            </div>
        </div>
        <div class="ss-card">
            <div class="ss-icon blue"><i class="fas fa-file-alt"></i></div>
            <div>
                <div class="ss-num">@Model.TotalRecords.ToString("N0")</div>
                <div class="ss-lbl">Total Records</div>
                <div class="text-muted small mt-1">Claims @Model.TotalClaimCount.ToString("N0")</div>
            </div>
        </div>
        <div class="ss-card">
            <div class="ss-icon purple"><i class="fas fa-download"></i></div>
            <div>
                <div class="ss-num">@Model.TotalFiles.ToString("N0")</div>
                <div class="ss-lbl">Files Downloaded</div>
            </div>
        </div>
    </div>

    <!-- Facility cards -->
    <div class="facility-grid">
        @foreach (var f in Model.Facilities)
        {
            var statusClass = f.Status switch {
                Analytika.Models.ViewModels.FacilityConnectionStatus.Connected    => "connected",
                Analytika.Models.ViewModels.FacilityConnectionStatus.Degraded     => "degraded",
                _                                                                  => "disconnected"
            };
            var statusLabel = f.Status switch {
                Analytika.Models.ViewModels.FacilityConnectionStatus.Connected    => "Connected",
                Analytika.Models.ViewModels.FacilityConnectionStatus.Degraded     => "Degraded",
                _                                                                  => f.HasCredential ? "Not Synced" : "No Credential"
            };
            <a href="/Portal/SyncedData?facilityId=@f.FacilityId@(f.Portal != null ? $"&portal={f.Portal}" : "")" class="fac-status-card @statusClass">
                <div class="fac-header">
                    <div class="fac-title-wrap">
                        <div class="fac-name">@f.FacilityName</div>
                        @if (f.Portal != null)
                        {
                            <span class="fac-portal mt-1 d-inline-block">@f.Portal</span>
                        }
                    </div>
                    <div class="fac-status-wrap"
                         title="@f.StatusReason" data-bs-toggle="tooltip" data-bs-placement="left">
                        <div class="status-dot @statusClass @(statusClass == "connected" ? "dot-pulse" : "")"></div>
                        <span class="status-label @statusClass">@statusLabel</span>
                    </div>
                </div>

                <div class="fac-meta">
                    @if (f.LastSyncTime != null)
                    {
                        <div class="fac-meta-row">
                            <i class="fas fa-clock"></i>
                            <span>Last sync: <span class="val">@f.LastSyncTime</span></span>
                        </div>
                        <div class="fac-meta-row">
                            <i class="fas fa-circle @(f.LastSyncStatus == "Success" ? "text-success" : "text-danger")" style="font-size:.5rem;"></i>
                            <span class="val">@(f.LastSyncStatus ?? "Unknown")</span>
                        </div>
                    }
                    else
                    {
                        <div class="fac-meta-row">
                            <i class="fas fa-clock"></i>
                            <span class="text-muted fst-italic">Never synced</span>
                        </div>
                    }
                </div>

                @if (f.TotalFilesWithStatus > 0)
                {
                    var downloadProgress = f.DownloadedFilesCount + f.PendingFilesCount > 0
                        ? Math.Round((double)f.DownloadedFilesCount / (f.DownloadedFilesCount + f.PendingFilesCount) * 100)
                        : 0;
                    <div class="fac-status-bar">
                        <div class="fac-status-label">
                            <span>File Download Status</span>
                            <span class="fac-status-counts">
                                <span class="downloaded">@f.DownloadedFilesCount</span>
                                <span>/</span>
                                <span class="pending">@f.PendingFilesCount</span>
                            </span>
                        </div>
                        <div class="fac-progress-container">
                            <div class="fac-progress-bar" style="width: @downloadProgress%;" title="@f.DownloadedFilesCount downloaded, @f.PendingFilesCount pending"></div>
                        </div>
                    </div>
                }

                <div class="fac-stats">
                    <div class="fac-stat">
                        <div class="n">@f.RecordCount.ToString("N0")</div>
                        <div class="l">Records</div>
                        <div class="meta-inline">Claims @f.ClaimCount.ToString("N0")</div>
                    </div>
                    <div class="fac-stat">
                        <div class="n">@f.FileCount.ToString("N0")</div>
                        <div class="l">Files</div>
                    </div>
                </div>
            </a>
        }
    </div>

    @if (!Model.Facilities.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="fas fa-hospital fa-3x d-block mb-3 opacity-25"></i>
            <p class="mb-0">No active facilities found. <a href="/Admin/Credentials">Add credentials</a> to get started.</p>
        </div>
    }
</div>
