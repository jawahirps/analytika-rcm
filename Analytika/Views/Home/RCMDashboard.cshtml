}
.metric-card:nth-child(2) .metric-delta,
.metric-card:nth-child(3) .metric-delta {
    color:#a7465e !important;
    background:#f2ccd5;
    border-color:#d99aaa;
}
.metric-spark {
    height:55px;
    margin-top:.85rem;
    display:flex;
    align-items:end;
    gap:7px;
    border-bottom:1px dashed #cfd6df;
}
.metric-spark span {
    width:18%;
    border-radius:999px 999px 0 0;
    background:linear-gradient(180deg, transparent 0 45%, #b7bec8 46% 52%, transparent 53% 100%);
    position:relative;
}
.metric-spark span::after {
    content:"";
    display:block;
    height:2px;
    background:#8a9098;
    transform:rotate(-20deg);
    transform-origin:left center;
}
.metric-spark span:nth-child(1)::after { transform:rotate(50deg); }
.metric-spark span:nth-child(2)::after { transform:rotate(-38deg); }
.metric-spark span:nth-child(3)::after { transform:rotate(18deg); }
.metric-spark span:nth-child(4)::after { transform:rotate(34deg); }
.metric-spark span:nth-child(5)::after { transform:rotate(-45deg); background:#53b66b; }
.metric-spark span:nth-child(6)::after { transform:rotate(24deg); background:#bb405e; }
.dash-grid {
    display:grid;
    grid-template-columns:minmax(0,1.5fr) minmax(360px,.9fr);
    gap:1.35rem;
    align-items:start;
}
.dash-grid .panel:first-child {
    grid-row:span 2;
    min-height:575px;
}
.panel {
    padding:1.35rem 1.45rem;
