@model Analytika.Models.ViewModels.RCMDashboardViewModel
@{
    ViewData["Title"] = "BI Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tabMeta = new Dictionary<string, (string Icon, string Desc)>
    {
        ["Submissions"]   = ("fa-paper-plane",    "Claim submission volumes, acceptance rates & timelines"),
        ["Resubmissions"] = ("fa-redo-alt",        "Resubmitted claims tracking & resolution outcomes"),
        ["Remittance"]    = ("fa-money-bill-wave", "Remittance advice reconciliation & payment analysis"),
        ["Denials"]       = ("fa-ban",             "Denial patterns, root causes & denial rate trends"),
        ["Clinicians"]    = ("fa-user-md",         "Clinician-level productivity & claim performance"),
        ["Operations"]    = ("fa-cogs",            "Operational KPIs, TAT metrics & SLA compliance"),
        ["Insurance"]     = ("fa-shield-alt",      "Payer-wise analysis, approval rates & payment terms"),
        ["Department"]    = ("fa-building",        "Department & facility breakdown with benchmarks"),
    };

    bool isConfigured = !string.IsNullOrEmpty(Model.EmbedToken)
                     && Model.EmbedToken != "PENDING"
                     && !Model.EmbedToken!.StartsWith("DEMO_TOKEN");
}

@section Styles {
<style>
:root { --navy:#0A1828; --gold:#C87A10; --gold-lt:#FDF3E0; --border:#e5e7eb; }

/* ── Full-height shell ─────────────────────────────────────────── */
.bi-shell {
    display:flex; flex-direction:column;
    height:calc(100vh - 56px);   /* subtract navbar */
    background:#f8f9fb;
}

/* ── Tab bar ───────────────────────────────────────────────────── */
.bi-tabs {
    display:flex; align-items:stretch; gap:0;
    background:#fff; border-bottom:2px solid var(--border);
    padding:0 1rem; overflow-x:auto; flex-shrink:0;
    scrollbar-width:none;
}
.bi-tabs::-webkit-scrollbar { display:none; }

.bi-tab {
    display:flex; align-items:center; gap:.45rem;
    padding:.7rem 1.1rem; cursor:pointer; white-space:nowrap;
    font-size:.8rem; font-weight:500; color:#6b7280;
    border-bottom:2.5px solid transparent; margin-bottom:-2px;
    transition:color .15s, border-color .15s; background:none; border-top:none; border-left:none; border-right:none;
    position:relative;
}
.bi-tab i { font-size:.78rem; }
.bi-tab:hover { color:var(--navy); }
.bi-tab.active { color:var(--navy); border-bottom-color:var(--gold); font-weight:600; }
.bi-tab.active i { color:var(--gold); }

/* ── Report header strip ───────────────────────────────────────── */
.bi-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:.6rem 1.2rem; background:#fff;
    border-bottom:1px solid var(--border); flex-shrink:0;
}
.bi-report-title { font-size:.85rem; font-weight:700; color:var(--navy); }
.bi-report-desc  { font-size:.72rem; color:#6b7280; margin-top:.1rem; }
.bi-actions { display:flex; gap:.5rem; align-items:center; }
.bi-btn {
    display:inline-flex; align-items:center; gap:.35rem;
    font-size:.75rem; padding:.3rem .75rem; border-radius:5px; cursor:pointer;
    border:1px solid var(--border); background:#fff; color:#374151;
    transition:background .15s, border-color .15s;
}
.bi-btn:hover { background:#f9fafb; border-color:#d1d5db; }
.bi-btn.primary { background:var(--navy); color:#fff; border-color:var(--navy); }
.bi-btn.primary:hover { background:#142030; }

/* ── Embed area ────────────────────────────────────────────────── */
.bi-embed-wrap { flex:1; position:relative; overflow:hidden; }
#biFrame { width:100%; height:100%; border:none; display:none; }

/* ── Preloader ─────────────────────────────────────────────────── */
#biLoader {
    position:absolute; inset:0; display:flex; flex-direction:column;
    align-items:center; justify-content:center; background:#f8f9fb; z-index:10;
}
.bi-spinner {
    width:48px; height:48px; border-radius:50%;
    border:4px solid #e5e7eb; border-top-color:var(--gold);
    animation:spin .9s linear infinite;
}
@@keyframes spin { to { transform:rotate(360deg); } }

/* ── Empty state ───────────────────────────────────────────────── */
#biEmpty {
    position:absolute; inset:0; display:none;
    flex-direction:column; align-items:center; justify-content:center;
    background:#f8f9fb; text-align:center; padding:2rem;
}
.bi-empty-icon {
    width:72px; height:72px; border-radius:50%;
    background:var(--gold-lt); display:flex; align-items:center; justify-content:center;
    margin:0 auto 1.25rem;
}
.bi-empty-icon i { font-size:1.75rem; color:var(--gold); }
</style>
}

<div class="bi-shell">

    <!-- ── Tab bar ────────────────────────────────────────────────────── -->
    <nav class="bi-tabs" role="tablist">
        @foreach (var tab in Model.Tabs)
        {
            var meta = tabMeta.GetValueOrDefault(tab, ("fa-chart-bar", ""));
            <button class="bi-tab @(tab == Model.ActiveTab ? "active" : "")"
                    data-tab="@tab" onclick="switchTab('@tab')" role="tab"
                    aria-selected="@(tab == Model.ActiveTab ? "true" : "false")">
                <i class="fas @meta.Item1"></i>@tab
            </button>
        }
    </nav>

    <!-- ── Report header ──────────────────────────────────────────────── -->
    <div class="bi-header">
        <div>
            <div class="bi-report-title" id="biReportTitle">@Model.ActiveTab</div>
            <div class="bi-report-desc"  id="biReportDesc">
                @tabMeta.GetValueOrDefault(Model.ActiveTab, ("", "Report data loading...")).Item2
            </div>
        </div>
        <div class="bi-actions">
            <button class="bi-btn" onclick="refreshReport()" id="btnRefresh">
                <i class="fas fa-sync-alt"></i>Refresh
            </button>
            <button class="bi-btn" onclick="toggleFullscreen()">
                <i class="fas fa-expand-alt" id="fsIcon"></i>Fullscreen
            </button>
            @if (User.IsInRole("Admin") || User.IsInRole("FacilityAdmin"))
            {
                <a href="/Admin/PowerBIReports" class="bi-btn primary">
                    <i class="fas fa-cog"></i>Configure
                </a>
            }
        </div>
    </div>

    <!-- ── Embed area ─────────────────────────────────────────────────── -->
    <div class="bi-embed-wrap" id="biWrap">

        <!-- Loader -->
        <div id="biLoader">
            <div class="bi-spinner"></div>
            <p class="mt-3" style="font-size:.82rem; color:#6b7280;">Loading @Model.ActiveTab report…</p>
        </div>

        <!-- Empty / not configured -->
        <div id="biEmpty">
            <div class="bi-empty-icon"><i class="fas fa-chart-pie"></i></div>
            <h6 style="color:var(--navy); font-weight:700;" id="biEmptyTitle">Report Not Configured</h6>
            <p style="font-size:.82rem; color:#6b7280; max-width:320px;" id="biEmptyMsg">
                No Power BI report has been linked to this tab yet.
            </p>
            @if (User.IsInRole("Admin") || User.IsInRole("FacilityAdmin"))
            {
                <a href="/Admin/PowerBIReports" class="bi-btn primary mt-2" style="text-decoration:none; display:inline-flex;">
                    <i class="fas fa-cog me-1"></i>Go to Power BI Settings
                </a>
            }
        </div>

        <!-- iframe -->
        <iframe id="biFrame" frameborder="0" allowfullscreen
                title="@Model.ActiveTab Power BI Report"></iframe>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/powerbi-client@2.23.1/dist/powerbi.min.js"></script>
<script>
const tabMeta = {
    @foreach (var tab in Model.Tabs)
    {
        var meta = tabMeta.GetValueOrDefault(tab, ("", ""));
        <text>'@tab': { desc: '@Html.Raw(meta.Item2.Replace("'","\\\'"))' },</text>
    }
};

let currentReport = null;

// ── Embed on initial load ──────────────────────────────────────────────────
(function () {
    const token    = '@Html.Raw(Model.EmbedToken ?? "")';
    const embedUrl = '@Html.Raw(Model.EmbedUrl ?? "")';
    const reportId = '@Html.Raw(Model.ReportId ?? "")';
    embedReport(token, embedUrl, reportId);
})();

// ── Switch tab ────────────────────────────────────────────────────────────
function switchTab(tab) {
    document.querySelectorAll('.bi-tab').forEach(t => {
        t.classList.toggle('active', t.dataset.tab === tab);
        t.setAttribute('aria-selected', t.dataset.tab === tab ? 'true' : 'false');
    });
    document.getElementById('biReportTitle').textContent = tab;
    document.getElementById('biReportDesc').textContent = tabMeta[tab]?.desc ?? '';
    document.getElementById('btnRefresh').setAttribute('data-tab', tab);

    showLoader(tab);

    fetch('/Home/GetEmbedToken?tab=' + encodeURIComponent(tab))
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            if (data) embedReport(data.accessToken, data.embedUrl, data.reportId);
            else       showEmpty('Report Not Configured', 'No Power BI report has been linked to this tab yet.');
        })
        .catch(() => showEmpty('Failed to Load', 'Could not fetch the report configuration. Please try again.'));
}

// ── Embed report ──────────────────────────────────────────────────────────
function embedReport(token, embedUrl, reportId) {
    if (!token || token === 'PENDING' || token.startsWith('DEMO_TOKEN')) {
        showEmpty('Report Not Configured', 'No Power BI report has been linked to this tab yet.');
        return;
    }

    const frame = document.getElementById('biFrame');
    if (currentReport) {
        try { powerbi.reset(frame); } catch {}
        currentReport = null;
    }

    const models = window['powerbi-client'].models;
    const config = {
        type: 'report',
        tokenType: models.TokenType.Embed,
        accessToken: token,
        embedUrl: embedUrl,
        id: reportId,
        permissions: models.Permissions.All,
        settings: {
            filterPaneEnabled: false,
            navContentPaneEnabled: false,
            background: models.BackgroundType.Transparent,
        }
    };

    frame.style.display = 'block';
    currentReport = powerbi.embed(frame, config);

    currentReport.on('loaded', () => {
        document.getElementById('biLoader').style.display = 'none';
        document.getElementById('biEmpty').style.display = 'none';
    });
    currentReport.on('error', () => {
        showEmpty('Report Error', 'The Power BI report failed to load. Check your embed configuration.');
    });
}

// ── Helpers ───────────────────────────────────────────────────────────────
function showLoader(tab) {
    const loader = document.getElementById('biLoader');
    loader.style.display = 'flex';
    loader.querySelector('p').textContent = `Loading ${tab} report\u2026`;
    document.getElementById('biEmpty').style.display = 'none';
    document.getElementById('biFrame').style.display = 'none';
}

function showEmpty(title, msg) {
    document.getElementById('biLoader').style.display = 'none';
    document.getElementById('biFrame').style.display = 'none';
    const empty = document.getElementById('biEmpty');
    empty.style.display = 'flex';
    document.getElementById('biEmptyTitle').textContent = title;
    document.getElementById('biEmptyMsg').textContent   = msg;
}

function refreshReport() {
    const active = document.querySelector('.bi-tab.active')?.dataset.tab;
    if (active) switchTab(active);
}

function toggleFullscreen() {
    const wrap = document.getElementById('biWrap');
    const icon = document.getElementById('fsIcon');
    if (!document.fullscreenElement) {
        wrap.requestFullscreen?.();
        icon.className = 'fas fa-compress-alt';
    } else {
        document.exitFullscreen?.();
        icon.className = 'fas fa-expand-alt';
    }
}

document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement)
        document.getElementById('fsIcon').className = 'fas fa-expand-alt';
});
</script>
}
