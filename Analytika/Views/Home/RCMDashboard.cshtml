@model Analytika.Models.ViewModels.RCMDashboardViewModel
@{
    ViewData["Title"] = "BI Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tabMeta = new Dictionary<string, (string Icon, string Desc)>
    {
        ["Submissions"]   = ("fa-paper-plane",    "Claim submission volumes, acceptance rates, and timelines"),
        ["Resubmissions"] = ("fa-redo-alt",        "Resubmitted claims tracking and resolution outcomes anchored to Encounter Date"),
        ["Remittance"]    = ("fa-money-bill-wave", "Payment reconciliation and remittance analysis"),
        ["Denials"]       = ("fa-ban",             "Denial patterns, root causes, and denial trends"),
        ["Clinicians"]    = ("fa-user-md",         "Clinician productivity and claim performance"),
        ["Operations"]    = ("fa-cogs",            "Operational KPIs, TAT metrics, and SLA compliance"),
        ["Insurance"]     = ("fa-shield-alt",      "Payer-wise approval, rejection, and payment behavior"),
        ["Department"]    = ("fa-building",        "Department and facility performance breakdown"),
    };

    var maxTrend = Math.Max(1, Model.Trend.Max(x => x.Value));
    var maxBreakdown = Math.Max(1, Model.Breakdown.Max(x => x.Value));
}

@section Styles {
<style>
:root { --navy:#011C40; --teal:#A7EBF2; --gold:#35577D; --line:#EAF4FB; --muted:#35577D; }
.bi-shell {
    min-height: calc(100vh - 56px);
    background: linear-gradient(180deg, #fbfdff 0%, #f7fafc 100%);
}
.bi-intro {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.75rem 1rem 1rem;
    text-align: center;
}
.bi-kicker {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .35rem .7rem;
    border-radius: 999px;
    background: rgba(216,232,243,.72);
    color: #023859;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.bi-kicker i { color: #54ACBF; }
.bi-intro h2 {
    margin: .9rem 0 .45rem;
    font-size: clamp(1.75rem, 2.8vw, 2.9rem);
    line-height: 1.08;
    color: #011C40;
    font-weight: 800;
    letter-spacing: -0.04em;
}
.bi-intro p {
    margin: 0 auto;
    max-width: 54rem;
    color: #35577D;
    font-size: .98rem;
    line-height: 1.7;
}
.bi-intro {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.75rem 1rem 1rem;
    text-align: center;
}
.bi-kicker {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .35rem .7rem;
    border-radius: 999px;
    background: rgba(216,232,243,.72);
    color: #023859;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.bi-kicker i { color: #54ACBF; }
.bi-intro h2 {
    margin: .9rem 0 .45rem;
    font-size: clamp(1.75rem, 2.8vw, 2.9rem);
    line-height: 1.08;
    color: #011C40;
    font-weight: 800;
    letter-spacing: -0.04em;
}
.bi-intro p {
    margin: 0 auto;
    max-width: 54rem;
    color: #35577D;
    font-size: .98rem;
    line-height: 1.7;
}
.bi-layout {
    max-width: 1480px;
    margin: 0 auto;
    padding: 1rem;
    display: grid;
    grid-template-columns: 238px minmax(0, 1fr);
    gap: .9rem;
}
.bi-tabs {
    display:flex;
    flex-direction:column;
    gap:.45rem;
    padding:.85rem;
    background:#ffffff;
    border:1px solid #e5e7eb;
    border-radius:18px;
    box-shadow: 0 10px 28px rgba(17,24,39,.04);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    align-self:start;
    position: sticky;
    top: 74px;
}
.bi-tab {
    display:flex;
    align-items:center;
    gap:.45rem;
    width:100%;
    padding:.82rem .9rem;
    border:1px solid transparent;
    border-left:3px solid transparent;
    background:#f8fafc;
    color:#023859;
    font-size:.82rem;
    font-weight:600;
    text-decoration:none;
    border-radius: 14px;
    transition: background .18s ease, color .18s ease, transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.bi-tab:hover, .bi-tab.active { color:var(--navy); }
.bi-tab:hover { background: #eef2f7; transform: translateX(2px); }
.bi-tab.active {
    border-left-color:var(--gold);
    background: #ffffff;
    box-shadow: 0 10px 20px rgba(17,24,39,.05);
}
.bi-tab.active i { color:var(--gold); }
.bi-content {
    min-width: 0;
}
.bi-header {
    display:flex;
    justify-content:space-between;
    gap:1rem;
    align-items:flex-start;
    padding:1rem 0 1.25rem;
    margin-bottom:1rem;
    border-bottom:1px solid #e5e7eb;
    background: transparent;
    box-shadow: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
}
.bi-header-left { display:flex; flex-direction:column; gap:.45rem; }
.bi-title { color:var(--navy); font-size:1.4rem; font-weight:800; margin:0; letter-spacing:-0.03em; }
.bi-desc { color:#023859; font-size:.88rem; margin:.2rem 0 0; font-weight:600; }
.bi-field {
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    align-self:flex-start;
    padding:.4rem .65rem;
    border-radius:999px;
    background: rgba(216,232,243,.66);
    border:1px solid rgba(8,20,35,.08);
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    line-height:1.35;
    max-width: 100%;
    white-space: normal;
}
.bi-field i { color:#54ACBF; }
.bi-field small { color:#023859; font-weight:700; display:block; }
.bi-refresh {
    color:#023859;
    font-size:.78rem;
    font-weight:700;
    white-space:nowrap;
    padding:.35rem .55rem;
    border-radius: 999px;
    background: rgba(216,232,243,.66);
    border: 1px solid rgba(8,20,35,.08);
}
.metric-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:.75rem; }
.metric-card, .panel {
    background:#ffffff;
    border:1px solid #e5e7eb;
    border-radius:20px;
    box-shadow:0 12px 28px rgba(17,24,39,.05);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
}
.tilt-card {
    --tilt-rotate-x: 0deg;
    --tilt-rotate-y: 0deg;
    --tilt-scale: 1;
    --spot-x: 50%;
    --spot-y: 50%;
    --spot-opacity: 0;
    transform:
        perspective(1200px)
        rotateX(var(--tilt-rotate-x))
        rotateY(var(--tilt-rotate-y))
        scale3d(var(--tilt-scale), var(--tilt-scale), var(--tilt-scale));
    transform-style: preserve-3d;
    transition: transform .18s ease-out, box-shadow .18s ease-out, border-color .18s ease-out;
    will-change: transform;
}
.tilt-card::after {
    content:'';
    position:absolute;
    inset:0;
    pointer-events:none;
    opacity: var(--spot-opacity, 0);
    background:
        radial-gradient(circle at var(--spot-x, 50%) var(--spot-y, 50%), rgba(255,255,255,.28), transparent 44%);
    transition: opacity .2s ease;
}
.tilt-card.is-tilting {
    box-shadow: 0 22px 48px rgba(17,24,39,.08);
    border-color: rgba(84,172,191,.22);
}
.metric-card {
    padding:1.15rem;
    display:flex;
    gap:.75rem;
    align-items:center;
    min-height:108px;
    position: relative;
    overflow:hidden;
}
.metric-card::before {
    content:'';
    position:absolute;
    inset:auto -15% -35% auto;
    width:120px;
    height:120px;
    border-radius:50%;
    background: radial-gradient(circle, rgba(167,235,242,.12), transparent 68%);
    pointer-events:none;
}
.metric-icon { width:44px; height:44px; border-radius:12px; display:grid; place-items:center; flex:0 0 auto; border:1px solid #e5e7eb; }
.tone-teal { background:rgba(167,235,242,.18); color:#023859; }
.tone-gold { background:rgba(53,87,125,.10); color:#023859; }
.tone-green { background:rgba(84,172,191,.16); color:#023859; }
.tone-blue { background:rgba(38,101,140,.12); color:#023859; }
.metric-label { color:#023859; font-size:.74rem; font-weight:800; text-transform:uppercase; letter-spacing:.03em; }
.metric-value { color:var(--navy); font-size:1.55rem; font-weight:800; line-height:1.1; letter-spacing:-0.03em; }
.metric-delta { color:#35577D; font-size:.72rem; font-weight:700; }
.dash-grid { display:grid; grid-template-columns:2fr 1fr; gap:.75rem; margin-top:.75rem; }
.panel { padding:1.15rem; }
.panel-title { color:var(--navy); font-size:1rem; font-weight:800; margin:0 0 .85rem; letter-spacing:-0.02em; }
.summary { color:#023859; font-size:.95rem; line-height:1.7; margin-bottom:1rem; font-weight:500; }
.trend { display:grid; grid-template-columns:repeat(6,1fr); gap:.65rem; align-items:end; min-height:260px; padding-top:.5rem; }
.trend-col { display:flex; flex-direction:column; align-items:center; gap:.45rem; min-width:0; }
.trend-bar { width:100%; max-width:62px; min-height:28px; border-radius:7px 7px 3px 3px; background:linear-gradient(180deg,var(--teal),#54ACBF); }
.trend-value { color:var(--navy); font-size:.8rem; font-weight:800; }
.trend-label { color:#023859; font-size:.74rem; font-weight:600; }
.breakdown-row { display:grid; grid-template-columns:96px 1fr 46px; gap:.6rem; align-items:center; padding:.55rem 0; border-top:1px solid #EAF4FB; }
.breakdown-row:first-of-type { border-top:0; }
.breakdown-label { color:var(--navy); font-size:.84rem; font-weight:800; }
.breakdown-detail { color:#023859; font-size:.74rem; font-weight:500; }
.breakdown-track { height:9px; border-radius:999px; background:#EAF4FB; overflow:hidden; }
.breakdown-fill { height:100%; border-radius:999px; background:linear-gradient(90deg, var(--teal), var(--gold)); }
.breakdown-value { color:var(--navy); font-size:.75rem; font-weight:800; text-align:right; }
.insight { border-top:1px solid #EAF4FB; padding:.75rem 0 0; margin-top:.75rem; }
.insight:first-of-type { border-top:0; padding-top:0; margin-top:0; }
.insight-head { display:flex; justify-content:space-between; gap:.5rem; align-items:center; }
.insight-title { color:var(--navy); font-size:.8rem; font-weight:800; }
.insight-badge { font-size:.68rem; font-weight:800; border-radius:999px; padding:.18rem .5rem; background:rgba(216,232,243,.88); color:#023859; }
.insight-detail { color:#023859; font-size:.78rem; margin:.25rem 0 0; line-height:1.55; }
@@media (max-width: 992px) {
    .metric-grid, .dash-grid { grid-template-columns:1fr 1fr; }
    .dash-grid .panel:first-child { grid-column:1 / -1; }
}
@@media (max-width: 640px) {
    .bi-intro { padding-top: 1rem; }
    .bi-intro h2 { font-size: 1.8rem; }
    .bi-layout { grid-template-columns: 1fr; }
    .bi-tabs {
        position: static;
        grid-row: 2;
    }
    .bi-header { flex-direction:column; }
    .bi-field { width:100%; }
    .metric-grid, .dash-grid { grid-template-columns:1fr; }
    .trend { min-height:210px; gap:.4rem; }
    .bi-content { padding:.75rem; }
}
</style>
}

<div class="bi-shell">
    <section class="bi-intro">
        <div class="bi-kicker"><i class="fas fa-chart-line"></i> Ghaf BI dashboard</div>
        <h2>Case-study style reporting for claim operations</h2>
        <p>Clearer hierarchy, cleaner spacing, and lighter cards make submission, resubmission, remittance, and operational performance easier to scan without losing detail.</p>
    </section>

    <div class="bi-layout">
        <nav class="bi-tabs" role="tablist" aria-label="Dashboard sections">
            @foreach (var tab in Model.Tabs)
            {
                var meta = tabMeta.GetValueOrDefault(tab, ("fa-chart-bar", ""));
                <a class="bi-tab @(tab == Model.ActiveTab ? "active" : "")"
                   asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@tab" role="tab"
                   aria-selected="@(tab == Model.ActiveTab ? "true" : "false")">
                    <i class="fas @meta.Item1"></i>
                    <span>@tab</span>
                </a>
            }
        </nav>

    <main class="bi-content">
        <div class="bi-header">
            <div class="bi-header-left">
                <h1 class="bi-title">@Model.ActiveTab</h1>
                <p class="bi-desc">@tabMeta.GetValueOrDefault(Model.ActiveTab, ("", "Local dashboard")).Item2</p>
                <div class="bi-field">
                    <i class="fas fa-calendar-day"></i>
                    Stable field: @Model.StableFieldTitle
                    <small>@Model.StableFieldDetail</small>
                </div>
            </div>
            <div class="bi-refresh">Updated @Model.RefreshedAt.ToString("dd MMM yyyy HH:mm")</div>
        </div>

        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (var metric in Model.Metrics)
            {
                <article class="metric-card tilt-card" data-tilt-limit="12" data-tilt-scale="1.035" data-tilt-effect="evade">
                    <div class="metric-icon tone-@metric.Tone"><i class="fas @metric.Icon"></i></div>
                    <div>
                        <div class="metric-label">@metric.Label</div>
                        <div class="metric-value">@metric.Value</div>
                        <div class="metric-delta">@metric.Delta</div>
                    </div>
                </article>
            }
        </section>

        <section class="dash-grid">
            <article class="panel tilt-card" data-tilt-limit="10" data-tilt-scale="1.02" data-tilt-effect="evade">
                <h2 class="panel-title">Performance Trend</h2>
                <p class="summary">@Model.Summary</p>
                <div class="trend">
                    @foreach (var point in Model.Trend)
                    {
                        var height = Math.Max(18, (int)Math.Round(point.Value * 100.0 / maxTrend));
                        <div class="trend-col">
                            <div class="trend-value">@point.Value%</div>
                            <div class="trend-bar" style="height:@height%;"></div>
                            <div class="trend-label">@point.Label</div>
                        </div>
                    }
                </div>
            </article>

            <article class="panel tilt-card" data-tilt-limit="10" data-tilt-scale="1.02" data-tilt-effect="evade">
                <h2 class="panel-title">Breakdown</h2>
                @foreach (var item in Model.Breakdown)
                {
                    var width = Math.Max(5, (int)Math.Round(item.Value * 100.0 / maxBreakdown));
                    <div class="breakdown-row">
                        <div>
                            <div class="breakdown-label">@item.Label</div>
                            <div class="breakdown-detail">@item.Detail</div>
                        </div>
                        <div class="breakdown-track"><div class="breakdown-fill" style="width:@width%;"></div></div>
                        <div class="breakdown-value">@item.Value%</div>
                    </div>
                }
            </article>

            <article class="panel tilt-card" data-tilt-limit="10" data-tilt-scale="1.02" data-tilt-effect="evade">
                <h2 class="panel-title">Insights</h2>
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight">
                        <div class="insight-head">
                            <div class="insight-title">@insight.Title</div>
                            <span class="insight-badge">@insight.Status</span>
                        </div>
                        <p class="insight-detail">@insight.Detail</p>
                    </div>
                }
            </article>
        </section>
    </main>
    </div>
</div>

@section Scripts {
<script>
(function initTiltCards() {
    const cards = Array.from(document.querySelectorAll('.tilt-card'));
    if (!cards.length) return;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (!finePointer) return;

    cards.forEach((card) => {
        const tiltLimit = Number(card.dataset.tiltLimit || 12);
        const scale = Number(card.dataset.tiltScale || 1.03);
        const effect = card.dataset.tiltEffect || 'evade';
        const direction = effect === 'evade' ? -1 : 1;

        const reset = () => {
            card.style.setProperty('--tilt-rotate-x', '0deg');
            card.style.setProperty('--tilt-rotate-y', '0deg');
            card.style.setProperty('--tilt-scale', '1');
            card.style.setProperty('--spot-opacity', '0');
            card.classList.remove('is-tilting');
        };

        card.addEventListener('pointerenter', () => {
            card.style.setProperty('--tilt-scale', String(scale));
            card.style.setProperty('--spot-opacity', '1');
            card.classList.add('is-tilting');
        });

        card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const px = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
            const py = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
            const rotateX = ((py - 0.5) * (tiltLimit * 2) * direction).toFixed(2);
            const rotateY = ((px - 0.5) * -(tiltLimit * 2) * direction).toFixed(2);

            card.style.setProperty('--tilt-rotate-x', `${rotateX}deg`);
            card.style.setProperty('--tilt-rotate-y', `${rotateY}deg`);
            card.style.setProperty('--spot-x', `${(px * 100).toFixed(2)}%`);
            card.style.setProperty('--spot-y', `${(py * 100).toFixed(2)}%`);
        });

        card.addEventListener('pointerleave', reset);
        card.addEventListener('pointercancel', reset);
    });
})();
</script>
}
