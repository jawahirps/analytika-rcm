@model Analytika.Models.ViewModels.RCMDashboardViewModel
@{
    ViewData["Title"] = "BI Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tabMeta = new Dictionary<string, (string Icon, string Desc)>
    {
        ["Submissions"]   = ("fa-paper-plane",    "Claim submission volumes, acceptance rates, and timelines"),
        ["Resubmissions"] = ("fa-redo-alt",        "Resubmitted claims tracking and resolution outcomes anchored to Encounter Date"),
        ["Remittance"]    = ("fa-money-bill-wave", "Payment reconciliation and remittance analysis"),
        ["Denials"]       = ("fa-ban",             "Denial patterns, root causes, and denial trends"),
        ["Clinicians"]    = ("fa-user-md",         "Clinician productivity and claim performance"),
        ["Operations"]    = ("fa-cogs",            "Operational KPIs, TAT metrics, and SLA compliance"),
        ["Insurance"]     = ("fa-shield-alt",      "Payer-wise approval, rejection, and payment behavior"),
        ["Department"]    = ("fa-building",        "Department and facility performance breakdown"),
    };

    var maxTrend = Math.Max(1, Model.Trend.Any() ? Model.Trend.Max(x => x.Value) : 0);
    var maxBreakdown = Math.Max(1, Model.Breakdown.Any() ? Model.Breakdown.Max(x => x.Value) : 0);
    var reportDateFrom = Model.Filters.DateFrom ?? new DateOnly(2023, 1, 1);
    var reportDateTo = Model.Filters.DateTo ?? DateOnly.FromDateTime(DateTime.Today);
    var reportDateFromText = reportDateFrom.ToString("dd/MM/yyyy");
    var reportDateToText = reportDateTo.ToString("dd/MM/yyyy");
}

@section Styles {
<style>
:root {
    --teal:#09D8C7;
    --blue:#17364F;
    --navy:#0D1A2F;
    --plum:#411E3A;
    --red:#BD0927;
    --burgundy:#500A1F;
    --line:rgba(9,216,199,.16);
    --muted:#17364F;
    --surface:rgba(255,255,255,.92);
}
.bi-shell {
    min-height: calc(100vh - 56px);
    background:
        radial-gradient(circle at 0% 18%, rgba(9,216,199,.26), transparent 30%),
        radial-gradient(circle at 100% 0%, rgba(189,9,39,.14), transparent 32%),
        linear-gradient(140deg, rgba(13,26,47,.12) 0%, rgba(23,54,79,.08) 42%, rgba(255,255,255,.98) 100%);
}
.bi-intro {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.75rem 1rem 1rem;
    text-align: center;
}
.bi-kicker {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .35rem .7rem;
    border-radius: 999px;
    background: rgba(9,216,199,.14);
    color: var(--blue);
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.bi-kicker i { color: var(--teal); }
.bi-intro h2 {
    margin: .9rem 0 .45rem;
    font-size: clamp(1.75rem, 2.8vw, 2.9rem);
    line-height: 1.08;
    color: var(--navy);
    font-weight: 800;
    letter-spacing: -0.04em;
}
.bi-intro p {
    margin: 0 auto;
    max-width: 54rem;
    color: var(--blue);
    font-size: .98rem;
    line-height: 1.7;
}
.bi-layout {
    max-width: 1480px;
    margin: 0 auto;
    padding: 1rem;
    display: grid;
    grid-template-columns: 238px minmax(0, 1fr);
    gap: .9rem;
    transition: grid-template-columns .28s ease, gap .28s ease;
}
.bi-layout.is-tabs-collapsed {
    grid-template-columns: 64px minmax(0, 1fr);
    gap: .6rem;
}
.bi-tabs-shell {
    position: sticky;
    top: 74px;
    align-self: start;
    width: 238px;
    transition: width .28s ease;
}
.bi-layout.is-tabs-collapsed .bi-tabs-shell {
    width: 64px;
}
.bi-tabs {
    display:flex;
    flex-direction:column;
    gap:.45rem;
    padding:.85rem;
    background:var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:18px;
    box-shadow: 0 18px 42px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    align-self:start;
    position: relative;
    overflow: hidden;
    transition: transform .28s ease, opacity .28s ease, filter .28s ease, box-shadow .28s ease;
    will-change: transform;
}
.bi-filter-card {
    display:flex;
    flex-direction:column;
    gap:.55rem;
    padding:3rem .85rem .85rem;
    margin-bottom:.6rem;
    border:1px solid rgba(23,54,79,.12);
    border-radius:18px;
    background:var(--surface);
    box-shadow: 0 18px 42px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    overflow:hidden;
}
.bi-filter-title {
    display:flex;
    align-items:center;
    gap:.45rem;
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    text-transform:uppercase;
    letter-spacing:.04em;
}
.bi-filter-title i { color:var(--teal); }
.bi-filter-field {
    display:flex;
    flex-direction:column;
    gap:.25rem;
}
.bi-filter-field label {
    color:var(--blue);
    font-size:.68rem;
    font-weight:800;
}
.bi-filter-field select {
    width:100%;
    min-height:34px;
    border:1px solid rgba(23,54,79,.16);
    border-radius:10px;
    background:#fff;
    color:var(--navy);
    font-size:.75rem;
    font-weight:700;
    padding:.35rem .5rem;
}
.bi-filter-actions {
    display:flex;
    gap:.4rem;
    align-items:center;
    margin-top:.15rem;
}
.bi-filter-submit,
.bi-filter-reset {
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.35rem;
    min-height:34px;
    border-radius:10px;
    font-size:.72rem;
    font-weight:800;
    text-decoration:none;
}
.bi-filter-submit {
    flex:1 1 auto;
    border:1px solid rgba(13,26,47,.22);
    background:var(--navy);
    color:#fff;
}
.bi-filter-reset {
    flex:0 0 34px;
    border:1px solid rgba(23,54,79,.16);
    background:rgba(255,255,255,.82);
    color:var(--blue);
}
.bi-filter-active {
    display:inline-flex;
    align-items:center;
    gap:.35rem;
    color:var(--blue);
    font-size:.68rem;
    font-weight:800;
}
.bi-tabs-toggle {
    position:absolute;
    top:.8rem;
    right:.8rem;
    z-index:2;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:2.1rem;
    height:2.1rem;
    border:1px solid rgba(23,54,79,.16);
    border-radius:999px;
    background:rgba(255,255,255,.92);
    color:var(--blue);
    box-shadow: 0 8px 18px rgba(13,26,47,.10);
    transition: transform .2s ease, background .2s ease, color .2s ease;
}
.bi-tabs-toggle:hover {
    background:#fff;
    color:var(--navy);
    transform: translateY(-1px);
}
.bi-tab {
    display:flex;
    align-items:center;
    gap:.45rem;
    width:100%;
    padding:.82rem .9rem;
    border:1px solid transparent;
    border-left:3px solid transparent;
    background:rgba(255,255,255,.54);
    color:var(--blue);
    font-size:.82rem;
    font-weight:600;
    text-decoration:none;
    border-radius: 14px;
    transition: background .18s ease, color .18s ease, transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.bi-tab:hover, .bi-tab.active { color:var(--navy); }
.bi-tab:hover { background: rgba(255,255,255,.72); transform: translateX(2px); }
.bi-tab.active {
    border-left-color:var(--teal);
    background: rgba(255,255,255,.96);
    box-shadow: 0 8px 20px rgba(13,26,47,.10);
}
.bi-tab.active i { color:var(--teal); }
.bi-tabs-shell.is-collapsed .bi-tabs {
    padding-left:.55rem;
    padding-right:.55rem;
    opacity: .96;
    filter: saturate(.96);
}
.bi-tabs-shell.is-collapsed .bi-filter-card {
    height:0;
    margin:0;
    padding:0;
    border:0;
    opacity:0;
    pointer-events:none;
}
.bi-tabs-shell.is-collapsed .bi-tabs-toggle i {
    transform: rotate(180deg);
}
.bi-tabs-shell.is-collapsed .bi-tab span {
    position:absolute;
    width:1px;
    height:1px;
    clip:rect(0 0 0 0);
    overflow: hidden;
}
.bi-tabs-shell.is-collapsed .bi-tab {
    justify-content:center;
    padding:.82rem .55rem;
}
.bi-tabs-shell.is-collapsed .bi-tab i {
    margin:0;
}
.bi-content {
    min-width: 0;
}
.bi-header {
    display:flex;
    justify-content:space-between;
    gap:1.25rem;
    align-items:center;
    padding:1.25rem 1.4rem;
    margin-bottom:1rem;
    border:1px solid rgba(23,54,79,.12);
    border-radius: 10px;
    background: rgba(255,255,255,.94);
    box-shadow: 0 8px 22px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.bi-header-left { display:flex; flex-direction:column; gap:.2rem; min-width:0; }
.bi-title { color:var(--navy); font-size:1.65rem; font-weight:900; margin:0; letter-spacing:-.025em; line-height:1.05; }
.bi-desc { color:var(--blue); font-size:1rem; margin:0; font-weight:600; }
.bi-header-tools {
    display:flex;
    align-items:center;
    justify-content:flex-end;
    gap:.7rem;
    flex:0 0 auto;
}
.bi-date-form {
    display:flex;
    align-items:center;
    gap:.55rem;
}
.bi-calendar-icon,
.bi-header-icon {
    width:40px;
    height:40px;
    display:grid;
    place-items:center;
    border:0;
    background:transparent;
    color:var(--blue);
    font-size:1.4rem;
    text-decoration:none;
}
.bi-date-range {
    display:flex;
    align-items:center;
    gap:.45rem;
    padding:.5rem;
    border-radius:8px;
    background:#fff;
    border:1px solid rgba(23,54,79,.12);
    box-shadow:0 2px 10px rgba(13,26,47,.08);
}
.bi-date-input {
    width:132px;
    min-height:38px;
    border:1px solid rgba(23,54,79,.12);
    border-radius:0;
    background:#fff;
    color:var(--blue);
    font-size:.88rem;
    font-weight:600;
    padding:.35rem .55rem;
}
.bi-date-submit {
    width:36px;
    height:36px;
    display:grid;
    place-items:center;
    border:0;
    border-radius:8px;
    background:var(--teal);
    color:var(--navy);
}
.bi-chat-icon {
    position:relative;
    color:var(--teal);
}
.bi-chat-icon::after {
    content:"?";
    position:absolute;
    top:2px;
    right:0;
    width:18px;
    height:18px;
    display:grid;
    place-items:center;
    border-radius:999px;
    background:var(--red);
    color:#fff;
    font-size:.8rem;
    font-weight:900;
}
.bi-back-icon { color:var(--navy); font-size:1.55rem; }
.bi-field {
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    align-self:flex-start;
    padding:.4rem .65rem;
    border-radius:999px;
    background: rgba(9,216,199,.13);
    border:1px solid rgba(23,54,79,.12);
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    line-height:1.35;
    max-width: 100%;
    white-space: normal;
}
.bi-field i { color:var(--teal); }
.bi-field small { color:var(--blue); font-weight:700; display:block; }
.metric-grid {
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:0;
    margin-bottom:.75rem;
    background: var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:16px;
    box-shadow:0 14px 34px rgba(13,26,47,.12);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    overflow:hidden;
}
.panel {
    background: var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:16px;
    box-shadow:0 14px 34px rgba(13,26,47,.12);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.glow-card {
    --x: 50;
    --y: 50;
    --xp: 0.5;
    --yp: 0.5;
    --base: 220;
    --spread: 200;
    --radius: 16;
    --border: 3;
    --spot-opacity: 0;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transform: translateZ(0);
    transition: box-shadow .2s ease, border-color .2s ease, transform .2s ease;
}
.glow-card::before,
.glow-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    opacity: var(--spot-opacity, 0);
    transition: opacity .2s ease;
}
.glow-card::before {
    background:
        radial-gradient(
            calc(var(--radius) * 1px) calc(var(--radius) * 1px) at
            calc(var(--x) * 1px)
            calc(var(--y) * 1px),
            hsla(calc(var(--base) + (var(--xp) * var(--spread))), 88%, 70%, 0.20),
            transparent 42%
        );
    filter: blur(6px);
}
.glow-card::after {
    inset: 1px;
    border: 1px solid rgba(9,216,199,.14);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,.65),
        0 0 0 1px rgba(255,255,255,.2);
}
.glow-card.is-glowing {
    box-shadow: 0 18px 42px rgba(13,26,47,.14);
    border-color: rgba(9,216,199,.26);
}
.metric-card {
    padding:1.05rem 1.15rem;
    display:flex;
    gap:.9rem;
    align-items:center;
    min-height:108px;
    position: relative;
    overflow:hidden;
    background:transparent;
    border-right:1px solid rgba(23,54,79,.10);
    border-bottom:1px solid rgba(23,54,79,.10);
    border-radius:0;
    box-shadow:none;
    backdrop-filter:none;
    -webkit-backdrop-filter:none;
}
.metric-card:nth-child(2n) { border-right:0; }
.metric-card:nth-last-child(-n + 2) { border-bottom:0; }
.metric-card::before {
    content:'';
    position:absolute;
    inset:auto -15% -35% auto;
    width:120px;
    height:120px;
    border-radius:50%;
    background: radial-gradient(circle, rgba(9,216,199,.14), transparent 68%);
    pointer-events:none;
}
.metric-icon { width:46px; height:46px; border-radius:10px; display:grid; place-items:center; flex:0 0 auto; }
.tone-teal { background:rgba(9,216,199,.12); color:var(--teal); }
.tone-gold { background:rgba(189,9,39,.10); color:var(--red); }
.tone-green { background:rgba(65,30,58,.10); color:var(--plum); }
.tone-blue { background:rgba(23,54,79,.12); color:var(--blue); }
.metric-label { color:var(--blue); font-size:.76rem; font-weight:800; text-transform:uppercase; letter-spacing:.03em; }
.metric-value { color:var(--navy); font-size:1.45rem; font-weight:800; line-height:1.15; }
.metric-delta { color:var(--red); font-size:.76rem; font-weight:800; }
.dash-grid { display:grid; grid-template-columns:2fr 1fr; gap:.75rem; margin-top:.75rem; }
.panel { padding:1rem; }
.panel-title { color:var(--navy); font-size:.9rem; font-weight:800; margin:0 0 .75rem; }
.summary { color:var(--blue); font-size:.92rem; line-height:1.65; margin-bottom:1rem; font-weight:500; }
.trend { display:grid; grid-template-columns:repeat(6,1fr); gap:.65rem; align-items:end; min-height:260px; padding-top:.5rem; }
.trend-col { display:flex; flex-direction:column; align-items:center; gap:.45rem; min-width:0; }
.trend-bar { width:100%; max-width:62px; min-height:28px; border-radius:7px 7px 3px 3px; background:linear-gradient(180deg,var(--teal),var(--blue)); }
.trend-value { color:var(--navy); font-size:.74rem; font-weight:800; }
.trend-label { color:var(--blue); font-size:.74rem; font-weight:600; }
.breakdown-row { display:grid; grid-template-columns:96px 1fr 46px; gap:.6rem; align-items:center; padding:.55rem 0; border-top:1px solid var(--line); }
.breakdown-row:first-of-type { border-top:0; }
.breakdown-label { color:var(--navy); font-size:.82rem; font-weight:800; }
.breakdown-detail { color:var(--blue); font-size:.74rem; font-weight:500; }
.breakdown-track { height:9px; border-radius:999px; background:rgba(23,54,79,.10); overflow:hidden; }
.breakdown-fill { height:100%; border-radius:999px; background:linear-gradient(90deg, var(--teal), var(--red)); }
.breakdown-value { color:var(--navy); font-size:.75rem; font-weight:800; text-align:right; }
.insight { border-top:1px solid var(--line); padding:.75rem 0 0; margin-top:.75rem; }
.insight:first-of-type { border-top:0; padding-top:0; margin-top:0; }
.insight-head { display:flex; justify-content:space-between; gap:.5rem; align-items:center; }
.insight-title { color:var(--navy); font-size:.8rem; font-weight:800; }
.insight-badge { font-size:.68rem; font-weight:800; border-radius:999px; padding:.18rem .5rem; background:rgba(9,216,199,.12); color:var(--blue); }
.insight-detail { color:var(--blue); font-size:.78rem; margin:.25rem 0 0; line-height:1.55; }
@@media (max-width: 992px) {
    .metric-grid, .dash-grid { grid-template-columns:1fr 1fr; }
    .dash-grid .panel:first-child { grid-column:1 / -1; }
}
@@media (max-width: 640px) {
    .bi-layout { grid-template-columns: 1fr; }
    .bi-tabs-shell {
        position: static;
        width: 100%;
        top: auto;
    }
    .bi-tabs {
        padding-top: .85rem;
        transform:none !important;
    }
    .bi-filter-card {
        padding: .85rem;
        border-radius:12px;
    }
    .bi-filter-card form {
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:.55rem;
    }
    .bi-filter-title,
    .bi-filter-actions {
        grid-column:1 / -1;
    }
    .bi-tabs-toggle {
        display:none;
    }
    .bi-header { flex-direction:column; }
    .bi-header-tools,
    .bi-date-form,
    .bi-date-range {
        width:100%;
    }
    .bi-header-tools {
        align-items:stretch;
        flex-wrap:wrap;
        justify-content:flex-start;
    }
    .bi-date-form {
        flex-wrap:wrap;
    }
    .bi-date-range {
        flex:1 1 260px;
    }
    .bi-date-input {
        flex:1 1 110px;
        width:auto;
        min-width:0;
    }
    .bi-field { width:100%; }
    .metric-grid { grid-template-columns:1fr; }
    .metric-card {
        border-right:0;
        border-bottom:1px solid rgba(23,54,79,.10);
    }
    .metric-card:last-child { border-bottom:0; }
    .dash-grid { grid-template-columns:1fr; }
    .trend { min-height:210px; gap:.4rem; }
    .bi-content { padding:.75rem; }
    .bi-shell { padding:.65rem; }
    .bi-header {
        gap:.85rem;
        padding:1rem;
        border-radius:12px;
    }
    .bi-title {
        font-size:1.35rem;
        line-height:1.18;
        letter-spacing:-0.025em;
    }
    .bi-desc {
        font-size:.82rem;
        line-height:1.5;
    }
    .bi-tabs {
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:.45rem;
    }
    .bi-tab {
        min-width:0;
        justify-content:center;
        text-align:center;
        padding:.62rem .5rem;
    }
    .metric-grid,
    .panel {
        border-radius:12px;
    }
    .metric-card { padding:.9rem; min-height:92px; }
    .metric-value { font-size:1.35rem; }
    .trend-bar { min-width:22px; }
}
@@media (max-width: 480px) {
    .bi-filter-card form {
        grid-template-columns:1fr;
    }
    .bi-date-range {
        display:grid;
        grid-template-columns:1fr;
    }
    .bi-date-submit,
    .bi-calendar-icon,
    .bi-header-icon {
        width:38px;
        height:38px;
    }
}

/* VaultX-inspired sky dashboard redesign */
:root {
    --sky-hero:#25a9ec;
    --sky-deep:#0782c8;
    --sky-soft:#dff5ff;
    --ink-blue:#102f55;
    --muted-blue:#5f7c96;
    --glass:rgba(255,255,255,.72);
    --glass-strong:rgba(255,255,255,.9);
    --glass-line:rgba(255,255,255,.55);
    --shadow-blue:rgba(15,85,130,.18);
}
.bi-shell {
    min-height:calc(100vh - 56px);
    position:relative;
    overflow:hidden;
    background:
        radial-gradient(circle at 14% 8%, rgba(255,255,255,.82) 0 5%, transparent 16%),
        radial-gradient(circle at 86% 4%, rgba(255,255,255,.6) 0 7%, transparent 18%),
        linear-gradient(180deg, #effbff 0%, #ffffff 48%, #eaf8ff 100%) !important;
    color:var(--ink-blue);
}
.bi-shell::before {
    content:"";
    position:fixed;
    inset:0;
    pointer-events:none;
    z-index:0;
    opacity:.72;
    background:
        radial-gradient(ellipse at 18% 8%, rgba(255,255,255,.8) 0 5%, transparent 18%),
        radial-gradient(ellipse at 76% 12%, rgba(255,255,255,.72) 0 6%, transparent 20%),
        linear-gradient(180deg, rgba(37,169,236,.26), transparent 45%),
