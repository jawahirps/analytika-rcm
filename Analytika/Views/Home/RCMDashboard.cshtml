@model Analytika.Models.ViewModels.RCMDashboardViewModel
@{
    ViewData["Title"] = "BI Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tabMeta = new Dictionary<string, (string Icon, string Desc)>
    {
        ["Submissions"]   = ("fa-paper-plane",    "Claim submission volumes, acceptance rates, and timelines"),
        ["Resubmissions"] = ("fa-redo-alt",        "Resubmitted claims tracking and resolution outcomes anchored to Encounter Date"),
        ["Remittance"]    = ("fa-money-bill-wave", "Payment reconciliation and remittance analysis"),
        ["Denials"]       = ("fa-ban",             "Denial patterns, root causes, and denial trends"),
        ["Clinicians"]    = ("fa-user-md",         "Clinician productivity and claim performance"),
        ["Operations"]    = ("fa-cogs",            "Operational KPIs, TAT metrics, and SLA compliance"),
        ["Insurance"]     = ("fa-shield-alt",      "Payer-wise approval, rejection, and payment behavior"),
        ["Department"]    = ("fa-building",        "Department and facility performance breakdown"),
    };

    var maxTrend = Math.Max(1, Model.Trend.Max(x => x.Value));
    var maxBreakdown = Math.Max(1, Model.Breakdown.Max(x => x.Value));
}

@section Styles {
<style>
:root { --navy:#011C40; --teal:#A7EBF2; --gold:#35577D; --line:#EAF4FB; --muted:#35577D; }
.bi-shell {
    min-height: calc(100vh - 56px);
    background:
        radial-gradient(circle at top left, rgba(167,235,242,.10), transparent 28%),
        linear-gradient(140deg, #EAF4FB 0%, rgba(246,248,252,.92) 38%, rgba(255,255,255,.98) 100%);
}
.bi-intro {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.75rem 1rem 1rem;
    text-align: center;
}
.bi-kicker {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .35rem .7rem;
    border-radius: 999px;
    background: rgba(216,232,243,.72);
    color: #023859;
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.bi-kicker i { color: #54ACBF; }
.bi-intro h2 {
    margin: .9rem 0 .45rem;
    font-size: clamp(1.75rem, 2.8vw, 2.9rem);
    line-height: 1.08;
    color: #011C40;
    font-weight: 800;
    letter-spacing: -0.04em;
}
.bi-intro p {
    margin: 0 auto;
    max-width: 54rem;
    color: #35577D;
    font-size: .98rem;
    line-height: 1.7;
}
.bi-layout {
    max-width: 1480px;
    margin: 0 auto;
    padding: 1rem;
    display: grid;
    grid-template-columns: 238px minmax(0, 1fr);
    gap: .9rem;
}
.bi-tabs {
    display:flex;
    flex-direction:column;
    gap:.45rem;
    padding:.85rem;
    background:rgba(255,255,255,.90);
    border:1px solid rgba(8,20,35,.10);
    border-radius:18px;
    box-shadow: 0 18px 42px rgba(1,28,64,.08);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    align-self:start;
    position: sticky;
    top: 74px;
}
.bi-tab {
    display:flex;
    align-items:center;
    gap:.45rem;
    width:100%;
    padding:.82rem .9rem;
    border:1px solid transparent;
    border-left:3px solid transparent;
    background:rgba(255,255,255,.54);
    color:#023859;
    font-size:.82rem;
    font-weight:600;
    text-decoration:none;
    border-radius: 14px;
    transition: background .18s ease, color .18s ease, transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.bi-tab:hover, .bi-tab.active { color:var(--navy); }
.bi-tab:hover { background: rgba(255,255,255,.72); transform: translateX(2px); }
.bi-tab.active {
    border-left-color:var(--gold);
    background: rgba(255,255,255,.96);
    box-shadow: 0 8px 20px rgba(1,28,64,.08);
}
.bi-tab.active i { color:var(--gold); }
.bi-content {
    min-width: 0;
}
.bi-header {
    display:flex;
    justify-content:space-between;
    gap:1rem;
    align-items:flex-start;
    padding:1rem 1.1rem;
    margin-bottom:1rem;
    border:1px solid rgba(8,20,35,.10);
    border-radius: 18px;
    background: rgba(255,255,255,.88);
    box-shadow: 0 18px 42px rgba(1,28,64,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.bi-header-left { display:flex; flex-direction:column; gap:.45rem; }
.bi-title { color:var(--navy); font-size:1.15rem; font-weight:800; margin:0; }
.bi-desc { color:#023859; font-size:.88rem; margin:.2rem 0 0; font-weight:600; }
.bi-field {
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    align-self:flex-start;
    padding:.4rem .65rem;
    border-radius:999px;
    background: rgba(216,232,243,.86);
    border:1px solid rgba(8,20,35,.10);
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    line-height:1.35;
    max-width: 100%;
    white-space: normal;
}
.bi-field i { color:#54ACBF; }
.bi-field small { color:#023859; font-weight:700; display:block; }
.bi-refresh {
    color:#023859;
    font-size:.78rem;
    font-weight:700;
    white-space:nowrap;
    padding:.35rem .55rem;
    border-radius: 999px;
    background: rgba(216,232,243,.88);
    border: 1px solid rgba(8,20,35,.10);
}
.metric-grid { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:.75rem; }
.metric-card, .panel {
    background: rgba(255,255,255,.92);
    border:1px solid rgba(8,20,35,.12);
    border-radius:16px;
    box-shadow:0 14px 34px rgba(1,28,64,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.glow-card {
    --x: 50;
    --y: 50;
    --xp: 0.5;
    --yp: 0.5;
    --base: 220;
    --spread: 200;
    --radius: 16;
    --border: 3;
    --spot-opacity: 0;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transform: translateZ(0);
    transition: box-shadow .2s ease, border-color .2s ease, transform .2s ease;
}
.glow-card::before,
.glow-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    opacity: var(--spot-opacity, 0);
    transition: opacity .2s ease;
}
.glow-card::before {
    background:
        radial-gradient(
            calc(var(--radius) * 1px) calc(var(--radius) * 1px) at
            calc(var(--x) * 1px)
            calc(var(--y) * 1px),
            hsla(calc(var(--base) + (var(--xp) * var(--spread))), 88%, 70%, 0.20),
            transparent 42%
        );
    filter: blur(6px);
}
.glow-card::after {
    inset: 1px;
    border: 1px solid rgba(84,172,191,.12);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,.65),
        0 0 0 1px rgba(255,255,255,.2);
}
.glow-card.is-glowing {
    box-shadow: 0 18px 42px rgba(1,28,64,.12);
    border-color: rgba(84,172,191,.22);
}
.metric-card {
    padding:.95rem;
    display:flex;
    gap:.75rem;
    align-items:center;
    min-height:96px;
    position: relative;
    overflow:hidden;
}
.metric-card::before {
    content:'';
    position:absolute;
    inset:auto -15% -35% auto;
    width:120px;
    height:120px;
    border-radius:50%;
    background: radial-gradient(circle, rgba(167,235,242,.16), transparent 68%);
    pointer-events:none;
}
.metric-icon { width:40px; height:40px; border-radius:8px; display:grid; place-items:center; flex:0 0 auto; }
.tone-teal { background:rgba(167,235,242,.12); color:var(--teal); }
.tone-gold { background:rgba(53,87,125,.12); color:var(--gold); }
.tone-green { background:rgba(84,172,191,.12); color:#54ACBF; }
.tone-blue { background:rgba(38,101,140,.12); color:#A7EBF2; }
.metric-label { color:#023859; font-size:.74rem; font-weight:800; text-transform:uppercase; letter-spacing:.03em; }
.metric-value { color:var(--navy); font-size:1.25rem; font-weight:800; line-height:1.2; }
.metric-delta { color:#023859; font-size:.72rem; font-weight:700; }
.dash-grid { display:grid; grid-template-columns:2fr 1fr; gap:.75rem; margin-top:.75rem; }
.panel { padding:1rem; }
.panel-title { color:var(--navy); font-size:.9rem; font-weight:800; margin:0 0 .75rem; }
.summary { color:#023859; font-size:.92rem; line-height:1.65; margin-bottom:1rem; font-weight:500; }
.trend { display:grid; grid-template-columns:repeat(6,1fr); gap:.65rem; align-items:end; min-height:260px; padding-top:.5rem; }
.trend-col { display:flex; flex-direction:column; align-items:center; gap:.45rem; min-width:0; }
.trend-bar { width:100%; max-width:62px; min-height:28px; border-radius:7px 7px 3px 3px; background:linear-gradient(180deg,var(--teal),#54ACBF); }
.trend-value { color:var(--navy); font-size:.74rem; font-weight:800; }
.trend-label { color:#023859; font-size:.74rem; font-weight:600; }
.breakdown-row { display:grid; grid-template-columns:96px 1fr 46px; gap:.6rem; align-items:center; padding:.55rem 0; border-top:1px solid #EAF4FB; }
.breakdown-row:first-of-type { border-top:0; }
.breakdown-label { color:var(--navy); font-size:.82rem; font-weight:800; }
.breakdown-detail { color:#023859; font-size:.74rem; font-weight:500; }
.breakdown-track { height:9px; border-radius:999px; background:#EAF4FB; overflow:hidden; }
.breakdown-fill { height:100%; border-radius:999px; background:linear-gradient(90deg, var(--teal), var(--gold)); }
.breakdown-value { color:var(--navy); font-size:.75rem; font-weight:800; text-align:right; }
.insight { border-top:1px solid #EAF4FB; padding:.75rem 0 0; margin-top:.75rem; }
.insight:first-of-type { border-top:0; padding-top:0; margin-top:0; }
.insight-head { display:flex; justify-content:space-between; gap:.5rem; align-items:center; }
.insight-title { color:var(--navy); font-size:.8rem; font-weight:800; }
.insight-badge { font-size:.68rem; font-weight:800; border-radius:999px; padding:.18rem .5rem; background:rgba(216,232,243,.88); color:#023859; }
.insight-detail { color:#023859; font-size:.78rem; margin:.25rem 0 0; line-height:1.55; }
@@media (max-width: 992px) {
    .metric-grid, .dash-grid { grid-template-columns:1fr 1fr; }
    .dash-grid .panel:first-child { grid-column:1 / -1; }
}
@@media (max-width: 640px) {
    .bi-layout { grid-template-columns: 1fr; }
    .bi-tabs {
        position: static;
        grid-row: 2;
    }
    .bi-header { flex-direction:column; }
    .bi-field { width:100%; }
    .metric-grid, .dash-grid { grid-template-columns:1fr; }
    .trend { min-height:210px; gap:.4rem; }
    .bi-content { padding:.75rem; }
}
</style>
}

<div class="bi-shell">
    <div class="bi-layout">
        <nav class="bi-tabs" role="tablist" aria-label="Dashboard sections">
            @foreach (var tab in Model.Tabs)
            {
                var meta = tabMeta.GetValueOrDefault(tab, ("fa-chart-bar", ""));
                <a class="bi-tab @(tab == Model.ActiveTab ? "active" : "")"
                   asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@tab" role="tab"
                   aria-selected="@(tab == Model.ActiveTab ? "true" : "false")">
                    <i class="fas @meta.Item1"></i>
                    <span>@tab</span>
                </a>
            }
        </nav>

    <main class="bi-content">
        <div class="bi-header">
            <div class="bi-header-left">
                <h1 class="bi-title">@Model.ActiveTab</h1>
                <p class="bi-desc">@tabMeta.GetValueOrDefault(Model.ActiveTab, ("", "Local dashboard")).Item2</p>
                <div class="bi-field">
                    <i class="fas fa-calendar-day"></i>
                    Stable field: @Model.StableFieldTitle
                    <small>@Model.StableFieldDetail</small>
                </div>
            </div>
            <div class="bi-refresh">Updated @Model.RefreshedAt.ToString("dd MMM yyyy HH:mm")</div>
        </div>

        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (var metric in Model.Metrics)
            {
            <article class="metric-card glow-card" data-glow-color="blue">
                <div class="metric-icon tone-@metric.Tone"><i class="fas @metric.Icon"></i></div>
                <div>
                    <div class="metric-label">@metric.Label</div>
                        <div class="metric-value">@metric.Value</div>
                        <div class="metric-delta">@metric.Delta</div>
                    </div>
                </article>
            }
        </section>

        <section class="dash-grid">
            <article class="panel glow-card" data-glow-color="blue">
                <h2 class="panel-title">Performance Trend</h2>
                <p class="summary">@Model.Summary</p>
                <div class="trend">
                    @foreach (var point in Model.Trend)
                    {
                        var height = Math.Max(18, (int)Math.Round(point.Value * 100.0 / maxTrend));
                        <div class="trend-col">
                            <div class="trend-value">@point.Value%</div>
                            <div class="trend-bar" style="height:@height%;"></div>
                            <div class="trend-label">@point.Label</div>
                        </div>
                    }
                </div>
            </article>

            <article class="panel glow-card" data-glow-color="purple">
                <h2 class="panel-title">Breakdown</h2>
                @foreach (var item in Model.Breakdown)
                {
                    var width = Math.Max(5, (int)Math.Round(item.Value * 100.0 / maxBreakdown));
                    <div class="breakdown-row">
                        <div>
                            <div class="breakdown-label">@item.Label</div>
                            <div class="breakdown-detail">@item.Detail</div>
                        </div>
                        <div class="breakdown-track"><div class="breakdown-fill" style="width:@width%;"></div></div>
                        <div class="breakdown-value">@item.Value%</div>
                    </div>
                }
            </article>

            <article class="panel glow-card" data-glow-color="green">
                <h2 class="panel-title">Insights</h2>
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight">
                        <div class="insight-head">
                            <div class="insight-title">@insight.Title</div>
                            <span class="insight-badge">@insight.Status</span>
                        </div>
                        <p class="insight-detail">@insight.Detail</p>
                    </div>
                }
            </article>
        </section>
    </main>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const colorMap = {
        blue: { base: 220, spread: 200 },
        purple: { base: 280, spread: 300 },
        green: { base: 120, spread: 200 },
        red: { base: 0, spread: 200 },
        orange: { base: 30, spread: 200 }
    };

    const cards = Array.from(document.querySelectorAll('.glow-card'));
    if (!cards.length) return;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (!finePointer) return;

    cards.forEach((card) => {
        const color = colorMap[card.dataset.glowColor || 'blue'] || colorMap.blue;
        card.style.setProperty('--base', String(color.base));
        card.style.setProperty('--spread', String(color.spread));

        const reset = () => {
            card.style.setProperty('--spot-opacity', '0');
            card.classList.remove('is-glowing');
        };

        card.addEventListener('pointerenter', () => {
            card.style.setProperty('--spot-opacity', '1');
            card.classList.add('is-glowing');
        });

        card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const px = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
            const py = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
            card.style.setProperty('--x', `${(px * rect.width).toFixed(2)}`);
            card.style.setProperty('--y', `${(py * rect.height).toFixed(2)}`);
            card.style.setProperty('--xp', px.toFixed(2));
            card.style.setProperty('--yp', py.toFixed(2));
        });

        card.addEventListener('pointerleave', reset);
        card.addEventListener('pointercancel', reset);
    });
</script>
}
