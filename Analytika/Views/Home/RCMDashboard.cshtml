/* Final coherent executive BI design */
.bi-shell {
    --ui-bg:#f2f1ee;
    --ui-card:#fbfaf7;
    --ui-ink:#111111;
    --ui-muted:#5f6260;
    --ui-soft:#ebe8e2;
    --ui-line:#d9d6cf;
    --ui-accent:#c0863f;
    --ui-accent-2:#332985;
    --ui-danger:#c61f32;
    --ui-black:#0d0d0d;
    --ui-shadow:0 18px 48px rgba(17,17,17,.10);
    min-height:calc(100vh - 56px);
    padding:0;
    background:
        linear-gradient(115deg, transparent 0 24%, rgba(51,41,133,.075) 24.1% 24.7%, transparent 24.8% 100%),
        radial-gradient(circle at 16% 12%, rgba(198,31,50,.10), transparent 28%),
        radial-gradient(circle at 88% 8%, rgba(192,134,63,.16), transparent 30%),
        linear-gradient(180deg, #fbfaf7 0%, var(--ui-bg) 100%) !important;
    color:var(--ui-ink);
    font-family:Inter, "Segoe UI", Arial, sans-serif;
    overflow-x:hidden;
}
.bi-shell::before,
.bi-shell::after,
.metric-card::before,
.dash-grid .panel:nth-child(2)::after,
.bi-tabs::before,
.bi-tabs::after {
    display:none !important;
    content:none !important;
}
.bi-layout {
    max-width:1520px;
    margin:0 auto;
    padding:22px;
    display:grid;
    grid-template-columns:280px minmax(0,1fr);
    gap:22px;
    position:relative;
    z-index:1;
}
.bi-tabs-shell {
    width:auto !important;
    position:sticky;
    top:76px;
    align-self:start;
}
.bi-filter-card,
.bi-tabs,
.bi-header,
.metric-card,
.panel,
.metric-grid {
    border:1px solid var(--ui-line) !important;
    border-radius:18px !important;
    background:rgba(255,255,255,.88) !important;
    box-shadow:var(--ui-shadow) !important;
    backdrop-filter:blur(18px) saturate(150%);
    -webkit-backdrop-filter:blur(18px) saturate(150%);
}
.bi-filter-card {
    display:block !important;
    padding:18px !important;
    margin:0 0 16px !important;
}
.bi-filter-title {
    color:var(--ui-ink) !important;
    font-size:.76rem;
    font-weight:900;
    letter-spacing:.08em;
    text-transform:uppercase;
    margin-bottom:10px;
}
.bi-filter-field {
    gap:6px;
    margin-bottom:10px;
}
.bi-filter-field label,
.bi-filter-active {
    color:var(--ui-muted) !important;
    font-size:.72rem;
    font-weight:800;
}
.bi-filter-field select,
.bi-date-input {
    width:100%;
    min-height:40px;
    border:1px solid var(--ui-line) !important;
    border-radius:12px !important;
    background:#fff !important;
    color:var(--ui-ink) !important;
    font-size:.84rem;
    font-weight:700;
    box-shadow:none !important;
}
.bi-filter-actions {
    margin-top:12px;
}
.bi-filter-agent {
    margin-top:10px;
    padding-top:10px;
    border-top:1px dashed rgba(21, 52, 91, .22);
}
.bi-filter-agent label {
    display:block;
    font-weight:700;
    margin-bottom:8px;
}
.bi-filter-agent-row {
    display:flex;
    gap:8px;
}
.bi-filter-agent-input {
    flex:1;
    min-width:0;
    border:1px solid rgba(21, 52, 91, .22);
    border-radius:12px;
    padding:9px 10px;
    background:rgba(255, 255, 255, .66);
    color:var(--ui-ink);
    font-size:.9rem;
}
.bi-filter-agent-run {
    border:1px solid rgba(9, 26, 47, .34);
    background:#070e22;
    color:#c8f5e8;
    border-radius:12px;
    font-size:.84rem;
    font-weight:700;
    padding:0 12px;
    min-height:40px;
}
.bi-filter-agent-hint,
.bi-filter-agent-status {
    margin-top:8px;
    font-size:.8rem;
    line-height:1.35;
}
.bi-filter-agent-hint { color:var(--ui-muted); }
.bi-filter-agent-status { color:#11734a; }
.bi-filter-agent-status.error { color:#8a1f2a; }
.bi-filter-submit,
.bi-date-submit {
    border:0 !important;
    border-radius:12px !important;
    background:var(--ui-ink) !important;
    color:#fff !important;
    min-height:40px;
    box-shadow:none !important;
}
.bi-filter-reset,
.bi-tabs-toggle,
.bi-header-icon,
.bi-calendar-icon {
    border:1px solid var(--ui-line) !important;
    border-radius:12px !important;
    background:#fff !important;
    color:var(--ui-ink) !important;
    box-shadow:none !important;
}
.bi-tabs {
    display:flex !important;
    flex-direction:column;
    gap:8px !important;
    padding:14px !important;
    min-height:auto !important;
}
.bi-tabs-toggle {
    display:none !important;
}
.bi-tab {
    min-height:44px !important;
    padding:0 12px !important;
    border:1px solid transparent !important;
    border-radius:12px !important;
    background:transparent !important;
    color:var(--ui-muted) !important;
    font-size:.86rem;
    font-weight:800;
    text-transform:none;
    letter-spacing:0;
    box-shadow:none !important;
    display:flex;
    align-items:center;
    gap:10px;
}
.bi-tab i {
    color:currentColor !important;
}
.bi-tab small {
    margin-left:auto;
    color:currentColor !important;
    opacity:.55;
}
.bi-tab:hover {
    background:var(--ui-soft) !important;
    color:var(--ui-ink) !important;
    transform:none !important;
}
.bi-tab.active {
    background:rgba(51,41,133,.10) !important;
    color:var(--ui-accent-2) !important;
    border-color:rgba(51,41,133,.26) !important;
}
.bi-content {
    min-width:0;
    padding:0 !important;
}
.bi-header {
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:20px;
    padding:22px 24px !important;
    margin:0 0 18px !important;
    min-height:auto !important;
    clip-path:none !important;
    color:var(--ui-ink) !important;
    position:relative;
    overflow:hidden;
}
.bi-header::before {
    content:"" !important;
    display:block !important;
    position:absolute;
    inset:auto 28px 18px auto;
    width:132px;
    height:48px;
    opacity:.22;
    background:
        repeating-linear-gradient(0deg, var(--ui-black) 0 3px, transparent 3px 10px),
        linear-gradient(135deg, transparent 0 44%, var(--ui-accent) 44% 56%, transparent 56% 100%);
    pointer-events:none;
}
.bi-header::after {
    content:"" !important;
    display:block !important;
    position:absolute;
    left:24px;
    bottom:18px;
    width:86px;
    height:6px;
    background:linear-gradient(90deg, var(--ui-accent-2) 0 30%, var(--ui-accent) 30% 62%, var(--ui-danger) 62% 100%);
    pointer-events:none;
}
.bi-title {
    margin:0;
    color:var(--ui-ink) !important;
    font-size:clamp(2rem, 3vw, 3.2rem);
    line-height:1;
    font-weight:900;
    letter-spacing:-.055em;
    text-shadow:none !important;
}
.bi-desc,
.bi-header-eyebrow {
    color:var(--ui-muted) !important;
    font-size:.9rem;
    font-weight:700;
    text-transform:none;
    letter-spacing:0;
}
.bi-header-tools,
.bi-date-form,
.bi-date-range {
    display:flex;
    align-items:center;
    gap:10px;
}
.bi-date-range {
    padding:6px;
    border:1px solid var(--ui-line) !important;
    border-radius:14px !important;
    background:#fff !important;
    box-shadow:none !important;
}
.bi-date-input {
    width:142px;
}
.bi-date-submit,
.bi-calendar-icon,
.bi-header-icon {
    width:40px;
    height:40px;
    display:grid;
    place-items:center;
    text-decoration:none;
}
.bi-chat-icon::after {
    background:var(--ui-danger);
}
.metric-grid {
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr)) !important;
    gap:14px !important;
    padding:0 !important;
    background:transparent !important;
    border:0 !important;
    box-shadow:none !important;
    margin:0 0 18px !important;
    overflow:visible;
}
.metric-card {
    min-height:148px !important;
    padding:18px !important;
    display:grid !important;
    grid-template-columns:1fr auto;
    grid-template-rows:auto 1fr;
    gap:10px 14px !important;
    position:relative;
    overflow:visible !important;
}
.metric-card > div:nth-child(2) {
    grid-column:1 / -1;
}
.metric-icon {
    width:44px !important;
    height:44px !important;
    border-radius:14px !important;
    display:grid;
    place-items:center;
    background:rgba(51,41,133,.10) !important;
    color:var(--ui-accent-2) !important;
    box-shadow:none !important;
}
.metric-label,
.panel-title,
.breakdown-label,
.insight-title {
    color:var(--ui-ink) !important;
    font-size:.78rem;
    font-weight:900;
    letter-spacing:.04em;
    text-transform:uppercase;
}
.metric-value {
    color:var(--ui-ink) !important;
    font-size:2rem;
    line-height:1.05;
    font-weight:900;
    letter-spacing:-.045em;
}
.metric-delta {
    display:inline-flex;
    width:max-content;
    padding:4px 10px;
    border-radius:999px;
    background:rgba(192,134,63,.14) !important;
    color:#8a551b !important;
    border:1px solid rgba(192,134,63,.34) !important;
    font-size:.78rem;
    font-weight:900;
}
.metric-card:nth-child(2) .metric-delta,
.metric-card:nth-child(3) .metric-delta {
    background:rgba(198,31,50,.10) !important;
    color:var(--ui-danger) !important;
    border-color:rgba(198,31,50,.28) !important;
}
.metric-spark {
    height:36px;
    margin-top:10px;
    display:flex;
    align-items:end;
    gap:6px;
    border-bottom:1px dashed var(--ui-line);
}
.metric-spark span {
    flex:1;
    height:100%;
    position:relative;
}
.metric-spark span::after {
    content:"";
    display:block;
    height:2px;
    background:var(--ui-accent);
    transform-origin:left center;
}
.metric-meter {
    width:100%;
    height:12px;
    margin-top:16px;
    border-radius:999px;
    background:
        linear-gradient(90deg, rgba(17,17,17,.07), rgba(192,134,63,.10)),
        repeating-linear-gradient(90deg, transparent 0 14%, rgba(17,17,17,.10) 14% 15%);
    overflow:hidden;
}
.metric-meter span {
    display:block;
    width:100%;
    height:100%;
    border-radius:inherit;
    background:linear-gradient(90deg, var(--ui-accent-2), var(--ui-accent));
    box-shadow:0 0 18px rgba(192,134,63,.28);
}
.dash-grid {
    display:grid;
    grid-template-columns:minmax(0,1.55fr) minmax(320px,.9fr);
    gap:18px !important;
    align-items:start;
    margin:0 !important;
}
.dash-grid .panel:first-child {
    grid-row:span 2;
    min-height:520px;
}
.panel {
    padding:20px !important;
}
.panel-title {
    margin:0 0 12px;
    padding-bottom:12px;
    border-bottom:1px solid var(--ui-line);
}
.summary,
.trend-label,
.breakdown-detail,
.insight-detail {
    color:var(--ui-muted) !important;
}
.zc-segmented {
    display:grid !important;
    grid-template-columns:repeat(4,minmax(0,1fr));
    gap:8px !important;
    margin:14px 0 18px;
    border:0 !important;
}
.zc-segmented span {
    min-height:38px;
    display:grid;
    place-items:center;
    border:1px solid var(--ui-line) !important;
    border-radius:12px !important;
    background:#fff !important;
    color:var(--ui-muted) !important;
    font-size:.78rem;
    font-weight:900;
}
.zc-segmented .active {
    background:var(--ui-ink) !important;
    color:#fff !important;
    border-color:var(--ui-ink) !important;
}
.trend {
    min-height:330px;
    display:grid;
    grid-template-columns:repeat(6,1fr);
    gap:12px;
    align-items:end;
    padding:16px 4px 4px;
    background:linear-gradient(#fff,#fff) !important;
}
.chart-panel {
    overflow:hidden;
}
.trend-line-chart {
    min-height:340px;
    display:block;
    padding:12px 0 0;
    background:
        linear-gradient(180deg, rgba(51,41,133,.045), rgba(192,134,63,.045)),
        var(--ui-card) !important;
    border:1px solid var(--ui-line);
    border-radius:16px;
}
.trend-svg {
    display:block;
    width:100%;
    height:auto;
    min-height:300px;
}
.trend-grid-lines line {
    stroke:#e4e7ec;
    stroke-width:1;
}
.trend-area {
    fill:url(#trendAreaGradient);
}
.trend-line {
    fill:none;
    stroke:url(#trendLineGradient);
    stroke-width:4;
    stroke-linecap:round;
    stroke-linejoin:round;
    filter:drop-shadow(0 8px 10px rgba(51,41,133,.16));
}
.trend-point circle {
    fill:#fff;
    stroke:var(--ui-accent);
    stroke-width:3;
}
.trend-point text {
    fill:var(--ui-ink);
    font-size:12px;
    font-weight:900;
    text-anchor:middle;
}
.trend-axis-label {
    fill:var(--ui-muted);
    font-size:12px;
    font-weight:800;
    text-anchor:middle;
}
.trend-y-label,
.trend-empty {
    fill:var(--ui-muted);
    font-size:12px;
    font-weight:800;
    text-anchor:end;
}
.trend-empty {
    text-anchor:middle;
    font-size:15px;
}
.trend-bar,
.breakdown-fill {
    background:linear-gradient(180deg, var(--ui-accent-2), var(--ui-accent)) !important;
    border-radius:999px 999px 6px 6px !important;
}
.breakdown-panel {
    position:relative;
}
.breakdown-panel .breakdown-row {
    display:grid;
    grid-template-columns:140px minmax(120px,1fr) 52px !important;
    justify-items:stretch !important;
    gap:12px;
    padding:14px 0;
    border-top:1px solid var(--ui-line) !important;
}
.breakdown-panel .breakdown-track {
    width:100%;
    height:14px;
    border-radius:999px !important;
    background:var(--ui-soft) !important;
    overflow:hidden;
    box-shadow:none !important;
}
.breakdown-panel .breakdown-fill {
    height:100%;
    border-radius:999px !important;
    background:linear-gradient(90deg, var(--ui-accent-2), var(--ui-accent)) !important;
}
.breakdown-panel .breakdown-value {
    color:var(--ui-ink);
    font-weight:900;
}
.insight {
    border-top:1px solid var(--ui-line);
}
.insight-badge {
    border-radius:999px;
    background:rgba(192,134,63,.14);
    color:#8a551b;
    border:1px solid rgba(192,134,63,.34);
}
.metric-explain {
    border-radius:16px !important;
    background:var(--ui-ink) !important;
    color:#fff !important;
    border:1px solid rgba(255,255,255,.1) !important;
    box-shadow:0 24px 54px rgba(16,24,40,.25) !important;
}
@@media (max-width: 1120px) {
    .bi-layout {
        grid-template-columns:1fr;
    }
    .bi-tabs-shell {
        position:static;
    }
    .bi-tabs {
        display:grid !important;
        grid-template-columns:repeat(4,minmax(0,1fr));
    }
    .metric-grid {
        grid-template-columns:repeat(2,minmax(0,1fr)) !important;
    }
    .dash-grid {
        grid-template-columns:1fr;
    }
    .bi-filter-card form {
        display:grid;
        grid-template-columns:repeat(2,minmax(0,1fr));
        gap:12px;
    }
    .bi-filter-title,
    .bi-filter-actions,
    .bi-filter-active {
        grid-column:1 / -1;
    }
}
@@media (max-width: 680px) {
    .bi-layout {
        padding:12px;
    }
    .bi-header {
        flex-direction:column;
        align-items:stretch;
    }
    .bi-header-tools,
    .bi-date-form,
    .bi-date-range {
        width:100%;
        flex-wrap:wrap;
    }
    .bi-date-input {
        flex:1 1 125px;
    }
    .bi-tabs,
    .metric-grid {
        grid-template-columns:1fr !important;
    }
    .bi-title {
        font-size:2.1rem;
    }
    .breakdown-row {
        grid-template-columns:1fr;
    }
}
</style>
}

<div class="bi-shell">
    <div class="bi-layout">
        <div class="bi-tabs-shell" data-bi-tabs-shell>
            <button type="button" class="bi-tabs-toggle" data-bi-tabs-toggle aria-expanded="true" aria-label="Collapse dashboard sections">
                <i class="fas fa-chevron-left"></i>
            </button>
            <section class="bi-filter-card" aria-label="Dashboard filters">
                <form method="get" asp-controller="Home" asp-action="RCMDashboard">
                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                    <div class="bi-filter-title">
                        <i class="fas fa-filter"></i>
                        Filters
                    </div>
                    <div class="bi-filter-field">
                        <label for="facilityId">Facility</label>
                        <select id="facilityId" name="facilityId">
                            <option value="">All facilities</option>
                            @foreach (var option in Model.FacilityOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.FacilityId?.ToString() == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="receiver">Receiver</label>
                        <select id="receiver" name="receiver">
                            <option value="">All receivers</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.Receiver) && !Model.ReceiverOptions.Any(o => o.Value == Model.Filters.Receiver))
                            {
                                <option value="@Model.Filters.Receiver" selected>@Model.Filters.Receiver</option>
                            }
                            @foreach (var option in Model.ReceiverOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.Receiver == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="payer">Payer</label>
                        <select id="payer" name="payer">
                            <option value="">All payers</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.Payer) && !Model.PayerOptions.Any(o => o.Value == Model.Filters.Payer))
                            {
                                <option value="@Model.Filters.Payer" selected>@Model.Filters.Payer</option>
                            }
                            @foreach (var option in Model.PayerOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.Payer == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="encounterType">Encounter Type</label>
                        <select id="encounterType" name="encounterType">
                            <option value="">All encounter types</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.EncounterType) && !Model.EncounterTypeOptions.Any(o => o.Value == Model.Filters.EncounterType))
                            {
                                <option value="@Model.Filters.EncounterType" selected>@Model.Filters.EncounterType</option>
                            }
                            @foreach (var option in Model.EncounterTypeOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.EncounterType == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-actions">
                        <button type="submit" class="bi-filter-submit">
                            <i class="fas fa-check"></i>
                            Apply
                        </button>
                        <a class="bi-filter-reset" asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@Model.ActiveTab" title="Reset filters" aria-label="Reset filters">
                            <i class="fas fa-rotate-left"></i>
                        </a>
                    </div>
                    @if (Model.HasActiveFilters)
                    {
                        <div class="bi-filter-active">
                            <i class="fas fa-circle-check"></i>
                            Filtered view
                        </div>
                    }
                    <div class="bi-filter-agent" aria-label="Filter Agent">
                        <label for="biFilterAgentInput">Filter Agent</label>
                        <div class="bi-filter-agent-row">
                            <input id="biFilterAgentInput" class="bi-filter-agent-input" type="text" placeholder="facility Alnoor Muhaisnah, payer TPA004, from 2026-05-01 to 2026-05-27" />
                            <button type="button" id="biFilterAgentRun" class="bi-filter-agent-run">Run</button>
                        </div>
                        <div class="bi-filter-agent-hint">Understands: facility, receiver, payer, encounter type, date range.</div>
                        <div id="biFilterAgentStatus" class="bi-filter-agent-status" aria-live="polite"></div>
                    </div>
                </form>
            </section>
            <nav class="bi-tabs" id="biTabsNav" role="tablist" aria-label="Dashboard sections">
                @foreach (var tab in Model.Tabs)
                {
                    var meta = tabMeta.GetValueOrDefault(tab, ("fa-chart-bar", ""));
                    <a class="bi-tab @(tab == Model.ActiveTab ? "active" : "")"
                       asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@tab"
                       asp-route-facilityId="@Model.Filters.FacilityId"
                       asp-route-receiver="@Model.Filters.Receiver"
                       asp-route-payer="@Model.Filters.Payer"
                       asp-route-encounterType="@Model.Filters.EncounterType"
                       asp-route-dateFrom="@Model.Filters.DateFrom"
                       asp-route-dateTo="@Model.Filters.DateTo"
                       role="tab"
                       aria-selected="@(tab == Model.ActiveTab ? "true" : "false")">
                        <i class="fas @meta.Item1"></i>
                        <span>@tab</span>
                    </a>
                }
            </nav>
        </div>

    <main class="bi-content">
        <div class="bi-header">
            <div class="bi-header-left">
                <h1 class="bi-title">@Model.ActiveTab Dashboard</h1>
                <p class="bi-desc">Reports from @reportDateFromText to @reportDateToText</p>
            </div>
            <div class="bi-header-tools">
                <form method="get" asp-controller="Home" asp-action="RCMDashboard" class="bi-date-form">
                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                    <input type="hidden" name="facilityId" value="@Model.Filters.FacilityId" />
                    <input type="hidden" name="receiver" value="@Model.Filters.Receiver" />
                    <input type="hidden" name="payer" value="@Model.Filters.Payer" />
                    <input type="hidden" name="encounterType" value="@Model.Filters.EncounterType" />
                    <div class="bi-calendar-icon" aria-hidden="true"><i class="far fa-calendar-alt"></i></div>
                    <div class="bi-date-range">
                        <input class="bi-date-input" type="date" name="dateFrom" value="@reportDateFrom.ToString("yyyy-MM-dd")" aria-label="Report start date" />
                        <input class="bi-date-input" type="date" name="dateTo" value="@reportDateTo.ToString("yyyy-MM-dd")" aria-label="Report end date" />
                        <button type="submit" class="bi-date-submit" aria-label="Apply date filters">
                            <i class="fas fa-check"></i>
                        </button>
                    </div>
                </form>
                <button type="button" class="bi-header-icon bi-chat-icon" aria-label="Dashboard help">
                    <i class="fas fa-comments"></i>
                </button>
                <a class="bi-header-icon bi-back-icon" asp-controller="Home" asp-action="Dashboard" aria-label="Back to facility dashboard">
                    <i class="fas fa-undo"></i>
                </a>
            </div>
        </div>

        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (var metric in Model.Metrics)
            {
            <article class="metric-card">
                <div class="metric-icon tone-@metric.Tone"><i class="fas @metric.Icon"></i></div>
                <div>
	                    <div class="metric-label">@metric.Label</div>
	                        <div class="metric-value">@metric.Value</div>
	                        <div class="metric-delta">@metric.Delta</div>
                            <div class="metric-meter" aria-hidden="true">
                                <span></span>
                            </div>
	                    </div>
	                </article>
            }
        </section>

        <section class="dash-grid">
            @{
                var trendValues = Model.Trend.Select(p => p.Value).ToList();
                var trendMin = trendValues.Any() ? trendValues.Min() : 0;
                var trendMax = trendValues.Any() ? trendValues.Max() : 1;
                if (trendMin == trendMax) { trendMin = Math.Max(0, trendMin - 10); trendMax += 10; }
                const double chartW = 720;
                const double chartH = 290;
                const double padL = 44;
                const double padR = 18;
                const double padT = 24;
                const double padB = 42;
                var plotW = chartW - padL - padR;
                var plotH = chartH - padT - padB;
                var trendCount = Math.Max(1, Model.Trend.Count);
                var chartPoints = Model.Trend.Select((p, i) =>
                {
                    var x = padL + (trendCount == 1 ? plotW / 2 : (plotW * i / (trendCount - 1)));
                    var y = padT + ((trendMax - p.Value) * plotH / Math.Max(1, trendMax - trendMin));
                    return new { p.Label, p.Value, X = x, Y = y };
                }).ToList();
                var linePoints = string.Join(" ", chartPoints.Select(p => $"{p.X.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)},{p.Y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}"));
                var areaPoints = chartPoints.Any()
                    ? $"{padL.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)},{(chartH - padB).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)} {linePoints} {(chartW - padR).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)},{(chartH - padB).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}"
                    : string.Empty;
            }
            <article class="panel glow-card chart-panel" data-glow-color="blue">
		                <h2 class="panel-title">Performance Trend</h2>
		                <p class="summary">@Model.Summary</p>
                    <div class="zc-segmented" aria-label="Trend metric selector">
                        <span class="active"># @Model.ActiveTab</span>
                        <span>Clean Rate</span>
                        <span>Net Value</span>
                        <span>TAT</span>
                    </div>
                <div class="trend trend-line-chart">
                    <svg class="trend-svg" viewBox="0 0 720 290" role="img" aria-label="@Model.ActiveTab trend chart">
                        <defs>
                            <linearGradient id="trendAreaGradient" x1="0" x2="0" y1="0" y2="1">
                                <stop offset="0%" stop-color="#332985" stop-opacity=".24" />
                                <stop offset="100%" stop-color="#c0863f" stop-opacity=".03" />
                            </linearGradient>
                            <linearGradient id="trendLineGradient" x1="0" x2="1" y1="0" y2="0">
                                <stop offset="0%" stop-color="#332985" />
                                <stop offset="62%" stop-color="#c0863f" />
                                <stop offset="100%" stop-color="#c61f32" />
                            </linearGradient>
                        </defs>
                        <g class="trend-grid-lines">
                            <line x1="44" y1="24" x2="702" y2="24" />
                            <line x1="44" y1="80" x2="702" y2="80" />
                            <line x1="44" y1="136" x2="702" y2="136" />
                            <line x1="44" y1="192" x2="702" y2="192" />
                            <line x1="44" y1="248" x2="702" y2="248" />
                        </g>
                        @Html.Raw($"<text class=\"trend-y-label\" x=\"30\" y=\"30\">{trendMax:N0}</text>")
                        @Html.Raw($"<text class=\"trend-y-label\" x=\"30\" y=\"252\">{trendMin:N0}</text>")
                        @if (chartPoints.Any())
                        {
                            <polygon class="trend-area" points="@areaPoints"></polygon>
                            <polyline class="trend-line" points="@linePoints"></polyline>
                        }
                        else
                        {
                            @Html.Raw("<text class=\"trend-empty\" x=\"360\" y=\"150\">No parsed records for selected filters</text>")
                        }
                        @foreach (var point in chartPoints)
                        {
                            <g class="trend-point" transform="translate(@point.X.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) @point.Y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))">
                                <circle r="5"></circle>
                                @Html.Raw($"<text y=\"-12\">{point.Value:N0}</text>")
                            </g>
                        }
                        @foreach (var point in chartPoints)
                        {
                            @Html.Raw($"<text class=\"trend-axis-label\" x=\"{point.X.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)}\" y=\"276\">{System.Net.WebUtility.HtmlEncode(point.Label)}</text>")
                        }
                    </svg>
                </div>
	            </article>

	            <article class="panel glow-card breakdown-panel" data-glow-color="purple">
	                <h2 class="panel-title">Breakdown</h2>
	                @foreach (var item in Model.Breakdown)
	                {
	                    var width = Math.Max(5, (int)Math.Round(item.Value * 100.0 / maxBreakdown));
	                    <div class="breakdown-row">
	                        <div>
	                            <div class="breakdown-label">@item.Label</div>
	                            <div class="breakdown-detail">@item.Detail</div>
	                        </div>
	                        <div class="breakdown-track"><div class="breakdown-fill" style="width:@width%;"></div></div>
	                        <div class="breakdown-value">@item.Value:N0</div>
	                    </div>
	                }
            </article>

            <article class="panel glow-card" data-glow-color="green">
                <h2 class="panel-title">Insights</h2>
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight">
                        <div class="insight-head">
                            <div class="insight-title">@insight.Title</div>
                            <span class="insight-badge">@insight.Status</span>
                        </div>
                        <p class="insight-detail">@insight.Detail</p>
                    </div>
                }
            </article>
        </section>
    </main>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const colorMap = {
        blue: { base: 220, spread: 200 },
        purple: { base: 280, spread: 300 },
        green: { base: 120, spread: 200 },
        red: { base: 0, spread: 200 },
        orange: { base: 30, spread: 200 }
    };

    const cards = Array.from(document.querySelectorAll('.glow-card'));
    if (!cards.length) return;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (!finePointer) return;

    cards.forEach((card) => {
        const color = colorMap[card.dataset.glowColor || 'blue'] || colorMap.blue;
        card.style.setProperty('--base', String(color.base));
        card.style.setProperty('--spread', String(color.spread));

        const reset = () => {
            card.style.setProperty('--spot-opacity', '0');
            card.classList.remove('is-glowing');
        };

        card.addEventListener('pointerenter', () => {
            card.style.setProperty('--spot-opacity', '1');
            card.classList.add('is-glowing');
        });

        card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const px = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
            const py = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
            card.style.setProperty('--x', `${(px * rect.width).toFixed(2)}`);
            card.style.setProperty('--y', `${(py * rect.height).toFixed(2)}`);
            card.style.setProperty('--xp', px.toFixed(2));
            card.style.setProperty('--yp', py.toFixed(2));
        });

        card.addEventListener('pointerleave', reset);
        card.addEventListener('pointercancel', reset);
    });

    const shell = document.querySelector('[data-bi-tabs-shell]');
    const toggle = document.querySelector('[data-bi-tabs-toggle]');
    const tabLinks = Array.from(document.querySelectorAll('.bi-tab'));
    const layout = shell?.closest('.bi-layout');
    if (!shell || !toggle || !layout || !tabLinks.length) return;

    const collapseAtKey = 'biTabsCollapseAt';
    const collapsedKey = 'biTabsCollapsed';
    let collapseTimer = null;

    const setCollapsed = (collapsed) => {
        shell.classList.toggle('is-collapsed', collapsed);
        layout.classList.toggle('is-tabs-collapsed', collapsed);
        toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        toggle.setAttribute('aria-label', collapsed ? 'Expand dashboard sections' : 'Collapse dashboard sections');
        window.sessionStorage.setItem(collapsedKey, collapsed ? '1' : '0');
        if (!collapsed) {
            window.sessionStorage.removeItem(collapseAtKey);
            if (collapseTimer) {
                window.clearTimeout(collapseTimer);
                collapseTimer = null;
            }
        }
    };

    const scheduleCollapse = (delayMs) => {
        if (collapseTimer) window.clearTimeout(collapseTimer);
        collapseTimer = window.setTimeout(() => setCollapsed(true), Math.max(0, delayMs));
    };

    const storedCollapsed = window.sessionStorage.getItem(collapsedKey) === '1';
    const collapseAt = Number(window.sessionStorage.getItem(collapseAtKey) || 0);
    if (storedCollapsed) {
        setCollapsed(true);
    } else if (collapseAt > Date.now()) {
        scheduleCollapse(collapseAt - Date.now());
    }

    toggle.addEventListener('click', () => {
        setCollapsed(!shell.classList.contains('is-collapsed'));
    });

    tabLinks.forEach((tab) => {
        tab.addEventListener('click', () => {
            window.sessionStorage.setItem(collapsedKey, '0');
            window.sessionStorage.setItem(collapseAtKey, String(Date.now() + 5000));
        });
    });

    const filterForm = document.querySelector('.bi-filter-card form');
    const dateForm = document.querySelector('.bi-date-form');
    const agentInput = document.getElementById('biFilterAgentInput');
    const agentRun = document.getElementById('biFilterAgentRun');
    const agentStatus = document.getElementById('biFilterAgentStatus');
    if (!filterForm || !dateForm || !agentInput || !agentRun || !agentStatus) return;

    const norm = (value) => (value || '').toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
    const selectMatch = (selectEl, targetText) => {
        const want = norm(targetText);
        if (!want) return false;
        const options = Array.from(selectEl.options);
        let best = null;
        for (const opt of options) {
            const text = norm(opt.textContent);
            const value = norm(opt.value);
            if (!text && !value) continue;
            if (text === want || value === want) {
                selectEl.value = opt.value;
                return true;
            }
            if (text.includes(want) || want.includes(text) || value.includes(want) || want.includes(value)) {
                const score = Math.max(text.length, value.length);
                if (!best || score > best.score) best = { value: opt.value, score };
            }
        }
        if (!best) return false;
        selectEl.value = best.value;
        return true;
    };

    const parseRange = (text) => {
        const ymd = text.match(/from\s+(\d{4}-\d{2}-\d{2})\s+to\s+(\d{4}-\d{2}-\d{2})/i);
        if (ymd) return { from: ymd[1], to: ymd[2] };
        const isoAny = text.match(/(\d{4}-\d{2}-\d{2}).*?(\d{4}-\d{2}-\d{2})/i);
        if (isoAny) return { from: isoAny[1], to: isoAny[2] };
        const now = new Date();
        if (/today/i.test(text)) {
            const d = now.toISOString().slice(0, 10);
            return { from: d, to: d };
        }
        if (/this\s+month/i.test(text)) {
            const from = new Date(now.getFullYear(), now.getMonth(), 1).toISOString().slice(0, 10);
            const to = now.toISOString().slice(0, 10);
            return { from, to };
        }
        if (/last\s+month/i.test(text)) {
            const fromDate = new Date(now.getFullYear(), now.getMonth() - 1, 1);
            const toDate = new Date(now.getFullYear(), now.getMonth(), 0);
            return { from: fromDate.toISOString().slice(0, 10), to: toDate.toISOString().slice(0, 10) };
        }
        return null;
    };

    const pullField = (text, key) => {
        const pattern = new RegExp(`${key}\\s*[:=]?\\s*([\\w\\-\\s@@.]+?)(?=\\s+(facility|receiver|payer|encounter|from|to)\\b|$)`, 'i');
        const match = text.match(pattern);
        return match ? match[1].trim() : '';
    };

    const applyFromText = () => {
        const text = (agentInput.value || '').trim();
        if (!text) {
            agentStatus.textContent = 'Type a request first.';
            agentStatus.classList.add('error');
            return;
        }
        agentStatus.classList.remove('error');
        const mapped = [];
        const misses = [];
        const facility = pullField(text, 'facility');
        const receiver = pullField(text, 'receiver');
        const payer = pullField(text, 'payer');
        const encounter = pullField(text, 'encounter(?:\\s*type)?');

        if (facility) (selectMatch(filterForm.querySelector('#facilityId'), facility) ? mapped : misses).push(`facility ${facility}`);
        if (receiver) (selectMatch(filterForm.querySelector('#receiver'), receiver) ? mapped : misses).push(`receiver ${receiver}`);
        if (payer) (selectMatch(filterForm.querySelector('#payer'), payer) ? mapped : misses).push(`payer ${payer}`);
        if (encounter) (selectMatch(filterForm.querySelector('#encounterType'), encounter) ? mapped : misses).push(`encounter ${encounter}`);

        const range = parseRange(text);
        if (range) {
            const fromInput = dateForm.querySelector('input[name="dateFrom"]');
            const toInput = dateForm.querySelector('input[name="dateTo"]');
            if (fromInput && toInput) {
                fromInput.value = range.from;
                toInput.value = range.to;
                mapped.push(`date ${range.from} to ${range.to}`);
            }
        }

        const message = [`Applied: ${mapped.length ? mapped.join(', ') : 'none'}`];
        if (misses.length) message.push(`Not matched: ${misses.join(', ')}`);
        agentStatus.textContent = message.join(' | ');
        if (!mapped.length) {
            agentStatus.classList.add('error');
            return;
        }
        filterForm.requestSubmit();
    };

    agentRun.addEventListener('click', applyFromText);
    agentInput.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter') return;
        event.preventDefault();
        applyFromText();
    });
})();
</script>
}
