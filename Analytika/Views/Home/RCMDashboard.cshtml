@model Analytika.Models.ViewModels.RCMDashboardViewModel
@{
    ViewData["Title"] = "BI Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var tabMeta = new Dictionary<string, (string Icon, string Desc)>
    {
        ["Submissions"]   = ("fa-paper-plane",    "Claim submission volumes, acceptance rates, and timelines"),
        ["Resubmissions"] = ("fa-redo-alt",        "Resubmitted claims tracking and resolution outcomes anchored to Encounter Date"),
        ["Remittance"]    = ("fa-money-bill-wave", "Payment reconciliation and remittance analysis"),
        ["Denials"]       = ("fa-ban",             "Denial patterns, root causes, and denial trends"),
        ["Clinicians"]    = ("fa-user-md",         "Clinician productivity and claim performance"),
        ["Operations"]    = ("fa-cogs",            "Operational KPIs, TAT metrics, and SLA compliance"),
        ["Insurance"]     = ("fa-shield-alt",      "Payer-wise approval, rejection, and payment behavior"),
        ["Department"]    = ("fa-building",        "Department and facility performance breakdown"),
    };

    var maxTrend = Math.Max(1, Model.Trend.Max(x => x.Value));
    var maxBreakdown = Math.Max(1, Model.Breakdown.Max(x => x.Value));
    var reportDateFrom = Model.Filters.DateFrom ?? new DateOnly(2023, 1, 1);
    var reportDateTo = Model.Filters.DateTo ?? DateOnly.FromDateTime(DateTime.Today);
    var reportDateFromText = reportDateFrom.ToString("dd/MM/yyyy");
    var reportDateToText = reportDateTo.ToString("dd/MM/yyyy");
    var activeTabIndex = Math.Max(0, Model.Tabs.FindIndex(t => t.Equals(Model.ActiveTab, StringComparison.OrdinalIgnoreCase))) + 1;
}

@section Styles {
<style>
:root {
    --teal:#54ACBF;
    --blue:#26658C;
    --navy:#011C40;
    --plum:#2F8F72;
    --red:#B94A3F;
    --burgundy:#7A3A30;
    --line:rgba(84,172,191,.16);
    --muted:#26658C;
    --surface:rgba(255,255,255,.92);
}
.bi-shell {
    min-height: calc(100vh - 56px);
    background:
        radial-gradient(circle at 0% 18%, rgba(84,172,191,.26), transparent 30%),
        radial-gradient(circle at 100% 0%, rgba(84,172,191,.14), transparent 32%),
        linear-gradient(140deg, rgba(13,26,47,.12) 0%, rgba(23,54,79,.08) 42%, rgba(255,255,255,.98) 100%);
}
.bi-intro {
    max-width: 980px;
    margin: 0 auto;
    padding: 1.75rem 1rem 1rem;
    text-align: center;
}
.bi-kicker {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .35rem .7rem;
    border-radius: 999px;
    background: rgba(84,172,191,.14);
    color: var(--blue);
    font-size: .72rem;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.bi-kicker i { color: var(--teal); }
.bi-intro h2 {
    margin: .9rem 0 .45rem;
    font-size: clamp(1.75rem, 2.8vw, 2.9rem);
    line-height: 1.08;
    color: var(--navy);
    font-weight: 800;
    letter-spacing: -0.04em;
}
.bi-intro p {
    margin: 0 auto;
    max-width: 54rem;
    color: var(--blue);
    font-size: .98rem;
    line-height: 1.7;
}
.bi-layout {
    max-width: 1480px;
    margin: 0 auto;
    padding: 1rem;
    display: grid;
    grid-template-columns: 238px minmax(0, 1fr);
    gap: .9rem;
    transition: grid-template-columns .28s ease, gap .28s ease;
}
.bi-layout.is-tabs-collapsed {
    grid-template-columns: 64px minmax(0, 1fr);
    gap: .6rem;
}
.bi-tabs-shell {
    position: sticky;
    top: 74px;
    align-self: start;
    width: 238px;
    transition: width .28s ease;
}
.bi-layout.is-tabs-collapsed .bi-tabs-shell {
    width: 64px;
}
.bi-tabs {
    display:flex;
    flex-direction:column;
    gap:.45rem;
    padding:.85rem;
    background:var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:18px;
    box-shadow: 0 18px 42px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    align-self:start;
    position: relative;
    overflow: hidden;
    transition: transform .28s ease, opacity .28s ease, filter .28s ease, box-shadow .28s ease;
    will-change: transform;
}
.bi-filter-card {
    display:flex;
    flex-direction:column;
    gap:.55rem;
    padding:3rem .85rem .85rem;
    margin-bottom:.6rem;
    border:1px solid rgba(23,54,79,.12);
    border-radius:18px;
    background:var(--surface);
    box-shadow: 0 18px 42px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    overflow:hidden;
}
.bi-filter-title {
    display:flex;
    align-items:center;
    gap:.45rem;
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    text-transform:uppercase;
    letter-spacing:.04em;
}
.bi-filter-title i { color:var(--teal); }
.bi-filter-field {
    display:flex;
    flex-direction:column;
    gap:.25rem;
}
.bi-filter-field label {
    color:var(--blue);
    font-size:.68rem;
    font-weight:800;
}
.bi-filter-field select {
    width:100%;
    min-height:34px;
    border:1px solid rgba(23,54,79,.16);
    border-radius:10px;
    background:#fff;
    color:var(--navy);
    font-size:.75rem;
    font-weight:700;
    padding:.35rem .5rem;
}
.bi-filter-actions {
    display:flex;
    gap:.4rem;
    align-items:center;
    margin-top:.15rem;
}
.bi-filter-submit,
.bi-filter-reset {
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.35rem;
    min-height:34px;
    border-radius:10px;
    font-size:.72rem;
    font-weight:800;
    text-decoration:none;
}
.bi-filter-submit {
    flex:1 1 auto;
    border:1px solid rgba(13,26,47,.22);
    background:var(--navy);
    color:#fff;
}
.bi-filter-reset {
    flex:0 0 34px;
    border:1px solid rgba(23,54,79,.16);
    background:rgba(255,255,255,.82);
    color:var(--blue);
}
.bi-filter-active {
    display:inline-flex;
    align-items:center;
    gap:.35rem;
    color:var(--blue);
    font-size:.68rem;
    font-weight:800;
}
.bi-tabs-toggle {
    position:absolute;
    top:.8rem;
    right:.8rem;
    z-index:2;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:2.1rem;
    height:2.1rem;
    border:1px solid rgba(23,54,79,.16);
    border-radius:999px;
    background:rgba(255,255,255,.92);
    color:var(--blue);
    box-shadow: 0 8px 18px rgba(13,26,47,.10);
    transition: transform .2s ease, background .2s ease, color .2s ease;
}
.bi-tabs-toggle:hover {
    background:#fff;
    color:var(--navy);
    transform: translateY(-1px);
}
.bi-tab {
    display:flex;
    align-items:center;
    gap:.45rem;
    width:100%;
    padding:.82rem .9rem;
    border:1px solid transparent;
    border-left:3px solid transparent;
    background:rgba(255,255,255,.54);
    color:var(--blue);
    font-size:.82rem;
    font-weight:600;
    text-decoration:none;
    border-radius: 14px;
    transition: background .18s ease, color .18s ease, transform .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.bi-tab:hover, .bi-tab.active { color:var(--navy); }
.bi-tab:hover { background: rgba(255,255,255,.72); transform: translateX(2px); }
.bi-tab.active {
    border-left-color:var(--teal);
    background: rgba(255,255,255,.96);
    box-shadow: 0 8px 20px rgba(13,26,47,.10);
}
.bi-tab.active i { color:var(--teal); }
.bi-tabs-shell.is-collapsed .bi-tabs {
    padding-left:.55rem;
    padding-right:.55rem;
    opacity: .96;
    filter: saturate(.96);
}
.bi-tabs-shell.is-collapsed .bi-filter-card {
    height:0;
    margin:0;
    padding:0;
    border:0;
    opacity:0;
    pointer-events:none;
}
.bi-tabs-shell.is-collapsed .bi-tabs-toggle i {
    transform: rotate(180deg);
}
.bi-tabs-shell.is-collapsed .bi-tab span {
    position:absolute;
    width:1px;
    height:1px;
    clip:rect(0 0 0 0);
    overflow: hidden;
}
.bi-tabs-shell.is-collapsed .bi-tab {
    justify-content:center;
    padding:.82rem .55rem;
}
.bi-tabs-shell.is-collapsed .bi-tab i {
    margin:0;
}
.bi-content {
    min-width: 0;
}
.bi-header {
    display:flex;
    justify-content:space-between;
    gap:1.25rem;
    align-items:center;
    padding:1.25rem 1.4rem;
    margin-bottom:1rem;
    border:1px solid rgba(23,54,79,.12);
    border-radius: 10px;
    background: rgba(255,255,255,.94);
    box-shadow: 0 8px 22px rgba(13,26,47,.10);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.bi-header-left { display:flex; flex-direction:column; gap:.2rem; min-width:0; }
.bi-title { color:var(--navy); font-size:1.65rem; font-weight:900; margin:0; letter-spacing:-.025em; line-height:1.05; }
.bi-desc { color:var(--blue); font-size:1rem; margin:0; font-weight:600; }
.bi-header-tools {
    display:flex;
    align-items:center;
    justify-content:flex-end;
    gap:.7rem;
    flex:0 0 auto;
}
.bi-date-form {
    display:flex;
    align-items:center;
    gap:.55rem;
}
.bi-calendar-icon,
.bi-header-icon {
    width:40px;
    height:40px;
    display:grid;
    place-items:center;
    border:0;
    background:transparent;
    color:var(--blue);
    font-size:1.4rem;
    text-decoration:none;
}
.bi-date-range {
    display:flex;
    align-items:center;
    gap:.45rem;
    padding:.5rem;
    border-radius:8px;
    background:#fff;
    border:1px solid rgba(23,54,79,.12);
    box-shadow:0 2px 10px rgba(13,26,47,.08);
}
.bi-date-input {
    width:132px;
    min-height:38px;
    border:1px solid rgba(23,54,79,.12);
    border-radius:0;
    background:#fff;
    color:var(--blue);
    font-size:.88rem;
    font-weight:600;
    padding:.35rem .55rem;
}
.bi-date-submit {
    width:36px;
    height:36px;
    display:grid;
    place-items:center;
    border:0;
    border-radius:8px;
    background:var(--teal);
    color:var(--navy);
}
.bi-chat-icon {
    position:relative;
    color:var(--teal);
}
.bi-chat-icon::after {
    content:"?";
    position:absolute;
    top:2px;
    right:0;
    width:18px;
    height:18px;
    display:grid;
    place-items:center;
    border-radius:999px;
    background:var(--red);
    color:#fff;
    font-size:.8rem;
    font-weight:900;
}
.bi-back-icon { color:var(--navy); font-size:1.55rem; }
.bi-field {
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    align-self:flex-start;
    padding:.4rem .65rem;
    border-radius:999px;
    background: rgba(84,172,191,.13);
    border:1px solid rgba(23,54,79,.12);
    color:var(--navy);
    font-size:.76rem;
    font-weight:800;
    line-height:1.35;
    max-width: 100%;
    white-space: normal;
}
.bi-field i { color:var(--teal); }
.bi-field small { color:var(--blue); font-weight:700; display:block; }
.metric-grid {
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:0;
    margin-bottom:.75rem;
    background: var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:16px;
    box-shadow:0 14px 34px rgba(13,26,47,.12);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
    overflow:hidden;
}
.panel {
    background: var(--surface);
    border:1px solid rgba(23,54,79,.12);
    border-radius:16px;
    box-shadow:0 14px 34px rgba(13,26,47,.12);
    backdrop-filter: blur(18px) saturate(160%);
    -webkit-backdrop-filter: blur(18px) saturate(160%);
}
.glow-card {
    --x: 50;
    --y: 50;
    --xp: 0.5;
    --yp: 0.5;
    --base: 220;
    --spread: 200;
    --radius: 16;
    --border: 3;
    --spot-opacity: 0;
    position: relative;
    isolation: isolate;
    overflow: hidden;
    transform: translateZ(0);
    transition: box-shadow .2s ease, border-color .2s ease, transform .2s ease;
}
.glow-card::before,
.glow-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    opacity: var(--spot-opacity, 0);
    transition: opacity .2s ease;
}
.glow-card::before {
    background:
        radial-gradient(
            calc(var(--radius) * 1px) calc(var(--radius) * 1px) at
            calc(var(--x) * 1px)
            calc(var(--y) * 1px),
            hsla(calc(var(--base) + (var(--xp) * var(--spread))), 88%, 70%, 0.20),
            transparent 42%
        );
    filter: blur(6px);
}
.glow-card::after {
    inset: 1px;
    border: 1px solid rgba(84,172,191,.14);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,.65),
        0 0 0 1px rgba(255,255,255,.2);
}
.glow-card.is-glowing {
    box-shadow: 0 18px 42px rgba(13,26,47,.14);
    border-color: rgba(84,172,191,.26);
}
.metric-card {
    padding:1.05rem 1.15rem;
    display:flex;
    gap:.9rem;
    align-items:center;
    min-height:108px;
    position: relative;
    overflow:hidden;
    background:transparent;
    border-right:1px solid rgba(23,54,79,.10);
    border-bottom:1px solid rgba(23,54,79,.10);
    border-radius:0;
    box-shadow:none;
    backdrop-filter:none;
    -webkit-backdrop-filter:none;
}
.metric-card:nth-child(2n) { border-right:0; }
.metric-card:nth-last-child(-n + 2) { border-bottom:0; }
.metric-card::before {
    content:'';
    position:absolute;
    inset:auto -15% -35% auto;
    width:120px;
    height:120px;
    border-radius:50%;
    background: radial-gradient(circle, rgba(84,172,191,.14), transparent 68%);
    pointer-events:none;
}
.metric-icon { width:46px; height:46px; border-radius:10px; display:grid; place-items:center; flex:0 0 auto; }
.tone-teal { background:rgba(84,172,191,.12); color:var(--teal); }
.tone-gold { background:rgba(184,137,36,.12); color:#B88924; }
.tone-green { background:rgba(47,143,114,.12); color:#2F8F72; }
.tone-blue { background:rgba(38,101,140,.12); color:var(--blue); }
.metric-label { color:var(--blue); font-size:.76rem; font-weight:800; text-transform:uppercase; letter-spacing:.03em; }
.metric-value { color:var(--navy); font-size:1.45rem; font-weight:800; line-height:1.15; }
.metric-delta { color:#2F8F72; font-size:.76rem; font-weight:800; }
.dash-grid { display:grid; grid-template-columns:2fr 1fr; gap:.75rem; margin-top:.75rem; }
.panel { padding:1rem; }
.panel-title { color:var(--navy); font-size:.9rem; font-weight:800; margin:0 0 .75rem; }
.summary { color:var(--blue); font-size:.92rem; line-height:1.65; margin-bottom:1rem; font-weight:500; }
.trend { display:grid; grid-template-columns:repeat(6,1fr); gap:.65rem; align-items:end; min-height:260px; padding-top:.5rem; }
.trend-col { display:flex; flex-direction:column; align-items:center; gap:.45rem; min-width:0; }
.trend-bar { width:100%; max-width:62px; min-height:28px; border-radius:7px 7px 3px 3px; background:linear-gradient(180deg,var(--teal),var(--blue)); }
.trend-value { color:var(--navy); font-size:.74rem; font-weight:800; }
.trend-label { color:var(--blue); font-size:.74rem; font-weight:600; }
.breakdown-row { display:grid; grid-template-columns:96px 1fr 46px; gap:.6rem; align-items:center; padding:.55rem 0; border-top:1px solid var(--line); }
.breakdown-row:first-of-type { border-top:0; }
.breakdown-label { color:var(--navy); font-size:.82rem; font-weight:800; }
.breakdown-detail { color:var(--blue); font-size:.74rem; font-weight:500; }
.breakdown-track { height:9px; border-radius:999px; background:rgba(23,54,79,.10); overflow:hidden; }
.breakdown-fill { height:100%; border-radius:999px; background:linear-gradient(90deg, #26658C, #54ACBF); }
.breakdown-value { color:var(--navy); font-size:.75rem; font-weight:800; text-align:right; }
.insight { border-top:1px solid var(--line); padding:.75rem 0 0; margin-top:.75rem; }
.insight:first-of-type { border-top:0; padding-top:0; margin-top:0; }
.insight-head { display:flex; justify-content:space-between; gap:.5rem; align-items:center; }
.insight-title { color:var(--navy); font-size:.8rem; font-weight:800; }
.insight-badge { font-size:.68rem; font-weight:800; border-radius:999px; padding:.18rem .5rem; background:rgba(84,172,191,.12); color:var(--blue); }
.insight-detail { color:var(--blue); font-size:.78rem; margin:.25rem 0 0; line-height:1.55; }
@@media (max-width: 992px) {
    .metric-grid, .dash-grid { grid-template-columns:1fr 1fr; }
    .dash-grid .panel:first-child { grid-column:1 / -1; }
}
@@media (max-width: 640px) {
    .bi-layout { grid-template-columns: 1fr; }
    .bi-tabs-shell {
        position: static;
        width: 100%;
        top: auto;
    }
    .bi-tabs {
        padding-top: .85rem;
        transform:none !important;
    }
    .bi-filter-card {
        padding: .85rem;
        border-radius:12px;
    }
    .bi-filter-card form {
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:.55rem;
    }
    .bi-filter-title,
    .bi-filter-actions {
        grid-column:1 / -1;
    }
    .bi-tabs-toggle {
        display:none;
    }
    .bi-header { flex-direction:column; }
    .bi-header-tools,
    .bi-date-form,
    .bi-date-range {
        width:100%;
    }
    .bi-header-tools {
        align-items:stretch;
        flex-wrap:wrap;
        justify-content:flex-start;
    }
    .bi-date-form {
        flex-wrap:wrap;
    }
    .bi-date-range {
        flex:1 1 260px;
    }
    .bi-date-input {
        flex:1 1 110px;
        width:auto;
        min-width:0;
    }
    .bi-field { width:100%; }
    .metric-grid { grid-template-columns:1fr; }
    .metric-card {
        border-right:0;
        border-bottom:1px solid rgba(23,54,79,.10);
    }
    .metric-card:last-child { border-bottom:0; }
    .dash-grid { grid-template-columns:1fr; }
    .trend { min-height:210px; gap:.4rem; }
    .bi-content { padding:.75rem; }
    .bi-shell { padding:.65rem; }
    .bi-header {
        gap:.85rem;
        padding:1rem;
        border-radius:12px;
    }
    .bi-title {
        font-size:1.35rem;
        line-height:1.18;
        letter-spacing:-0.025em;
    }
    .bi-desc {
        font-size:.82rem;
        line-height:1.5;
    }
    .bi-tabs {
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:.45rem;
    }
    .bi-tab {
        min-width:0;
        justify-content:center;
        text-align:center;
        padding:.62rem .5rem;
    }
    .metric-grid,
    .panel {
        border-radius:12px;
    }
    .metric-card { padding:.9rem; min-height:92px; }
    .metric-value { font-size:1.35rem; }
    .trend-bar { min-width:22px; }
}
@@media (max-width: 480px) {
    .bi-filter-card form {
        grid-template-columns:1fr;
    }
    .bi-date-range {
        display:grid;
        grid-template-columns:1fr;
    }
    .bi-date-submit,
    .bi-calendar-icon,
    .bi-header-icon {
        width:38px;
        height:38px;
    }
}

/* Astryon-inspired editorial finance theme */
.bi-shell {
    --astryon-ink:#050505;
    --astryon-muted:#606060;
    --astryon-paper:#f2f2f2;
    --astryon-card:#ffffff;
    --astryon-line:rgba(5,5,5,.12);
    --astryon-soft:rgba(5,5,5,.045);
    --astryon-accent:#54ACBF;
    --astryon-risk:#B94A3F;
    background:var(--astryon-paper) !important;
    color:var(--astryon-ink);
    font-family:"Mona Sans", "Inter", "Segoe UI", Arial, sans-serif;
}
.bi-layout {
    max-width:1520px;
    gap:1rem;
}
.bi-filter-card,
.bi-tabs,
.bi-header,
.metric-grid,
.panel {
    background:var(--astryon-card);
    border:1px solid var(--astryon-line);
    border-radius:8px;
    box-shadow:none;
    backdrop-filter:none;
    -webkit-backdrop-filter:none;
}
.bi-filter-card {
    padding:2.75rem .85rem .85rem;
}
.bi-filter-title,
.panel-title,
.metric-label,
.breakdown-label,
.insight-title {
    color:var(--astryon-ink);
    letter-spacing:0;
}
.bi-filter-title::before {
    content:"✼";
    color:var(--astryon-ink);
}
.bi-filter-title i {
    display:none;
}
.bi-filter-field label,
.bi-filter-active,
.bi-desc,
.summary,
.trend-label,
.breakdown-detail,
.insight-detail {
    color:var(--astryon-muted);
}
.bi-filter-field select,
.bi-date-input {
    border:1px solid var(--astryon-line);
    border-radius:0;
    color:var(--astryon-ink);
    background:#fff;
}
.bi-filter-submit,
.bi-date-submit {
    border:1px solid var(--astryon-ink);
    border-radius:999px;
    background:var(--astryon-ink);
    color:#fff;
}
.bi-filter-reset,
.bi-tabs-toggle,
.bi-header-icon,
.bi-calendar-icon {
    border-color:var(--astryon-line);
    color:var(--astryon-ink);
}
.bi-tabs {
    gap:.35rem;
    padding:.65rem;
}
.bi-tab {
    justify-content:space-between;
    gap:.65rem;
    border:1px solid transparent;
    border-radius:999px;
    background:transparent;
    color:var(--astryon-ink);
    font-size:.8rem;
    font-weight:800;
}
.bi-tab i {
    color:var(--astryon-muted);
}
.bi-tab span {
    flex:1 1 auto;
}
.bi-tab small {
    color:var(--astryon-muted);
    font-size:.68rem;
    font-weight:800;
}
.bi-tab:hover {
    background:var(--astryon-soft);
    transform:none;
}
.bi-tab.active {
    background:var(--astryon-ink);
    border-color:var(--astryon-ink);
    color:#fff;
    box-shadow:none;
}
.bi-tab.active i,
.bi-tab.active small {
    color:#fff;
}
.bi-header {
    align-items:flex-end;
    padding:1.45rem 1.55rem;
    margin-bottom:.8rem;
}
.bi-header-left {
    gap:.35rem;
}
.bi-header-eyebrow {
    color:var(--astryon-muted);
    font-size:.78rem;
    font-weight:800;
    letter-spacing:0;
}
.bi-header-eyebrow::before {
    content:"✼ ";
    color:var(--astryon-ink);
}
.bi-title {
    color:var(--astryon-ink);
    font-family:"Mona Sans Narrow", "Arial Narrow", "Inter", "Segoe UI", Arial, sans-serif;
    font-size:clamp(2.25rem, 5vw, 5.2rem);
    line-height:.9;
    font-weight:900;
    letter-spacing:-.05em;
}
.bi-desc {
    font-size:1rem;
    font-weight:700;
}
.bi-date-range {
    border:1px solid var(--astryon-line);
    border-radius:8px;
    box-shadow:none;
}
.bi-chat-icon {
    color:var(--astryon-accent);
}
.bi-chat-icon::after {
    background:var(--astryon-risk);
}
.metric-grid {
    grid-template-columns:repeat(4,minmax(0,1fr));
    margin-bottom:1rem;
}
.metric-card {
    min-height:132px;
    align-items:flex-start;
    flex-direction:column;
    gap:.85rem;
    padding:1.2rem;
    border-right:1px solid var(--astryon-line);
    border-bottom:0;
}
.metric-card:nth-child(2n) {
    border-right:1px solid var(--astryon-line);
}
.metric-card:last-child {
    border-right:0;
}
.metric-card::before {
    display:none;
}
.metric-icon {
    width:42px;
    height:42px;
    border-radius:0;
    background:transparent;
    color:var(--astryon-ink);
    font-size:1.35rem;
}
.tone-teal,
.tone-gold,
.tone-green,
.tone-blue {
    background:transparent;
    color:var(--astryon-ink);
}
.metric-label {
    color:var(--astryon-muted);
    font-size:.76rem;
    font-weight:800;
    text-transform:none;
}
.metric-value {
    color:var(--astryon-ink);
    font-size:clamp(1.65rem, 2.7vw, 2.4rem);
    font-weight:900;
    letter-spacing:-.04em;
}
.metric-delta {
    color:var(--astryon-risk);
    font-weight:900;
}
.dash-grid {
    gap:1rem;
}
.panel {
    padding:1.15rem;
}
.trend-bar {
    border-radius:999px 999px 0 0;
    background:linear-gradient(180deg, #011C40, #54ACBF);
}
.breakdown-track {
    background:var(--astryon-soft);
}
.breakdown-fill {
    background:linear-gradient(90deg, #26658C, #54ACBF);
}
.insight,
.breakdown-row {
    border-color:var(--astryon-line);
}
.insight-badge {
    background:var(--astryon-soft);
    color:var(--astryon-ink);
}
@@media (max-width: 992px) {
    .metric-grid {
        grid-template-columns:repeat(2,minmax(0,1fr));
    }
    .metric-card:nth-child(2n) {
        border-right:0;
    }
    .metric-card:nth-child(-n + 2) {
        border-bottom:1px solid var(--astryon-line);
    }
}
@@media (max-width: 640px) {
    .bi-title {
        font-size:2.2rem;
    }
    .bi-header {
        align-items:flex-start;
    }
    .metric-grid {
        grid-template-columns:1fr;
    }
    .metric-card,
    .metric-card:nth-child(2n),
    .metric-card:nth-child(-n + 2) {
        border-right:0;
        border-bottom:1px solid var(--astryon-line);
    }
    .metric-card:last-child {
        border-bottom:0;
    }
}
</style>
}

<div class="bi-shell">
    <div class="bi-layout">
        <div class="bi-tabs-shell" data-bi-tabs-shell>
            <button type="button" class="bi-tabs-toggle" data-bi-tabs-toggle aria-expanded="true" aria-label="Collapse dashboard sections">
                <i class="fas fa-chevron-left"></i>
            </button>
            <section class="bi-filter-card" aria-label="Dashboard filters">
                <form method="get" asp-controller="Home" asp-action="RCMDashboard">
                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                    <div class="bi-filter-title">
                        <i class="fas fa-filter"></i>
                        Filters
                    </div>
                    <div class="bi-filter-field">
                        <label for="facilityId">Facility</label>
                        <select id="facilityId" name="facilityId">
                            <option value="">All facilities</option>
                            @foreach (var option in Model.FacilityOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.FacilityId?.ToString() == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="receiver">Receiver</label>
                        <select id="receiver" name="receiver">
                            <option value="">All receivers</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.Receiver) && !Model.ReceiverOptions.Any(o => o.Value == Model.Filters.Receiver))
                            {
                                <option value="@Model.Filters.Receiver" selected>@Model.Filters.Receiver</option>
                            }
                            @foreach (var option in Model.ReceiverOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.Receiver == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="payer">Payer</label>
                        <select id="payer" name="payer">
                            <option value="">All payers</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.Payer) && !Model.PayerOptions.Any(o => o.Value == Model.Filters.Payer))
                            {
                                <option value="@Model.Filters.Payer" selected>@Model.Filters.Payer</option>
                            }
                            @foreach (var option in Model.PayerOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.Payer == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-field">
                        <label for="encounterType">Encounter Type</label>
                        <select id="encounterType" name="encounterType">
                            <option value="">All encounter types</option>
                            @if (!string.IsNullOrWhiteSpace(Model.Filters.EncounterType) && !Model.EncounterTypeOptions.Any(o => o.Value == Model.Filters.EncounterType))
                            {
                                <option value="@Model.Filters.EncounterType" selected>@Model.Filters.EncounterType</option>
                            }
                            @foreach (var option in Model.EncounterTypeOptions)
                            {
                                <option value="@option.Value" selected="@(Model.Filters.EncounterType == option.Value ? "selected" : null)">@option.Label</option>
                            }
                        </select>
                    </div>
                    <div class="bi-filter-actions">
                        <button type="submit" class="bi-filter-submit">
                            <i class="fas fa-check"></i>
                            Apply
                        </button>
                        <a class="bi-filter-reset" asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@Model.ActiveTab" title="Reset filters" aria-label="Reset filters">
                            <i class="fas fa-rotate-left"></i>
                        </a>
                    </div>
                    @if (Model.HasActiveFilters)
                    {
                        <div class="bi-filter-active">
                            <i class="fas fa-circle-check"></i>
                            Filtered view
                        </div>
                    }
                </form>
            </section>
            <nav class="bi-tabs" id="biTabsNav" role="tablist" aria-label="Dashboard sections">
                @foreach (var tab in Model.Tabs)
                {
                    var meta = tabMeta.GetValueOrDefault(tab, ("fa-chart-bar", ""));
                    var tabIndex = Model.Tabs.IndexOf(tab) + 1;
                    <a class="bi-tab @(tab == Model.ActiveTab ? "active" : "")"
                       asp-controller="Home" asp-action="RCMDashboard" asp-route-tab="@tab"
                       asp-route-facilityId="@Model.Filters.FacilityId"
                       asp-route-receiver="@Model.Filters.Receiver"
                       asp-route-payer="@Model.Filters.Payer"
                       asp-route-encounterType="@Model.Filters.EncounterType"
                       asp-route-dateFrom="@Model.Filters.DateFrom"
                       asp-route-dateTo="@Model.Filters.DateTo"
                       role="tab"
                       aria-selected="@(tab == Model.ActiveTab ? "true" : "false")">
                        <i class="fas @meta.Item1"></i>
                        <span>@tab</span>
                        <small>(@tabIndex.ToString("00"))</small>
                    </a>
                }
            </nav>
        </div>

    <main class="bi-content">
        <div class="bi-header">
            <div class="bi-header-left">
                <div class="bi-header-eyebrow">Finance Intelligence (@activeTabIndex.ToString("00"))</div>
                <h1 class="bi-title">@Model.ActiveTab Dashboard</h1>
                <p class="bi-desc">Reports from @reportDateFromText to @reportDateToText</p>
            </div>
            <div class="bi-header-tools">
                <form method="get" asp-controller="Home" asp-action="RCMDashboard" class="bi-date-form">
                    <input type="hidden" name="tab" value="@Model.ActiveTab" />
                    <input type="hidden" name="facilityId" value="@Model.Filters.FacilityId" />
                    <input type="hidden" name="receiver" value="@Model.Filters.Receiver" />
                    <input type="hidden" name="payer" value="@Model.Filters.Payer" />
                    <input type="hidden" name="encounterType" value="@Model.Filters.EncounterType" />
                    <div class="bi-calendar-icon" aria-hidden="true"><i class="far fa-calendar-alt"></i></div>
                    <div class="bi-date-range">
                        <input class="bi-date-input" type="date" name="dateFrom" value="@reportDateFrom.ToString("yyyy-MM-dd")" aria-label="Report start date" />
                        <input class="bi-date-input" type="date" name="dateTo" value="@reportDateTo.ToString("yyyy-MM-dd")" aria-label="Report end date" />
                        <button type="submit" class="bi-date-submit" aria-label="Apply date filters">
                            <i class="fas fa-check"></i>
                        </button>
                    </div>
                </form>
                <button type="button" class="bi-header-icon bi-chat-icon" aria-label="Dashboard help">
                    <i class="fas fa-comments"></i>
                </button>
                <a class="bi-header-icon bi-back-icon" asp-controller="Home" asp-action="Dashboard" aria-label="Back to facility dashboard">
                    <i class="fas fa-undo"></i>
                </a>
            </div>
        </div>

        <section class="metric-grid" aria-label="Dashboard metrics">
            @foreach (var metric in Model.Metrics)
            {
            <article class="metric-card">
                <div class="metric-icon tone-@metric.Tone"><i class="fas @metric.Icon"></i></div>
                <div>
                    <div class="metric-label">@metric.Label</div>
                        <div class="metric-value">@metric.Value</div>
                        <div class="metric-delta">@metric.Delta</div>
                    </div>
                </article>
            }
        </section>

        <section class="dash-grid">
            <article class="panel glow-card" data-glow-color="blue">
                <h2 class="panel-title">Performance Trend</h2>
                <p class="summary">@Model.Summary</p>
                <div class="trend">
                    @foreach (var point in Model.Trend)
                    {
                        var height = Math.Max(18, (int)Math.Round(point.Value * 100.0 / maxTrend));
                        <div class="trend-col">
                            <div class="trend-value">@point.Value%</div>
                            <div class="trend-bar" style="height:@height%;"></div>
                            <div class="trend-label">@point.Label</div>
                        </div>
                    }
                </div>
            </article>

            <article class="panel glow-card" data-glow-color="purple">
                <h2 class="panel-title">Breakdown</h2>
                @foreach (var item in Model.Breakdown)
                {
                    var width = Math.Max(5, (int)Math.Round(item.Value * 100.0 / maxBreakdown));
                    <div class="breakdown-row">
                        <div>
                            <div class="breakdown-label">@item.Label</div>
                            <div class="breakdown-detail">@item.Detail</div>
                        </div>
                        <div class="breakdown-track"><div class="breakdown-fill" style="width:@width%;"></div></div>
                        <div class="breakdown-value">@item.Value%</div>
                    </div>
                }
            </article>

            <article class="panel glow-card" data-glow-color="green">
                <h2 class="panel-title">Insights</h2>
                @foreach (var insight in Model.Insights)
                {
                    <div class="insight">
                        <div class="insight-head">
                            <div class="insight-title">@insight.Title</div>
                            <span class="insight-badge">@insight.Status</span>
                        </div>
                        <p class="insight-detail">@insight.Detail</p>
                    </div>
                }
            </article>
        </section>
    </main>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const colorMap = {
        blue: { base: 220, spread: 200 },
        purple: { base: 280, spread: 300 },
        green: { base: 120, spread: 200 },
        red: { base: 0, spread: 200 },
        orange: { base: 30, spread: 200 }
    };

    const cards = Array.from(document.querySelectorAll('.glow-card'));
    if (!cards.length) return;
    const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    if (!finePointer) return;

    cards.forEach((card) => {
        const color = colorMap[card.dataset.glowColor || 'blue'] || colorMap.blue;
        card.style.setProperty('--base', String(color.base));
        card.style.setProperty('--spread', String(color.spread));

        const reset = () => {
            card.style.setProperty('--spot-opacity', '0');
            card.classList.remove('is-glowing');
        };

        card.addEventListener('pointerenter', () => {
            card.style.setProperty('--spot-opacity', '1');
            card.classList.add('is-glowing');
        });

        card.addEventListener('pointermove', (event) => {
            const rect = card.getBoundingClientRect();
            const px = Math.min(1, Math.max(0, (event.clientX - rect.left) / rect.width));
            const py = Math.min(1, Math.max(0, (event.clientY - rect.top) / rect.height));
            card.style.setProperty('--x', `${(px * rect.width).toFixed(2)}`);
            card.style.setProperty('--y', `${(py * rect.height).toFixed(2)}`);
            card.style.setProperty('--xp', px.toFixed(2));
            card.style.setProperty('--yp', py.toFixed(2));
        });

        card.addEventListener('pointerleave', reset);
        card.addEventListener('pointercancel', reset);
    });

    const shell = document.querySelector('[data-bi-tabs-shell]');
    const toggle = document.querySelector('[data-bi-tabs-toggle]');
    const tabLinks = Array.from(document.querySelectorAll('.bi-tab'));
    const layout = shell?.closest('.bi-layout');
    if (!shell || !toggle || !layout || !tabLinks.length) return;

    const collapseAtKey = 'biTabsCollapseAt';
    const collapsedKey = 'biTabsCollapsed';
    let collapseTimer = null;

    const setCollapsed = (collapsed) => {
        shell.classList.toggle('is-collapsed', collapsed);
        layout.classList.toggle('is-tabs-collapsed', collapsed);
        toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        toggle.setAttribute('aria-label', collapsed ? 'Expand dashboard sections' : 'Collapse dashboard sections');
        window.sessionStorage.setItem(collapsedKey, collapsed ? '1' : '0');
        if (!collapsed) {
            window.sessionStorage.removeItem(collapseAtKey);
            if (collapseTimer) {
                window.clearTimeout(collapseTimer);
                collapseTimer = null;
            }
        }
    };

    const scheduleCollapse = (delayMs) => {
        if (collapseTimer) window.clearTimeout(collapseTimer);
        collapseTimer = window.setTimeout(() => setCollapsed(true), Math.max(0, delayMs));
    };

    const storedCollapsed = window.sessionStorage.getItem(collapsedKey) === '1';
    const collapseAt = Number(window.sessionStorage.getItem(collapseAtKey) || 0);
    if (storedCollapsed) {
        setCollapsed(true);
    } else if (collapseAt > Date.now()) {
        scheduleCollapse(collapseAt - Date.now());
    }

    toggle.addEventListener('click', () => {
        setCollapsed(!shell.classList.contains('is-collapsed'));
    });

    tabLinks.forEach((tab) => {
        tab.addEventListener('click', () => {
            window.sessionStorage.setItem(collapsedKey, '0');
            window.sessionStorage.setItem(collapseAtKey, String(Date.now() + 5000));
        });
    });
})();
</script>
}
