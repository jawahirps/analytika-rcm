    }
    .metric-grid {
        grid-template-columns:repeat(2,minmax(0,1fr));
    }
}
@@media (max-width: 640px) {
    .bi-layout {
        padding:.75rem;
    }
    .bi-header {
        clip-path:polygon(0 0, 100% 0, 100% 88%, 50% 100%, 0 88%);
        min-height:300px;
        border-radius:22px 22px 0 0 !important;
    }
